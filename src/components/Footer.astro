---
/**
 * Footer.astro — Consorcio Helitec  v2 (Licorn-style)
 *
 * CAMBIOS v2:
 *   1. Social boxes → fondo sólido Rojo Helitec (var(--c-red)), flecha blanca.
 *   2. CTA "Solicitar cotización" reemplazado por botón PILL "CONTACTAR"
 *      que dispara el ContactSheet existente (id="csheet-trigger").
 *      NOTA: border-radius: 999px es un override intencional del Tech Lead
 *      para esta pieza específica (referencia Licorn). Fuera de esta excepción
 *      el límite de 4px se mantiene en todos los demás elementos.
 *   3. Fade-in escalonado: IntersectionObserver activa data-anim con delay
 *      individual por elemento (translateY 20px → 0, opacity 0 → 1).
 *   4. UX crítico: body.footer-visible oculta .slcta__trigger y .csheet__fabs
 *      con transición suave. CSS :global() aplicado desde este componente.
 *
 * Reglas anti-slop:
 *   PROHIBIDO box-shadow        — ✓
 *   PROHIBIDO linear-gradient   — ✓
 *   border-radius ≤ 4px         — ✓ (excepto .footer__pill-cta, ver nota arriba)
 *   object-fit: cover/contain   — ✓
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const navLinks = [
  { href: '#por-que-helitec', label: lang === 'es' ? 'Por qué Helitec' : 'Why Helitec' },
  { href: '#flota',           label: lang === 'es' ? 'Nuestra Flota'   : 'Our Fleet'   },
  { href: '#empresa',         label: lang === 'es' ? 'La Empresa'       : 'About Us'    },
  { href: '#seguridad',       label: lang === 'es' ? 'Seguridad'        : 'Safety'      },
  { href: '#contacto',        label: lang === 'es' ? 'Contacto B2B'     : 'B2B Contact' },
];

const logoSrc   = '/assets/Logo-Helitec-horiz-no-bkg-1-blanco.png';
const currentYear = new Date().getFullYear();
---


<footer
  class="footer"
  id="site-footer"
  role="contentinfo"
  aria-label={lang === 'es' ? 'Pie de página Consorcio Helitec' : 'Consorcio Helitec footer'}
  data-footer
>

  <!-- ════════════════════════════════════════════════════════════════════════
       MAIN — GRID 3 COLUMNAS
  ════════════════════════════════════════════════════════════════════════ -->
  <div class="footer__main">
    <div class="footer__inner">

      <!-- ── COL 1: Identidad corporativa ──────────────────────────────── -->
      <div class="footer__col footer__col--brand">

        <a
          href="/"
          class="footer__logo-link"
          aria-label="Consorcio Helitec — Inicio"
          data-anim
          data-anim-delay="0"
        >
          <img
            class="footer__logo"
            src={logoSrc}
            alt="Consorcio Helitec"
            width="180"
            height="48"
            loading="lazy"
            decoding="async"
          />
        </a>

        <!-- Recurso rojo — reveal de izquierda a derecha -->
        <img
          src="/assets/recurso%20rojo%20helitec.png"
          class="footer__logo-deco"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />

        <p class="footer__tagline" data-anim data-anim-delay="80">
          {lang === 'es'
            ? 'Aviación ejecutiva y aeromédica. Venezuela.'
            : 'Executive and aeromedical aviation. Venezuela.'
          }
        </p>

        <address class="footer__address" data-anim data-anim-delay="160">
          <p class="footer__address-line">
            {lang === 'es' ? 'Sede:' : 'HQ:'}
            &nbsp;<span class="footer__address-value">Caracas, Venezuela</span>
          </p>
          <p class="footer__address-line">
            RIF:&nbsp;<span class="footer__address-value">[DATO: RIF]</span>
          </p>
        </address>

        <div class="footer__certs" data-anim data-anim-delay="200">
          <span class="footer__cert-tag">INAC</span>
          <span class="footer__cert-tag">OACI</span>
        </div>

        <!-- Redes sociales — cuadraditos Rojo Helitec (v2) -->
        <div
          class="footer__socials"
          aria-label={lang === 'es' ? 'Redes sociales' : 'Social media'}
          data-anim
          data-anim-delay="240"
        >
          <a
            class="footer__social-link"
            href="https://www.linkedin.com/company/consorcio-helitec"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn de Consorcio Helitec (abre en nueva pestaña)"
          >
            <!-- Cuadrado rojo con flecha diagonal — igual que referencia Licorn -->
            <span class="footer__social-box" aria-hidden="true">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none" aria-hidden="true">
                <path d="M1 8L8 1M8 1H3M8 1v5" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/>
              </svg>
            </span>
            <span class="footer__social-label">LinkedIn</span>
          </a>

          <a
            class="footer__social-link"
            href="https://www.youtube.com/@consorciohtelitec"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube de Consorcio Helitec (abre en nueva pestaña)"
          >
            <span class="footer__social-box" aria-hidden="true">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none" aria-hidden="true">
                <path d="M1 8L8 1M8 1H3M8 1v5" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/>
              </svg>
            </span>
            <span class="footer__social-label">YouTube</span>
          </a>
        </div>

      </div>


      <!-- ── COL 2: Navegación ──────────────────────────────────────────── -->
      <nav
        class="footer__col footer__col--nav"
        aria-label={lang === 'es' ? 'Navegación del footer' : 'Footer navigation'}
      >

        <p class="footer__col-heading" data-anim data-anim-delay="60">
          {lang === 'es' ? 'Navegación' : 'Navigation'}
        </p>

        <ul class="footer__nav-list" role="list">
          {navLinks.map((link, i) => (
            <li
              class="footer__nav-item"
              data-anim
              data-anim-delay={String(120 + i * 55)}
            >
              <a class="footer__nav-link" href={link.href}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>

      </nav>


      <!-- ── COL 3: Contacto B2B ─────────────────────────────────────────── -->
      <div class="footer__col footer__col--contact">

        <p class="footer__col-heading" data-anim data-anim-delay="60">
          {lang === 'es' ? 'Contacto B2B' : 'B2B Contact'}
        </p>

        <ul class="footer__contact-list" role="list" data-anim data-anim-delay="140">

          <li class="footer__contact-item">
            <span class="footer__contact-icon" aria-hidden="true">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20.52 3.48A11.9 11.9 0 0 0 12 0C5.37 0 0 5.37 0 12c0 2.12.55 4.18 1.6 6L0 24l6.17-1.57A11.94 11.94 0 0 0 12 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.22-3.48-8.52ZM12 21.94a9.9 9.9 0 0 1-5.04-1.37l-.36-.22-3.66.94.97-3.56-.24-.37A9.9 9.9 0 0 1 2.06 12C2.06 6.49 6.49 2.06 12 2.06S21.94 6.49 21.94 12 17.51 21.94 12 21.94Z" fill="currentColor"/>
              </svg>
            </span>
            <a
              class="footer__contact-link"
              href="https://wa.me/584166235254"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="WhatsApp operativo: +58 416 623 5254"
            >
              +58 (416) 623-5254
            </a>
          </li>

          <li class="footer__contact-item">
            <span class="footer__contact-icon" aria-hidden="true">
              <svg width="13" height="11" viewBox="0 0 14 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="1" y="1" width="12" height="9" stroke="currentColor" stroke-width="1.2"/>
                <path d="M1 1L7 6.5L13 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/>
              </svg>
            </span>
            <a
              class="footer__contact-link"
              href="mailto:[DATO: email corporativo]"
              aria-label={lang === 'es' ? 'Email corporativo' : 'Corporate email'}
            >
              [DATO: email corporativo]
            </a>
          </li>

          <li class="footer__contact-item footer__contact-item--address">
            <span class="footer__contact-icon" aria-hidden="true">
              <svg width="10" height="14" viewBox="0 0 10 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 1C2.79 1 1 2.79 1 5C1 8.5 5 13 5 13C5 13 9 8.5 9 5C9 2.79 7.21 1 5 1Z" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="5" cy="5" r="1.5" stroke="currentColor" stroke-width="1.2"/>
              </svg>
            </span>
            <span class="footer__contact-text">[DATO: aeropuerto/sede operativa]</span>
          </li>

        </ul>

      </div>

    </div>
  </div>


  <!-- ════════════════════════════════════════════════════════════════════════
       PILL CTA — "CONTACTAR" — Licorn-style, full-width centered
       border-radius: 999px → override intencional por Tech Lead (ver header)
  ════════════════════════════════════════════════════════════════════════ -->
  <div class="footer__cta-row" data-anim data-anim-delay="400">
    <div class="footer__inner">
      <!--
        Este botón NO es un <a>: dispara el ContactSheet existente (#csheet-trigger)
        mediante JS delegado. Sin duplicar la lógica del panel.
      -->
      <button
        class="footer__pill-cta"
        id="footer-cta-contactar"
        type="button"
        aria-label={lang === 'es' ? 'Abrir formulario de contacto' : 'Open contact form'}
      >
        <span class="footer__pill-cta__label">
          {lang === 'es' ? 'Contactar' : 'Contact us'}
        </span>
        <!-- Flecha derecha — desliza en hover -->
        <svg
          class="footer__pill-cta__arrow"
          width="16"
          height="12"
          viewBox="0 0 16 12"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path d="M1 6h14M10 1l5 5-5 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
        </svg>
      </button>
    </div>
  </div>


  <!-- ════════════════════════════════════════════════════════════════════════
       BOTTOM BAR — copyright
  ════════════════════════════════════════════════════════════════════════ -->
  <div class="footer__bottom" data-anim data-anim-delay="460">
    <div class="footer__inner footer__bottom-inner">

      <p class="footer__copyright">
        © {currentYear} Consorcio Helitec.
        {lang === 'es' ? ' Todos los derechos reservados.' : ' All rights reserved.'}
      </p>

      <div class="footer__bottom-links">
        <a
          class="footer__bottom-link"
          href="/"
          aria-label={lang === 'es' ? 'Política de privacidad' : 'Privacy policy'}
        >
          {lang === 'es' ? 'Privacidad' : 'Privacy'}
        </a>
        <span class="footer__bottom-sep" aria-hidden="true">·</span>
        <a
          class="footer__bottom-link"
          href="/"
          aria-label={lang === 'es' ? 'Aviso legal' : 'Legal notice'}
        >
          {lang === 'es' ? 'Aviso legal' : 'Legal'}
        </a>
      </div>

    </div>
  </div>

</footer>


<style>
  /* ════════════════════════════════════════════════════════════════════════
     BASE
  ════════════════════════════════════════════════════════════════════════ */

  .footer {
    background-color: var(--c-bg);
    border-top:       1px solid var(--c-line);
  }

  .footer__inner {
    max-width:      var(--content-max);
    margin-inline:  auto;
    padding-inline: calc(var(--sidebar-w) + var(--gutter));
  }


  /* ════════════════════════════════════════════════════════════════════════
     FADE-IN ESCALONADO
     Estado inicial vía JS (para no flash de FOUC al cargar).
     La CSS define solo la transición de llegada; JS setea opacity:0/transform inicial.
  ════════════════════════════════════════════════════════════════════════ */

  [data-anim] {
    /*
     * Sin opacity:0 aquí — el JS lo aplica antes de que el elemento sea visible.
     * Esto evita FOUC: si JS falla, el elemento es visible por defecto.
     */
    transition:
      opacity   0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: opacity, transform;
  }


  /* ════════════════════════════════════════════════════════════════════════
     MAIN — GRID 3 COLUMNAS
  ════════════════════════════════════════════════════════════════════════ */

  .footer__main {
    padding-block: clamp(52px, 8vh, 88px);
  }

  .footer__main .footer__inner {
    display:               grid;
    grid-template-columns: 1.4fr 1fr 1.2fr;
    gap:                   clamp(32px, 5vw, 64px);
    align-items:           start;
  }

  .footer__col {
    display:        flex;
    flex-direction: column;
    gap:            20px;
  }


  /* ════════════════════════════════════════════════════════════════════════
     COL 1 — IDENTIDAD
  ════════════════════════════════════════════════════════════════════════ */

  .footer__logo-link {
    display:    inline-block;
    line-height: 0;
    opacity:     1;
  }

  .footer__logo-link:hover,
  .footer__logo-link:focus-visible {
    opacity: 1;
  }

  .footer__logo {
    width:      clamp(120px, 15vw, 160px);
    height:     auto;
    object-fit: contain;
    opacity:    0.90;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .footer__logo-link:hover .footer__logo {
    opacity: 1;
  }

  /* Recurso rojo — reveal izq → der */
  .footer__logo-deco {
    display:          block;
    width:            clamp(60px, 40%, 130px);
    height:           auto;
    object-fit:       contain;
    object-position:  left center;
    margin-top:       -12px;
    clip-path:        inset(0 100% 0 0);
    transition:       clip-path 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s;
  }

  .footer__logo-deco.is-revealed {
    clip-path: inset(0 0% 0 0);
  }

  .footer__tagline {
    font-family: var(--font-sans);
    font-size:   clamp(0.75rem, 1.2vw, 0.875rem);
    font-weight: var(--fw-light);
    color:       var(--c-text-2);
    line-height: 1.55;
    margin-top:  -4px;
  }

  .footer__address {
    display:        flex;
    flex-direction: column;
    gap:            5px;
    font-style:     normal;
  }

  .footer__address-line {
    font-family:    var(--font-sans);
    font-size:      0.6875rem;
    font-weight:    var(--fw-regular);
    letter-spacing: var(--ls-wide);
    color:          var(--c-text-3);
  }

  .footer__address-value {
    color: var(--c-text-2);
  }

  .footer__certs {
    display:  flex;
    gap:      8px;
    flex-wrap: wrap;
  }

  .footer__cert-tag {
    font-family:    var(--font-sans);
    font-size:      0.5625rem;
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);
    padding:        3px 7px;
    border:         1px solid rgba(88, 181, 240, 0.30);
    border-radius:  var(--r-micro);
  }


  /* ════════════════════════════════════════════════════════════════════════
     SOCIAL BOXES — Rojo Helitec sólido (v2)
     Referencia: Licorn Publishing — cuadros con fondo sólido + flecha diagonal.
     Cambio de azul/outline a rojo/sólido = identidad de marca más pronunciada.
  ════════════════════════════════════════════════════════════════════════ */

  .footer__socials {
    display:    flex;
    gap:        10px;
    flex-wrap:  wrap;
    margin-top: -4px;
  }

  .footer__social-link {
    display:         inline-flex;
    align-items:     center;
    gap:             7px;
    text-decoration: none;

    font-family:    var(--font-sans);
    font-size:      0.6875rem;
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wide);
    color:          var(--c-text-2);

    transition: color var(--dur-fast) var(--ease-out);
  }

  .footer__social-link:hover,
  .footer__social-link:focus-visible {
    color:   var(--c-white);
    opacity: 1;
  }

  .footer__social-link:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 3px;
    border-radius:  var(--r-micro);
  }

  /* Cuadradito rojo — fondo sólido + flecha blanca */
  .footer__social-box {
    display:         inline-flex;
    align-items:     center;
    justify-content: center;
    width:           20px;
    height:          20px;
    flex-shrink:     0;

    /* Rojo Helitec sólido, como en la referencia Licorn */
    background-color: var(--c-red);
    border:           1px solid var(--c-red);
    border-radius:    var(--r-micro); /* 4px */
    color:            var(--c-white); /* flecha en blanco puro */

    transition:
      background-color var(--dur-fast) var(--ease-out),
      border-color     var(--dur-fast) var(--ease-out);
  }

  .footer__social-link:hover .footer__social-box,
  .footer__social-link:focus-visible .footer__social-box {
    /* Hover: ligeramente más oscuro pero manteniendo el rojo */
    background-color: #c43218;
    border-color:     #c43218;
  }


  /* ════════════════════════════════════════════════════════════════════════
     COL 2 — NAVEGACIÓN
  ════════════════════════════════════════════════════════════════════════ */

  .footer__col-heading {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-text-1);
    margin-bottom:  4px;
  }

  .footer__nav-list {
    list-style: none;
    padding:    0;
    margin:     0;
    display:    flex;
    flex-direction: column;
    gap:        2px;
  }

  .footer__nav-link {
    display:     inline-block;
    padding:     5px 0;

    font-family: var(--font-sans);
    font-size:   0.8125rem;
    font-weight: var(--fw-light);
    color:       var(--c-text-2);
    text-decoration: none;

    transition: color var(--dur-fast) var(--ease-out);
  }

  .footer__nav-link:hover,
  .footer__nav-link:focus-visible {
    color: var(--c-sky);
  }

  .footer__nav-link:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
    border-radius:  var(--r-micro);
  }


  /* ════════════════════════════════════════════════════════════════════════
     COL 3 — CONTACTO B2B
  ════════════════════════════════════════════════════════════════════════ */

  .footer__contact-list {
    list-style: none;
    padding:    0;
    margin:     0;
    display:    flex;
    flex-direction: column;
    gap:        10px;
  }

  .footer__contact-item {
    display:     flex;
    align-items: center;
    gap:         8px;
  }

  .footer__contact-item--address {
    align-items: flex-start;
  }

  .footer__contact-icon {
    display:     flex;
    align-items: center;
    flex-shrink: 0;
    color:       var(--c-sky);
    margin-top:  1px;
  }

  .footer__contact-link {
    font-family:     var(--font-sans);
    font-size:       0.8125rem;
    font-weight:     var(--fw-regular);
    color:           var(--c-text-2);
    text-decoration: none;
    transition:      color var(--dur-fast) var(--ease-out);
  }

  .footer__contact-link:hover,
  .footer__contact-link:focus-visible {
    color: var(--c-text-1);
  }

  .footer__contact-link:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
    border-radius:  var(--r-micro);
  }

  .footer__contact-text {
    font-family: var(--font-sans);
    font-size:   0.8125rem;
    font-weight: var(--fw-light);
    color:       var(--c-text-2);
    line-height: 1.5;
  }


  /* ════════════════════════════════════════════════════════════════════════
     PILL CTA — "CONTACTAR"
     OVERRIDE INTENCIONAL: border-radius: 999px — autorizado por Tech Lead.
     Referencia visual: Licorn Publishing "Contactez-nous" (ver brief v2).
     Este es el único elemento del proyecto con border-radius > 4px.
  ════════════════════════════════════════════════════════════════════════ */

  .footer__cta-row {
    padding-block: clamp(32px, 4vh, 48px);
    border-top:    1px solid var(--c-line);
  }

  .footer__cta-row .footer__inner {
    display:         flex;
    justify-content: center;
  }

  .footer__pill-cta {
    /* Ancho generoso — imita el estilo "ancho" de Licorn */
    width:      100%;
    max-width:  clamp(280px, 55vw, 560px);

    display:     flex;
    align-items: center;
    justify-content: center;
    gap:         14px;

    padding:     clamp(18px, 2.5vh, 24px) clamp(28px, 5vw, 48px);

    /* Ghost pill con borde elegante */
    background:    transparent;
    border:        1px solid rgba(255, 255, 255, 0.22);
    /* Excepción autorizada — Licorn-style pill */
    border-radius: 999px;

    font-family:    var(--font-sans);
    font-size:      clamp(0.75rem, 1.2vw, 0.875rem);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-1);
    cursor:         pointer;
    text-decoration: none;

    transition:
      border-color     var(--dur-mid) var(--ease-out),
      background-color var(--dur-mid) var(--ease-out),
      color            var(--dur-fast) var(--ease-out);
  }

  .footer__pill-cta:hover {
    background-color: rgba(255, 255, 255, 0.05);
    border-color:     rgba(255, 255, 255, 0.50);
    color:            var(--c-white);
  }

  .footer__pill-cta:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 4px;
    border-radius:  999px; /* preserve pill shape */
  }

  .footer__pill-cta__label {
    flex-shrink: 0;
  }

  /* Flecha — desliza a la derecha en hover */
  .footer__pill-cta__arrow {
    flex-shrink: 0;
    transition:  transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer__pill-cta:hover .footer__pill-cta__arrow,
  .footer__pill-cta:focus-visible .footer__pill-cta__arrow {
    transform: translateX(6px);
  }


  /* ════════════════════════════════════════════════════════════════════════
     BOTTOM BAR
  ════════════════════════════════════════════════════════════════════════ */

  .footer__bottom {
    border-top:    1px solid var(--c-line);
    padding-block: 20px;
  }

  .footer__bottom-inner {
    display:         flex;
    align-items:     center;
    justify-content: space-between;
    flex-wrap:       wrap;
    gap:             12px;
  }

  .footer__copyright {
    font-family:    var(--font-sans);
    font-size:      0.75rem;
    font-weight:    var(--fw-regular);
    letter-spacing: var(--ls-wide);
    color:          var(--c-text-3);
    line-height:    1.5;
  }

  .footer__bottom-links {
    display:     flex;
    align-items: center;
    gap:         8px;
  }

  .footer__bottom-link {
    font-family:     var(--font-sans);
    font-size:       0.75rem;
    font-weight:     var(--fw-regular);
    color:           var(--c-text-3);
    text-decoration: none;
    transition:      color var(--dur-fast) var(--ease-out);
  }

  .footer__bottom-link:hover,
  .footer__bottom-link:focus-visible {
    color: var(--c-sky);
  }

  .footer__bottom-link:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
    border-radius:  var(--r-micro);
  }

  .footer__bottom-sep {
    font-size:   0.75rem;
    color:       var(--c-text-3);
    user-select: none;
  }


  /* ════════════════════════════════════════════════════════════════════════
     UX CRÍTICO — OCULTAR BOTONES FLOTANTES CUANDO EL FOOTER ES VISIBLE
     body.footer-visible se agrega/remueve por JS IntersectionObserver.
     Targets: .slcta__trigger (SideLeadCTA) + .csheet__fabs (ContactSheet).
     Usa :global() porque son clases de otros componentes.
  ════════════════════════════════════════════════════════════════════════ */

  :global(body.footer-visible .slcta__trigger) {
    opacity:        0 !important;
    visibility:     hidden !important;
    pointer-events: none !important;
    transition:
      opacity    0.35s var(--ease-out),
      visibility 0s    linear 0.35s;
  }

  :global(body.footer-visible .csheet__fabs) {
    opacity:        0 !important;
    visibility:     hidden !important;
    pointer-events: none !important;
    transition:
      opacity    0.35s var(--ease-out),
      visibility 0s    linear 0.35s;
  }

  /*
   * Los !important son necesarios: .slcta__trigger.is-visible y
   * .csheet__fabs tienen transition inline y reglas de mayor especificidad
   * en sus propios componentes. Con footer-visible queremos forzar el override.
   */


  /* ════════════════════════════════════════════════════════════════════════
     RESPONSIVE
  ════════════════════════════════════════════════════════════════════════ */

  @media (max-width: 1023px) {
    .footer__inner {
      padding-inline: var(--gutter);
    }

    .footer__main .footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: clamp(28px, 4vw, 48px);
    }

    .footer__col--brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 639px) {
    .footer__main .footer__inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .footer__col--brand {
      grid-column: auto;
    }

    .footer__bottom-inner {
      flex-direction: column;
      align-items:    flex-start;
      gap:            8px;
    }

    .footer__pill-cta {
      max-width: 100%;
    }
  }
</style>


<script>
  /**
   * Footer v2 — Controller unificado
   *
   * 1. Staggered fade-in: IntersectionObserver aplica opacity 0→1 +
   *    translateY 20px→0 a cada [data-anim] con su delay individual.
   *    Estado inicial vía JS para evitar FOUC si JS está deshabilitado.
   *
   * 2. Footer visible → body.footer-visible: oculta .slcta__trigger
   *    y .csheet__fabs. Al salir del viewport, los vuelve a mostrar.
   *
   * 3. Pill CTA → dispara csheet-trigger: delegate click sin duplicar
   *    la lógica del ContactSheet.
   *
   * 4. Recurso rojo: reveal de clip-path al entrar en viewport.
   */
  (function () {
    'use strict';

    var footer = document.querySelector('[data-footer]');
    if (!footer) return;

    /* ── 1. Staggered fade-in ────────────────────────────────────────── */

    var animEls = footer.querySelectorAll('[data-anim]');
    var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!reducedMotion) {
      /* Aplicar estado invisible ANTES de que IO dispare para evitar flash */
      animEls.forEach(function (el) {
        el.style.opacity   = '0';
        el.style.transform = 'translateY(20px)';
      });
    }

    var animObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;

        animEls.forEach(function (el) {
          if (reducedMotion) {
            el.style.opacity   = '1';
            el.style.transform = 'none';
            return;
          }
          var delay = parseInt(el.dataset.animDelay || '0', 10);
          setTimeout(function () {
            el.style.opacity   = '1';
            el.style.transform = 'translateY(0)';
          }, delay);
        });

        animObs.disconnect(); /* One-shot: se anima solo al primer avistamiento */
      });
    }, { threshold: 0.04 });

    animObs.observe(footer);


    /* ── 2. body.footer-visible → oculta botones flotantes ─────────── */

    var fabsObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          document.body.classList.add('footer-visible');
        } else {
          document.body.classList.remove('footer-visible');
        }
      });
    }, {
      /*
       * threshold: 0 + rootMargin: detecta desde que cualquier pixel
       * del footer entra al viewport (tope del footer visible).
       * La FAB ya no estorba visualmente aunque el footer se vea parcialmente.
       */
      threshold:  0,
      rootMargin: '0px 0px 0px 0px',
    });

    fabsObs.observe(footer);


    /* ── 3. Pill CTA dispara ContactSheet ───────────────────────────── */

    var pillCta = document.getElementById('footer-cta-contactar');
    if (pillCta) {
      pillCta.addEventListener('click', function () {
        /*
         * El ContactSheet está controlado por id="csheet-trigger".
         * Un click programático invoca su handler sin duplicar lógica.
         */
        var csBtn = document.getElementById('csheet-trigger');
        if (csBtn) {
          csBtn.click();
        }
      });
    }


    /* ── 4. Recurso rojo — reveal clip-path ─────────────────────────── */

    var deco = footer.querySelector('.footer__logo-deco');
    if (deco) {
      var decoObs = new IntersectionObserver(function (entries) {
        if (entries[0].isIntersecting) {
          deco.classList.add('is-revealed');
          decoObs.disconnect();
        }
      }, { threshold: 0.3 });
      decoObs.observe(deco);
    }

  })();
</script>
