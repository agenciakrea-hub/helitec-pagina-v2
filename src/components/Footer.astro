---
/**
 * Footer.astro
 * Consorcio Helitec — Footer corporativo (Fase 6)
 *
 * Estructura:
 *   Main grid 3 columnas:
 *     Col 1 — Identidad: Logo + tagline + datos legales de la empresa
 *     Col 2 — Navegación: Links a secciones de la página
 *     Col 3 — Contacto B2B: WhatsApp + datos de contacto operativo
 *   Bottom bar:
 *     Copyright + nota legal + créditos
 *
 * Diseño:
 *   · Fondo: var(--c-bg) — el más oscuro disponible (#07080C)
 *   · Separación del contenido principal: border-top 1px var(--c-line)
 *   · Bottom bar separada por border-top 1px var(--c-line)
 *   · Tipografía: Inter (--font-sans), tamaños pequeños, color text-2 / text-3
 *   · Copyright: 12px, sutil, text-3
 *
 * Datos con placeholders:
 *   Los campos marcados [DATO: ...] deben ser completados por el cliente.
 *   No se inventan datos comerciales per reglas del proyecto.
 *
 * Reglas anti-slop:
 *   PROHIBIDO box-shadow       — ✓
 *   PROHIBIDO linear-gradient  — ✓
 *   border-radius ≤ 4px        — ✓ (var(--r-micro) en todo)
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

/* ── Datos de navegación ─────────────────────────────────────────────────── */
const navLinks = [
  { href: '#por-que-helitec', label: lang === 'es' ? 'Por qué Helitec' : 'Why Helitec' },
  { href: '#flota',           label: lang === 'es' ? 'Nuestra Flota'   : 'Our Fleet'   },
  { href: '#empresa',         label: lang === 'es' ? 'La Empresa'       : 'About Us'    },
  { href: '#seguridad',       label: lang === 'es' ? 'Seguridad'        : 'Safety'      },
  { href: '#contacto',        label: lang === 'es' ? 'Contacto B2B'     : 'B2B Contact' },
];

/* ── Logo ────────────────────────────────────────────────────────────────── */
const logoSrc = '/assets/Logo-Helitec-horiz-no-bkg-1-blanco.png';

const currentYear = new Date().getFullYear();
---


<footer class="footer" role="contentinfo" aria-label={lang === 'es' ? 'Pie de página Consorcio Helitec' : 'Consorcio Helitec footer'}>

  <!-- ── Contenido principal del footer ─────────────────────────────────── -->
  <div class="footer__main">
    <div class="footer__inner">

      <!-- ── COLUMNA 1: Identidad corporativa ──────────────────────────── -->
      <div class="footer__col footer__col--brand">

        <!-- Logo horizontal blanco -->
        <a href="/" class="footer__logo-link" aria-label="Consorcio Helitec — Inicio">
          <img
            class="footer__logo"
            src={logoSrc}
            alt="Consorcio Helitec"
            width="180"
            height="48"
            loading="lazy"
          />
        </a>

        <!-- Tagline / descripción corta -->
        <p class="footer__tagline">
          {lang === 'es'
            ? 'Aviación ejecutiva y aeromédica. Venezuela.'
            : 'Executive and aeromedical aviation. Venezuela.'
          }
        </p>

        <!-- Datos legales de la empresa -->
        <!--
          NOTA AL CLIENTE: Completar los campos marcados [DATO: ...] con
          la información legal real antes del lanzamiento.
        -->
        <address class="footer__address">
          <p class="footer__address-line">
            {lang === 'es' ? 'Sede:' : 'HQ:'}
            &nbsp;<span class="footer__address-value">
              {/* [DATO: dirección sede operativa, ej: Caracas, Venezuela] */}
              Caracas, Venezuela
            </span>
          </p>
          <p class="footer__address-line">
            RIF:&nbsp;<span class="footer__address-value">
              {/* [DATO: RIF de la empresa, ej: J-XXXXXXXXX-X] */}
              [DATO: RIF]
            </span>
          </p>
        </address>

        <!-- Certificaciones (badges de texto) -->
        <div class="footer__certs">
          <span class="footer__cert-tag">INAC</span>
          <span class="footer__cert-tag">OACI</span>
        </div>

        <!-- Redes sociales — recuadros estilo Helitec -->
        <div class="footer__socials" aria-label={lang === 'es' ? 'Redes sociales' : 'Social media'}>
          <a
            class="footer__social-link"
            href="https://www.linkedin.com/company/consorcio-helitec"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn de Consorcio Helitec (abre en nueva pestaña)"
          >
            <span class="footer__social-box" aria-hidden="true">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none" aria-hidden="true">
                <path d="M1 8L8 1M8 1H3M8 1v5" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/>
              </svg>
            </span>
            <span class="footer__social-label">LinkedIn</span>
          </a>
          <a
            class="footer__social-link"
            href="https://www.youtube.com/@consorciohtelitec"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube de Consorcio Helitec (abre en nueva pestaña)"
          >
            <span class="footer__social-box" aria-hidden="true">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="none" aria-hidden="true">
                <path d="M1 8L8 1M8 1H3M8 1v5" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/>
              </svg>
            </span>
            <span class="footer__social-label">YouTube</span>
          </a>
        </div>

      </div>

      <!-- ── COLUMNA 2: Navegación ──────────────────────────────────────── -->
      <nav class="footer__col footer__col--nav" aria-label={lang === 'es' ? 'Navegación del footer' : 'Footer navigation'}>

        <p class="footer__col-heading">
          {lang === 'es' ? 'Navegación' : 'Navigation'}
        </p>

        <ul class="footer__nav-list" role="list">
          {navLinks.map((link) => (
            <li class="footer__nav-item">
              <a class="footer__nav-link" href={link.href}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>

      </nav>

      <!-- ── COLUMNA 3: Contacto B2B ──────────────────────────────────── -->
      <div class="footer__col footer__col--contact">

        <p class="footer__col-heading">
          {lang === 'es' ? 'Contacto B2B' : 'B2B Contact'}
        </p>

        <ul class="footer__contact-list" role="list">

          <!-- WhatsApp operativo -->
          <li class="footer__contact-item">
            <span class="footer__contact-icon" aria-hidden="true">
              <!-- WhatsApp icon simplificado -->
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20.52 3.48A11.9 11.9 0 0 0 12 0C5.37 0 0 5.37 0 12c0 2.12.55 4.18 1.6 6L0 24l6.17-1.57A11.94 11.94 0 0 0 12 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.22-3.48-8.52ZM12 21.94a9.9 9.9 0 0 1-5.04-1.37l-.36-.22-3.66.94.97-3.56-.24-.37A9.9 9.9 0 0 1 2.06 12C2.06 6.49 6.49 2.06 12 2.06S21.94 6.49 21.94 12 17.51 21.94 12 21.94Z" fill="currentColor"/>
              </svg>
            </span>
            <a
              class="footer__contact-link"
              href="https://wa.me/584166235254"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="WhatsApp operativo: +58 416 623 5254"
            >
              +58 (416) 623-5254
            </a>
          </li>

          <!-- Email corporativo -->
          <li class="footer__contact-item">
            <span class="footer__contact-icon" aria-hidden="true">
              <!-- Email icon -->
              <svg width="13" height="11" viewBox="0 0 14 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="1" y="1" width="12" height="9" stroke="currentColor" stroke-width="1.2"/>
                <path d="M1 1L7 6.5L13 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/>
              </svg>
            </span>
            <a
              class="footer__contact-link"
              href="mailto:[DATO: email corporativo]"
              aria-label={lang === 'es' ? 'Email corporativo' : 'Corporate email'}
            >
              {/* [DATO: email corporativo, ej: operaciones@helitec.aero] */}
              [DATO: email corporativo]
            </a>
          </li>

          <!-- Sede / Aeropuerto base -->
          <li class="footer__contact-item footer__contact-item--address">
            <span class="footer__contact-icon" aria-hidden="true">
              <!-- Location pin -->
              <svg width="10" height="14" viewBox="0 0 10 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 1C2.79 1 1 2.79 1 5C1 8.5 5 13 5 13C5 13 9 8.5 9 5C9 2.79 7.21 1 5 1Z" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="5" cy="5" r="1.5" stroke="currentColor" stroke-width="1.2"/>
              </svg>
            </span>
            <span class="footer__contact-text">
              {/* [DATO: aeropuerto o dirección base operativa] */}
              [DATO: aeropuerto/sede operativa]
            </span>
          </li>

        </ul>

        <!-- CTA WhatsApp — ghost button -->
        <a
          class="footer__cta"
          href="https://wa.me/584166235254"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={lang === 'es' ? 'Solicitar cotización de vuelo vía WhatsApp' : 'Request flight quote via WhatsApp'}
        >
          <span>{lang === 'es' ? 'Solicitar cotización' : 'Request a quote'}</span>
          <!-- Flecha derecha — animada en hover (estilo Licorn) -->
          <svg class="footer__cta-arrow" width="12" height="10" viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M1 5h10M7 1l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/>
          </svg>
        </a>

      </div>

    </div>
  </div>

  <!-- ── Bottom bar — copyright y créditos ─────────────────────────────── -->
  <div class="footer__bottom">
    <div class="footer__inner footer__bottom-inner">

      <p class="footer__copyright">
        © {currentYear} Consorcio Helitec.
        {lang === 'es'
          ? ' Todos los derechos reservados.'
          : ' All rights reserved.'
        }
      </p>

      <div class="footer__bottom-links">
        <a class="footer__bottom-link" href="#" aria-label={lang === 'es' ? 'Política de privacidad' : 'Privacy policy'}>
          {lang === 'es' ? 'Privacidad' : 'Privacy'}
        </a>
        <span class="footer__bottom-sep" aria-hidden="true">·</span>
        <a class="footer__bottom-link" href="#" aria-label={lang === 'es' ? 'Aviso legal' : 'Legal notice'}>
          {lang === 'es' ? 'Aviso legal' : 'Legal'}
        </a>
      </div>

    </div>
  </div>

</footer>


<style>
  /* ════════════════════════════════════════════════════════════════════════
     FOOTER BASE
  ════════════════════════════════════════════════════════════════════════ */

  .footer {
    background-color: var(--c-bg); /* #07080C — el más oscuro */
    border-top:       1px solid var(--c-line);
  }

  .footer__inner {
    max-width:      var(--content-max);
    margin-inline:  auto;
    padding-inline: calc(var(--sidebar-w) + var(--gutter));
  }

  /* ════════════════════════════════════════════════════════════════════════
     MAIN — grid 3 columnas
  ════════════════════════════════════════════════════════════════════════ */

  .footer__main {
    padding-block: clamp(48px, 7vh, 80px);
  }

  .footer__main .footer__inner {
    display:               grid;
    grid-template-columns: 1.4fr 1fr 1.2fr;
    gap:                   clamp(32px, 5vw, 64px);
    align-items:           start;
  }

  /* ════════════════════════════════════════════════════════════════════════
     COLUMNA 1 — IDENTIDAD
  ════════════════════════════════════════════════════════════════════════ */

  .footer__col {
    display:        flex;
    flex-direction: column;
    gap:            20px;
  }

  .footer__logo-link {
    display:    inline-block;
    line-height: 0; /* Evita espacio extra bajo la imagen */
  }

  .footer__logo {
    width:      clamp(120px, 15vw, 160px);
    height:     auto;
    object-fit: contain;
    opacity:    0.90;

    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .footer__logo-link:hover .footer__logo,
  .footer__logo-link:focus-visible .footer__logo {
    opacity: 1;
  }

  .footer__tagline {
    font-family: var(--font-sans);
    font-size:   clamp(0.75rem, 1.2vw, 0.875rem);
    font-weight: var(--fw-light);
    color:       var(--c-text-2);
    line-height: 1.55;
    margin-top:  -4px; /* Reducir gap visual con el logo */
  }

  /* Datos legales / address */
  .footer__address {
    display:        flex;
    flex-direction: column;
    gap:            5px;
    font-style:     normal; /* Neutralizar el italic del <address> */
  }

  .footer__address-line {
    font-family:    var(--font-sans);
    font-size:      0.6875rem; /* 11px */
    font-weight:    var(--fw-regular);
    letter-spacing: var(--ls-wide);
    color:          var(--c-text-3);
  }

  .footer__address-value {
    color: var(--c-text-2);
  }

  /* Badges de certificación */
  .footer__certs {
    display: flex;
    gap:     8px;
    flex-wrap: wrap;
  }

  .footer__cert-tag {
    font-family:    var(--font-sans);
    font-size:      0.5625rem; /* 9px */
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);

    padding:       3px 7px;
    border:        1px solid rgba(88, 181, 240, 0.30);
    border-radius: var(--r-micro); /* 4px */
  }

  /* Redes sociales */
  .footer__socials {
    display:   flex;
    gap:       10px;
    flex-wrap: wrap;
    margin-top: -4px; /* Compensa el gap del flex del col */
  }

  .footer__social-link {
    display:     inline-flex;
    align-items: center;
    gap:         7px;
    text-decoration: none;

    font-family:    var(--font-sans);
    font-size:      0.6875rem; /* 11px */
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wide);
    color:          var(--c-text-2);

    transition: color var(--dur-fast) var(--ease-out);
  }

  .footer__social-link:hover,
  .footer__social-link:focus-visible {
    color:   var(--c-white);
    opacity: 1;
  }

  .footer__social-box {
    display:         inline-flex;
    align-items:     center;
    justify-content: center;
    width:           20px;
    height:          20px;
    flex-shrink:     0;

    background-color: rgba(88, 181, 240, 0.08);
    border:           1px solid rgba(88, 181, 240, 0.28);
    border-radius:    var(--r-micro); /* 4px */
    color:            var(--c-sky);

    transition:
      background-color var(--dur-fast) var(--ease-out),
      border-color     var(--dur-fast) var(--ease-out);
  }

  .footer__social-link:hover .footer__social-box,
  .footer__social-link:focus-visible .footer__social-box {
    background-color: rgba(88, 181, 240, 0.16);
    border-color:     rgba(88, 181, 240, 0.52);
  }

  /* ════════════════════════════════════════════════════════════════════════
     COLUMNA 2 — NAVEGACIÓN
  ════════════════════════════════════════════════════════════════════════ */

  .footer__col-heading {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-text-1);
    margin-bottom:  4px;
  }

  .footer__nav-list {
    list-style: none;
    padding:    0;
    margin:     0;
    display:    flex;
    flex-direction: column;
    gap:        4px;
  }

  .footer__nav-link {
    display:     inline-block;
    padding:     5px 0;

    font-family: var(--font-sans);
    font-size:   0.8125rem; /* 13px */
    font-weight: var(--fw-light);
    color:       var(--c-text-2);

    text-decoration: none;

    transition: color var(--dur-fast) var(--ease-out);
  }

  .footer__nav-link:hover,
  .footer__nav-link:focus-visible {
    color: var(--c-text-1);
  }

  .footer__nav-link:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
    border-radius:  var(--r-micro);
  }

  /* ════════════════════════════════════════════════════════════════════════
     COLUMNA 3 — CONTACTO B2B
  ════════════════════════════════════════════════════════════════════════ */

  .footer__contact-list {
    list-style: none;
    padding:    0;
    margin:     0;
    display:    flex;
    flex-direction: column;
    gap:        10px;
  }

  .footer__contact-item {
    display:     flex;
    align-items: center;
    gap:         8px;
  }

  .footer__contact-item--address {
    align-items: flex-start;
  }

  .footer__contact-icon {
    display:     flex;
    align-items: center;
    flex-shrink: 0;
    color:       var(--c-text-3);
    margin-top:  1px; /* Alineación óptica con el texto */
  }

  .footer__contact-link {
    font-family: var(--font-sans);
    font-size:   0.8125rem; /* 13px */
    font-weight: var(--fw-regular);
    color:       var(--c-text-2);

    text-decoration: none;

    transition: color var(--dur-fast) var(--ease-out);
  }

  .footer__contact-link:hover,
  .footer__contact-link:focus-visible {
    color: var(--c-text-1);
  }

  .footer__contact-link:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
    border-radius:  var(--r-micro);
  }

  .footer__contact-text {
    font-family: var(--font-sans);
    font-size:   0.8125rem; /* 13px */
    font-weight: var(--fw-light);
    color:       var(--c-text-2);
    line-height: 1.5;
  }

  /* CTA ghost button — acento azul Helitec + flecha animada (estilo Licorn) */
  .footer__cta {
    display:         inline-flex;
    align-items:     center;
    gap:             8px;
    margin-top:      8px;

    padding:       9px 16px;

    font-family:    var(--font-sans);
    font-size:      0.6875rem; /* 11px */
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-1);
    text-decoration: none;

    /* Ghost: borde azul Helitec sutil en lugar de blanco */
    background:    transparent;
    border:        1px solid rgba(88, 181, 240, 0.35);
    border-radius: var(--r-micro); /* 4px */

    transition:
      border-color     var(--dur-fast) var(--ease-out),
      color            var(--dur-fast) var(--ease-out),
      background-color var(--dur-fast) var(--ease-out);
  }

  .footer__cta:hover {
    border-color:     rgba(88, 181, 240, 0.65);
    background-color: rgba(88, 181, 240, 0.06);
    color:            var(--c-white);
  }

  .footer__cta:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 3px;
  }

  /* Flecha animada — desliza a la derecha en hover */
  .footer__cta-arrow {
    flex-shrink: 0;
    transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer__cta:hover .footer__cta-arrow,
  .footer__cta:focus-visible .footer__cta-arrow {
    transform: translateX(5px);
  }

  /* ════════════════════════════════════════════════════════════════════════
     BOTTOM BAR — copyright
  ════════════════════════════════════════════════════════════════════════ */

  .footer__bottom {
    border-top:   1px solid var(--c-line);
    padding-block: 20px;
  }

  .footer__bottom-inner {
    display:         flex;
    align-items:     center;
    justify-content: space-between;
    flex-wrap:       wrap;
    gap:             12px;
  }

  .footer__copyright {
    font-family:    var(--font-sans);
    font-size:      0.75rem; /* 12px — sutil, per spec */
    font-weight:    var(--fw-regular);
    letter-spacing: var(--ls-wide);
    color:          var(--c-text-3);
    line-height:    1.5;
  }

  .footer__bottom-links {
    display:     flex;
    align-items: center;
    gap:         8px;
  }

  .footer__bottom-link {
    font-family:    var(--font-sans);
    font-size:      0.75rem; /* 12px */
    font-weight:    var(--fw-regular);
    color:          var(--c-text-3);
    text-decoration: none;

    transition: color var(--dur-fast) var(--ease-out);
  }

  .footer__bottom-link:hover,
  .footer__bottom-link:focus-visible {
    color: var(--c-text-2);
  }

  .footer__bottom-link:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
    border-radius:  var(--r-micro);
  }

  .footer__bottom-sep {
    font-size:   0.75rem;
    color:       var(--c-text-3);
    user-select: none;
  }

  /* ════════════════════════════════════════════════════════════════════════
     RESPONSIVE
  ════════════════════════════════════════════════════════════════════════ */

  /* Tablet (640–1023px): quitar offset del sidebar, grid 2+1 */
  @media (max-width: 1023px) {
    .footer__inner {
      padding-inline: var(--gutter);
    }

    .footer__main .footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: clamp(28px, 4vw, 48px);
    }

    /* Columna 1 ocupa todo el ancho en la primera fila */
    .footer__col--brand {
      grid-column: 1 / -1;
    }
  }

  /* Mobile (< 640px): columna única */
  @media (max-width: 639px) {
    .footer__main .footer__inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .footer__col--brand {
      grid-column: auto;
    }

    .footer__bottom-inner {
      flex-direction: column;
      align-items:    flex-start;
      gap:            8px;
    }
  }
</style>
