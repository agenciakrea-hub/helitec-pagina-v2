---
/**
 * SideLeadCTA.astro
 * Consorcio Helitec — Cotizador de Vuelo Privado Premium (Panel lateral)
 *
 * v2 — Motor Sundown Jet-style, adaptado a panel 380px
 *
 * Estructura del formulario:
 *   1. Selector de tipo de viaje  → tabs "Solo Ida" / "Ida y Vuelta"
 *   2. Campos de aviación:
 *        Origen        → aeropuerto / ciudad de salida
 *        Destino       → aeropuerto / ciudad de llegada
 *        Fecha Salida  → <input type="date"> dark-themed
 *        Fecha Regreso → <input type="date"> condicional (Solo Ida → oculto)
 *        Pasajeros     → contador custom con botones − / +
 *   3. Datos corporativos B2B:
 *        Nombre del solicitante (requerido)
 *        Empresa / Institución  (requerido)
 *   4. Submit → construye mensaje WhatsApp estructurado y abre wa.me/584166235254
 *
 * Formato del mensaje WhatsApp (exacto):
 *   *SOLICITUD DE COTIZACIÓN WEB — HELITEC*
 *
 *   • *Tipo:* Solo Ida / Ida y Vuelta
 *   • *Ruta:* [Origen] ➔ [Destino]
 *   • *Salida:* DD/MM/YYYY
 *   • *Regreso:* DD/MM/YYYY | No aplica
 *   • *Pasajeros:* N
 *
 *   *DATOS DEL CLIENTE:*
 *   • *Nombre:* [Nombre]
 *   • *Empresa:* [Empresa]
 *
 * Reglas anti-slop (v2):
 *   PROHIBIDO box-shadow     — ✓
 *   PROHIBIDO linear-gradient — ✓
 *   border-radius ≤ 4px      — ✓ (var(--r-micro) en todo)
 *   object-fit: cover        — N/A
 *   Tipografía labels: Inter  — ✓
 *
 * z-index: var(--z-cta-float) = 850 (trigger) / 848 (panel) / 847 (backdrop)
 */
---

<!-- ── BACKDROP ───────────────────────────────────────────────────────────── -->
<div
  class="slcta__backdrop"
  id="slcta-backdrop"
  aria-hidden="true"
></div>

<!-- ── PANEL DESLIZANTE ──────────────────────────────────────────────────── -->
<div
  class="slcta__panel"
  id="slcta-panel"
  role="dialog"
  aria-modal="true"
  aria-label="Cotizador de vuelo privado"
  aria-hidden="true"
>

  <!-- ── CABECERA DEL PANEL ──────────────────────────────────────────────── -->
  <div class="slcta__header">
    <div class="slcta__header-meta">
      <p class="slcta__overline">Consorcio Helitec</p>
      <h2 class="slcta__title">Cotizar<br>Vuelo Privado</h2>
    </div>
    <!-- Botón cerrar dentro del panel -->
    <button
      class="slcta__panel-close"
      id="slcta-panel-close"
      type="button"
      aria-label="Cerrar cotizador"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
      </svg>
    </button>
  </div>

  <!-- ── FORMULARIO ──────────────────────────────────────────────────────── -->
  <form class="slcta__form" id="slcta-form" novalidate>

    <!-- ── 1. TIPO DE VIAJE — tabs Solo Ida / Ida y Vuelta ──────────────── -->
    <div class="slcta__section">
      <p class="slcta__section-label">Tipo de viaje</p>
      <div class="slcta__trip-tabs" role="group" aria-label="Tipo de viaje">
        <button
          class="slcta__trip-tab is-active"
          type="button"
          data-trip="one-way"
          aria-pressed="true"
        >
          Solo Ida
        </button>
        <button
          class="slcta__trip-tab"
          type="button"
          data-trip="round-trip"
          aria-pressed="false"
        >
          Ida y Vuelta
        </button>
      </div>
      <!-- Campo oculto que guarda el valor del tipo de viaje -->
      <input type="hidden" id="slcta-trip-type" name="trip_type" value="one-way" />
    </div>

    <!-- ── 2. RUTA ─────────────────────────────────────────────────────── -->
    <div class="slcta__section">
      <p class="slcta__section-label">Ruta</p>

      <div class="slcta__route-wrap">

        <!-- Origen -->
        <div class="slcta__field">
          <label class="slcta__label" for="slcta-origen">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="slcta__label-icon">
              <circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="1.2"/>
              <circle cx="5" cy="5" r="1.5" fill="currentColor"/>
            </svg>
            Origen
          </label>
          <input
            class="slcta__input"
            type="text"
            id="slcta-origen"
            name="origen"
            placeholder="Ciudad o aeropuerto de salida"
            autocomplete="off"
            required
          />
        </div>

        <!-- Flecha separadora -->
        <div class="slcta__route-arrow" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/>
          </svg>
        </div>

        <!-- Destino -->
        <div class="slcta__field">
          <label class="slcta__label" for="slcta-destino">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="slcta__label-icon">
              <path d="M5 1L5 9M2 6l3 3 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/>
            </svg>
            Destino
          </label>
          <input
            class="slcta__input"
            type="text"
            id="slcta-destino"
            name="destino"
            placeholder="Ciudad o aeropuerto de llegada"
            autocomplete="off"
            required
          />
        </div>

      </div>
    </div>

    <!-- ── 3. FECHAS ───────────────────────────────────────────────────── -->
    <div class="slcta__section">
      <p class="slcta__section-label">Fechas</p>

      <!-- Fecha de Salida (siempre visible) -->
      <div class="slcta__field">
        <label class="slcta__label" for="slcta-fecha-salida">Fecha de Salida *</label>
        <input
          class="slcta__input slcta__input--date"
          type="date"
          id="slcta-fecha-salida"
          name="fecha_salida"
          required
        />
      </div>

      <!-- Fecha de Regreso (condicional: visible solo en "Ida y Vuelta") -->
      <div class="slcta__return-wrap" id="slcta-return-wrap" aria-hidden="true">
        <div class="slcta__field">
          <label class="slcta__label" for="slcta-fecha-regreso">Fecha de Regreso *</label>
          <input
            class="slcta__input slcta__input--date"
            type="date"
            id="slcta-fecha-regreso"
            name="fecha_regreso"
            disabled
            tabindex="-1"
          />
        </div>
      </div>

    </div>

    <!-- ── 4. PASAJEROS — contador custom ─────────────────────────────── -->
    <div class="slcta__section">
      <p class="slcta__section-label">Pasajeros</p>

      <div class="slcta__field">
        <label class="slcta__label" for="slcta-pasajeros">Número de pasajeros *</label>
        <div class="slcta__counter">
          <button
            class="slcta__counter-btn"
            type="button"
            data-action="decrement"
            aria-label="Reducir pasajeros"
          >
            <svg width="12" height="2" viewBox="0 0 12 2" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M1 1h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            </svg>
          </button>
          <input
            class="slcta__counter-input"
            type="number"
            id="slcta-pasajeros"
            name="pasajeros"
            value="1"
            min="1"
            max="19"
            readonly
            aria-live="polite"
            required
          />
          <button
            class="slcta__counter-btn"
            type="button"
            data-action="increment"
            aria-label="Aumentar pasajeros"
          >
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            </svg>
          </button>
        </div>
        <p class="slcta__field-hint">Máximo 19 pasajeros por solicitud</p>
      </div>
    </div>

    <!-- ── 5. DATOS CORPORATIVOS B2B ──────────────────────────────────── -->
    <div class="slcta__section slcta__section--last">
      <p class="slcta__section-label">Datos del solicitante</p>

      <div class="slcta__field">
        <label class="slcta__label" for="slcta-nombre">Nombre completo *</label>
        <input
          class="slcta__input"
          type="text"
          id="slcta-nombre"
          name="nombre"
          autocomplete="name"
          placeholder="Ej: Carlos Rodríguez"
          required
        />
      </div>

      <div class="slcta__field">
        <label class="slcta__label" for="slcta-empresa">Empresa / Institución *</label>
        <input
          class="slcta__input"
          type="text"
          id="slcta-empresa"
          name="empresa"
          autocomplete="organization"
          placeholder="Ej: Pdvsa, Chevron, PDVSA Gas"
          required
        />
      </div>

    </div>

    <!-- ── MENSAJE DE ERROR ────────────────────────────────────────────── -->
    <p
      class="slcta__error"
      id="slcta-error"
      role="alert"
      aria-live="assertive"
      hidden
    ></p>

    <!-- ── SUBMIT ──────────────────────────────────────────────────────── -->
    <div class="slcta__submit-wrap">
      <button class="slcta__submit" type="submit">
        <!-- Ícono WhatsApp -->
        <svg class="slcta__submit-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M20.52 3.48A11.9 11.9 0 0 0 12 0C5.37 0 0 5.37 0 12c0 2.12.55 4.18 1.6 6L0 24l6.17-1.57A11.94 11.94 0 0 0 12 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.22-3.48-8.52ZM12 21.94a9.9 9.9 0 0 1-5.04-1.37l-.36-.22-3.66.94.97-3.56-.24-.37A9.9 9.9 0 0 1 2.06 12C2.06 6.49 6.49 2.06 12 2.06S21.94 6.49 21.94 12 17.51 21.94 12 21.94Zm5.44-7.42c-.3-.15-1.76-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.14-1.26-.46-2.4-1.47-.89-.79-1.49-1.77-1.66-2.06-.17-.3-.02-.46.13-.6.13-.13.3-.35.44-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.2-.24-.58-.48-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.03 1.01-1.03 2.46s1.06 2.85 1.2 3.05c.15.2 2.08 3.18 5.04 4.46.7.3 1.25.48 1.68.62.7.22 1.34.19 1.85.11.56-.08 1.76-.72 2-1.41.25-.7.25-1.3.18-1.42-.07-.12-.27-.2-.57-.34Z" fill="currentColor"/>
        </svg>
        Solicitar cotización vía WhatsApp
      </button>

      <p class="slcta__privacy">
        Su consulta se envía directamente al equipo operativo vía WhatsApp. Sin intermediarios ni formularios en servidor.
      </p>
    </div>

  </form>
</div>

<!-- ── TRIGGER — strip vertical "COTIZACIÓN" ─────────────────────────────
  position: fixed · right: 0 · encima del grupo de FABs de ContactSheet.
  Scroll trigger: oculto sobre el Hero, visible al salir (IntersectionObserver).
  Todo el CSS y el scroll-trigger JS viven en este mismo archivo (autocontenido).
──────────────────────────────────────────────────────────────────────────── -->
<button
  class="slcta__trigger"
  id="slcta-trigger"
  type="button"
  aria-expanded="false"
  aria-controls="slcta-panel"
  aria-label="Solicitar cotización de vuelo privado"
>
  <!-- Ícono avión (estado cerrado) -->
  <span class="slcta__trigger-icon" aria-hidden="true">
    <svg width="17" height="15" viewBox="0 0 18 16" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1 1L17 8L1 15V9.5L11 8L1 6.5V1Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="square" stroke-linejoin="miter"/>
    </svg>
  </span>
  <!-- Texto vertical permanente (estado cerrado) -->
  <span class="slcta__trigger-text" aria-hidden="true">COTIZACIÓN</span>
  <!-- ✕ (estado abierto) -->
  <span class="slcta__trigger-close" aria-hidden="true">
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1 1L11 11M11 1L1 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
    </svg>
  </span>
</button>


<style>
  /* ════════════════════════════════════════════════════════════════════════
     BACKDROP
  ════════════════════════════════════════════════════════════════════════ */

  .slcta__backdrop {
    position:         fixed;
    inset:            0;
    z-index:          847;

    background-color: rgba(7, 8, 12, 0.70);

    opacity:          0;
    pointer-events:   none;
    visibility:       hidden;

    transition:
      opacity    var(--dur-mid) var(--ease-out),
      visibility 0s linear calc(var(--dur-mid) + 10ms);
  }

  .slcta__backdrop.is-open {
    opacity:        1;
    pointer-events: auto;
    visibility:     visible;
    transition:
      opacity    var(--dur-mid) var(--ease-out),
      visibility 0s linear 0s;
  }

  /* ════════════════════════════════════════════════════════════════════════
     PANEL
  ════════════════════════════════════════════════════════════════════════ */

  .slcta__panel {
    --panel-w: clamp(300px, 92vw, 400px);

    position:   fixed;
    right:      0;
    top:        0;
    height:     100dvh;
    width:      var(--panel-w);

    z-index:    848;

    background-color: var(--c-bg-raised);
    border-left:      2px solid var(--c-brand);

    overflow-y:          auto;
    overscroll-behavior: contain;

    /* Slide in desde la derecha */
    transform:  translateX(100%);
    visibility: hidden;

    transition:
      transform  var(--dur-mid) var(--ease-menu),
      visibility 0s linear calc(var(--dur-mid) + 10ms);
  }

  .slcta__panel.is-open {
    transform:  translateX(0);
    visibility: visible;
    transition:
      transform  var(--dur-mid) var(--ease-menu),
      visibility 0s linear 0s;
  }

  /* ════════════════════════════════════════════════════════════════════════
     CABECERA DEL PANEL
  ════════════════════════════════════════════════════════════════════════ */

  .slcta__header {
    position: sticky;
    top:      0;
    z-index:  1;

    display:         flex;
    align-items:     flex-start;
    justify-content: space-between;
    gap:             16px;

    padding:          clamp(24px, 4vh, 36px) clamp(20px, 5vw, 28px) 20px;
    border-bottom:    1px solid var(--c-line);
    background-color: var(--c-bg-raised); /* Para que el sticky tape el contenido */
  }

  .slcta__overline {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-brand);
    margin-bottom:  8px;
  }

  .slcta__title {
    font-family:    var(--font-display);
    font-size:      clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight:    var(--fw-thin);   /* 200 — OBLIGATORIO */
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    line-height:    1.05;
    color:          var(--c-text-1);
  }

  /* Botón cerrar en la cabecera */
  .slcta__panel-close {
    flex-shrink: 0;
    margin-top:  4px;

    display:         flex;
    align-items:     center;
    justify-content: center;

    width:  32px;
    height: 32px;

    background:    none;
    border:        1px solid var(--c-line);
    border-radius: var(--r-micro); /* 4px */
    cursor:        pointer;
    color:         var(--c-text-3);

    transition:
      border-color var(--dur-fast) var(--ease-out),
      color        var(--dur-fast) var(--ease-out);
  }

  .slcta__panel-close:hover {
    border-color: var(--c-line-strong);
    color:        var(--c-text-1);
  }

  .slcta__panel-close:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
  }

  /* ════════════════════════════════════════════════════════════════════════
     FORMULARIO — estructura
  ════════════════════════════════════════════════════════════════════════ */

  .slcta__form {
    padding: 0 clamp(20px, 5vw, 28px) 32px;
  }

  /* Sección: agrupa label de sección + campos relacionados */
  .slcta__section {
    padding-block: 20px;
    border-bottom: 1px solid var(--c-line);
    display:       flex;
    flex-direction: column;
    gap:           12px;
  }

  .slcta__section--last {
    border-bottom: none;
  }

  /* Label de sección (no de campo) */
  .slcta__section-label {
    font-family:    var(--font-sans);
    font-size:      0.625rem; /* 10px */
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-text-3);
  }

  /* Campo individual */
  .slcta__field {
    display:        flex;
    flex-direction: column;
    gap:            5px;
  }

  /* Label de campo */
  .slcta__label {
    display:        flex;
    align-items:    center;
    gap:            5px;

    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-2);
  }

  .slcta__label-icon {
    color:       var(--c-text-3);
    flex-shrink: 0;
  }

  .slcta__field-hint {
    font-family: var(--font-sans);
    font-size:   0.65rem;
    color:       var(--c-text-3);
  }

  /* ════════════════════════════════════════════════════════════════════════
     TABS DE TIPO DE VIAJE
  ════════════════════════════════════════════════════════════════════════ */

  .slcta__trip-tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap:    1px;

    background-color: var(--c-line); /* Línea divisora entre tabs */
    border:           1px solid var(--c-line);
    border-radius:    var(--r-micro); /* 4px */
    overflow:         hidden;
  }

  .slcta__trip-tab {
    padding: 9px 12px;

    font-family:    var(--font-sans);
    font-size:      0.6875rem; /* 11px */
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-3);

    background:  var(--c-bg);
    border:      none;
    cursor:      pointer;

    transition:
      background-color var(--dur-fast) var(--ease-out),
      color            var(--dur-fast) var(--ease-out);
  }

  /* Tab activo */
  .slcta__trip-tab.is-active {
    background-color: var(--c-brand);
    color:            var(--c-white);
  }

  .slcta__trip-tab:not(.is-active):hover {
    background-color: var(--c-bg-raised);
    color:            var(--c-text-2);
  }

  .slcta__trip-tab:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: -2px;
  }

  /* ════════════════════════════════════════════════════════════════════════
     RUTA — origen + flecha + destino
  ════════════════════════════════════════════════════════════════════════ */

  .slcta__route-wrap {
    display:        flex;
    flex-direction: column;
    gap:            4px;
  }

  /* Flecha separadora entre origen y destino */
  .slcta__route-arrow {
    display:         flex;
    align-items:     center;
    padding-inline:  12px;
    color:           var(--c-text-3);
    height:          16px;
  }

  /* ════════════════════════════════════════════════════════════════════════
     INPUT BASE
  ════════════════════════════════════════════════════════════════════════ */

  .slcta__input {
    width:  100%;
    padding: 9px 12px;

    font-family: var(--font-sans);
    font-size:   0.875rem;
    font-weight: var(--fw-regular);
    color:       var(--c-text-1);

    background-color: var(--c-bg);
    border:           1px solid var(--c-line);  /* 1px — sin bordes gruesos */
    border-radius:    var(--r-micro);            /* 4px — límite sagrado */

    outline:    none;
    appearance: none;

    transition:
      border-color     var(--dur-fast) var(--ease-out),
      background-color var(--dur-fast) var(--ease-out);
  }

  .slcta__input::placeholder {
    color: var(--c-text-3);
  }

  .slcta__input:hover:not(:focus) {
    border-color: var(--c-line-strong);
  }

  .slcta__input:focus {
    border-color:     var(--c-brand);
    background-color: rgba(2, 58, 120, 0.05);
  }

  /* ── Input type="date" — dark theme ──────────────────────────────────── */
  .slcta__input--date {
    /*
     * color-scheme: dark instruye al navegador a renderizar
     * el picker nativo de fecha con colores oscuros.
     * Compatible con Chrome 93+, Firefox 96+, Safari 15.4+.
     */
    color-scheme: dark;
    cursor:       pointer;
  }

  /* Forzar color del texto en navegadores WebKit */
  .slcta__input--date::-webkit-datetime-edit {
    color: var(--c-text-1);
  }

  .slcta__input--date::-webkit-datetime-edit-fields-wrapper {
    padding: 0;
  }

  .slcta__input--date::-webkit-datetime-edit-text {
    color: var(--c-text-3);
    padding: 0 2px;
  }

  .slcta__input--date::-webkit-datetime-edit-year-field,
  .slcta__input--date::-webkit-datetime-edit-month-field,
  .slcta__input--date::-webkit-datetime-edit-day-field {
    color: var(--c-text-1);
  }

  /* Ocultar el ícono de calendario nativo de Chrome (reemplazado por color-scheme) */
  .slcta__input--date::-webkit-calendar-picker-indicator {
    filter:  invert(0.6);
    cursor:  pointer;
    opacity: 0.5;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .slcta__input--date:hover::-webkit-calendar-picker-indicator,
  .slcta__input--date:focus::-webkit-calendar-picker-indicator {
    opacity: 0.9;
  }

  /* ── Fecha de Regreso — animación de visibilidad ──────────────────────
   *
   * Usa max-height + opacity para una transición fluida.
   * max-height: 0          → campo colapsado (Solo Ida)
   * max-height: 120px      → campo expandido (Ida y Vuelta)
   * overflow: hidden       → oculta el contenido durante el colapso
   *
   * NUNCA usar display:none directamente para esto —
   * impediría la transición CSS.
   ───────────────────────────────────────────────────────────────────── */
  .slcta__return-wrap {
    max-height:     0;
    overflow:       hidden;
    opacity:        0;
    pointer-events: none;

    transition:
      max-height var(--dur-mid) var(--ease-out),
      opacity    var(--dur-fast) var(--ease-out);
  }

  .slcta__return-wrap.is-visible {
    max-height:     120px;
    opacity:        1;
    pointer-events: auto;

    transition:
      max-height var(--dur-mid)  var(--ease-out),
      opacity    var(--dur-mid)  var(--ease-out) 80ms; /* 80ms delay para leer después de expand */
  }

  /* ════════════════════════════════════════════════════════════════════════
     CONTADOR DE PASAJEROS
  ════════════════════════════════════════════════════════════════════════ */

  .slcta__counter {
    display:     flex;
    align-items: center;

    border:        1px solid var(--c-line);
    border-radius: var(--r-micro); /* 4px */
    overflow:      hidden;

    /* Líneas divisoras entre botones e input mediante background trick */
    background-color: var(--c-line);
    gap:              1px;
  }

  .slcta__counter-btn {
    display:         flex;
    align-items:     center;
    justify-content: center;

    width:      40px;
    height:     38px;
    flex-shrink: 0;

    background:  var(--c-bg);
    border:      none;
    cursor:      pointer;
    color:       var(--c-text-2);

    transition:
      background-color var(--dur-fast) var(--ease-out),
      color            var(--dur-fast) var(--ease-out);
  }

  .slcta__counter-btn:hover {
    background-color: var(--c-bg-raised);
    color:            var(--c-text-1);
  }

  .slcta__counter-btn:active {
    background-color: var(--c-brand);
    color:            var(--c-white);
  }

  .slcta__counter-btn:disabled {
    opacity:        0.3;
    cursor:         not-allowed;
    pointer-events: none;
  }

  .slcta__counter-btn:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: -2px;
  }

  /* Input numérico del contador — solo lectura, centrado */
  .slcta__counter-input {
    flex:      1;
    min-width: 0;
    height:    38px;
    padding:   0;

    font-family:    var(--font-display);
    font-size:      1.1rem;
    font-weight:    var(--fw-light);
    letter-spacing: var(--ls-wide);
    text-align:     center;
    color:          var(--c-text-1);

    background-color: var(--c-bg);
    border:           none;
    outline:          none;
    appearance:       textfield; /* Ocultar flechas nativas del input number */

    cursor: default;
  }

  /* Ocultar flechas nativas de number input en Chrome/Safari */
  .slcta__counter-input::-webkit-outer-spin-button,
  .slcta__counter-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Firefox */
  .slcta__counter-input[type=number] {
    -moz-appearance: textfield;
  }

  /* ════════════════════════════════════════════════════════════════════════
     MENSAJE DE ERROR
  ════════════════════════════════════════════════════════════════════════ */

  .slcta__error {
    margin-inline: clamp(20px, 5vw, 28px);
    padding:       10px 12px;

    font-family: var(--font-sans);
    font-size:   var(--text-xs);
    color:       var(--c-red);
    line-height: 1.5;

    border:        1px solid rgba(229, 59, 28, 0.25);
    border-radius: var(--r-micro);
    background:    rgba(229, 59, 28, 0.06);
  }

  .slcta__error[hidden] { display: none; }

  /* ════════════════════════════════════════════════════════════════════════
     SUBMIT + PRIVACIDAD
  ════════════════════════════════════════════════════════════════════════ */

  .slcta__submit-wrap {
    padding: 20px clamp(20px, 5vw, 28px) 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .slcta__submit {
    display:         flex;
    align-items:     center;
    justify-content: center;
    gap:             10px;

    width:   100%;
    padding: 13px 20px;

    font-family:    var(--font-sans);
    font-size:      0.6875rem; /* 11px */
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-white);

    /* WhatsApp green — excepción justificada (branding externo) */
    background-color: #25D366;
    border:           none;
    border-radius:    var(--r-micro); /* 4px */
    cursor:           pointer;

    transition:
      background-color var(--dur-fast) var(--ease-out),
      opacity          var(--dur-fast) var(--ease-out);
  }

  .slcta__submit:hover  { background-color: #1DA851; }
  .slcta__submit:active { opacity: 0.85; }

  .slcta__submit-icon {
    flex-shrink: 0;
  }

  .slcta__privacy {
    font-family: var(--font-sans);
    font-size:   0.65rem;
    color:       var(--c-text-3);
    line-height: 1.55;
    text-align:  center;

    padding-bottom: 8px;
  }

  /* ════════════════════════════════════════════════════════════════════════
     TRIGGER — strip vertical fijo · borde derecho
     position: fixed; right: 0 → flush contra el borde derecho.
     z-index: 850 — sobre el panel (848) y bajo el backdrop ContactSheet (898).
     Scroll trigger: oculto en el Hero, visible fuera.
  ════════════════════════════════════════════════════════════════════════ */

  .slcta__trigger {
    position: fixed;
    right:    0;
    bottom:   calc(clamp(16px, 3vh, 24px) + 112px); /* encima del grupo de FABs */
    z-index:  850;

    display:        flex;
    flex-direction: column;
    align-items:    center;
    justify-content: center;
    gap:            8px;

    width:       44px;
    height:      auto;
    min-height:  134px;
    padding:     12px 0;

    background:   rgba(5, 50, 130, 0.55);
    border:       1px solid rgba(88, 181, 240, 0.22);
    border-right: none;                  /* flush contra el borde derecho */
    border-radius: 4px 0 0 4px;         /* solo esquinas izquierdas */
    color:        rgba(255, 255, 255, 0.88);
    cursor:       pointer;

    /* Scroll trigger: inicial → off-screen derecha */
    transform:      translateX(calc(100% + 2px));
    opacity:        0;
    visibility:     hidden;
    pointer-events: none;

    transition:
      transform  0.55s cubic-bezier(0.16, 1, 0.3, 1),
      opacity    0.40s ease-out,
      visibility 0s   linear  0.40s,
      background 0.2s ease-out,
      border-color 0.2s ease-out;
  }

  .slcta__trigger.is-visible {
    transform:      translateX(0);
    opacity:        1;
    visibility:     visible;
    pointer-events: auto;

    transition:
      transform  0.55s cubic-bezier(0.16, 1, 0.3, 1),
      opacity    0.40s ease-out,
      visibility 0s   linear  0s,
      background 0.2s ease-out,
      border-color 0.2s ease-out;
  }

  .slcta__trigger:hover {
    background:   rgba(10, 77, 158, 0.70);
    border-color: rgba(88, 181, 240, 0.45);
    color:        var(--c-white);
  }

  .slcta__trigger:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
  }

  .slcta__trigger[aria-expanded="true"] {
    background:   rgba(10, 77, 158, 0.80);
    border-color: rgba(88, 181, 240, 0.55);
  }

  /* Texto vertical */
  .slcta__trigger-text {
    writing-mode:     vertical-rl;
    text-orientation: mixed;
    transform:        rotate(180deg);

    font-family:    var(--font-sans);
    font-size:      8.5px;
    font-weight:    var(--fw-medium);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color:          inherit;
    white-space:    nowrap;

    opacity:    1;
    transition: opacity 0.15s ease-out;
  }

  .slcta__trigger[aria-expanded="true"] .slcta__trigger-text { opacity: 0; }

  /* Ícono avión / ✕ swap */
  .slcta__trigger-icon,
  .slcta__trigger-close {
    display:         flex;
    align-items:     center;
    justify-content: center;
    flex-shrink:     0;
    transition:      opacity 0.15s ease-out;
  }

  .slcta__trigger-icon  { opacity: 1; }
  .slcta__trigger-close { opacity: 0; }

  .slcta__trigger[aria-expanded="true"] .slcta__trigger-icon  { opacity: 0; }
  .slcta__trigger[aria-expanded="true"] .slcta__trigger-close { opacity: 1; }

  /* Ocultar cuando el menú modal está abierto */
  :global(body.menu-is-open)   .slcta__trigger,
  :global(body.menu-is-closing) .slcta__trigger {
    opacity:        0;
    visibility:     hidden;
    pointer-events: none;
  }

  /* ════════════════════════════════════════════════════════════════════════
     MOBILE — Alineación con el grupo de FABs de ContactSheet
     right: 16px → se alinea con el borde izquierdo del grupo de iconos.
     border-right + border-radius: ya no es flush contra el borde — bordes completos.
     translateX inicial aumentado para quedar totalmente off-screen con right: 16px.
  ════════════════════════════════════════════════════════════════════════ */

  @media (max-width: 767px) {
    .slcta__trigger {
      right:         16px;                              /* alineado con los FABs */
      border-right:  1px solid rgba(88, 181, 240, 0.22); /* restaurar borde derecho */
      border-radius: 4px;                               /* todas las esquinas */

      /* off-screen: 100% propio (44px) + right (16px) + 2px margen = 62px */
      transform:     translateX(calc(100% + 18px));
    }
  }
</style>


<script>
  /**
   * SideLeadCTA v2 — Controller
   *
   * Responsabilidades:
   *   A. Abrir / cerrar el panel (trigger strip + botón cerrar + backdrop + Escape)
   *   B. Tabs de tipo de viaje (Solo Ida / Ida y Vuelta) con toggle condicional
   *      del campo "Fecha de Regreso"
   *   C. Contador de pasajeros (botones − / +)
   *   D. Fecha mínima: hoy (previene selección de fechas pasadas)
   *   E. Validación del formulario (campos requeridos)
   *   F. Formateador del mensaje de WhatsApp con codificación URI
   *   G. Focus trap mientras el panel está abierto (accesibilidad)
   */
  (function () {

    /* ── Referencias al DOM ─────────────────────────────────────────────── */
    const trigger     = document.getElementById('slcta-trigger');
    const panelClose  = document.getElementById('slcta-panel-close');
    const panel       = document.getElementById('slcta-panel');
    const backdrop    = document.getElementById('slcta-backdrop');
    const form        = document.getElementById('slcta-form');
    const errorMsg    = document.getElementById('slcta-error');

    /* Tipo de viaje */
    const tripTabs      = panel.querySelectorAll('.slcta__trip-tab');
    const tripTypeInput = document.getElementById('slcta-trip-type');
    const returnWrap    = document.getElementById('slcta-return-wrap');
    const returnInput   = document.getElementById('slcta-fecha-regreso');

    /* Contador de pasajeros */
    const counterBtns  = panel.querySelectorAll('.slcta__counter-btn');
    const pasajeroInput = document.getElementById('slcta-pasajeros');

    /* Fechas */
    const fechaSalidaInput  = document.getElementById('slcta-fecha-salida');
    const fechaRegresoInput = document.getElementById('slcta-fecha-regreso');

    if (!trigger || !panel || !backdrop || !form) return;

    /* ════════════════════════════════════════════════════════════════════
       A. ABRIR / CERRAR PANEL
    ════════════════════════════════════════════════════════════════════ */

    let isOpen = false;

    function openPanel() {
      isOpen = true;

      panel.classList.add('is-open');
      backdrop.classList.add('is-open');

      trigger.setAttribute('aria-expanded', 'true');
      trigger.setAttribute('aria-label', 'Cerrar cotizador de vuelo privado');
      panel.setAttribute('aria-hidden', 'false');

      document.body.style.overflow = 'hidden';

      /* Foco al primer campo interactivo tras la animación */
      const DUR_MID = parseFloat(
        getComputedStyle(document.documentElement)
          .getPropertyValue('--dur-mid')
      ) || 450;

      setTimeout(() => {
        const firstFocusable = panel.querySelector(
          'button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled])'
        );
        if (firstFocusable) firstFocusable.focus();
      }, DUR_MID);
    }

    function closePanel() {
      isOpen = false;

      panel.classList.remove('is-open');
      backdrop.classList.remove('is-open');

      trigger.setAttribute('aria-expanded', 'false');
      trigger.setAttribute('aria-label', 'Abrir cotizador de vuelo privado');
      panel.setAttribute('aria-hidden', 'true');

      document.body.style.overflow = '';
      trigger.focus();
    }

    trigger.addEventListener('click', () => isOpen ? closePanel() : openPanel());

    if (panelClose) panelClose.addEventListener('click', closePanel);

    backdrop.addEventListener('click', closePanel);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        e.preventDefault();
        closePanel();
      }
    });

    /* ════════════════════════════════════════════════════════════════════
       B. TABS DE TIPO DE VIAJE
    ════════════════════════════════════════════════════════════════════ */

    function setTripType(type) {
      /* type: 'one-way' | 'round-trip' */

      /* Actualizar campo oculto */
      tripTypeInput.value = type;

      /* Actualizar estilos y aria de los tabs */
      tripTabs.forEach((tab) => {
        const isActive = tab.dataset.trip === type;
        tab.classList.toggle('is-active', isActive);
        tab.setAttribute('aria-pressed', String(isActive));
      });

      /* Mostrar / ocultar la fecha de regreso */
      const showReturn = type === 'round-trip';

      if (showReturn) {
        returnWrap.classList.add('is-visible');
        returnWrap.setAttribute('aria-hidden', 'false');
        returnInput.disabled  = false;
        returnInput.tabIndex  = 0;
        returnInput.required  = true;
      } else {
        returnWrap.classList.remove('is-visible');
        returnWrap.setAttribute('aria-hidden', 'true');
        returnInput.disabled  = true;
        returnInput.tabIndex  = -1;
        returnInput.required  = false;
        returnInput.value     = ''; /* Limpiar la fecha si se cambia a Solo Ida */
      }
    }

    tripTabs.forEach((tab) => {
      tab.addEventListener('click', () => setTripType(tab.dataset.trip));
    });

    /* ════════════════════════════════════════════════════════════════════
       C. CONTADOR DE PASAJEROS
    ════════════════════════════════════════════════════════════════════ */

    const MIN_PAX = 1;
    const MAX_PAX = 19;

    function updateCounter(delta) {
      const current = parseInt(pasajeroInput.value, 10) || 1;
      const next    = Math.max(MIN_PAX, Math.min(MAX_PAX, current + delta));

      pasajeroInput.value = String(next);

      /* Deshabilitar botones en los extremos */
      counterBtns.forEach((btn) => {
        if (btn.dataset.action === 'decrement') {
          btn.disabled = next <= MIN_PAX;
        } else if (btn.dataset.action === 'increment') {
          btn.disabled = next >= MAX_PAX;
        }
      });
    }

    counterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const delta = btn.dataset.action === 'increment' ? 1 : -1;
        updateCounter(delta);
      });
    });

    /* Inicializar estado de los botones */
    updateCounter(0);

    /* ════════════════════════════════════════════════════════════════════
       D. FECHA MÍNIMA — prevenir fechas pasadas
    ════════════════════════════════════════════════════════════════════ */

    (function setMinDates() {
      const today = new Date();
      const yyyy  = today.getFullYear();
      const mm    = String(today.getMonth() + 1).padStart(2, '0');
      const dd    = String(today.getDate()).padStart(2, '0');
      const todayStr = `${yyyy}-${mm}-${dd}`;

      if (fechaSalidaInput)  fechaSalidaInput.min  = todayStr;
      if (fechaRegresoInput) fechaRegresoInput.min = todayStr;

      /*
       * Sincronizar la fecha mínima de regreso con la fecha de salida.
       * Si el usuario elige una fecha de salida, la fecha de regreso
       * no puede ser anterior.
       */
      if (fechaSalidaInput && fechaRegresoInput) {
        fechaSalidaInput.addEventListener('change', () => {
          if (fechaSalidaInput.value) {
            fechaRegresoInput.min = fechaSalidaInput.value;
            /* Si la fecha de regreso es anterior a la nueva salida, resetear */
            if (fechaRegresoInput.value && fechaRegresoInput.value < fechaSalidaInput.value) {
              fechaRegresoInput.value = '';
            }
          }
        });
      }
    })();

    /* ════════════════════════════════════════════════════════════════════
       E. VALIDACIÓN
    ════════════════════════════════════════════════════════════════════ */

    function showError(msg) {
      errorMsg.textContent = msg;
      errorMsg.removeAttribute('hidden');
      errorMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function clearError() {
      errorMsg.setAttribute('hidden', '');
      errorMsg.textContent = '';
    }

    function validateForm(data) {
      const origen       = (data.get('origen')       || '').toString().trim();
      const destino      = (data.get('destino')      || '').toString().trim();
      const fechaSalida  = (data.get('fecha_salida') || '').toString().trim();
      const tripType     = (data.get('trip_type')    || '').toString().trim();
      const fechaRegreso = (data.get('fecha_regreso')|| '').toString().trim();
      const nombre       = (data.get('nombre')       || '').toString().trim();
      const empresa      = (data.get('empresa')      || '').toString().trim();

      if (!origen)      { showError('Por favor indique el aeropuerto o ciudad de origen.'); return false; }
      if (!destino)     { showError('Por favor indique el aeropuerto o ciudad de destino.'); return false; }
      if (!fechaSalida) { showError('Seleccione una fecha de salida.'); return false; }
      if (tripType === 'round-trip' && !fechaRegreso) {
        showError('Seleccione una fecha de regreso para el vuelo de ida y vuelta.');
        return false;
      }
      if (!nombre)      { showError('Indique el nombre completo del solicitante.'); return false; }
      if (!empresa)     { showError('Indique la empresa o institución.'); return false; }

      return true;
    }

    /* ════════════════════════════════════════════════════════════════════
       F. FORMATEADOR DE MENSAJE WHATSAPP
    ════════════════════════════════════════════════════════════════════ */

    /**
     * Convierte YYYY-MM-DD → DD/MM/YYYY
     * Formato venezolano estándar para el operador.
     */
    function formatDate(dateStr) {
      if (!dateStr) return 'No especificada';
      const parts = dateStr.split('-');
      if (parts.length !== 3) return dateStr;
      const [y, m, d] = parts;
      return `${d}/${m}/${y}`;
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      clearError();

      const data = new FormData(form);

      if (!validateForm(data)) return;

      /* Extraer valores */
      const tripType     = data.get('trip_type').toString().trim();
      const origen       = data.get('origen').toString().trim();
      const destino      = data.get('destino').toString().trim();
      const fechaSalida  = data.get('fecha_salida').toString().trim();
      const fechaRegreso = data.get('fecha_regreso').toString().trim();
      const pasajeros    = data.get('pasajeros').toString().trim();
      const nombre       = data.get('nombre').toString().trim();
      const empresa      = data.get('empresa').toString().trim();

      /* Formatear tipo de viaje para el mensaje */
      const tipoLabel = tripType === 'round-trip' ? 'Ida y Vuelta' : 'Solo Ida';

      /* Formatear fecha de regreso */
      const regresoLabel = (tripType === 'round-trip' && fechaRegreso)
        ? formatDate(fechaRegreso)
        : 'No aplica';

      /*
       * Construir el mensaje con el formato exacto requerido.
       * Usamos el carácter ➔ (U+27A4) y • (U+2022) directamente —
       * encodeURIComponent() los codifica correctamente.
       *
       * WhatsApp interpreta *texto* como negrita.
       */
      const lines = [
        '*SOLICITUD DE COTIZACIÓN WEB — HELITEC*',
        '',
        `• *Tipo:* ${tipoLabel}`,
        `• *Ruta:* ${origen} ➔ ${destino}`,
        `• *Salida:* ${formatDate(fechaSalida)}`,
        `• *Regreso:* ${regresoLabel}`,
        `• *Pasajeros:* ${pasajeros}`,
        '',
        '*DATOS DEL CLIENTE:*',
        `• *Nombre:* ${nombre}`,
        `• *Empresa:* ${empresa}`,
      ];

      const message    = lines.join('\n');
      const encodedMsg = encodeURIComponent(message);
      const waURL      = `https://wa.me/584166235254?text=${encodedMsg}`;

      /* Abrir WhatsApp en nueva pestaña */
      window.open(waURL, '_blank', 'noopener,noreferrer');

      /* Cerrar panel y resetear formulario */
      closePanel();

      /* Pequeño delay para que el cierre sea visible antes del reset */
      setTimeout(() => {
        form.reset();
        setTripType('one-way'); /* Volver al estado por defecto */
        updateCounter(0);       /* Resetear contador al mínimo */
        clearError();
      }, 500);
    });

    /* ════════════════════════════════════════════════════════════════════
       G. FOCUS TRAP (accesibilidad — WCAG 2.1 §2.1.2)
    ════════════════════════════════════════════════════════════════════ */

    panel.addEventListener('keydown', function (e) {
      if (!isOpen || e.key !== 'Tab') return;

      const focusableSelectors = [
        'a[href]',
        'button:not([disabled])',
        'input:not([disabled]):not([tabindex="-1"])',
        'select:not([disabled])',
        'textarea:not([disabled])',
        '[tabindex]:not([tabindex="-1"])',
      ].join(', ');

      const focusableEls = Array.from(panel.querySelectorAll(focusableSelectors));

      if (!focusableEls.length) return;

      const first = focusableEls[0];
      const last  = focusableEls[focusableEls.length - 1];

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });

  })();

  /* ════════════════════════════════════════════════════════════════════════
     SCROLL TRIGGER — visibilidad del strip COTIZACIÓN
     Oculto mientras el Hero es visible; slide-in desde la derecha al salir.
     IntersectionObserver con fallback a scroll event.
  ════════════════════════════════════════════════════════════════════════ */
  (function () {
    var strip = document.querySelector('.slcta__trigger');
    if (!strip) return;

    var THRESHOLD_PX = window.innerHeight * 0.60;

    var heroSection = document.querySelector('.hero__section, .hero, [data-section="hero"], section:first-of-type');

    if (heroSection && 'IntersectionObserver' in window) {
      var heroObs = new IntersectionObserver(
        function (entries) {
          if (entries[0].isIntersecting) {
            strip.classList.remove('is-visible');
          } else {
            strip.classList.add('is-visible');
          }
        },
        { threshold: 0, rootMargin: '-40% 0px 0px 0px' }
      );
      heroObs.observe(heroSection);
    } else {
      var ticking = false;
      function checkScroll() {
        if (window.scrollY > THRESHOLD_PX) {
          strip.classList.add('is-visible');
        } else {
          strip.classList.remove('is-visible');
        }
        ticking = false;
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { requestAnimationFrame(checkScroll); ticking = true; }
      }, { passive: true });
      checkScroll();
    }
  })();

  /* ════════════════════════════════════════════════════════════════════════
     DELEGACIÓN — Hero CTA "Solicitar Cotización" abre el mismo panel
     Cualquier elemento con [data-open-slcta] simula click en #slcta-trigger.
     Permite conectar el hero CTA con el panel sin cambiar el controller.
  ════════════════════════════════════════════════════════════════════════ */
  (function () {
    const mainTrigger = document.getElementById('slcta-trigger');
    if (!mainTrigger) return;

    const delegates = document.querySelectorAll('[data-open-slcta]');
    delegates.forEach(function (el) {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        mainTrigger.click(); /* Dispara el handler del controller principal */
      });
    });
  })();
</script>
