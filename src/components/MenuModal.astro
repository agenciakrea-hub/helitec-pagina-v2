---
/**
 * MenuModal.astro  v2 — Layout asimétrico Konpo.studio
 * Consorcio Helitec
 *
 * ┌─────────────────┬──────────────┐
 * │                 │  Servicio 1  │  ← row 1
 * │   NAV CARD      ├──────────────┤
 * │  (col 1, 1/2)   │  Servicio 2  │  ← row 2
 * ├─────────────────┼──────────────┤
 * │  Servicio 3     │  Servicio 4  │  ← row 3
 * └─────────────────┴──────────────┘
 *
 * Grid único: display:grid, 2 columnas × 3 filas iguales (1fr cada una).
 * La Nav card tiene grid-row: 1 / span 2 — ocupa 2/3 de altura en col 1.
 * Las 4 cards de servicio son auto-placed por el algoritmo (sin CSS explícito
 * en ellas): el algoritmo rellena (col2,row1) → (col2,row2) → (col1,row3) →
 * (col2,row3) al encontrar la Nav card bloqueando (col1, rows 1-2).
 *
 * Separadores: gap 1px + background del grid = --c-line (líneas de 1px).
 * Fondo: transiciona de --c-bg → --c-menu-open al abrir.
 *
 * Header z-index: se eleva a 850 (> --z-menu 800) con :global cuando
 * el menú está abierto, para mantener el botón ✕ siempre accesible.
 *
 * Stagger:
 *   · Links nav:     --i (0-5) × 80ms + base 120ms
 *   · Cards servicio: --j (0-3) × 60ms + base 200ms
 *   · Cierre: delay invertido (menor en los últimos) → salida fluida
 *
 * Assets asignados (en /assets/):
 *   YV1923_1.jpg · Helicoptero%20en%20pantano.jpg · Avion%20y%20Ambulancia%201.jpg · Helicoptero%20Eslinga%201.jpg
 */

interface Props {
  /** Idioma activo — marca el link correcto en ES | EN */
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const navLinks = [
  { label: 'La Empresa',           href: '/#empresa'    },
  { label: 'Seguridad & Calidad',  href: '/#seguridad'  },
  { label: 'Flota',                href: '/flota'        },
  { label: 'Servicios',            href: '/#servicios'  },
  { label: 'Contacto',             href: '/#contacto'   },
  { label: 'Legal',                href: '/#legal'      },
];

/*
 * Rutas con espacios en nombre de archivo → encodeURI() obligatorio.
 * Sincronizadas con el array de ServicesSection.astro (mismas fotos, mismo orden).
 */
const services = [
  {
    label: 'Aviación Ejecutiva',
    href:  '/#servicios',
    img:   '/assets/IMG_0968.jpg',
    alt:   'Cabina ejecutiva Consorcio Helitec — asientos de cuero premium',
  },
  {
    label: 'Operaciones Petroleras',
    href:  '/#servicios',
    img:   '/assets/opepetroleras.png',
    alt:   'Helicóptero Helitec en operación petrolera',
  },
  {
    label: 'Traslados Aeromédicos',
    href:  '/#servicios',
    img:   encodeURI('/assets/Avion y Ambulancia1.jpg'),
    alt:   'Metro III Helitec junto a ambulancia — servicio aeromédico',
  },
  {
    label: 'Carga y Eslinga',
    href:  '/#servicios',
    img:   encodeURI('/assets/Helicoptero Eslinga 2.jpg'),
    alt:   'Helicóptero MD Helitec con eslinga de carga externa sobre vegetación',
  },
];
---

<div
  class="menu-modal"
  id="menu-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Menú principal de Consorcio Helitec"
  aria-hidden="true"
>

  <!--
    ┌── GRID ÚNICO ─────────────────────────────────────────────────────────┐
    │  2 columnas × 3 filas. El NAV ocupa col 1 / rows 1-2.                │
    │  Los 4 cards de servicio son auto-placed por el algoritmo CSS Grid.   │
    └───────────────────────────────────────────────────────────────────────┘
  -->
  <div class="menu-modal__grid">

    <!-- ══ NAV CARD — col 1, row 1 / span 2 ════════════════════════════════ -->
    <nav
      class="menu-modal__nav"
      aria-label="Navegación principal"
    >

      <!-- Links de navegación con stagger fade-up (--i) -->
      <ul class="menu-modal__links" role="list">
        {navLinks.map((link, i) => (
          <li class="menu-modal__link-item" style={`--i:${i}`}>
            <a href={link.href} class="menu-modal__link">
              <span class="menu-modal__link-text">{link.label}</span>

              <!-- Flecha inline SVG: stroke-only, sin fill -->
              <svg
                class="menu-modal__link-arrow"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                focusable="false"
              >
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </li>
        ))}
      </ul>

      <!-- Selector de idioma — fondo absoluto de la Nav Card (Pilatus-style) -->
      <div class="menu-modal__lang" aria-label="Selector de idioma">
        <a
          href="/es/"
          class:list={['menu-modal__lang-link', { 'is-active': lang === 'es' }]}
          hreflang="es"
          lang="es"
          aria-current={lang === 'es' ? 'page' : undefined}
        >ES</a>
        <span class="menu-modal__lang-sep" aria-hidden="true">|</span>
        <a
          href="/en/"
          class:list={['menu-modal__lang-link', { 'is-active': lang === 'en' }]}
          hreflang="en"
          lang="en"
          aria-current={lang === 'en' ? 'page' : undefined}
        >EN</a>
      </div>

    </nav>

    <!-- ══ SERVICE CARDS — auto-placed por algoritmo Grid ═══════════════════
         Orden de placement:  (col2,row1) → (col2,row2) → (col1,row3) → (col2,row3)
    ════════════════════════════════════════════════════════════════════════ -->
    {services.map((service, j) => (
      <a
        href={service.href}
        class="menu-modal__card"
        style={`--j:${j}`}
      >
        <!--
          Imagen de fondo real.
          aria-hidden="true": el <span> del label ya describe el servicio.
          object-fit: cover OBLIGATORIO (ver reset.css + refuerzo explícito aquí).
        -->
        <img
          src={service.img}
          alt={service.alt}
          class="menu-modal__card-img"
          loading="lazy"
          aria-hidden="true"
        />

        <!--
          Overlay rgba: SOLO para legibilidad del texto sobre foto real.
          NO es linear-gradient decorativo — autorizado por anti-slop rules.
        -->
        <div class="menu-modal__card-overlay" aria-hidden="true"></div>

        <!-- Label: bottom-left, Montserrat uppercase, z por encima del overlay -->
        <span class="menu-modal__card-label">{service.label}</span>
      </a>
    ))}

  </div><!-- /.menu-modal__grid -->

</div><!-- /.menu-modal -->


<style>
  /* ══════════════════════════════════════════════════════════════════════════
     OVERLAY PRINCIPAL
     · position fixed inset 0 → cubre toda la pantalla incluyendo bajo el header
     · Invisible por defecto; visible + fondo corporativo al abrir
  ══════════════════════════════════════════════════════════════════════════ */

  .menu-modal {
    position:   fixed;
    inset:      0;
    z-index:    var(--z-menu);       /* 800 */
    overflow:   hidden;

    /*
     * PREMIUM REVEAL:
     * Fondo transparente → las celdas se deslizan sobre el índice visible.
     * El fondo del modal se oscurece progresivamente mientras las celdas llegan.
     */
    background-color: transparent;

    /* Estado CERRADO */
    visibility:     hidden;
    pointer-events: none;

    /*
     * CIERRE — fondo transparente inmediato:
     *
     * background-color snaps a transparent en t=0 (delay 0ms).
     * Las celdas se deslizan hacia abajo SOBRE el hero visible.
     * El usuario ve el índice normal mientras las celdas salen de pantalla.
     *
     * Timeline del cierre:
     *   t=0ms      → class removed, fondo snaps a transparent, celdas inician salida
     *   t=0-560ms  → celdas animando sobre el hero visible
     *   t=580ms    → visibility:hidden (oculta todo limpiamente)
     */
    transition:
      background-color 0s   linear   0ms,
      visibility       0s   linear   580ms;
  }

  /* Estado ABIERTO */
  :global(body.menu-is-open) .menu-modal {
    visibility:       visible;
    pointer-events:   auto;

    /*
     * Fondo oscuro se construye mientras las celdas cubren la pantalla.
     * 700ms: tiempo suficiente para que las celdas lleguen antes que el fondo.
     */
    background-color: var(--c-bg);   /* #07080C */

    transition:
      background-color 700ms var(--ease-out),
      visibility       0s    linear     0s;
  }

  /*
   * Elevación del Header cuando el menú está abierto.
   * Header (--z-header: 200) quedaría bajo el modal (--z-menu: 800).
   * Esta regla lo sube a 850 → botón hamburguesa→✕ siempre visible y clickeable.
   */
  :global(body.menu-is-open #site-header) {
    z-index: 850;
  }

  /*
   * Anti-glitch de backdrop-filter durante el cierre del menú.
   *
   * Bug: al quitar menu-is-open, el header vuelve de z-850 a z-200.
   * El compositor (GPU layers) puede mostrar la capa del header —que tiene
   * backdrop-filter:blur— por encima del modal durante la transición,
   * produciendo un fondo blanco/grisáceo visible antes de que el modal
   * termine su animación de salida.
   *
   * Fix: durante menu-is-closing (620ms añadido por JS en Header.astro),
   * el header se hace invisible al instante sin ninguna transition.
   * El modal permanece sólido negro y se oculta limpiamente a t=580ms.
   */
  :global(body.menu-is-closing #site-header) {
    opacity:        0 !important;
    pointer-events: none !important;
    transition:     none !important;
  }


  /* ══════════════════════════════════════════════════════════════════════════
     GRID ÚNICO 2 × 3
     ┌──────────┬──────────┐
     │  NAV     │ Serv. 1  │  ← 1fr
     │  CARD    ├──────────┤
     │ (span 2) │ Serv. 2  │  ← 1fr
     ├──────────┼──────────┤
     │ Serv. 3  │ Serv. 4  │  ← 1fr
     └──────────┴──────────┘
  ══════════════════════════════════════════════════════════════════════════ */

  .menu-modal__grid {
    display:               grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows:    1fr 1fr 1fr;   /* 3 filas iguales */

    /*
     * El grid empieza justo debajo del header fijo (68px) para que
     * los textos de las celdas no colisionen con el logo y la ✕.
     * height se reduce en la misma cantidad para que el grid llene
     * el área visible restante (calc evita desbordamiento).
     */
    margin-top: var(--header-h);
    height:     calc(100% - var(--header-h));

    gap:              1px;
    background-color: var(--c-line);      /* rgba(255,255,255,.10) */
  }


  /* ══════════════════════════════════════════════════════════════════════════
     NAV CARD — grid-column: 1 / grid-row: 1 / span 2
  ══════════════════════════════════════════════════════════════════════════ */

  .menu-modal__nav {
    /* Placement explícito: col 1, abarca rows 1 y 2 */
    grid-column: 1;
    grid-row:    1 / span 2;

    /* Flex column: links centrados verticalmente + lang pegado al fondo */
    display:        flex;
    flex-direction: column;
    overflow-y:     auto;   /* Scroll interno si el viewport es muy bajo */

    background-color: var(--c-bg-raised);  /* #0D1117 — superficie elevada */

    /*
     * Padding top: solo --gutter porque el grid ya tiene margin-top: var(--header-h)
     * — el nav no necesita compensar el header de nuevo.
     * Padding left desktop: clearance del sidebar (72px) + gutter
     * → en mobile (<1024px) solo --gutter (sidebar no existe)
     */
    padding-top:    var(--gutter);
    padding-bottom: var(--sp-8);
    padding-left:   calc(var(--sidebar-w) + var(--gutter));
    padding-right:  var(--gutter);

    /*
     * PREMIUM REVEAL — estado CERRADO:
     * Celda oculta completamente debajo del viewport.
     * El overflow:hidden del .menu-modal la recorta → invisible.
     * Sale con delay 160ms (con la wave 1), curva de salida rápida.
     */
    transform: translateY(100vh);
    transition:
      transform 400ms cubic-bezier(0.4, 0, 1, 1);
    transition-delay: 160ms;
  }

  /* Estado ABIERTO — nav card */
  :global(body.menu-is-open) .menu-modal__nav {
    transform: translateY(0);

    /*
     * Wave 1 (0ms): nav card + service 0 suben primero.
     * cubic-bezier(0.16,1,0.3,1) = spring suave: rápido al inicio, deceleración premium.
     */
    transition: transform 620ms cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0ms;
  }


  /* ── Lista de links ─────────────────────────────────────────────────────── */

  .menu-modal__links {
    flex:            1;
    display:         flex;
    flex-direction:  column;
    justify-content: center;  /* Links verticalmente centrados */
    gap:             0;
  }


  /* ── Link item (li): stagger fade-up bidireccional ─────────────────────── */

  .menu-modal__link-item {
    /* Estado CERRADO: invisible + desplazado 24px hacia abajo */
    opacity:   0;
    transform: translateY(24px);

    /*
     * Delay de SALIDA: delay decreciente con --i
     * → ítems más abajo salen primero → efecto cascade hacia arriba
     */
    transition:
      opacity   var(--dur-mid) var(--ease-out),
      transform var(--dur-mid) var(--ease-out);
    transition-delay: calc(var(--i, 0) * 30ms);
  }

  /* Estado ABIERTO: visible + delay creciente → cascade hacia abajo */
  :global(body.menu-is-open) .menu-modal__link-item {
    opacity:   1;
    transform: translateY(0);

    /*
     * Base 320ms: la nav card está ~90% en posición (spring 620ms)
     * antes de que los links empiecen a aparecer → coherencia visual.
     * + 70ms × --i: cascade de arriba a abajo.
     */
    transition-delay: calc(var(--i, 0) * 70ms + 320ms);
  }


  /* ── Link (a) ──────────────────────────────────────────────────────────── */

  .menu-modal__link {
    display:         flex;
    align-items:     center;
    justify-content: space-between;

    font-family:     var(--font-display);   /* Montserrat */
    font-size:       var(--text-2xl);       /* clamp(2rem, 1.5rem + 2.5vw, 3.5rem) */
    font-weight:     var(--fw-thin);        /* 200 — "Exclusividad Silenciosa" */
    letter-spacing:  var(--ls-wide);        /* 0.06em */
    color:           var(--c-text-1);

    padding-block:   var(--sp-3);

    border-bottom:   1px solid var(--c-line);

    /* Cancelar el opacity:0.75 del reset en hover */
    opacity: 1;

    transition:
      color   var(--dur-fast) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out);
  }

  .menu-modal__link-item:first-child .menu-modal__link {
    border-top: 1px solid var(--c-line);
  }

  .menu-modal__link:hover,
  .menu-modal__link:focus-visible {
    color:   var(--c-sky);   /* #58b5f0 — acento de marca en hover */
    opacity: 1;
  }

  .menu-modal__link-text {
    flex: 1;
  }

  /* ── Flecha → ──────────────────────────────────────────────────────────── */

  .menu-modal__link-arrow {
    width:       18px;
    height:      18px;
    flex-shrink: 0;
    margin-left: var(--sp-4);
    opacity:     0.28;

    transition:
      transform var(--dur-fast) var(--ease-out),
      opacity   var(--dur-fast) var(--ease-out);
  }

  .menu-modal__link:hover .menu-modal__link-arrow,
  .menu-modal__link:focus-visible .menu-modal__link-arrow {
    transform: translateX(5px);
    opacity:   0.75;
  }


  /* ── Selector de idioma — fondo de la nav card ────────────────────────── */

  .menu-modal__lang {
    margin-top:  auto;          /* Empuja al fondo del flex column */
    padding-top: var(--sp-8);

    display:     flex;
    align-items: center;
    gap:         var(--sp-3);
  }

  .menu-modal__lang-link {
    font-family:    var(--font-sans);    /* Inter */
    font-size:      var(--text-sm);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-3);     /* rgba(255,255,255,.35) */
    opacity:        1;                   /* Cancelar reset */

    transition: color var(--dur-fast) var(--ease-out);
  }

  .menu-modal__lang-link.is-active {
    color: var(--c-text-1);
  }

  .menu-modal__lang-link:hover {
    color:   var(--c-text-1);
    opacity: 1;
  }

  .menu-modal__lang-sep {
    font-size:   var(--text-sm);
    color:       var(--c-line-strong);
    user-select: none;
  }


  /* ══════════════════════════════════════════════════════════════════════════
     SERVICE CARDS — auto-placed por el grid
     Placement resuelto automáticamente:
       --j:0 → (col 2, row 1)  Aviación Ejecutiva
       --j:1 → (col 2, row 2)  Operaciones Petroleras
       --j:2 → (col 1, row 3)  Traslados Aeromédicos
       --j:3 → (col 2, row 3)  Mantenimiento
  ══════════════════════════════════════════════════════════════════════════ */

  .menu-modal__card {
    position: relative;
    overflow: hidden;
    display:  flex;
    align-items: flex-end;          /* Label pegado al borde inferior */

    background-color: var(--c-bg-raised);  /* Fallback mientras carga la foto */

    /*
     * PREMIUM REVEAL — estado CERRADO:
     * Cada celda empieza completamente fuera del viewport por abajo.
     * El overflow:hidden del .menu-modal la recorta → invisible.
     *
     * Delay de SALIDA (cierre) — orden inverso al de entrada:
     *   j=2 y j=3 salen primero (wave 3) → delay 0ms   (fila inferior)
     *   j=1 sale después (wave 2)         → delay 80ms
     *   j=0 sale al final (wave 1)        → delay 160ms (igual que nav card)
     * Fórmula: (2 - min(j, 2)) × 80ms
     */
    transform: translateY(100vh);
    transition: transform 400ms cubic-bezier(0.4, 0, 1, 1);
    transition-delay: calc((2 - min(var(--j, 0), 2)) * 80ms);
  }

  /* Estado ABIERTO — stagger wave escalonado */
  :global(body.menu-is-open) .menu-modal__card {
    transform: translateY(0);

    /*
     * WAVE STAGGER (entrada):
     *   j=0 → wave 1 (0ms):   Aviación Ejecutiva (col derecha, fila 1)
     *   j=1 → wave 2 (100ms): Operaciones Petroleras (col derecha, fila 2)
     *   j=2 → wave 3 (200ms): Traslados Aeromédicos (fila 3 izquierda)
     *   j=3 → wave 3 (200ms): Carga y Eslinga (fila 3 derecha)
     * Fórmula: min(j, 2) × 100ms
     */
    transition: transform 620ms cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(min(var(--j, 0), 2) * 100ms);
  }

  /* Hover: no atenuar — cancelar el opacity:0.75 del reset */
  .menu-modal__card:hover {
    opacity: 1;
  }

  /* Hover: zoom premium en la imagen */
  .menu-modal__card:hover .menu-modal__card-img {
    transform: scale(1.05);
  }


  /* ── Imagen de fondo ─────────────────────────────────────────────────────── */

  .menu-modal__card-img {
    position: absolute;
    inset:    0;
    width:    100%;
    height:   100%;

    /*
     * OBLIGATORIO: object-fit cover en todas las imágenes del proyecto.
     * Declarado también en reset.css globalmente.
     * Se reitera aquí para reforzar la intención semántica (foto de fondo).
     */
    object-fit:      cover;
    object-position: center;

    transition: transform var(--dur-slow) var(--ease-out);
  }


  /* ── Overlay rgba oscuro ─────────────────────────────────────────────────────
     ANTI-SLOP COMPLIANCE — justificación explícita:
     · PROHIBIDO: linear-gradient como fondo decorativo
     · PERMITIDO: overlay rgba oscuro "sobre fotografías reales para mejorar
       la lectura" (regla del proyecto, anti-slop section)
     · background-color: rgba puro, sin gradient.
  ──────────────────────────────────────────────────────────────────────────── */

  .menu-modal__card-overlay {
    position:         absolute;
    inset:            0;
    background-color: rgba(7, 8, 12, 0.50);  /* --c-bg al 50% opacidad */

    transition: background-color var(--dur-fast) var(--ease-out);
  }

  /* Hover: levanta opacidad → más detalle de la fotografía */
  .menu-modal__card:hover .menu-modal__card-overlay {
    background-color: rgba(7, 8, 12, 0.30);
  }


  /* ── Label del servicio ──────────────────────────────────────────────────── */

  .menu-modal__card-label {
    position:   relative;   /* z-order natural sobre los absolute siblings */
    z-index:    1;

    padding: var(--sp-3) var(--sp-4);

    font-family:    var(--font-display);   /* Montserrat */
    font-size:      var(--text-xs);        /* 11–12px */
    font-weight:    var(--fw-medium);      /* 500 */
    letter-spacing: var(--ls-widest);      /* 0.20em */
    text-transform: uppercase;
    color:          var(--c-text-1);

    /* Única text-shadow permitida: legibilidad sobre foto */
    text-shadow: var(--text-shadow-hero);
  }


  /* ══════════════════════════════════════════════════════════════════════════
     RESPONSIVE

     ≥ 1024px (Desktop):
       · Sidebar activo → padding-left en nav card ya lo contempla
       · Tipografía de links en su tamaño máximo (text-2xl)

     < 1024px (Tablet / Mobile):
       · Sin sidebar → padding-left reduce a --gutter
       · text-xl para links

     < 480px (Mobile pequeño):
       · text-lg para links (espacio más limitado en col izquierda)
       · Labels de cards más compactos
  ══════════════════════════════════════════════════════════════════════════ */

  /* ── Tablet y mobile (sin sidebar) ─────────────────────────────────────── */
  @media (max-width: 1023px) {
    .menu-modal__nav {
      padding-left: var(--gutter);   /* Sin sidebar → sin offset de 72px */
    }

    .menu-modal__link {
      font-size:    var(--text-xl);   /* clamp(1.5rem, 1.2rem+1.5vw, 2.25rem) */
      padding-block: var(--sp-3);
    }
  }

  /* ── Mobile pequeño ──────────────────────────────────────────────────────── */
  @media (max-width: 479px) {
    .menu-modal__nav {
      padding-top:   var(--sp-4);
      padding-left:  var(--sp-5);
      padding-right: var(--sp-4);
      padding-bottom: var(--sp-5);
    }

    .menu-modal__link {
      font-size:     var(--text-lg);   /* clamp(1.125rem, 1rem+0.6vw, 1.375rem) */
      padding-block: var(--sp-2);
      letter-spacing: 0.04em;          /* Reducir tracking en espacio estrecho */
    }

    .menu-modal__link-arrow {
      width:  14px;
      height: 14px;
      margin-left: var(--sp-2);
    }

    .menu-modal__card-label {
      padding:       var(--sp-2) var(--sp-3);
      font-size:     0.62rem;          /* ~10px — muy compacto pero legible */
      letter-spacing: var(--ls-wider); /* 0.12em — reducir de 0.20em */
    }

    .menu-modal__lang {
      padding-top: var(--sp-5);
    }
  }

  /* ── Desktop: nav links en grilla 2 × 3 ─────────────────────────────────── */
  @media (min-width: 1024px) {
    .menu-modal__links {
      /* Reemplaza el flex column por una grilla 2 columnas × 3 filas */
      display:               grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows:    repeat(3, auto);
      flex:                  unset;     /* Override del flex:1 heredado */
      justify-content:       unset;
    }

    .menu-modal__link {
      font-size:    var(--text-xl);    /* Reducido vs --text-2xl: celdas más angostas */
      padding-block: var(--sp-4);
    }

    /*
     * En la grilla 2-col, la primera FILA contiene los ítems 1 y 2.
     * El ítem 1 ya tiene border-top via :first-child.
     * El ítem 2 (primera fila, col derecha) también necesita border-top.
     */
    .menu-modal__link-item:nth-child(2) .menu-modal__link {
      border-top: 1px solid var(--c-line);
    }
  }
</style>


<script>
  /**
   * MenuModal — Accesibilidad y gestión de eventos
   *
   * 1. Sincronizar aria-hidden con body.menu-is-open via MutationObserver
   * 2. Cerrar con tecla Escape → devuelve foco al botón hamburguesa
   * 3. Mover foco al primer link al abrir (delay respeta la transición CSS)
   * 4. Cerrar al clickear cualquier link interno (navegación SPA)
   */
  (function () {
    const modal   = /** @type {HTMLElement|null} */ (document.getElementById('menu-modal'));
    const menuBtn = /** @type {HTMLElement|null} */ (document.getElementById('menu-toggle'));

    if (!modal) return;

    /** Cierra el menú y devuelve el foco al botón hamburguesa */
    function closeMenu() {
      document.body.classList.remove('menu-is-open');
      menuBtn?.setAttribute('aria-expanded', 'false');
      menuBtn?.setAttribute('aria-label', 'Abrir menú de navegación');
      menuBtn?.focus();
    }

    /* ── Tecla Escape ───────────────────────────────────────────────────── */
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && document.body.classList.contains('menu-is-open')) {
        closeMenu();
      }
    });

    /* ── Click en link: cierra el modal antes de navegar ───────────────── */
    modal.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', function () {
        document.body.classList.remove('menu-is-open');
        menuBtn?.setAttribute('aria-expanded', 'false');
        menuBtn?.setAttribute('aria-label', 'Abrir menú de navegación');
        /* No devolver foco: la página navega */
      });
    });

    /* ── MutationObserver: aria-hidden + foco inicial ───────────────────── */
    const observer = new MutationObserver(function () {
      const isOpen = document.body.classList.contains('menu-is-open');
      modal.setAttribute('aria-hidden', String(!isOpen));

      if (isOpen) {
        /*
         * Delay de 150ms: respeta la transición de apertura del modal.
         * Los link-items aún están en opacity:0 en el frame 0.
         */
        setTimeout(function () {
          const firstLink = /** @type {HTMLAnchorElement|null} */
            (modal.querySelector('.menu-modal__link'));
          firstLink?.focus({ preventScroll: true });
        }, 150);
      }
    });

    observer.observe(document.body, {
      attributes:      true,
      attributeFilter: ['class'],
    });
  })();
</script>
