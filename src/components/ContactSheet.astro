---
/**
 * ContactSheet.astro
 * Consorcio Helitec — Panel de contacto deslizante (Bottom Sheet)
 *
 * Referencia visual: aventuradentalarts.com — panel inferior con tarjetas de contacto
 *
 * Estructura:
 *   · Trigger: botón fijo bottom-right con icono de teléfono
 *   · Sheet: panel que sube desde bottom: 0 (translateY 100% → 0)
 *   · Contenido: 3 tarjetas de contacto con acción directa (tel:, wa.me)
 *     1. Oficina Caracas      → llamada directa
 *     2. Operaciones 24/7     → llamada directa
 *     3. Ambulancia Aérea     → WhatsApp directo
 *
 * Reglas anti-slop:
 *   border-radius: var(--r-micro) solo en esquinas superiores del sheet
 *   z-index: var(--z-bottom-sheet) = 900
 *   PROHIBIDO box-shadow — ✓
 *
 * NOTA PARA EL CLIENTE: Reemplazar los números de contacto con los reales.
 *   Los marcados con [NÚMERO] son placeholders.
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
---

<!-- ── BACKDROP ──────────────────────────────────────────────────────────── -->
<div
  class="csheet__backdrop"
  id="csheet-backdrop"
  aria-hidden="true"
></div>

<!-- ── BOTTOM SHEET ──────────────────────────────────────────────────────── -->
<div
  class="csheet__sheet"
  id="csheet-sheet"
  role="dialog"
  aria-modal="true"
  aria-label="Información de contacto"
  aria-hidden="true"
>
  <!-- Handle — barra de arrastre visual -->
  <div class="csheet__handle-wrap" aria-hidden="true">
    <span class="csheet__handle"></span>
  </div>

  <!-- Cabecera del sheet -->
  <div class="csheet__header">
    <div class="csheet__header-text">
      <p class="csheet__overline">Consorcio Helitec</p>
      <h2 class="csheet__title">Contáctenos</h2>
    </div>
    <button
      class="csheet__close"
      id="csheet-close"
      type="button"
      aria-label="Cerrar panel de contacto"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
      </svg>
    </button>
  </div>

  <!-- Tarjetas de contacto -->
  <div class="csheet__cards">

    <!-- 01 — Oficina Caracas -->
    <a
      href="tel:+582125551234"
      class="csheet__card"
      data-type="phone"
    >
      <span class="csheet__card-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 5a2 2 0 0 1 2-2h3.28a1 1 0 0 1 .948.684l1.498 4.493a1 1 0 0 1-.502 1.21L8.5 10.5a11.042 11.042 0 0 0 4.998 5l1.113-1.724a1 1 0 0 1 1.21-.502l4.493 1.498A1 1 0 0 1 21 15.72V19a2 2 0 0 1-2 2h-1C9.163 21 3 14.837 3 7V5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
      </span>
      <div class="csheet__card-info">
        <span class="csheet__card-label">Oficina Caracas</span>
        <span class="csheet__card-value">+58 (212) [NÚMERO]</span>
        <span class="csheet__card-hint">Lun – Vie · 8:00 – 17:00</span>
      </div>
      <span class="csheet__card-arrow" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </span>
    </a>

    <!-- 02 — Operaciones 24/7 -->
    <a
      href="tel:+584166235254"
      class="csheet__card"
      data-type="phone"
    >
      <span class="csheet__card-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </span>
      <div class="csheet__card-info">
        <span class="csheet__card-label">Operaciones</span>
        <span class="csheet__card-value">+58 416-6235254</span>
        <span class="csheet__card-hint">Disponibilidad 24 / 7</span>
      </div>
      <span class="csheet__card-arrow" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </span>
    </a>

    <!-- 03 — Ambulancia Aérea (WhatsApp) -->
    <a
      href="https://wa.me/584166235254?text=EMERGENCIA%20AEROM%C3%89DICA%20%E2%80%94%20Consorcio%20Helitec%0A%0ASolicito%20servicio%20de%20ambulancia%20a%C3%A9rea.%20Favor%20contactar%20con%20urgencia."
      class="csheet__card csheet__card--urgent"
      target="_blank"
      rel="noopener noreferrer"
      data-type="whatsapp"
    >
      <span class="csheet__card-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Cruz médica + hélice estilizada -->
          <path d="M12 2L12 22M2 12L22 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </span>
      <div class="csheet__card-info">
        <span class="csheet__card-label">Ambulancia Aérea</span>
        <span class="csheet__card-value">WhatsApp Emergencias</span>
        <span class="csheet__card-hint csheet__card-hint--urgent">Respuesta inmediata</span>
      </div>
      <span class="csheet__card-arrow" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </span>
    </a>

  </div>

  <!-- Línea separadora -->
  <div class="csheet__divider" aria-hidden="true"></div>

  <!-- Footer del sheet -->
  <div class="csheet__footer">
    <p class="csheet__footer-text">
      Consorcio Helitec C.A. · Caracas, Venezuela<br>
      INAC Certificado · Reg. [N° AOC]
    </p>
  </div>

</div>

<!-- ── FABs — Layout L invertida ─────────────────────────────────────────── -->
<!--
  Esquina inferior derecha. Estructura:

      [Cotización]            ← columna, arriba  (abre cotizador)
      [Linktree]              ← columna, medio   (hub de redes)
  [LinkedIn][IG][Contacto]   ← fila inferior, izq→der

  z-index: 895 — encima de SideLeadCTA (848), debajo del backdrop ContactSheet (898).
  #slcta-trigger vive aquí; SideLeadCTA.astro lo localiza por ID.
-->
<div class="csheet__fabs">

  <!-- FAB Cotización — CTA primario, abre panel SideLeadCTA -->
  <button
    class="csheet__fab csheet__fab--cotizar"
    id="slcta-trigger"
    type="button"
    aria-expanded="false"
    aria-controls="slcta-panel"
    aria-label="Solicitar cotización de vuelo privado"
  >
    <!-- Tooltip onboarding: aparece 0.5s tras carga, desaparece a los 4s -->
    <span class="csheet__fab-label" aria-hidden="true">Cotización</span>
    <span class="csheet__fab-icon" aria-hidden="true">
      <svg width="18" height="16" viewBox="0 0 18 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L17 8L1 15V9.5L11 8L1 6.5V1Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="square" stroke-linejoin="miter"/>
      </svg>
    </span>
    <span class="csheet__fab-close" aria-hidden="true">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L11 11M11 1L1 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
      </svg>
    </span>
  </button>

  <!-- FAB Linktree — hub de redes sociales -->
  <!-- [DATO: reemplazar href con la URL real del Linktree de Consorcio Helitec] -->
  <a
    class="csheet__fab csheet__linktree-btn"
    href="https://linktr.ee/helitec"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Ver todas las redes de Consorcio Helitec en Linktree"
  >
    <!-- Tooltip onboarding: aparece 0.85s tras carga (cascada con Cotización) -->
    <span class="csheet__fab-label" aria-hidden="true">Linktree</span>
    <svg width="14" height="16" viewBox="0 0 14 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M7 2V16"    stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
      <path d="M7 6L3 2"   stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
      <path d="M7 6L11 2"  stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
      <path d="M7 10L3 6"  stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
      <path d="M7 10L11 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
    </svg>
  </a>

  <!-- Fila inferior: LinkedIn → Instagram → Contacto -->
  <div class="csheet__fabs-row">

    <!-- FAB LinkedIn -->
    <!-- [DATO: reemplazar href con la URL real de LinkedIn de Consorcio Helitec] -->
    <a
      class="csheet__fab csheet__fab--linkedin"
      href="https://linkedin.com/company/consorcio-helitec"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn de Consorcio Helitec"
    >
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M16 8a6 6 0 0 1 6 6v6h-4v-6a2 2 0 0 0-4 0v6h-4v-6a6 6 0 0 1 6-6z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="miter"/>
        <rect x="2" y="9" width="4" height="11" stroke="currentColor" stroke-width="1.4" stroke-linejoin="miter"/>
        <circle cx="4" cy="4.5" r="1.8" stroke="currentColor" stroke-width="1.4"/>
      </svg>
    </a>

    <!-- FAB Instagram -->
    <!-- [DATO: reemplazar href con la URL real de Instagram de Consorcio Helitec] -->
    <a
      class="csheet__fab csheet__fab--instagram"
      href="https://instagram.com/helitec"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Instagram de Consorcio Helitec"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="2" y="2" width="20" height="20" rx="4" stroke="currentColor" stroke-width="1.4"/>
        <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.4"/>
        <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/>
      </svg>
    </a>

    <!-- FAB Contacto — abre bottom sheet -->
    <button
      class="csheet__fab csheet__trigger"
      id="csheet-trigger"
      type="button"
      aria-expanded="false"
      aria-controls="csheet-sheet"
      aria-label="Abrir información de contacto"
    >
      <svg width="18" height="17" viewBox="0 0 18 17" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M1 1h16v10H4.5L1 15V1Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="square" stroke-linejoin="miter"/>
      </svg>
    </button>

  </div>

</div>


<style>
  /* ── BACKDROP ───────────────────────────────────────────────────────────── */
  .csheet__backdrop {
    position:       fixed;
    inset:          0;
    z-index:        898; /* Debajo del sheet (899) */

    background-color: rgba(7, 8, 12, 0.70);

    opacity:        0;
    pointer-events: none;
    visibility:     hidden;

    transition:
      opacity    var(--dur-mid) var(--ease-out),
      visibility 0s linear calc(var(--dur-mid) + 10ms);
  }

  .csheet__backdrop.is-open {
    opacity:        1;
    pointer-events: auto;
    visibility:     visible;
    transition:
      opacity    var(--dur-mid) var(--ease-out),
      visibility 0s linear 0s;
  }

  /* ── SHEET ──────────────────────────────────────────────────────────────── */
  .csheet__sheet {
    position: fixed;
    bottom:   0;
    left:     0;
    right:    0;

    z-index:  var(--z-bottom-sheet); /* 900 */

    background-color: var(--c-bg-raised);

    /* Esquinas superiores: 4px — límite absoluto del proyecto */
    border-radius: var(--r-micro) var(--r-micro) 0 0;
    border-top:    1px solid var(--c-line-strong);

    /* Slide desde abajo */
    transform:  translateY(100%);
    visibility: hidden;

    transition:
      transform  var(--dur-mid) var(--ease-menu),
      visibility 0s linear calc(var(--dur-mid) + 10ms);

    /* Limitar altura en pantallas grandes */
    max-height: 85dvh;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .csheet__sheet.is-open {
    transform:  translateY(0);
    visibility: visible;
    transition:
      transform  var(--dur-mid) var(--ease-menu),
      visibility 0s linear 0s;
  }

  /* ── Handle ─────────────────────────────────────────────────────────────── */
  .csheet__handle-wrap {
    display:         flex;
    justify-content: center;
    padding-top:     14px;
    padding-bottom:  8px;
  }

  .csheet__handle {
    display:          block;
    width:            32px;
    height:           3px;
    background-color: var(--c-line-strong);
    border-radius:    var(--r-micro); /* 4px */
  }

  /* ── Cabecera ────────────────────────────────────────────────────────────── */
  .csheet__header {
    display:     flex;
    align-items: center;
    justify-content: space-between;

    padding: 8px clamp(20px, 5vw, 36px) 20px;
    border-bottom: 1px solid var(--c-line);
  }

  .csheet__overline {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-brand);
    margin-bottom:  4px;
  }

  .csheet__title {
    font-family:    var(--font-display);
    font-size:      clamp(1.4rem, 3vw, 1.75rem);
    font-weight:    var(--fw-thin);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color:          var(--c-text-1);
  }

  .csheet__close {
    display:         flex;
    align-items:     center;
    justify-content: center;

    width:  36px;
    height: 36px;
    flex-shrink: 0;

    background:    none;
    border:        1px solid var(--c-line);
    border-radius: var(--r-micro);
    cursor:        pointer;
    color:         var(--c-text-2);

    transition: border-color var(--dur-fast) var(--ease-out),
                color        var(--dur-fast) var(--ease-out);
  }

  .csheet__close:hover {
    border-color: var(--c-line-strong);
    color:        var(--c-text-1);
  }

  .csheet__close:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
  }

  /* ── Tarjetas ────────────────────────────────────────────────────────────── */
  .csheet__cards {
    display:        flex;
    flex-direction: column;

    /* Líneas divisoras entre tarjetas sin border */
    gap:            1px;
    background-color: var(--c-line);

    border-bottom: 1px solid var(--c-line);
  }

  .csheet__card {
    display:     flex;
    align-items: center;
    gap:         16px;

    padding: 18px clamp(20px, 5vw, 36px);

    background-color: var(--c-bg-raised);
    text-decoration:  none;
    color:            inherit;

    transition: background-color var(--dur-fast) var(--ease-out);
  }

  .csheet__card:hover {
    background-color: var(--c-bg);
  }

  .csheet__card--urgent {
    /* Tarjeta de urgencia: acento rojo sutil en el indicador */
  }

  .csheet__card-icon {
    display:         flex;
    align-items:     center;
    justify-content: center;
    flex-shrink:     0;

    width:  40px;
    height: 40px;

    border:        1px solid var(--c-line-strong);
    border-radius: var(--r-micro);
    color:         var(--c-sky);
  }

  .csheet__card--urgent .csheet__card-icon {
    color:        var(--c-red);
    border-color: rgba(229, 59, 28, 0.30);
  }

  .csheet__card-info {
    display:        flex;
    flex-direction: column;
    gap:            2px;
    flex:           1;
    min-width:      0;
  }

  .csheet__card-label {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-3);
  }

  .csheet__card-value {
    font-family: var(--font-display);
    font-size:   clamp(0.9rem, 2vw, 1.05rem);
    font-weight: var(--fw-regular);
    color:       var(--c-text-1);
    white-space: nowrap;
    overflow:    hidden;
    text-overflow: ellipsis;
  }

  .csheet__card-hint {
    font-family: var(--font-sans);
    font-size:   0.7rem;
    color:       var(--c-text-3);
  }

  .csheet__card-hint--urgent {
    color: var(--c-red);
    font-weight: var(--fw-medium);
  }

  .csheet__card-arrow {
    flex-shrink: 0;
    color:       var(--c-text-3);
    transition:  transform var(--dur-fast) var(--ease-out),
                 color     var(--dur-fast) var(--ease-out);
  }

  .csheet__card:hover .csheet__card-arrow {
    transform: translateX(3px);
    color:     var(--c-text-2);
  }

  /* ── Divisor y footer ────────────────────────────────────────────────────── */
  .csheet__divider {
    height:           1px;
    background-color: var(--c-line);
  }

  .csheet__footer {
    padding: 16px clamp(20px, 5vw, 36px) 24px;
  }

  .csheet__footer-text {
    font-family: var(--font-sans);
    font-size:   0.7rem;
    color:       var(--c-text-3);
    line-height: 1.6;
  }

  /* ── FABs — Layout L invertida ──────────────────────────────────────────── */
  /*
   * Columna en esquina inferior-derecha:
   *   [Cotización]            top
   *   [Linktree]              middle
   *   [LinkedIn][IG][Info]    bottom-row
   *
   * align-items: flex-end asegura que la fila inferior quede alineada a la derecha.
   */
  .csheet__fabs {
    position: fixed;
    bottom:   clamp(16px, 3vh, 24px);
    right:    12px;
    z-index:  895;

    display:        flex;
    flex-direction: column;
    align-items:    flex-end;
    gap:            8px;

    /* Transición para ocultarse suavemente cuando el menú está abierto */
    transition:
      opacity    var(--dur-mid) var(--ease-out),
      visibility var(--dur-mid) var(--ease-out);
  }

  /* Ocultar FABs cuando el menú principal está abierto */
  :global(body.menu-is-open) .csheet__fabs {
    opacity:        0;
    visibility:     hidden;
    pointer-events: none;
  }

  /* Fila inferior: LinkedIn + Instagram + Contacto */
  .csheet__fabs-row {
    display:        flex;
    flex-direction: row;
    align-items:    center;
    gap:            8px;
  }

  /* ── Base compartida — Efecto Cristal (todos los FABs) ──────────────────── */
  .csheet__fab {
    position:    relative;
    width:       44px;
    height:      44px;
    flex-shrink: 0;

    display:         flex;
    align-items:     center;
    justify-content: center;

    backdrop-filter:         blur(12px) saturate(1.3);
    -webkit-backdrop-filter: blur(12px) saturate(1.3);
    border-radius:   var(--r-micro);
    cursor:          pointer;
    text-decoration: none;

    transition:
      background   var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      color        var(--dur-fast) var(--ease-out);
  }

  /* ── FAB Cotización (CTA primario — azul marca) ─────────────────────────── */
  .csheet__fab--cotizar {
    background:  rgba(2, 58, 120, 0.50);
    border:      1px solid rgba(88, 181, 240, 0.22);
    color:       rgba(255, 255, 255, 0.88);
  }

  .csheet__fab--cotizar:hover {
    background:   rgba(10, 77, 158, 0.70);
    border-color: rgba(88, 181, 240, 0.45);
    color:        var(--c-white);
  }

  .csheet__fab--cotizar:focus-visible {
    outline: 2px solid var(--c-sky);
    outline-offset: 2px;
  }

  .csheet__fab--cotizar[aria-expanded="true"] {
    background:   rgba(10, 77, 158, 0.80);
    border-color: rgba(88, 181, 240, 0.55);
  }

  /* Swap icono avión ↔ ✕ */
  .csheet__fab-icon,
  .csheet__fab-close {
    position: absolute;
    display:  flex;
    align-items:     center;
    justify-content: center;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .csheet__fab-icon  { opacity: 1; }
  .csheet__fab-close { opacity: 0; }

  .csheet__fab--cotizar[aria-expanded="true"] .csheet__fab-icon  { opacity: 0; }
  .csheet__fab--cotizar[aria-expanded="true"] .csheet__fab-close { opacity: 1; }

  /* ── FABs cristal blanco: Linktree + LinkedIn + Instagram + Contacto ─────── */
  .csheet__trigger,
  .csheet__linktree-btn,
  .csheet__fab--linkedin,
  .csheet__fab--instagram {
    background: rgba(255, 255, 255, 0.08);
    border:     1px solid rgba(255, 255, 255, 0.14);
    color:      rgba(255, 255, 255, 0.75);
  }

  .csheet__trigger:hover,
  .csheet__linktree-btn:hover,
  .csheet__fab--linkedin:hover,
  .csheet__fab--instagram:hover {
    background: rgba(255, 255, 255, 0.16);
    color:      rgba(255, 255, 255, 1);
  }

  /* Hover border accent por identidad de red */
  .csheet__trigger:hover       { border-color: rgba(88, 181, 240, 0.50); } /* Azul */
  .csheet__linktree-btn:hover  { border-color: rgba(68, 195, 92,  0.45); } /* Verde Linktree */
  .csheet__fab--linkedin:hover { border-color: rgba(10, 102, 194, 0.55); } /* Azul LinkedIn */
  .csheet__fab--instagram:hover { border-color: rgba(225, 48, 108, 0.45); } /* Rosa IG */

  .csheet__trigger:focus-visible,
  .csheet__linktree-btn:focus-visible,
  .csheet__fab--linkedin:focus-visible,
  .csheet__fab--instagram:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
  }

  /* ── Tooltip onboarding: aparece al cargar y se desvanece ───────────────── */
  /*
   * Solo en Cotización (delay 0.5s) y Linktree (delay 0.85s, cascada).
   * Aparece a la IZQUIERDA: right: calc(100% + 10px).
   * La animación controla el transform + opacity completos.
   * Sin localStorage — se muestra una vez por carga de página.
   */

  @keyframes fab-label-show {
    0%   { opacity: 0; transform: translateY(-50%) translateX(8px);  }
    8%   { opacity: 1; transform: translateY(-50%) translateX(0);    }
    85%  { opacity: 1; transform: translateY(-50%) translateX(0);    }
    100% { opacity: 0; transform: translateY(-50%) translateX(4px);  }
  }

  .csheet__fab-label {
    position:       absolute;
    right:          calc(100% + 10px); /* A la izquierda del botón */
    top:            50%;
    /* La animación maneja el transform inicial (keyframe 0%) */

    white-space:    nowrap;
    pointer-events: none;
    user-select:    none;

    font-family:    var(--font-sans);
    font-size:      10px;
    font-weight:    var(--fw-medium);
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color:          var(--c-white);

    background:              rgba(7, 8, 12, 0.82);
    backdrop-filter:         blur(10px) saturate(1.2);
    -webkit-backdrop-filter: blur(10px) saturate(1.2);
    border:        1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--r-micro); /* 4px */
    padding:       5px 10px;

    opacity:         0;
    animation:       fab-label-show 3.5s ease forwards;
    animation-delay: 0.5s; /* Cotización — primer tooltip */
  }

  /* Mini-flecha → apunta hacia el botón (hacia la derecha) */
  .csheet__fab-label::after {
    content:  '';
    position: absolute;
    right:    -5px;
    top:      50%;
    transform: translateY(-50%);

    /* Triángulo CSS apuntando a la derecha */
    width:  0;
    height: 0;
    border-top:    4px solid transparent;
    border-bottom: 4px solid transparent;
    border-left:   5px solid rgba(7, 8, 12, 0.82);
  }

  /* Linktree: aparece 350ms después de Cotización (efecto cascada) */
  .csheet__linktree-btn .csheet__fab-label {
    animation-delay: 0.85s;
  }
</style>


<script>
  /**
   * ContactSheet — Controller
   *
   * Maneja open/close del bottom sheet.
   * Cierra con: clic backdrop, botón ✕, tecla Escape.
   * Previene scroll de fondo cuando está abierto.
   */
  (function () {
    const trigger  = document.getElementById('csheet-trigger');
    const sheet    = document.getElementById('csheet-sheet');
    const backdrop = document.getElementById('csheet-backdrop');
    const closeBtn = document.getElementById('csheet-close');

    if (!trigger || !sheet || !backdrop) return;

    let isOpen = false;

    function open() {
      isOpen = true;
      sheet.classList.add('is-open');
      backdrop.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
      trigger.setAttribute('aria-label', 'Cerrar información de contacto');
      sheet.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      /* Foco al primer elemento interactivo */
      setTimeout(() => {
        const first = sheet.querySelector('a, button');
        if (first) first.focus();
      }, 460);
    }

    function close() {
      isOpen = false;
      sheet.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
      trigger.setAttribute('aria-label', 'Abrir información de contacto');
      sheet.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      trigger.focus();
    }

    trigger.addEventListener('click', () => isOpen ? close() : open());
    backdrop.addEventListener('click', close);
    if (closeBtn) closeBtn.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        e.preventDefault();
        close();
      }
    });

    /* Touch swipe down → cierra (UX mobile mejorado) */
    let startY = 0;
    sheet.addEventListener('touchstart', (e) => {
      startY = e.touches[0].clientY;
    }, { passive: true });

    sheet.addEventListener('touchend', (e) => {
      const endY = e.changedTouches[0].clientY;
      if (endY - startY > 80 && isOpen) close(); /* 80px swipe down */
    }, { passive: true });

  })();
</script>
