---
/**
 * ContactSheet.astro
 * Consorcio Helitec — Panel de contacto deslizante (Bottom Sheet)
 *
 * Referencia visual: aventuradentalarts.com — panel inferior con tarjetas de contacto
 *
 * Estructura:
 *   · Trigger: botón fijo bottom-right con icono de teléfono
 *   · Sheet: panel que sube desde bottom: 0 (translateY 100% → 0)
 *   · Contenido: 3 tarjetas de contacto con acción directa (tel:, wa.me)
 *     1. Oficina Caracas      → llamada directa
 *     2. Operaciones 24/7     → llamada directa
 *     3. Ambulancia Aérea     → WhatsApp directo
 *
 * Reglas anti-slop:
 *   border-radius: var(--r-micro) solo en esquinas superiores del sheet
 *   z-index: var(--z-bottom-sheet) = 900
 *   PROHIBIDO box-shadow — ✓
 *
 * NOTA PARA EL CLIENTE: Reemplazar los números de contacto con los reales.
 *   Los marcados con [NÚMERO] son placeholders.
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
---

<!-- ── BACKDROP ──────────────────────────────────────────────────────────── -->
<div
  class="csheet__backdrop"
  id="csheet-backdrop"
  aria-hidden="true"
></div>

<!-- ── BOTTOM SHEET ──────────────────────────────────────────────────────── -->
<div
  class="csheet__sheet"
  id="csheet-sheet"
  role="dialog"
  aria-modal="true"
  aria-label="Información de contacto"
  aria-hidden="true"
>
  <!-- Handle — barra de arrastre visual -->
  <div class="csheet__handle-wrap" aria-hidden="true">
    <span class="csheet__handle"></span>
  </div>

  <!-- Cabecera del sheet -->
  <div class="csheet__header">
    <div class="csheet__header-text">
      <p class="csheet__overline">Consorcio Helitec</p>
      <h2 class="csheet__title">Contáctenos</h2>
    </div>
    <button
      class="csheet__close"
      id="csheet-close"
      type="button"
      aria-label="Cerrar panel de contacto"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
      </svg>
    </button>
  </div>

  <!-- Tarjetas de contacto -->
  <div class="csheet__cards">

    <!-- 01 — Oficina Caracas -->
    <a
      href="tel:+582125551234"
      class="csheet__card"
      data-type="phone"
    >
      <span class="csheet__card-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 5a2 2 0 0 1 2-2h3.28a1 1 0 0 1 .948.684l1.498 4.493a1 1 0 0 1-.502 1.21L8.5 10.5a11.042 11.042 0 0 0 4.998 5l1.113-1.724a1 1 0 0 1 1.21-.502l4.493 1.498A1 1 0 0 1 21 15.72V19a2 2 0 0 1-2 2h-1C9.163 21 3 14.837 3 7V5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
      </span>
      <div class="csheet__card-info">
        <span class="csheet__card-label">Oficina Caracas</span>
        <span class="csheet__card-value">+58 (212) [NÚMERO]</span>
        <span class="csheet__card-hint">Lun – Vie · 8:00 – 17:00</span>
      </div>
      <span class="csheet__card-arrow" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </span>
    </a>

    <!-- 02 — Operaciones 24/7 -->
    <a
      href="tel:+584166235254"
      class="csheet__card"
      data-type="phone"
    >
      <span class="csheet__card-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </span>
      <div class="csheet__card-info">
        <span class="csheet__card-label">Operaciones</span>
        <span class="csheet__card-value">+58 416-6235254</span>
        <span class="csheet__card-hint">Disponibilidad 24 / 7</span>
      </div>
      <span class="csheet__card-arrow" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </span>
    </a>

    <!-- 03 — Ambulancia Aérea (WhatsApp) -->
    <a
      href="https://wa.me/584166235254?text=EMERGENCIA%20AEROM%C3%89DICA%20%E2%80%94%20Consorcio%20Helitec%0A%0ASolicito%20servicio%20de%20ambulancia%20a%C3%A9rea.%20Favor%20contactar%20con%20urgencia."
      class="csheet__card csheet__card--urgent"
      target="_blank"
      rel="noopener noreferrer"
      data-type="whatsapp"
    >
      <span class="csheet__card-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Cruz médica + hélice estilizada -->
          <path d="M12 2L12 22M2 12L22 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </span>
      <div class="csheet__card-info">
        <span class="csheet__card-label">Ambulancia Aérea</span>
        <span class="csheet__card-value">WhatsApp Emergencias</span>
        <span class="csheet__card-hint csheet__card-hint--urgent">Respuesta inmediata</span>
      </div>
      <span class="csheet__card-arrow" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </span>
    </a>

  </div>

  <!-- Línea separadora -->
  <div class="csheet__divider" aria-hidden="true"></div>

  <!-- Footer del sheet -->
  <div class="csheet__footer">
    <p class="csheet__footer-text">
      Consorcio Helitec C.A. · Caracas, Venezuela<br>
      INAC Certificado · Reg. [N° AOC]
    </p>
  </div>

</div>

<!-- ── FABs AGRUPADOS: Cotización + Contacto + Linktree ──────────────────── -->
<!--
  Tres FABs 44×44px en fila horizontal — esquina inferior derecha.
  Orden izq→der: Cotización (primario) · Contacto (secundario) · Linktree (terciario).
  El trigger #slcta-trigger vive aquí; SideLeadCTA.astro lo encuentra por ID.
  z-index: 895 — encima del panel SideLeadCTA (848) y su backdrop (847).
-->
<div class="csheet__fabs">

  <!-- FAB 1: Cotización — abre panel SideLeadCTA (CTA primario) -->
  <button
    class="csheet__fab csheet__fab--cotizar"
    id="slcta-trigger"
    type="button"
    aria-expanded="false"
    aria-controls="slcta-panel"
    aria-label="Solicitar cotización de vuelo privado"
  >
    <span class="csheet__fab-icon" aria-hidden="true">
      <!-- Avión de papel — solicitar vuelo / cotización -->
      <svg width="18" height="16" viewBox="0 0 18 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L17 8L1 15V9.5L11 8L1 6.5V1Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="square" stroke-linejoin="miter"/>
      </svg>
    </span>
    <span class="csheet__fab-close" aria-hidden="true">
      <!-- ✕ — cerrar panel cotizador (visible cuando aria-expanded="true") -->
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L11 11M11 1L1 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
      </svg>
    </span>
  </button>

  <!-- FAB 2: Contacto — abre bottom sheet de información -->
  <button
    class="csheet__fab csheet__trigger"
    id="csheet-trigger"
    type="button"
    aria-expanded="false"
    aria-controls="csheet-sheet"
    aria-label="Abrir información de contacto"
  >
    <!-- Burbuja de mensaje minimalista -->
    <svg width="18" height="17" viewBox="0 0 18 17" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M1 1h16v10H4.5L1 15V1Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="square" stroke-linejoin="miter"/>
    </svg>
  </button>

  <!-- FAB 3: Linktree — redes sociales de Helitec -->
  <!-- [DATO: reemplazar href con la URL real del Linktree de Consorcio Helitec] -->
  <a
    class="csheet__fab csheet__linktree-btn"
    href="https://linktr.ee/helitec"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Ver redes sociales de Consorcio Helitec en Linktree"
  >
    <!-- Linktree minimal icon: tronco + 2 pares de ramas diagonales -->
    <svg width="14" height="16" viewBox="0 0 14 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M7 2V16"    stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
      <path d="M7 6L3 2"   stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
      <path d="M7 6L11 2"  stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
      <path d="M7 10L3 6"  stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
      <path d="M7 10L11 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
    </svg>
  </a>

</div>


<style>
  /* ── BACKDROP ───────────────────────────────────────────────────────────── */
  .csheet__backdrop {
    position:       fixed;
    inset:          0;
    z-index:        898; /* Debajo del sheet (899) */

    background-color: rgba(7, 8, 12, 0.70);

    opacity:        0;
    pointer-events: none;
    visibility:     hidden;

    transition:
      opacity    var(--dur-mid) var(--ease-out),
      visibility 0s linear calc(var(--dur-mid) + 10ms);
  }

  .csheet__backdrop.is-open {
    opacity:        1;
    pointer-events: auto;
    visibility:     visible;
    transition:
      opacity    var(--dur-mid) var(--ease-out),
      visibility 0s linear 0s;
  }

  /* ── SHEET ──────────────────────────────────────────────────────────────── */
  .csheet__sheet {
    position: fixed;
    bottom:   0;
    left:     0;
    right:    0;

    z-index:  var(--z-bottom-sheet); /* 900 */

    background-color: var(--c-bg-raised);

    /* Esquinas superiores: 4px — límite absoluto del proyecto */
    border-radius: var(--r-micro) var(--r-micro) 0 0;
    border-top:    1px solid var(--c-line-strong);

    /* Slide desde abajo */
    transform:  translateY(100%);
    visibility: hidden;

    transition:
      transform  var(--dur-mid) var(--ease-menu),
      visibility 0s linear calc(var(--dur-mid) + 10ms);

    /* Limitar altura en pantallas grandes */
    max-height: 85dvh;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .csheet__sheet.is-open {
    transform:  translateY(0);
    visibility: visible;
    transition:
      transform  var(--dur-mid) var(--ease-menu),
      visibility 0s linear 0s;
  }

  /* ── Handle ─────────────────────────────────────────────────────────────── */
  .csheet__handle-wrap {
    display:         flex;
    justify-content: center;
    padding-top:     14px;
    padding-bottom:  8px;
  }

  .csheet__handle {
    display:          block;
    width:            32px;
    height:           3px;
    background-color: var(--c-line-strong);
    border-radius:    var(--r-micro); /* 4px */
  }

  /* ── Cabecera ────────────────────────────────────────────────────────────── */
  .csheet__header {
    display:     flex;
    align-items: center;
    justify-content: space-between;

    padding: 8px clamp(20px, 5vw, 36px) 20px;
    border-bottom: 1px solid var(--c-line);
  }

  .csheet__overline {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-brand);
    margin-bottom:  4px;
  }

  .csheet__title {
    font-family:    var(--font-display);
    font-size:      clamp(1.4rem, 3vw, 1.75rem);
    font-weight:    var(--fw-thin);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color:          var(--c-text-1);
  }

  .csheet__close {
    display:         flex;
    align-items:     center;
    justify-content: center;

    width:  36px;
    height: 36px;
    flex-shrink: 0;

    background:    none;
    border:        1px solid var(--c-line);
    border-radius: var(--r-micro);
    cursor:        pointer;
    color:         var(--c-text-2);

    transition: border-color var(--dur-fast) var(--ease-out),
                color        var(--dur-fast) var(--ease-out);
  }

  .csheet__close:hover {
    border-color: var(--c-line-strong);
    color:        var(--c-text-1);
  }

  .csheet__close:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
  }

  /* ── Tarjetas ────────────────────────────────────────────────────────────── */
  .csheet__cards {
    display:        flex;
    flex-direction: column;

    /* Líneas divisoras entre tarjetas sin border */
    gap:            1px;
    background-color: var(--c-line);

    border-bottom: 1px solid var(--c-line);
  }

  .csheet__card {
    display:     flex;
    align-items: center;
    gap:         16px;

    padding: 18px clamp(20px, 5vw, 36px);

    background-color: var(--c-bg-raised);
    text-decoration:  none;
    color:            inherit;

    transition: background-color var(--dur-fast) var(--ease-out);
  }

  .csheet__card:hover {
    background-color: var(--c-bg);
  }

  .csheet__card--urgent {
    /* Tarjeta de urgencia: acento rojo sutil en el indicador */
  }

  .csheet__card-icon {
    display:         flex;
    align-items:     center;
    justify-content: center;
    flex-shrink:     0;

    width:  40px;
    height: 40px;

    border:        1px solid var(--c-line-strong);
    border-radius: var(--r-micro);
    color:         var(--c-sky);
  }

  .csheet__card--urgent .csheet__card-icon {
    color:        var(--c-red);
    border-color: rgba(229, 59, 28, 0.30);
  }

  .csheet__card-info {
    display:        flex;
    flex-direction: column;
    gap:            2px;
    flex:           1;
    min-width:      0;
  }

  .csheet__card-label {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-3);
  }

  .csheet__card-value {
    font-family: var(--font-display);
    font-size:   clamp(0.9rem, 2vw, 1.05rem);
    font-weight: var(--fw-regular);
    color:       var(--c-text-1);
    white-space: nowrap;
    overflow:    hidden;
    text-overflow: ellipsis;
  }

  .csheet__card-hint {
    font-family: var(--font-sans);
    font-size:   0.7rem;
    color:       var(--c-text-3);
  }

  .csheet__card-hint--urgent {
    color: var(--c-red);
    font-weight: var(--fw-medium);
  }

  .csheet__card-arrow {
    flex-shrink: 0;
    color:       var(--c-text-3);
    transition:  transform var(--dur-fast) var(--ease-out),
                 color     var(--dur-fast) var(--ease-out);
  }

  .csheet__card:hover .csheet__card-arrow {
    transform: translateX(3px);
    color:     var(--c-text-2);
  }

  /* ── Divisor y footer ────────────────────────────────────────────────────── */
  .csheet__divider {
    height:           1px;
    background-color: var(--c-line);
  }

  .csheet__footer {
    padding: 16px clamp(20px, 5vw, 36px) 24px;
  }

  .csheet__footer-text {
    font-family: var(--font-sans);
    font-size:   0.7rem;
    color:       var(--c-text-3);
    line-height: 1.6;
  }

  /* ── FABs WRAPPER — Fila horizontal, esquina inferior derecha ───────────── */
  /*
   * Tres FABs 44×44px en row horizontal.
   * right: 12px — ya no hay strip SideLeadCTA que desplazar (fue eliminado).
   * z-index: 895 — encima del panel SideLeadCTA (848), debajo del backdrop de
   *               ContactSheet (898) para que el backdrop cubra los FABs al abrir.
   */
  .csheet__fabs {
    position: fixed;
    bottom:   clamp(16px, 3vh, 24px);
    right:    12px;
    z-index:  895;

    display:     flex;
    flex-direction: row;
    align-items: center;
    gap:         8px;
  }

  /* ── Base compartida — Efecto Cristal (todos los FABs) ──────────────────── */
  /*
   * CUMPLE reglas anti-slop:
   *   ✓ Sin box-shadow
   *   ✓ Sin linear-gradient (fondo es rgba puro)
   *   ✓ border-radius: var(--r-micro) = 4px
   *   ✓ backdrop-filter: blur() — no prohibido
   */
  .csheet__fab {
    position:    relative; /* necesario para span hijos con position:absolute */
    width:       44px;
    height:      44px;
    flex-shrink: 0;

    display:         flex;
    align-items:     center;
    justify-content: center;

    backdrop-filter:         blur(12px) saturate(1.3);
    -webkit-backdrop-filter: blur(12px) saturate(1.3);
    border-radius: var(--r-micro); /* 4px — límite sagrado */
    cursor:        pointer;
    text-decoration: none; /* reset para <a> */

    transition:
      background   var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      color        var(--dur-fast) var(--ease-out);
  }

  /* ── FAB 1: Cotización (CTA primario — azul marca) ───────────────────────── */
  .csheet__fab--cotizar {
    background:  rgba(2, 58, 120, 0.50);    /* --c-brand tinted glass */
    border:      1px solid rgba(88, 181, 240, 0.22);
    color:       rgba(255, 255, 255, 0.88);
  }

  .csheet__fab--cotizar:hover {
    background:   rgba(10, 77, 158, 0.70);  /* --c-brand-hover al 70% */
    border-color: rgba(88, 181, 240, 0.45);
    color:        var(--c-white);
  }

  .csheet__fab--cotizar:focus-visible {
    outline: 2px solid var(--c-sky);
    outline-offset: 2px;
  }

  /* Estado activo: panel cotizador abierto */
  .csheet__fab--cotizar[aria-expanded="true"] {
    background:   rgba(10, 77, 158, 0.80);
    border-color: rgba(88, 181, 240, 0.55);
  }

  /* Swap icono avión ↔ ✕ según aria-expanded */
  .csheet__fab-icon,
  .csheet__fab-close {
    position:  absolute;
    display:   flex;
    align-items:     center;
    justify-content: center;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .csheet__fab-icon  { opacity: 1; }
  .csheet__fab-close { opacity: 0; }

  .csheet__fab--cotizar[aria-expanded="true"] .csheet__fab-icon  { opacity: 0; }
  .csheet__fab--cotizar[aria-expanded="true"] .csheet__fab-close { opacity: 1; }

  /* ── FABs 2 y 3: Contacto + Linktree (cristal blanco translúcido) ─────── */
  .csheet__trigger,
  .csheet__linktree-btn {
    background: rgba(255, 255, 255, 0.08);
    border:     1px solid rgba(255, 255, 255, 0.14);
    color:      rgba(255, 255, 255, 0.75);
  }

  .csheet__trigger:hover,
  .csheet__linktree-btn:hover {
    background: rgba(255, 255, 255, 0.16);
    color:      rgba(255, 255, 255, 1);
  }

  .csheet__trigger:hover     { border-color: rgba(88, 181, 240, 0.50); }
  .csheet__linktree-btn:hover { border-color: rgba(68, 195, 92,  0.45); }

  .csheet__trigger:focus-visible,
  .csheet__linktree-btn:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
  }
</style>


<script>
  /**
   * ContactSheet — Controller
   *
   * Maneja open/close del bottom sheet.
   * Cierra con: clic backdrop, botón ✕, tecla Escape.
   * Previene scroll de fondo cuando está abierto.
   */
  (function () {
    const trigger  = document.getElementById('csheet-trigger');
    const sheet    = document.getElementById('csheet-sheet');
    const backdrop = document.getElementById('csheet-backdrop');
    const closeBtn = document.getElementById('csheet-close');

    if (!trigger || !sheet || !backdrop) return;

    let isOpen = false;

    function open() {
      isOpen = true;
      sheet.classList.add('is-open');
      backdrop.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
      trigger.setAttribute('aria-label', 'Cerrar información de contacto');
      sheet.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      /* Foco al primer elemento interactivo */
      setTimeout(() => {
        const first = sheet.querySelector('a, button');
        if (first) first.focus();
      }, 460);
    }

    function close() {
      isOpen = false;
      sheet.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
      trigger.setAttribute('aria-label', 'Abrir información de contacto');
      sheet.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      trigger.focus();
    }

    trigger.addEventListener('click', () => isOpen ? close() : open());
    backdrop.addEventListener('click', close);
    if (closeBtn) closeBtn.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        e.preventDefault();
        close();
      }
    });

    /* Touch swipe down → cierra (UX mobile mejorado) */
    let startY = 0;
    sheet.addEventListener('touchstart', (e) => {
      startY = e.touches[0].clientY;
    }, { passive: true });

    sheet.addEventListener('touchend', (e) => {
      const endY = e.changedTouches[0].clientY;
      if (endY - startY > 80 && isOpen) close(); /* 80px swipe down */
    }, { passive: true });

  })();
</script>
