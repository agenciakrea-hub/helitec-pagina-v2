---
/**
 * HELITEC — CTAFloat.astro
 * Botón flotante permanente de contacto WhatsApp.
 *
 * Diseño: rojo de marca (#e53b1c) sobre fondo oscuro semitransparente.
 * Aparece con delay de 3s al cargar la página (no-intrusivo).
 * En desktop: icono + texto "Cotizar Vuelo".
 * En mobile (<640px): icono + texto corto "Cotizar".
 *
 * El número y mensaje son configurables en /src/data/config.js.
 * Por ahora hardcodeados aquí como placeholder.
 *
 * Props:
 *   lang — 'es' | 'en'
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

/* ── WhatsApp config ─────────────────────────────────────
   Número: +58 212 9596385 → formato wa.me: 582129596385
   TODO: mover a src/data/config.js cuando el dominio esté activo
────────────────────────────────────────────────────────── */
const WA_NUMBER  = '582129596385';
const WA_MSG_ES  = 'Hola Helitec, me gustaría recibir asesoría corporativa sobre sus servicios de vuelos chárter.';
const WA_MSG_EN  = 'Hello Helitec, I would like to receive corporate advisory on your charter flight services.';

const waMsg  = lang === 'es' ? WA_MSG_ES : WA_MSG_EN;
const waHref = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(waMsg)}`;

const i18n = {
  es: {
    labelFull:  'Cotizar Vuelo',
    labelShort: 'Cotizar',
    srLabel:    'Solicitar cotización vía WhatsApp',
  },
  en: {
    labelFull:  'Request Quote',
    labelShort: 'Quote',
    srLabel:    'Request a quote via WhatsApp',
  },
}[lang];
---

<!-- ─────────────────────────────────────────────────────────
     BOTÓN FLOTANTE WHATSAPP
     Posicionado: bottom-right, z-index máximo (var --z-cta-float)
───────────────────────────────────────────────────────────── -->
<div class="cta-float-wrapper" id="cta-float">
  <a
    href={waHref}
    class="cta-float"
    target="_blank"
    rel="noopener noreferrer"
    aria-label={i18n.srLabel}
    title={i18n.srLabel}
  >
    <!-- Anillo de pulso animado (detrás del botón) -->
    <span class="cta-float__pulse" aria-hidden="true"></span>

    <!-- Icono WhatsApp — SVG oficial simplificado -->
    <svg
      class="cta-float__icon"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
    </svg>

    <!-- Etiqueta de texto -->
    <span class="cta-float__label cta-float__label--full"  aria-hidden="true">{i18n.labelFull}</span>
    <span class="cta-float__label cta-float__label--short" aria-hidden="true">{i18n.labelShort}</span>
  </a>
</div>


<style>

  /* ── WRAPPER ─────────────────────────────────────────────── */

  .cta-float-wrapper {
    position: fixed;
    bottom: var(--space-8);
    right:  var(--space-8);
    z-index: var(--z-cta-float);

    /* Aparece con fade-in tras delay (activado por JS) */
    opacity: 0;
    transform: translateY(12px) scale(0.92);
    transition:
      opacity   500ms var(--ease-out),
      transform 500ms var(--ease-out);
    pointer-events: none;
  }

  .cta-float-wrapper.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  @media (max-width: 480px) {
    .cta-float-wrapper {
      bottom: var(--space-5);
      right:  var(--space-4);
    }
  }


  /* ── BOTÓN PRINCIPAL ──────────────────────────────────────── */

  .cta-float {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-6);
    background: var(--brand-rojo-helitec);
    color: #ffffff;
    border-radius: var(--radius-full);
    text-decoration: none;
    font-family: var(--font-primary);
    font-size: var(--text-sm);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-wide);
    line-height: 1;
    white-space: nowrap;

    /* Sombra con glow rojizo */
    box-shadow:
      0 4px 20px rgba(229, 59, 28, 0.40),
      0 2px  8px rgba(0, 0, 0, 0.35);

    transition:
      background   var(--transition-fast),
      box-shadow   var(--transition-base),
      transform    var(--transition-base);

    /* Borde sutil para separarlo del fondo oscuro */
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .cta-float:hover {
    background: #c93218;
    box-shadow:
      0 6px 28px rgba(229, 59, 28, 0.55),
      0 3px 12px rgba(0, 0, 0, 0.40);
    transform: translateY(-2px);
    color: #ffffff;
  }

  .cta-float:active {
    transform: translateY(0) scale(0.97);
    box-shadow:
      0 2px 10px rgba(229, 59, 28, 0.35),
      0 1px  4px rgba(0, 0, 0, 0.30);
  }


  /* ── ANILLO DE PULSO ─────────────────────────────────────── */

  .cta-float__pulse {
    position: absolute;
    inset: -4px;
    border-radius: var(--radius-full);
    border: 2px solid var(--brand-rojo-helitec);
    opacity: 0;
    animation: cta-pulse 3s ease-out infinite;
  }

  /* Segundo anillo con desfase */
  .cta-float__pulse::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: var(--radius-full);
    border: 1.5px solid var(--brand-rojo-helitec);
    opacity: 0;
    animation: cta-pulse 3s ease-out 0.8s infinite;
  }

  @keyframes cta-pulse {
    0%   { transform: scale(1);    opacity: 0.55; }
    70%  { transform: scale(1.18); opacity: 0;    }
    100% { transform: scale(1.18); opacity: 0;    }
  }

  /* Detener pulso en hover — mejor UX */
  .cta-float:hover ~ .cta-float__pulse,
  .cta-float:hover .cta-float__pulse {
    animation-play-state: paused;
  }


  /* ── ICONO ─────────────────────────────────────────────── */

  .cta-float__icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    /* Transición de escala en hover para micro-interacción */
    transition: transform var(--transition-fast);
  }

  .cta-float:hover .cta-float__icon {
    transform: scale(1.10);
  }


  /* ── ETIQUETAS DE TEXTO ─────────────────────────────────── */

  .cta-float__label {
    font-size: var(--text-sm);
  }

  /* Desktop: etiqueta larga */
  .cta-float__label--short { display: none; }

  @media (max-width: 640px) {
    .cta-float__label--full  { display: none; }
    .cta-float__label--short { display: inline; }

    .cta-float {
      padding: var(--space-3) var(--space-5);
      font-size: var(--text-xs);
      gap: var(--space-2);
    }

    .cta-float__icon {
      width: 18px;
      height: 18px;
    }
  }


  /* ── ACCESIBILIDAD ──────────────────────────────────────── */

  /* Respetar preferencia de movimiento reducido */
  @media (prefers-reduced-motion: reduce) {
    .cta-float__pulse,
    .cta-float__pulse::after {
      animation: none;
      display: none;
    }

    .cta-float-wrapper {
      transition: opacity 300ms var(--ease-standard);
      transform: none;
    }
  }

</style>


<!-- ── Script: aparece con delay de 3s al cargar ─────────── -->
<script>
  (() => {
    const wrapper = document.getElementById('cta-float');
    if (!wrapper) return;

    /* Pequeño delay para no competir visualmente con el hero */
    const DELAY_MS = 2800;

    const show = () => wrapper.classList.add('is-visible');

    if (document.readyState === 'complete') {
      setTimeout(show, DELAY_MS);
    } else {
      window.addEventListener('load', () => setTimeout(show, DELAY_MS), { once: true });
    }
  })();
</script>
