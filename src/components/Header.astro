---
/**
 * HELITEC — Header.astro
 * Navbar sticky con glassmorphism + menú overlay fullscreen estilo Konpo Studio.
 *
 * Cambios v2:
 *   — WhatsApp real: +58 416-6235254 (wa.me/584166235254)
 *   — Servicios actualizados: foco corporativo/petrolero/industrial
 *   — CTA WhatsApp visible dentro del menú overlay
 *   — Lang toggle más prominente
 *   — Estética: 2px border-radius, fw-light en nav labels (Exclusividad Silenciosa)
 *
 * Props:
 *   lang        — 'es' | 'en'
 *   currentPath — ruta activa para marcar link activo (ej. '/nosotros')
 */

interface Props {
  lang?:        'es' | 'en';
  currentPath?: string;
}

const { lang = 'es', currentPath = '/' } = Astro.props;

/* ── WhatsApp ──────────────────────────────────────────────────
   Número real del cliente: +58 416-6235254
   wa.me formato: 584166235254
────────────────────────────────────────────────────────────── */
const WA_NUMBER = '584166235254';

const WA_MSG: Record<string, string> = {
  es: 'Hola Consorcio Helitec. Estoy interesado en solicitar asesoría sobre sus servicios de aviación corporativa. Por favor contáctenme.',
  en: 'Hello Consorcio Helitec. I am interested in requesting information about your corporate aviation services. Please contact me.',
};

const waHref = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(WA_MSG[lang] ?? WA_MSG['es'])}`;

/* ── Traducciones ─────────────────────────────────────────── */
const i18n = {
  es: {
    langSwitch: 'EN',
    langHref:   '/en/',
    ctaLabel:   'Solicitar Servicio',
    menuOpen:   'Menú',
    menuClose:  'Cerrar',
    logoAlt:    'Consorcio Helitec — Inicio',
    menuWaLabel: 'Contactar vía WhatsApp',

    nav: [
      { label: 'La Empresa',          href: '/nosotros'            },
      { label: 'Seguridad & Calidad', href: '/seguridad-y-calidad' },
      { label: 'Flota',               href: '/flota'               },
      { label: 'Servicios',           href: '/servicios'           },
      { label: 'Contacto',            href: '/contacto'            },
    ],

    /*
     * Servicios en el menú — tono corporativo/industrial.
     * Cero lenguaje turístico. El cliente opera Oil & Gas, Banca, Industria.
     */
    services: [
      {
        num:  '01',
        tag:  'Ala Fija',
        title: 'Aviación Ejecutiva',
        desc:  'Charter corporativo en Metro Series. Continuidad operacional para alta dirección.',
        href:  '/flota#ala-fija',
        photo: '/assets/PHOTO-2024-10-30-15-40-52.JPG',
      },
      {
        num:  '02',
        tag:  'Ala Rotatoria',
        title: 'Operaciones Petroleras',
        desc:  'MD Series certificado. Plataformas offshore, campos remotos Oil & Gas.',
        href:  '/flota#ala-rotatoria',
        photo: '/assets/Helicoptero_en%20pico.jpg',
      },
      {
        num:  '03',
        tag:  'Aeromédico',
        title: 'Traslados Aeromédicos',
        desc:  'Evacuaciones críticas para Banca, Industria y sector petrolero. 24/7.',
        href:  '/servicios#aeromedico',
        photo: '/assets/Aeromedico_1.jpg',
      },
      {
        num:  '04',
        tag:  'Carga',
        title: 'Logística de Carga',
        desc:  'Transporte de equipos industriales y suministros a zonas de difícil acceso.',
        href:  '/servicios#carga',
        photo: '/assets/Helicoptero%20Eslinga%201.jpg',
      },
    ],

    certifications: [
      'Certificado INAC',
      'SMS OACI Anexo 19',
      'Auditorías IOSA compatibles',
    ],

    contact: {
      phone:   '+58 416-623-5254',
      email:   'info@helitec.com',
      address: 'CCCT, Chuao — Caracas, Venezuela',
    },
  },

  en: {
    langSwitch: 'ES',
    langHref:   '/',
    ctaLabel:   'Request Service',
    menuOpen:   'Menu',
    menuClose:  'Close',
    logoAlt:    'Consorcio Helitec — Home',
    menuWaLabel: 'Contact via WhatsApp',

    nav: [
      { label: 'About',            href: '/en/about'          },
      { label: 'Safety & Quality', href: '/en/safety-quality' },
      { label: 'Fleet',            href: '/en/fleet'          },
      { label: 'Services',         href: '/en/services'       },
      { label: 'Contact',          href: '/en/contact'        },
    ],

    services: [
      {
        num:  '01',
        tag:  'Fixed Wing',
        title: 'Executive Aviation',
        desc:  'Corporate charter on Metro Series. Operational continuity for senior management.',
        href:  '/en/fleet#fixed-wing',
        photo: '/assets/PHOTO-2024-10-30-15-40-52.JPG',
      },
      {
        num:  '02',
        tag:  'Rotary Wing',
        title: 'Petroleum Operations',
        desc:  'Certified MD Series. Offshore platforms, remote Oil & Gas fields.',
        href:  '/en/fleet#rotary-wing',
        photo: '/assets/Helicoptero_en%20pico.jpg',
      },
      {
        num:  '03',
        tag:  'Aeromedical',
        title: 'Aeromedical Transfers',
        desc:  'Critical evacuations for Banking, Industry & Oil sector. 24/7.',
        href:  '/en/services#aeromedical',
        photo: '/assets/Aeromedico_1.jpg',
      },
      {
        num:  '04',
        tag:  'Cargo',
        title: 'Cargo Logistics',
        desc:  'Industrial equipment and supplies to remote or hard-to-reach locations.',
        href:  '/en/services#cargo',
        photo: '/assets/Helicoptero%20Eslinga%201.jpg',
      },
    ],

    certifications: [
      'INAC Certified Operator',
      'ICAO SMS Annex 19',
      'IOSA-compatible Audits',
    ],

    contact: {
      phone:   '+58 416-623-5254',
      email:   'info@helitec.com',
      address: 'CCCT, Chuao — Caracas, Venezuela',
    },
  },
}[lang];
---

<!-- ─────────────────────────────────────────────────────────
     HEADER — Navbar sticky
───────────────────────────────────────────────────────────── -->
<header class="site-header" id="site-header" role="banner">
  <div class="header-inner">

    <!-- Logo -->
    <a href={lang === 'es' ? '/' : '/en/'} class="header-logo" aria-label={i18n.logoAlt}>
      <img
        src="/assets/Logo-Helitec-horiz-no-bkg-1-blanco.png"
        alt="Consorcio Helitec"
        class="header-logo__img"
        width="160"
        height="32"
        loading="eager"
        decoding="sync"
      />
    </a>

    <!-- Acciones del header -->
    <div class="header-actions">

      <!-- Selector de idioma — ES / EN visible y claro -->
      <a
        href={i18n.langHref}
        class="lang-toggle"
        aria-label={`Cambiar idioma a ${i18n.langSwitch}`}
        title={`Switch to ${i18n.langSwitch}`}
      >
        <span class={`lang-opt ${lang === 'es' ? 'lang-opt--active' : ''}`}>ES</span>
        <span class="lang-sep" aria-hidden="true">/</span>
        <span class={`lang-opt ${lang === 'en' ? 'lang-opt--active' : ''}`}>EN</span>
      </a>

      <!-- CTA WhatsApp — desktop only -->
      <a
        href={waHref}
        class="header-cta"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={i18n.ctaLabel}
      >
        <!-- Ícono WhatsApp pequeño -->
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        {i18n.ctaLabel}
      </a>

      <!-- Botón hamburguesa -->
      <button
        class="menu-toggle"
        id="menu-toggle"
        aria-controls="menu-overlay"
        aria-expanded="false"
        aria-label={i18n.menuOpen}
        type="button"
      >
        <span class="menu-toggle__label menu-toggle__label--open"  aria-hidden="true">{i18n.menuOpen}</span>
        <span class="menu-toggle__label menu-toggle__label--close" aria-hidden="true">{i18n.menuClose}</span>
        <span class="menu-toggle__icon" aria-hidden="true">
          <span class="menu-toggle__bar"></span>
          <span class="menu-toggle__bar"></span>
        </span>
      </button>

    </div>
  </div>
</header>


<!-- ─────────────────────────────────────────────────────────
     MENÚ OVERLAY — fullscreen Konpo Studio
     Estructura: header del overlay / body (nav + servicios) / footer
───────────────────────────────────────────────────────────── -->
<div
  class="menu-overlay"
  id="menu-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
  aria-hidden="true"
>

  <!-- ── CABECERA DEL OVERLAY ─────────────────────────── -->
  <div class="menu-overlay__head">
    <a href={lang === 'es' ? '/' : '/en/'} class="header-logo" tabindex="-1" aria-label={i18n.logoAlt}>
      <img
        src="/assets/Logo-Helitec-horiz-no-bkg-1-blanco.png"
        alt="Consorcio Helitec"
        class="header-logo__img"
        width="160"
        height="32"
        loading="eager"
        decoding="sync"
      />
    </a>
    <div class="menu-overlay__head-actions">
      <!-- Lang toggle en el overlay -->
      <a
        href={i18n.langHref}
        class="lang-toggle lang-toggle--overlay"
        tabindex="-1"
        aria-label={`Cambiar idioma a ${i18n.langSwitch}`}
      >
        <span class={`lang-opt ${lang === 'es' ? 'lang-opt--active' : ''}`}>ES</span>
        <span class="lang-sep" aria-hidden="true">/</span>
        <span class={`lang-opt ${lang === 'en' ? 'lang-opt--active' : ''}`}>EN</span>
      </a>
      <button class="menu-close" id="menu-close" aria-label={i18n.menuClose} type="button">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M1 1L17 17M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- ── CUERPO: nav principal + grid de servicios ─────── -->
  <div class="menu-overlay__body">

    <!-- Columna izquierda: links de navegación -->
    <nav class="menu-nav" aria-label="Navegación principal">
      <ul class="menu-nav__list" role="list">
        {i18n.nav.map((item, i) => (
          <li class="menu-nav__item" style={`--item-index: ${i}`}>
            <a
              href={item.href}
              class={`menu-nav__link ${currentPath === item.href ? 'is-active' : ''}`}
              tabindex="-1"
            >
              <span class="menu-nav__num" aria-hidden="true">0{i + 1}</span>
              <span class="menu-nav__label">{item.label}</span>
              <svg class="menu-nav__arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M3 15L15 3M15 3H7M15 3V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>

      <!-- WhatsApp CTA dentro del nav — siempre visible -->
      <a
        href={waHref}
        class="menu-wa-cta"
        target="_blank"
        rel="noopener noreferrer"
        tabindex="-1"
        aria-label={i18n.menuWaLabel}
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        {i18n.menuWaLabel}
        <span class="menu-wa-cta__num">{i18n.contact.phone}</span>
      </a>
    </nav>

    <!-- Columna derecha: grid de servicios corporativos -->
    <div class="menu-services">
      <p class="menu-services__label text-overline" aria-hidden="true">
        {lang === 'es' ? 'Servicios' : 'Services'}
      </p>
      <div class="menu-services__grid">
        {i18n.services.map((svc, i) => (
          <a
            href={svc.href}
            class="menu-svc-box"
            style={`--svc-index: ${i}; background-image: linear-gradient(160deg, rgba(4,10,22,0.92) 0%, rgba(2,20,58,0.80) 50%, rgba(6,14,28,0.88) 100%), url('${svc.photo}')`}
            tabindex="-1"
          >
            <div class="menu-svc-box__header">
              <span class="menu-svc-box__num" aria-hidden="true">{svc.num}</span>
              <span class="menu-svc-box__tag">{svc.tag}</span>
            </div>
            <span class="menu-svc-box__title">{svc.title}</span>
            <span class="menu-svc-box__desc">{svc.desc}</span>
            <svg class="menu-svc-box__arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M1 11L11 1M11 1H4M11 1V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        ))}
      </div>

      <!-- Certificaciones — elemento de confianza -->
      <div class="menu-certs">
        {i18n.certifications.map(cert => (
          <span class="menu-cert-tag">
            <svg width="9" height="9" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M2 5L4.5 7.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {cert}
          </span>
        ))}
      </div>
    </div>

  </div>

  <!-- ── PIE DEL OVERLAY ───────────────────────────────── -->
  <div class="menu-overlay__foot">
    <div class="menu-foot-contact">
      <a href={`tel:+584166235254`} class="menu-foot-contact__item">
        {i18n.contact.phone}
      </a>
      <a href={`mailto:${i18n.contact.email}`} class="menu-foot-contact__item">
        {i18n.contact.email}
      </a>
      <span class="menu-foot-contact__item menu-foot-contact__item--muted">
        {i18n.contact.address}
      </span>
    </div>
    <div class="menu-foot-right">
      <div class="menu-foot-social">
        <a href="#" class="menu-foot-social__link" aria-label="Instagram" target="_blank" rel="noopener" tabindex="-1">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <a href="#" class="menu-foot-social__link" aria-label="LinkedIn" target="_blank" rel="noopener" tabindex="-1">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
      </div>
      <p class="menu-foot-legal">
        {lang === 'es' ? 'Operador certificado INAC · SMS OACI Anexo 19' : 'INAC Certified Operator · ICAO SMS Annex 19'}
      </p>
    </div>
  </div>

</div>

<!-- Backdrop oscuro detrás del overlay (z-index inferior al overlay) -->
<div class="menu-backdrop" id="menu-backdrop" aria-hidden="true"></div>


<!-- ─────────────────────────────────────────────────────────
     ESTILOS SCOPED
───────────────────────────────────────────────────────────── -->
<style>

  /* ══════════════════════════════════════════════════════════
     HEADER BASE
  ════════════════════════════════════════════════════════════ */

  .site-header {
    position:     fixed;
    top: 0; left: 0; right: 0;
    z-index:      var(--z-sticky);
    height:       72px;
    background:   transparent;
    border-bottom:1px solid transparent;
    transition:
      background    400ms var(--ease-standard),
      border-color  400ms var(--ease-standard),
      box-shadow    400ms var(--ease-standard);
  }

  :global(body.header-scrolled) .site-header {
    background:           rgba(6, 14, 28, 0.90);
    -webkit-backdrop-filter: blur(18px);
            backdrop-filter: blur(18px);
    border-bottom-color:  rgba(255,255,255,0.05);
    box-shadow:           0 1px 28px rgba(0,0,0,0.30);
  }

  :global(body.menu-open) .site-header {
    background:   var(--color-bg-void);
    backdrop-filter: none;
    border-bottom-color: rgba(255,255,255,0.05);
  }

  .header-inner {
    display:        flex;
    align-items:    center;
    justify-content:space-between;
    height:         100%;
    max-width:      var(--container-xl);
    margin-inline:  auto;
    padding-inline: var(--container-px);
  }


  /* ══════════════════════════════════════════════════════════
     LOGO
  ════════════════════════════════════════════════════════════ */

  .header-logo {
    display:     inline-flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    opacity:     1;
    transition:  opacity var(--transition-fast);
  }

  .header-logo:hover { opacity: 0.82; }

  .header-logo__img {
    height: 28px;
    width:  auto;
    display: block;
    image-rendering: -webkit-optimize-contrast;
  }

  @media (max-width: 480px) {
    .header-logo__img { height: 24px; }
  }


  /* ══════════════════════════════════════════════════════════
     ACCIONES DEL HEADER
  ════════════════════════════════════════════════════════════ */

  .header-actions {
    display:     flex;
    align-items: center;
    gap:         var(--space-2);
  }


  /* ══════════════════════════════════════════════════════════
     LANG TOGGLE — ES / EN
     Ambas opciones visibles. La activa en blanco, la otra muted.
  ════════════════════════════════════════════════════════════ */

  .lang-toggle {
    display:         inline-flex;
    align-items:     center;
    gap:             3px;
    padding:         var(--space-2) var(--space-3);
    font-family:     var(--font-primary);
    font-size:       0.60rem;
    font-weight:     var(--fw-semibold);
    letter-spacing:  0.18em;
    text-transform:  uppercase;
    text-decoration: none;
    border-radius:   2px;
    border:          1px solid rgba(255,255,255,0.08);
    transition:
      border-color var(--transition-fast),
      background   var(--transition-fast);
  }

  .lang-toggle:hover {
    border-color: rgba(255,255,255,0.18);
    background:   rgba(255,255,255,0.04);
  }

  .lang-opt {
    color:      rgba(255,255,255,0.32);
    transition: color var(--transition-fast);
  }

  .lang-opt--active { color: #fff; }

  .lang-sep {
    color:   rgba(255,255,255,0.18);
    margin:  0 1px;
    font-weight: var(--fw-light);
  }


  /* ══════════════════════════════════════════════════════════
     CTA WHATSAPP — Header desktop
  ════════════════════════════════════════════════════════════ */

  .header-cta {
    display:         inline-flex;
    align-items:     center;
    gap:             var(--space-2);
    padding:         var(--space-2) var(--space-5);
    font-family:     var(--font-primary);
    font-size:       0.60rem;
    font-weight:     var(--fw-medium);
    letter-spacing:  0.16em;
    text-transform:  uppercase;
    text-decoration: none;
    color:           var(--color-text-primary);
    border:          1px solid rgba(255,255,255,0.14);
    border-radius:   2px;
    line-height:     1;
    white-space:     nowrap;
    transition:
      background   var(--transition-fast),
      border-color var(--transition-fast),
      color        var(--transition-fast);
  }

  .header-cta:hover {
    background:   rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.28);
    color:        #fff;
  }

