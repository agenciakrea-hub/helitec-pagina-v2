---
/**
 * HELITEC — Header.astro
 * Navbar sticky con glassmorphism + menú overlay fullscreen estilo Konpo Studio.
 *
 * Props:
 *   lang        — 'es' | 'en'
 *   currentPath — ruta activa para marcar link activo (ej. '/nosotros')
 */

interface Props {
  lang?:        'es' | 'en';
  currentPath?: string;
}

const { lang = 'es', currentPath = '/' } = Astro.props;

/* ── Traducciones ─────────────────────────────────────────── */
const i18n = {
  es: {
    langSwitch:  'EN',
    langHref:    '/en/',
    ctaLabel:    'Solicitar Servicio',
    ctaHref:     '/contacto',
    menuOpen:    'Menú',
    menuClose:   'Cerrar',
    logoAlt:     'Consorcio Helitec — Inicio',
    nav: [
      { label: 'La Empresa',         href: '/nosotros'           },
      { label: 'Seguridad & Calidad', href: '/seguridad-y-calidad'},
      { label: 'Flota',              href: '/flota'              },
      { label: 'Galería',            href: '/galeria'            },
      { label: 'Contacto',           href: '/contacto'           },
    ],
    services: [
      {
        num: '01',
        title: 'Ala Fija',
        desc: 'Metro Series · Vuelos ejecutivos',
        href: '/flota#ala-fija',
      },
      {
        num: '02',
        title: 'Ala Rotatoria',
        desc: 'MD Series · Plataformas y zonas remotas',
        href: '/flota#ala-rotatoria',
      },
      {
        num: '03',
        title: 'Aeromédico',
        desc: 'Traslados críticos nacionales e internacionales',
        href: '/servicios#aeromedico',
      },
      {
        num: '04',
        title: 'Transporte de Carga',
        desc: 'Logística aérea especializada',
        href: '/servicios',
      },
    ],
    contact: {
      phone:   '+58 212 959-6385',
      email:   'info@helitec.com',
      address: 'CCCT, Chuao — Caracas, Venezuela',
    },
    legal: 'Operador certificado INAC',
  },
  en: {
    langSwitch:  'ES',
    langHref:    '/',
    ctaLabel:    'Request Service',
    ctaHref:     '/en/contact',
    menuOpen:    'Menu',
    menuClose:   'Close',
    logoAlt:     'Consorcio Helitec — Home',
    nav: [
      { label: 'About',           href: '/en/about'          },
      { label: 'Safety & Quality', href: '/en/safety-quality' },
      { label: 'Fleet',           href: '/en/fleet'          },
      { label: 'Gallery',         href: '/en/gallery'        },
      { label: 'Contact',         href: '/en/contact'        },
    ],
    services: [
      {
        num: '01',
        title: 'Fixed Wing',
        desc: 'Metro Series · Executive flights',
        href: '/en/fleet#fixed-wing',
      },
      {
        num: '02',
        title: 'Rotary Wing',
        desc: 'MD Series · Platforms & remote areas',
        href: '/en/fleet#rotary-wing',
      },
      {
        num: '03',
        title: 'Aeromedical',
        desc: 'Critical national & international transfers',
        href: '/en/services#aeromedical',
      },
      {
        num: '04',
        title: 'Air Cargo',
        desc: 'Specialized air logistics',
        href: '/en/services',
      },
    ],
    contact: {
      phone:   '+58 212 959-6385',
      email:   'info@helitec.com',
      address: 'CCCT, Chuao — Caracas, Venezuela',
    },
    legal: 'INAC certified operator',
  },
}[lang];
---

<!-- ─────────────────────────────────────────────────────────
     HEADER — Navbar fija
───────────────────────────────────────────────────────────── -->
<header class="site-header" id="site-header" role="banner">
  <div class="header-inner">

    <!-- Logo -->
    <a href={lang === 'es' ? '/' : '/en/'} class="header-logo" aria-label={i18n.logoAlt}>
      <img
        src="/assets/Logo-Helitec-horiz-no-bkg-1-blanco.png"
        alt="Consorcio Helitec"
        class="header-logo__img"
        width="160"
        height="32"
        loading="eager"
        decoding="sync"
      />
    </a>

    <!-- Acciones del header -->
    <div class="header-actions">

      <!-- Selector de idioma -->
      <a href={i18n.langHref} class="lang-toggle" aria-label={`Switch to ${i18n.langSwitch}`}>
        <span class="lang-toggle__current">{lang.toUpperCase()}</span>
        <span class="lang-toggle__divider" aria-hidden="true">/</span>
        <span class="lang-toggle__other">{i18n.langSwitch}</span>
      </a>

      <!-- CTA principal — visible solo en desktop -->
      <a href={i18n.ctaHref} class="header-cta btn btn--ghost btn--sm">
        {i18n.ctaLabel}
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M1 11L11 1M11 1H4M11 1V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <!-- Botón de menú hamburguesa -->
      <button
        class="menu-toggle"
        id="menu-toggle"
        aria-controls="menu-overlay"
        aria-expanded="false"
        aria-label={i18n.menuOpen}
      >
        <span class="menu-toggle__label menu-toggle__label--open"  aria-hidden="true">{i18n.menuOpen}</span>
        <span class="menu-toggle__label menu-toggle__label--close" aria-hidden="true">{i18n.menuClose}</span>
        <span class="menu-toggle__icon" aria-hidden="true">
          <span class="menu-toggle__bar"></span>
          <span class="menu-toggle__bar"></span>
          <span class="menu-toggle__bar"></span>
        </span>
      </button>

    </div>
  </div>
</header>


<!-- ─────────────────────────────────────────────────────────
     MENÚ OVERLAY — fullscreen, estilo Konpo Studio
     Animación: translateY(-100%) → translateY(0) con ease-out spring
───────────────────────────────────────────────────────────── -->
<div
  class="menu-overlay"
  id="menu-overlay"
  role="dialog"
  aria-modal="true"
  aria-label={i18n.menuOpen}
  aria-hidden="true"
>
  <!-- Cabecera del overlay: logo + botón cerrar -->
  <div class="menu-overlay__head">
    <a href={lang === 'es' ? '/' : '/en/'} class="header-logo header-logo--overlay" tabindex="-1">
      <img
        src="/assets/Logo-Helitec-horiz-no-bkg-1-blanco.png"
        alt="Consorcio Helitec"
        class="header-logo__img"
        width="160"
        height="32"
        loading="eager"
        decoding="sync"
      />
    </a>
    <button
      class="menu-close"
      id="menu-close"
      aria-label={i18n.menuClose}
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M1 1L19 19M19 1L1 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Cuerpo del overlay: nav principal + servicios -->
  <div class="menu-overlay__body">

    <!-- Navegación principal — links grandes -->
    <nav class="menu-nav" aria-label="Navegación principal">
      <ul class="menu-nav__list" role="list">
        {i18n.nav.map((item, i) => (
          <li class="menu-nav__item" style={`--item-index: ${i}`}>
            <a
              href={item.href}
              class={`menu-nav__link ${currentPath === item.href ? 'is-active' : ''}`}
              tabindex="-1"
            >
              <span class="menu-nav__num" aria-hidden="true">0{i + 1}</span>
              <span class="menu-nav__label">{item.label}</span>
              <svg class="menu-nav__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 16L16 4M16 4H8M16 4V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Panel de servicios — recuadros oscuros -->
    <div class="menu-services">
      <p class="menu-services__label text-overline" aria-hidden="true">Servicios</p>
      <div class="menu-services__grid">
        {i18n.services.map((svc, i) => (
          <a
            href={svc.href}
            class="menu-svc-box"
            style={`--svc-index: ${i}`}
            tabindex="-1"
          >
            <span class="menu-svc-box__num" aria-hidden="true">{svc.num}</span>
            <span class="menu-svc-box__title">{svc.title}</span>
            <span class="menu-svc-box__desc">{svc.desc}</span>
            <svg class="menu-svc-box__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 12L12 2M12 2H6M12 2V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        ))}
      </div>
    </div>

  </div>

  <!-- Pie del overlay: contacto + legal -->
  <div class="menu-overlay__foot">
    <div class="menu-foot-contact">
      <a href={`tel:${i18n.contact.phone.replace(/\s|-/g, '')}`} class="menu-foot-contact__item">
        {i18n.contact.phone}
      </a>
      <a href={`mailto:${i18n.contact.email}`} class="menu-foot-contact__item">
        {i18n.contact.email}
      </a>
      <span class="menu-foot-contact__item menu-foot-contact__item--muted">
        {i18n.contact.address}
      </span>
    </div>
    <div class="menu-foot-social">
      <!-- Instagram -->
      <a href="#" class="menu-foot-social__link" aria-label="Instagram" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
      </a>
      <!-- LinkedIn -->
      <a href="#" class="menu-foot-social__link" aria-label="LinkedIn" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
        </svg>
      </a>
    </div>
    <p class="menu-foot-legal">{i18n.legal} · SMS OACI Anexo 19</p>
  </div>

</div>

<!-- Backdrop para cerrar el menú al clickear fuera (mobile) -->
<div class="menu-backdrop" id="menu-backdrop" aria-hidden="true"></div>


<!-- ─────────────────────────────────────────────────────────
     ESTILOS SCOPED DEL COMPONENTE
───────────────────────────────────────────────────────────── -->
<style>

  /* ── HEADER BASE ────────────────────────────────────────── */

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-sticky);
    height: 72px;
    background: transparent;
    transition:
      background  400ms var(--ease-standard),
      border-color 400ms var(--ease-standard),
      box-shadow   400ms var(--ease-standard);
    border-bottom: 1px solid transparent;
  }

  /* Efecto glassmorphism al hacer scroll */
  :global(body.header-scrolled) .site-header {
    background:   rgba(6, 14, 28, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: var(--color-border-subtle);
    box-shadow: 0 1px 24px rgba(0, 0, 0, 0.30);
  }

  /* Cuando el menú está abierto: header sólido para no competir */
  :global(body.menu-open) .site-header {
    background: var(--color-bg-void);
    backdrop-filter: none;
    border-bottom-color: var(--color-border-subtle);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: var(--container-xl);
    margin-inline: auto;
    padding-inline: var(--container-px);
  }


  /* ── LOGO ───────────────────────────────────────────────── */

  .header-logo {
    display: inline-flex;
    align-items: center;
    gap: 0;
    text-decoration: none;
    flex-shrink: 0;
  }

  .header-logo__img {
    height: 30px;
    width: auto;
    display: block;
    /* Garantiza que se vea nítido en pantallas de alta densidad */
    image-rendering: -webkit-optimize-contrast;
  }

  @media (max-width: 480px) {
    .header-logo__img { height: 26px; }
  }


  /* ── ACCIONES DEL HEADER ─────────────────────────────────── */

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }


  /* ── SELECTOR DE IDIOMA ──────────────────────────────────── */

  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-primary);
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-widest);
    text-decoration: none;
    color: var(--color-text-muted);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .lang-toggle:hover {
    color: var(--color-text-primary);
    background: rgba(255,255,255,0.05);
  }

  .lang-toggle__current { color: var(--color-text-primary); }
  .lang-toggle__divider { color: var(--color-border-medium); }
  .lang-toggle__other   { color: var(--color-text-muted); }


  /* ── CTA HEADER — solo desktop ────────────────────────────── */

  .header-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-5);
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-medium);
    border-radius: var(--radius-sm);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .header-cta:hover {
    background: rgba(255,255,255,0.06);
    border-color: var(--color-border-strong);
  }

  @media (max-width: 640px) {
    .header-cta { display: none; }
  }


  /* ── BOTÓN HAMBURGUESA ───────────────────────────────────── */

  .menu-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: none;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
    cursor: pointer;
    color: var(--color-text-primary);
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }

  .menu-toggle:hover {
    border-color: var(--color-border-medium);
    background: rgba(255,255,255,0.04);
  }

  .menu-toggle__label {
    font-family: var(--font-primary);
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    line-height: 1;
    transition: opacity var(--duration-fast) var(--ease-standard);
  }

  .menu-toggle__label--close {
    display: none;
    position: absolute;
    opacity: 0;
  }

  :global(body.menu-open) .menu-toggle__label--open  { display: none; opacity: 0; }
  :global(body.menu-open) .menu-toggle__label--close { display: inline; opacity: 1; position: static; }

  .menu-toggle__icon {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 20px;
    height: 14px;
    flex-shrink: 0;
  }

  .menu-toggle__bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background: currentColor;
    border-radius: var(--radius-full);
    transform-origin: center;
    transition:
      transform var(--duration-base) var(--ease-in-out),
      opacity   var(--duration-base) var(--ease-standard),
      width     var(--duration-base) var(--ease-standard);
  }

  /* Animación hamburguesa → X */
  :global(body.menu-open) .menu-toggle__bar:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }
  :global(body.menu-open) .menu-toggle__bar:nth-child(2) {
    opacity: 0;
    width: 0;
  }
  :global(body.menu-open) .menu-toggle__bar:nth-child(3) {
    transform: translateY(-5.5px) rotate(-45deg);
  }


  /* ── MENÚ OVERLAY ────────────────────────────────────────── */

  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    background: var(--color-bg-void);
    display: grid;
    grid-template-rows: 72px 1fr auto;
    padding-inline: var(--container-px);

    /* Estado cerrado — sube fuera de pantalla */
    transform: translateY(-100%);
    visibility: hidden;
    transition:
      transform 700ms var(--ease-out),
      visibility 700ms step-end;

    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .menu-overlay.is-open {
    transform: translateY(0);
    visibility: visible;
    transition:
      transform 700ms var(--ease-out),
      visibility 1ms step-start;
  }

  /* Backdrop semitransparente (debajo del overlay, encima del header) */
  .menu-backdrop {
    display: none;
  }


  /* ── CABECERA DEL OVERLAY ─────────────────────────────────── */

  .menu-overlay__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    border-bottom: 1px solid var(--color-border-subtle);
    flex-shrink: 0;
  }

  .menu-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: none;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    cursor: pointer;
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .menu-close:hover {
    color: var(--color-text-primary);
    border-color: var(--color-border-medium);
    background: rgba(255,255,255,0.05);
  }


  /* ── CUERPO DEL OVERLAY ──────────────────────────────────── */

  .menu-overlay__body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
    padding-block: var(--space-16);
    max-width: var(--container-xl);
    margin-inline: auto;
    width: 100%;
  }

  @media (max-width: 900px) {
    .menu-overlay__body {
      grid-template-columns: 1fr;
      gap: var(--space-12);
      padding-block: var(--space-10);
    }
  }


  /* ── NAV LINKS PRINCIPALES ───────────────────────────────── */

  .menu-nav__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .menu-nav__item {
    border-bottom: 1px solid var(--color-border-subtle);

    /* Estado inicial: oculto hacia abajo */
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity    500ms var(--ease-out),
      transform  500ms var(--ease-out);

    /* Stagger calculado desde --item-index */
    transition-delay: calc(200ms + var(--item-index, 0) * 60ms);
  }

  .menu-overlay.is-open .menu-nav__item {
    opacity: 1;
    transform: translateY(0);
  }

  /* Al cerrar: sin stagger, todos desaparecen juntos rápido */
  .menu-overlay:not(.is-open) .menu-nav__item {
    transition-delay: 0ms;
    transition-duration: 200ms;
  }

  .menu-nav__link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-6);
    text-decoration: none;
    color: var(--color-text-secondary);
    transition: color var(--transition-fast), gap var(--transition-base);
    overflow: hidden;
  }

  .menu-nav__link:hover,
  .menu-nav__link.is-active {
    color: var(--color-text-primary);
    gap: var(--space-6);
  }

  .menu-nav__link.is-active {
    color: var(--brand-azul-cielo);
  }

  .menu-nav__num {
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
    color: var(--color-text-faint);
    letter-spacing: var(--tracking-wider);
    font-variant-numeric: tabular-nums;
    transition: color var(--transition-fast);
    flex-shrink: 0;
  }

  .menu-nav__link:hover .menu-nav__num {
    color: var(--color-text-muted);
  }

  .menu-nav__label {
    font-family: var(--font-primary);
    font-size: clamp(var(--text-xl), 3.5vw, var(--text-3xl));
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    flex: 1;
  }

  .menu-nav__arrow {
    color: var(--color-text-faint);
    flex-shrink: 0;
    transform: translateX(-8px);
    opacity: 0;
    transition:
      transform var(--transition-base),
      opacity   var(--transition-base),
      color     var(--transition-fast);
  }

  .menu-nav__link:hover .menu-nav__arrow {
    color: var(--brand-azul-cielo);
    transform: translateX(0);
    opacity: 1;
  }


  /* ── PANEL DE SERVICIOS ──────────────────────────────────── */

  .menu-services {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .menu-services__label {
    /* .text-overline de global.css — solo ajuste de color */
    color: var(--color-text-faint);
    margin-bottom: var(--space-2);

    /* Animación */
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 400ms var(--ease-out) 350ms, transform 400ms var(--ease-out) 350ms;
  }

  .menu-overlay.is-open .menu-services__label {
    opacity: 1;
    transform: translateY(0);
  }

  .menu-overlay:not(.is-open) .menu-services__label {
    transition-delay: 0ms;
    transition-duration: 200ms;
  }

  .menu-services__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }

  @media (max-width: 480px) {
    .menu-services__grid {
      grid-template-columns: 1fr;
    }
  }


  /* ── CAJA DE SERVICIO EN MENÚ ─────────────────────────────── */

  .menu-svc-box {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition:
      background    var(--transition-base),
