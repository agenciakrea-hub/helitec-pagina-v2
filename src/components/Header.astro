<!-- ─────────────────────────────────────────────────────────
     SCRIPT — Toggle menú + glassmorphism en scroll
───────────────────────────────────────────────────────────── -->
<script>
  (() => {
    const overlay  = document.getElementById('menu-overlay');
    const toggle   = document.getElementById('menu-toggle');
    const closeBtn = document.getElementById('menu-close');
    if (!overlay || !toggle || !closeBtn) return;

    const body = document.body;

    /* ── Helpers ─────────────────────────────────────────── */

    function openMenu() {
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      body.classList.add('menu-open');
      // Restaurar tabindex en todos los interactivos del overlay
      overlay.querySelectorAll<HTMLElement>('a, button').forEach(el =>
        el.removeAttribute('tabindex')
      );
      closeBtn.focus();
    }

    function closeMenu() {
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      body.classList.remove('menu-open');
      // Deshabilitar tabindex: evita focus en elementos invisibles
      overlay.querySelectorAll<HTMLElement>('a, button').forEach(el =>
        el.setAttribute('tabindex', '-1')
      );
      toggle.focus();
    }

    /* ── Eventos ─────────────────────────────────────────── */

    toggle.addEventListener('click', () =>
      overlay.classList.contains('is-open') ? closeMenu() : openMenu()
    );

    closeBtn.addEventListener('click', closeMenu);

    // Cerrar con Escape
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeMenu();
    });

    // Cerrar al navegar
    overlay.querySelectorAll('a').forEach(link =>
      link.addEventListener('click', closeMenu)
    );

    /* ── Glassmorphism en scroll (rAF throttled) ─────────── */

    let ticking = false;

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          body.classList.toggle('header-scrolled', window.scrollY > 40);
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });

    // Estado inicial si la página ya está scrolleada al cargar
    if (window.scrollY > 40) body.classList.add('header-scrolled');
  })();
</script>
