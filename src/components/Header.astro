<!-- ─────────────────────────────────────────────────────────
     SCRIPT — Toggle menú + glassmorphism en scroll
     Vanilla JS mínimo: ~45 líneas
───────────────────────────────────────────────────────────── -->
<script>
  (() => {
    const header   = document.getElementById('site-header')!;
    const overlay  = document.getElementById('menu-overlay')!;
    const toggle   = document.getElementById('menu-toggle')!;
    const closeBtn = document.getElementById('menu-close')!;
    const body     = document.body;

    /* ── Abrir/cerrar menú ──────────────────────────────── */

    function openMenu() {
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      body.classList.add('menu-open');

      /* Activar tabindex en links del overlay */
      overlay.querySelectorAll('a, button').forEach(el =>
        el.removeAttribute('tabindex')
      );
      closeBtn.focus();
    }

    function closeMenu() {
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      body.classList.remove('menu-open');

      /* Desactivar tabindex: evita focus en links invisibles */
      overlay.querySelectorAll('a, button').forEach(el =>
        el.setAttribute('tabindex', '-1')
      );
      toggle.focus();
    }

    toggle.addEventListener('click', () => {
      overlay.classList.contains('is-open') ? closeMenu() : openMenu();
    });

    closeBtn.addEventListener('click', closeMenu);

    /* Cerrar con ESC */
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeMenu();
    });

    /* Cerrar al navegar a otro link del overlay */
    overlay.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    /* ── Glassmorphism en scroll ─────────────────────────── */

    let ticking = false;

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          body.classList.toggle('header-scrolled', window.scrollY > 40);
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });

    /* Estado inicial si la página ya está scrolleada */
    if (window.scrollY > 40) body.classList.add('header-scrolled');
  })();
</script>
