---
/**
 * ServicesSection.astro  v3 — Grid 2×2 + Parallax Licorn-style
 * Consorcio Helitec
 *
 * Reemplaza el sticky scroll-stack por una grilla estática 2×2.
 * Efecto visual: imagen dentro de cada tarjeta se desplaza a velocidad
 * diferente al marco (parallax de ventana, idéntico al de "Nos réalisations"
 * en licornpublishing.com).
 *
 * Arquitectura:
 *   .sgrid__frame  → overflow: hidden, ventana fija
 *   .sgrid__photo  → height: 130%, top: -15%, will-change: transform
 *   JS rAF driver  → translateY basado en posición del frame vs viewport
 *
 * STRENGTH = 0.20 → máx desplazamiento ≈ 30px (< 45px de margen) → sin clipping.
 *
 * Anti-slop:
 *   PROHIBIDO box-shadow      ✓
 *   PROHIBIDO linear-gradient ✓  (solo overlay rgba sobre foto)
 *   border-radius ≤ 4px       ✓
 *   object-fit: cover         ✓
 *   H3 font-weight: 200       ✓
 */

interface Props { lang?: 'es' | 'en'; }
const { lang = 'es' } = Astro.props;

const services = [
  {
    num:   '01',
    title: lang === 'es' ? 'Aviación Ejecutiva'          : 'Executive Aviation',
    desc:  lang === 'es'
      ? 'Flota Metro y Merlin de ala fija para transporte corporativo de alta eficiencia. Conexión directa entre Caracas, el interior y el Caribe.'
      : 'Fixed-wing Metro and Merlin fleet for high-efficiency corporate transport. Direct connections between Caracas, interior, and the Caribbean.',
    cta:       lang === 'es' ? 'Solicitar vuelo ejecutivo'  : 'Request executive flight',
    href:      '/#contacto',
    img:       '/assets/IMG_0968.jpg',
    alt:       lang === 'es' ? 'Cabina ejecutiva Consorcio Helitec — asientos de cuero premium' : 'Helitec executive cabin — premium leather seating',
  },
  {
    num:   '02',
    title: lang === 'es' ? 'Operaciones Petroleras'       : 'Petroleum Operations',
    desc:  lang === 'es'
      ? 'Helicópteros MD con disponibilidad 24/7 para soporte aéreo en plataformas marítimas e instalaciones del sector energético.'
      : 'MD helicopters with 24/7 availability for aerial support on offshore platforms and onshore energy sector facilities.',
    cta:       lang === 'es' ? 'Consultar operaciones'      : 'Inquire about operations',
    href:      '/#contacto',
    img:       '/assets/opepetroleras.png',
    alt:       lang === 'es' ? 'Helicóptero Helitec en operación petrolera' : 'Helitec helicopter on petroleum operations',
  },
  {
    num:   '03',
    title: lang === 'es' ? 'Traslados Aeromédicos'        : 'Aeromedical Transfers',
    desc:  lang === 'es'
      ? 'Metro III con configuración aeromédica certificada y camilla Spectrum Aeromed. Coordinación inmediata con ambulancias en tierra. Respuesta 24/7.'
      : 'Metro III with certified aeromedical configuration and Spectrum Aeromed stretcher. Immediate coordination with ground ambulances. 24/7 response.',
    cta:       lang === 'es' ? 'Activar emergencia médica'  : 'Activate medical emergency',
    href:      'https://wa.me/584166235254?text=EMERGENCIA+AEROM%C3%89DICA',
    img:       encodeURI('/assets/Avion y Ambulancia1.jpg'),
    alt:       lang === 'es' ? 'Metro III Helitec junto a ambulancia — servicio aeromédico' : 'Helitec Metro III alongside ambulance — aeromedical service',
    isExternal: true,
  },
  {
    num:   '04',
    title: lang === 'es' ? 'Operaciones de Carga y Eslinga' : 'Cargo & Sling Operations',
    desc:  lang === 'es'
      ? 'Helicópteros MD equipados para carga externa con eslinga certificada. Transporte de equipos industriales a zonas de difícil acceso. Hasta 650 kg externos.'
      : 'MD helicopters equipped for external sling load operations. Industrial equipment transport to hard-to-reach zones. Up to 650 kg external capacity.',
    cta:       lang === 'es' ? 'Consultar operaciones de carga' : 'Inquire about cargo ops',
    href:      '/#contacto',
    img:       encodeURI('/assets/Helicoptero Eslinga 2.jpg'),
    alt:       lang === 'es' ? 'Helicóptero MD Helitec con eslinga de carga externa sobre vegetación' : 'Helitec MD helicopter with external sling load over vegetation',
  },
];
---


<section
  class="sgrid"
  id="servicios"
  aria-labelledby="sgrid-heading"
>

  <!-- ── Header de sección ──────────────────────────────────────────────── -->
  <div class="sgrid__header">
    <span class="sgrid__tag" aria-hidden="true">
      {lang === 'es' ? '— Servicios' : '— Services'}
    </span>
    <h2 class="sgrid__heading" id="sgrid-heading">
      {lang === 'es'
        ? 'Soluciones aéreas\npara cada misión'
        : 'Aerial solutions\nfor every mission'}
    </h2>
  </div>


  <!-- ── Grid 2 × 2 ──────────────────────────────────────────────────────── -->
  <div class="sgrid__grid">

    {services.map((svc, i) => (
      <article class="sgrid__card" style={`--i:${i}`} aria-label={svc.title}>

        <!--
          Frame de imagen: actúa como ventana fija (overflow: hidden).
          La imagen (.sgrid__photo) tiene height: 130% y se desplaza
          verticalmente mediante JS para crear el efecto parallax.
        -->
        <a
          href={svc.href}
          class="sgrid__frame"
          tabindex="-1"
          aria-hidden="true"
          {...(svc.isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          <img
            class="sgrid__photo"
            src={svc.img}
            alt={svc.alt}
            loading={i < 2 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </a>

        <!-- Cuerpo de texto -->
        <div class="sgrid__body">

          <div class="sgrid__body-top">
            <span class="sgrid__num">{svc.num}</span>
            <h3 class="sgrid__title">{svc.title}</h3>
            <p class="sgrid__desc">{svc.desc}</p>
          </div>

          <a
            href={svc.href}
            class="sgrid__cta"
            {...(svc.isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <span>{svc.cta}</span>
            <svg
              width="16" height="16" viewBox="0 0 16 16"
              fill="none" xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M3 8h10M9 4l4 4-4 4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="square"
              />
            </svg>
          </a>

        </div>

      </article>
    ))}

  </div>

</section>


<style>
  /* ── Sección contenedora ───────────────────────────────────────────────── */

  .sgrid {
    background-color: var(--c-bg);
  }


  /* ── Header ────────────────────────────────────────────────────────────── */

  .sgrid__header {
    display:         flex;
    flex-direction:  column;
    gap:             var(--sp-2);

    padding-top:     var(--sp-14);
    padding-bottom:  var(--sp-8);
    padding-inline:  var(--gutter);
    padding-left:    calc(var(--sidebar-w) + var(--gutter));

    border-bottom:   1px solid var(--c-line);
  }

  .sgrid__tag {
    font-family:    var(--font-sans);
    font-size:      0.72rem;
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-3);
  }

  .sgrid__heading {
    font-family:    var(--font-display);
    font-size:      var(--text-3xl);
    font-weight:    var(--fw-thin);      /* 200 — ANTI-SLOP */
    letter-spacing: var(--ls-wide);
    color:          var(--c-text-1);
    line-height:    1.05;
    white-space:    pre-line;            /* Respeta \n en el texto Astro */
  }


  /* ── Grid 2×2 ───────────────────────────────────────────────────────────── */

  .sgrid__grid {
    display:                grid;
    grid-template-columns:  1fr 1fr;

    /*
     * Separadores de 1px entre celdas: el gap expone el background-color
     * del grid (= --c-line) como líneas entre tarjetas.
     * Más limpio que borders por celda.
     */
    gap:              1px;
    background-color: var(--c-line);
  }


  /* ── Tarjeta ────────────────────────────────────────────────────────────── */

  .sgrid__card {
    background-color: var(--c-bg);
    display:          flex;
    flex-direction:   column;
  }


  /* ── Frame de imagen: la "ventana" con overflow hidden ──────────────────── */

  .sgrid__frame {
    /*
     * Ventana de visualización: tamaño fijo, overflow hidden.
     * La imagen (.sgrid__photo) es más alta que este frame;
     * el JS la desplaza verticalmente dentro sin salirse.
     */
    position:         relative;
    overflow:         hidden;
    display:          block;   /* <a> necesita block para ocupar espacio */

    height:           clamp(200px, 36vh, 400px);
    background-color: #09090f;  /* Placeholder mientras carga la imagen */
  }


  /* ── Imagen con parallax ─────────────────────────────────────────────────── */

  .sgrid__photo {
    /*
     * Imagen con exceso de altura para margen de desplazamiento:
     *   height: 130% → excedente = 30% del frame en cada lado = ~15% arriba/abajo
     *   top: -15%    → centra la imagen inicialmente dentro del frame
     *
     * JS calcula offset = progress × STRENGTH × frameHeight
     * Con STRENGTH=0.20 y frame=300px → maxOffset ≈ 30px < 45px de margen → sin clipping.
     */
    position:         absolute;
    left:             0;
    top:              -25%;
    width:            100%;
    height:           150%;   /* 150%: margen de 25% en cada lado para STRENGTH=0.40 */

    object-fit:       cover;    /* ANTI-SLOP OBLIGATORIO */
    object-position:  center;

    will-change:      transform;    /* Hint GPU: compositor layer */
    /* Sin transition CSS — rAF en JS controla el movimiento */
  }


  /* ── Cuerpo de texto ─────────────────────────────────────────────────────── */

  .sgrid__body {
    padding:        var(--sp-5) var(--sp-6) var(--sp-7);
    display:        flex;
    flex-direction: column;
    gap:            var(--sp-4);
    flex:           1;          /* Hace que todas las cards tengan igual altura en la fila */
  }

  .sgrid__body-top {
    display:        flex;
    flex-direction: column;
    gap:            var(--sp-2);
    flex:           1;
  }

  .sgrid__num {
    font-family:    var(--font-sans);
    font-size:      0.68rem;
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-sky);
  }

  .sgrid__title {
    font-family:    var(--font-display);
    font-size:      var(--text-xl);
    font-weight:    var(--fw-thin);   /* 200 — ANTI-SLOP */
    letter-spacing: var(--ls-wide);
    color:          var(--c-text-1);
    line-height:    1.1;
  }

  .sgrid__desc {
    font-family: var(--font-sans);
    font-size:   var(--text-sm);
    color:       var(--c-text-3);
    line-height: 1.65;
    flex:        1;
  }


  /* ── CTA — Ghost button ──────────────────────────────────────────────────── */

  .sgrid__cta {
    display:     inline-flex;
    align-items: center;
    gap:         var(--sp-2);

    padding:         9px var(--sp-4);
    border:          1px solid rgba(255, 255, 255, 0.22);
    border-radius:   var(--r-micro);   /* 4px — límite absoluto anti-slop */

    font-family:    var(--font-sans);
    font-size:      0.68rem;
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-2);

    align-self: flex-start;

    transition:
      border-color var(--dur-fast) var(--ease-out),
      color        var(--dur-fast) var(--ease-out);
  }

  .sgrid__cta:hover {
    border-color: var(--c-sky);
    color:        var(--c-sky);
    opacity:      1;
  }

  .sgrid__cta svg {
    opacity:    0.55;
    flex-shrink: 0;
    transition: transform var(--dur-fast) var(--ease-out),
                opacity   var(--dur-fast) var(--ease-out);
  }

  .sgrid__cta:hover svg {
    transform: translateX(4px);
    opacity:   1;
  }


  /* ── Responsive ──────────────────────────────────────────────────────────── */

  @media (max-width: 767px) {
    .sgrid__header {
      padding-left: var(--gutter);
    }

    .sgrid__heading {
      font-size: var(--text-2xl);
    }

    /* Grid 2×2 conservado en móvil — celdas más compactas */
    .sgrid__frame {
      height: clamp(130px, 32vw, 200px);
    }
  }

  @media (max-width: 479px) {
    .sgrid__header {
      padding-block: var(--sp-10) var(--sp-5);
    }

    .sgrid__frame {
      height: clamp(180px, 58vw, 260px);
    }

    .sgrid__body {
      padding: var(--sp-4) var(--sp-4) var(--sp-5);
    }
  }
</style>


<script>
(function () {
  'use strict';

  /*
   * ServicesSection v3 — Parallax de imágenes (Licorn-style)
   *
   * Efecto: la imagen (.sgrid__photo) se desplaza verticalmente a una fracción
   * de la velocidad del scroll relativa al frame (.sgrid__frame).
   * Resultado: ilusión de profundidad — la imagen "flota" detrás de la ventana.
   *
   * STRENGTH = 0.20:
   *   progress = (frameCenterY - viewportCenterY) / viewportHeight → [-0.5, +0.5]
   *   offset   = progress × STRENGTH × frameHeight
   *   Con frame 300px → maxOffset ≈ 30px < 45px margen → nunca se clipea.
   *
   * Performance:
   *   · requestAnimationFrame: max 1 frame en cola (flag ticking)
   *   · passive scroll listener: nunca bloquea el scroll del browser
   *   · will-change: transform en CSS: compositor layer en GPU
   *   · Skip frames fuera del viewport: ahorra cálculos innecesarios
   */

  var STRENGTH = 0.40;
  var frames   = Array.from(document.querySelectorAll('.sgrid__frame'));
  var ticking  = false;

  function clamp(v, lo, hi) {
    return v < lo ? lo : v > hi ? hi : v;
  }

  function updateParallax() {
    var vh = window.innerHeight;

    frames.forEach(function (frame) {
      var img = frame.querySelector('.sgrid__photo');
      if (!img) return;

      var rect = frame.getBoundingClientRect();

      /* Saltar frames completamente fuera del viewport */
      if (rect.bottom < -120 || rect.top > vh + 120) return;

      /*
       * progress: posición relativa del centro del frame vs centro del viewport.
       *   +0.5 → frame justo entrando por abajo (imagen muestra su parte superior)
       *    0   → frame centrado (imagen centrada)
       *   -0.5 → frame justo saliendo por arriba (imagen muestra su parte inferior)
       */
      var frameCenter = rect.top + rect.height * 0.5;
      var progress    = (frameCenter - vh * 0.5) / vh;
      progress        = clamp(progress, -0.5, 0.5);

      var offset = progress * STRENGTH * rect.height;
      img.style.transform = 'translateY(' + offset.toFixed(2) + 'px)';
    });

    ticking = false;
  }

  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(updateParallax);
      ticking = true;
    }
  }

  /* Calcular posición inicial antes del primer scroll */
  updateParallax();

  window.addEventListener('scroll', onScroll, { passive: true });

  /* Re-calcular al cambiar el tamaño de la ventana o rotar el dispositivo */
  if (typeof ResizeObserver !== 'undefined') {
    new ResizeObserver(function () { updateParallax(); })
      .observe(document.documentElement);
  }
})();
</script>
