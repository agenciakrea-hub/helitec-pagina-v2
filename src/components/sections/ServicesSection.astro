---
/**
 * ServicesSection.astro  v4 — Grid 2×2, texto superpuesto sobre foto
 * Consorcio Helitec
 *
 * v4 vs v3:
 *   · Texto ahora flota sobre la fotografía (overlay) — como "Nos réalisations"
 *     en licornpublishing.com.
 *   · Elimina el .sgrid__body separado bajo la imagen.
 *   · Gradiente oscuro inferior para legibilidad (anti-slop compliant).
 *   · Acentos azul Helitec: tag "— Servicios", número de servicio, flecha CTA,
 *     y la palabra "misión" en el titular.
 *   · Flecha CTA animada: deslizamiento horizontal en hover.
 *   · Parallax JS idéntico a v3 (usa .sgrid__frame y .sgrid__photo).
 *
 * ANTI-SLOP compliance:
 *   PROHIBIDO box-shadow            ✓
 *   linear-gradient SOLO como overlay sobre foto para legibilidad del texto ✓
 *   border-radius ≤ 4px             ✓
 *   object-fit: cover               ✓
 *   H3 font-weight: 200             ✓
 */

interface Props { lang?: 'es' | 'en'; }
const { lang = 'es' } = Astro.props;

const services = [
  {
    num:   '01',
    title: lang === 'es' ? 'Aviación Ejecutiva'            : 'Executive Aviation',
    desc:  lang === 'es'
      ? 'Flota Metro y Merlin de ala fija para transporte corporativo de alta eficiencia. Conexión directa entre Caracas, el interior y el Caribe.'
      : 'Fixed-wing Metro and Merlin fleet for high-efficiency corporate transport. Direct connections between Caracas, interior, and the Caribbean.',
    cta:       lang === 'es' ? 'Solicitar vuelo ejecutivo'     : 'Request executive flight',
    href:      '/#contacto',
    img:       '/assets/IMG_0968.jpg',
    alt:       lang === 'es'
      ? 'Cabina ejecutiva Consorcio Helitec — asientos de cuero premium'
      : 'Helitec executive cabin — premium leather seating',
    /*
     * Menos zoom: scale reduce el tamaño visible de la imagen dentro del frame
     * sin afectar el translateY del parallax (usa la propiedad CSS `scale`,
     * independiente de `transform` — Transforms Level 2).
     * object-position: center 35% — se ve el techo de la cabina y los asientos.
     */
    imgStyle: 'object-position: center 35%; scale: 0.86',
  },
  {
    num:   '02',
    title: lang === 'es' ? 'Operaciones Petroleras'          : 'Petroleum Operations',
    desc:  lang === 'es'
      ? 'Helicópteros MD con disponibilidad 24/7 para soporte aéreo en plataformas marítimas e instalaciones del sector energético.'
      : 'MD helicopters with 24/7 availability for aerial support on offshore platforms and onshore energy sector facilities.',
    cta:       lang === 'es' ? 'Consultar operaciones'         : 'Inquire about operations',
    href:      '/#contacto',
    img:       '/assets/opepetroleras.png',
    alt:       lang === 'es'
      ? 'Helicóptero Helitec en operación petrolera'
      : 'Helitec helicopter on petroleum operations',
    /*
     * Foco hacia la izquierda: el helicóptero está en el lado derecho de la foto
     * pero se recorta. Moviendo object-position hacia 15% el sujeto entra en cuadro.
     */
    imgStyle: 'object-position: 15% center',
  },
  {
    num:   '03',
    title: lang === 'es' ? 'Traslados Aeromédicos'           : 'Aeromedical Transfers',
    desc:  lang === 'es'
      ? 'Metro III con configuración aeromédica certificada y camilla Spectrum Aeromed. Coordinación inmediata con ambulancias en tierra. Respuesta 24/7.'
      : 'Metro III with certified aeromedical configuration and Spectrum Aeromed stretcher. Immediate coordination with ground ambulances. 24/7 response.',
    cta:       lang === 'es' ? 'Activar emergencia médica'     : 'Activate medical emergency',
    href:      'https://wa.me/584166235254?text=EMERGENCIA+AEROM%C3%89DICA',
    img:       encodeURI('/assets/Avion y Ambulancia1.jpg'),
    alt:       lang === 'es'
      ? 'Metro III Helitec junto a ambulancia — servicio aeromédico'
      : 'Helitec Metro III alongside ambulance — aeromedical service',
    isExternal: true,
    /*
     * Reduce zoom para que entren en cuadro avión + ambulancia.
     * scale 0.82 = imagen encoge dentro del frame → más contexto visible.
     * object-position centrada verticalmente para no cortar ninguno de los dos.
     */
    imgStyle: 'object-position: center 55%; scale: 0.82',
  },
  {
    num:   '04',
    title: lang === 'es' ? 'Operaciones de Carga y Eslinga'  : 'Cargo & Sling Operations',
    desc:  lang === 'es'
      ? 'Helicópteros MD equipados para carga externa con eslinga certificada. Transporte de equipos industriales a zonas de difícil acceso. Hasta 650 kg externos.'
      : 'MD helicopters equipped for external sling load operations. Industrial equipment transport to hard-to-reach zones. Up to 650 kg external capacity.',
    cta:       lang === 'es' ? 'Consultar operaciones de carga': 'Inquire about cargo ops',
    href:      '/#contacto',
    img:       encodeURI('/assets/Helicoptero Eslinga 2.jpg'),
    alt:       lang === 'es'
      ? 'Helicóptero MD Helitec con eslinga de carga externa sobre vegetación'
      : 'Helitec MD helicopter with external sling load over vegetation',
    /* Sin ajuste — encuadre por defecto está bien */
  },
];
---


<section
  class="sgrid"
  id="servicios"
  aria-labelledby="sgrid-heading"
>

  <!-- ── Header de sección ──────────────────────────────────────────────── -->
  <div class="sgrid__header">
    <span class="sgrid__tag" aria-hidden="true">
      {lang === 'es' ? '— Servicios' : '— Services'}
    </span>
    <h2
      class="sgrid__heading"
      id="sgrid-heading"
      set:html={lang === 'es'
        ? 'Soluciones aéreas<br>para cada <em class="sgrid__accent">misión</em>'
        : 'Aerial solutions<br>for every <em class="sgrid__accent">mission</em>'}
    />
  </div>


  <!-- ── Grid 2 × 2 ──────────────────────────────────────────────────────── -->
  <div class="sgrid__grid">

    {services.map((svc, i) => (
      <article class="sgrid__card" style={`--i:${i}`}>

        <!--
          .sgrid__frame es el <a> y también el contenedor de toda la tarjeta:
          imagen de fondo + gradiente de legibilidad + texto superpuesto.
          El parallax JS controla translateY en .sgrid__photo.
        -->
        <a
          href={svc.href}
          class="sgrid__frame"
          {...(svc.isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >

          <!-- Imagen con parallax + encuadre per-card vía imgStyle inline -->
          <img
            class="sgrid__photo"
            src={svc.img}
            alt={svc.alt}
            style={svc.imgStyle ?? ''}
            loading={i < 2 ? 'eager' : 'lazy'}
            decoding="async"
          />

          <!--
            Gradiente oscuro inferior para legibilidad del texto.
            ANTI-SLOP COMPLIANT:
            · PROHIBIDO: linear-gradient como fondo decorativo.
            · PERMITIDO: overlay rgba oscuro sobre fotografía real
              "para mejorar la lectura" — regla explícita del proyecto.
          -->
          <div class="sgrid__veil" aria-hidden="true"></div>

          <!-- Texto superpuesto sobre la foto -->
          <div class="sgrid__info">
            <span class="sgrid__num">{svc.num}</span>
            <h3 class="sgrid__title">{svc.title}</h3>
            <!-- Recurso rojo — subrayado decorativo con reveal izq→der -->
            <img
              src="/assets/recurso%20rojo%20helitec.png"
              class="sgrid__title-deco"
              alt=""
              aria-hidden="true"
              loading="lazy"
              decoding="async"
            />
            <p class="sgrid__desc">{svc.desc}</p>
            <span class="sgrid__cta">
              <span class="sgrid__cta-label">{svc.cta}</span>
              <svg
                width="15" height="15" viewBox="0 0 16 16"
                fill="none" xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                class="sgrid__arrow"
              >
                <path
                  d="M3 8h10M9 4l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="square"
                />
              </svg>
            </span>
          </div>

        </a>
      </article>
    ))}

  </div>

</section>


<style>
  /* ── Sección ────────────────────────────────────────────────────────────── */

  .sgrid {
    background-color: var(--c-bg);
    padding-block:    clamp(48px, 7vh, 80px);
    padding-inline:   calc(var(--sidebar-w) + var(--gutter));
  }


  /* ── Header ────────────────────────────────────────────────────────────── */

  .sgrid__header {
    display:         flex;
    flex-direction:  column;
    gap:             var(--sp-2);

    padding-bottom:  var(--sp-8);

    border-bottom:   1px solid var(--c-line);
    margin-bottom:   clamp(20px, 3vh, 32px);
  }

  /*
   * Etiqueta "— Servicios" en azul Helitec.
   * Acento cromático sutil que introduce la paleta de las tarjetas.
   */
  .sgrid__tag {
    font-family:    var(--font-sans);
    font-size:      0.72rem;
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-sky);   /* Azul Helitec */
  }

  .sgrid__heading {
    font-family:    var(--font-display);
    font-size:      var(--text-3xl);
    font-weight:    var(--fw-thin);      /* 200 — ANTI-SLOP */
    letter-spacing: var(--ls-wide);
    color:          var(--c-text-1);
    line-height:    1.05;
  }

  /*
   * Palabra acento en el titular — "misión" / "mission".
   * Acento cromático minimalista: solo cambio de color, sin subrayado ni caja.
   * <em> se usa semánticamente; font-style: normal cancela la cursiva.
   */
  .sgrid__accent {
    font-style: normal;
    color:      var(--c-sky);
  }


  /* ── Grid 2×2 ───────────────────────────────────────────────────────────── */

  .sgrid__grid {
    display:               grid;
    grid-template-columns: 1fr 1fr;

    gap: clamp(12px, 1.5vw, 18px);
  }


  /* ── Tarjeta ────────────────────────────────────────────────────────────── */

  .sgrid__card {
    /* El .sgrid__frame ocupa toda la altura — sin background en el article */
  }


  /* ── Frame: link + contenedor completo de la tarjeta ─────────────────────── */

  .sgrid__frame {
    position:         relative;
    display:          block;
    overflow:         hidden;
    border-radius:    var(--r-micro);         /* 4px — ANTI-SLOP */
    border:           1px solid var(--c-line);

    /*
     * Altura completa de la tarjeta — incluye foto + texto superpuesto.
     * Más alta que v3 al no haber un body separado debajo.
     */
    height:           clamp(280px, 48vh, 520px);
    background-color: #09090f;     /* Placeholder mientras carga la imagen */

    /* Cancelar opacity:0.75 del reset en hover */
    opacity:     1;
    color:       var(--c-text-1);
    text-decoration: none;
  }

  .sgrid__frame:hover { opacity: 1; }


  /* ── Imagen con parallax ─────────────────────────────────────────────────── */

  .sgrid__photo {
    /*
     * height: 150%, top: -25% → margen de 25% por lado para STRENGTH=0.40.
     * maxOffset = 0.5 × 0.40 × frameH → < 25% × frameH → sin clipping.
     * El parallax JS aplica translateY; la CSS scale actúa por separado
     * (propiedad CSS `scale` es independiente de `transform`).
     */
    position:        absolute;
    left:            0;
    top:             -25%;
    width:           100%;
    height:          150%;

    object-fit:      cover;
    object-position: center;
    will-change:     transform;

    /*
     * CSS `scale` es una propiedad separada de `transform` (CSS Transforms L2).
     * El JS del parallax escribe `style.transform = 'translateY(Xpx)'`.
     * CSS controla `scale`; JS controla `transform` — sin interferencia.
     */
    scale:      1;
    transition: scale var(--dur-slow) var(--ease-out);
  }

  /* Zoom suave en hover — no conflictúa con el translateY del parallax */
  .sgrid__frame:hover .sgrid__photo {
    scale: 1.04;
  }


  /* ── Gradiente de legibilidad ────────────────────────────────────────────── */
  /*
   * Overlay en la mitad inferior de la tarjeta para que el texto blanco
   * sea legible sobre cualquier fotografía.
   *
   * ANTI-SLOP: "Solo se permiten como overlays oscuros sutiles (rgba)
   * sobre fotografías reales para mejorar la lectura." ✓
   */

  .sgrid__veil {
    position: absolute;
    inset:    0;

    background: linear-gradient(
      to top,
      rgba(7, 8, 12, 0.92)  0%,
      rgba(7, 8, 12, 0.62)  28%,
      rgba(7, 8, 12, 0.16)  58%,
      transparent           100%
    );

    transition: opacity var(--dur-mid) var(--ease-out);
  }

  /* Hover: velo levemente más claro → más foto visible */
  .sgrid__frame:hover .sgrid__veil {
    opacity: 0.86;
  }


  /* ── Texto superpuesto (absolute, pegado al fondo) ───────────────────────── */

  .sgrid__info {
    position:       absolute;
    bottom:         0;
    left:           0;
    right:          0;
    z-index:        2;

    display:        flex;
    flex-direction: column;
    gap:            var(--sp-1);

    padding: var(--sp-5) var(--sp-5) var(--sp-6);
  }

  /* Número de servicio — acento azul Helitec */
  .sgrid__num {
    font-family:    var(--font-sans);
    font-size:      0.65rem;
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);  /* 0.20em */
    text-transform: uppercase;
    color:          var(--c-sky);
    margin-bottom:  var(--sp-1);
  }

  /* Título del servicio */
  .sgrid__title {
    font-family:    var(--font-display);
    font-size:      clamp(var(--text-lg), 1.8vw, var(--text-2xl));
    font-weight:    var(--fw-thin);   /* 200 — ANTI-SLOP */
    letter-spacing: var(--ls-wide);
    color:          var(--c-text-1);
    line-height:    1.1;
    margin-bottom:  var(--sp-2);
  }

  /* ── Recurso rojo — subrayado decorativo ───────────────────────────────── */

  .sgrid__title-deco {
    display:          block;
    width:            clamp(48px, 35%, 110px);
    height:           auto;
    object-fit:       contain;
    object-position:  left center;
    margin-bottom:    var(--sp-2);

    /*
     * Reveal izquierda → derecha mediante clip-path.
     * Estado inicial: completamente recortado (no visible).
     * Estado activo (.sgrid__frame--revealed): clip-path 0% → imagen visible.
     * Delay de 0.15s para que entre después del título.
     */
    clip-path:  inset(0 100% 0 0);
    transition: clip-path 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.15s;
  }

  .sgrid__frame--revealed .sgrid__title-deco {
    clip-path: inset(0 0% 0 0);
  }

  /* Descripción — texto secundario muted */
  .sgrid__desc {
    font-family:   var(--font-sans);
    font-size:     var(--text-sm);
    color:         rgba(255, 255, 255, 0.58);
    line-height:   1.55;
    margin-bottom: var(--sp-3);
  }


  /* ── CTA inline con flecha animada ──────────────────────────────────────── */

  .sgrid__cta {
    display:        inline-flex;
    align-items:    center;
    gap:            var(--sp-2);

    font-family:    var(--font-sans);
    font-size:      0.63rem;
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-sky);
  }

  /*
   * Flecha SVG:
   *   · Estado base:  opacity 0.65, en posición neutra.
   *   · Hover:        desliza 6px a la derecha + opacity 1.
   *   · Easing spring (0.16,1,0.3,1) — mismo que las celdas del menú.
   */
  .sgrid__arrow {
    flex-shrink: 0;
    opacity:     0.65;
    transition:
      transform 0.28s cubic-bezier(0.16, 1, 0.3, 1),
      opacity   0.22s var(--ease-out);
  }

  .sgrid__frame:hover .sgrid__arrow {
    transform: translateX(6px);
    opacity:   1;
  }


  /* ── Responsive ──────────────────────────────────────────────────────────── */

  @media (max-width: 1023px) {
    .sgrid {
      padding-inline: var(--gutter);
    }
  }

  @media (max-width: 767px) {
    .sgrid__grid {
      gap: 10px;
    }

    .sgrid__heading {
      font-size: var(--text-2xl);
    }

    .sgrid__frame {
      /* Tarjetas más compactas en móvil (la mitad del ancho = ~50vw) */
      height: clamp(220px, 48vw, 320px);
    }

    .sgrid__info {
      padding: var(--sp-3) var(--sp-3) var(--sp-4);
      gap: 0;
    }

    .sgrid__title {
      font-size:     var(--text-base);
      margin-bottom: var(--sp-1);
    }

    /* Máximo 2 líneas de descripción en móvil */
    .sgrid__desc {
      display:            -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow:           hidden;
      font-size:          0.70rem;
      margin-bottom:      var(--sp-2);
    }
  }

  @media (max-width: 479px) {
    .sgrid__header {
      padding-bottom: var(--sp-5);
    }

    .sgrid__frame {
      height: clamp(230px, 60vw, 290px);
    }

    /* Pantallas muy pequeñas: ocultar descripción — solo número, título, CTA */
    .sgrid__desc {
      display: none;
    }
  }
</style>


<script>
(function () {
  'use strict';

  /*
   * ServicesSection v4 — Parallax de imágenes (idéntico a v3)
   *
   * STRENGTH = 0.40:
   *   progress = (frameCenterY − vpCenterY) / vpH  →  clamped a [-0.5, +0.5]
   *   offset   = progress × STRENGTH × frameHeight
   *   maxOffset = 0.5 × 0.40 × frameH < 25% × frameH → sin clipping.
   *
   * Nota: el JS aplica `style.transform = 'translateY(Xpx)'`.
   * El CSS hover usa la propiedad `scale` (independiente de `transform`).
   * Ambas coexisten sin conflicto en navegadores modernos.
   */

  var STRENGTH = 0.40;
  var frames   = Array.from(document.querySelectorAll('.sgrid__frame'));
  var ticking  = false;

  function clamp(v, lo, hi) {
    return v < lo ? lo : v > hi ? hi : v;
  }

  function updateParallax() {
    var vh = window.innerHeight;

    frames.forEach(function (frame) {
      var img = frame.querySelector('.sgrid__photo');
      if (!img) return;

      var rect = frame.getBoundingClientRect();

      /* Saltar frames completamente fuera del viewport */
      if (rect.bottom < -120 || rect.top > vh + 120) return;

      var frameCenter = rect.top + rect.height * 0.5;
      var progress    = (frameCenter - vh * 0.5) / vh;
      progress        = clamp(progress, -0.5, 0.5);

      var offset = progress * STRENGTH * rect.height;
      img.style.transform = 'translateY(' + offset.toFixed(2) + 'px)';
    });

    ticking = false;
  }

  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(updateParallax);
      ticking = true;
    }
  }

  updateParallax();
  window.addEventListener('scroll', onScroll, { passive: true });

  if (typeof ResizeObserver !== 'undefined') {
    new ResizeObserver(function () { updateParallax(); })
      .observe(document.documentElement);
  }

  /*
   * ── Reveal del recurso rojo (subrayado izq→der) ──────────────────────────
   * Cuando cada .sgrid__frame entra en el viewport (threshold 0.25),
   * añadimos .sgrid__frame--revealed → CSS activa clip-path transition.
   * Once: true — se dispara una sola vez por tarjeta.
   */
  if ('IntersectionObserver' in window) {
    var revealObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('sgrid__frame--revealed');
          revealObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.25 });

    frames.forEach(function (frame) { revealObs.observe(frame); });
  } else {
    /* Fallback sin IntersectionObserver (IE11): revelar inmediatamente */
    frames.forEach(function (frame) { frame.classList.add('sgrid__frame--revealed'); });
  }
})();
</script>
