---
/**
 * ServicesSection.astro
 * Consorcio Helitec — Sección Servicios con scroll-stack Licorn-style
 *
 * Patrón visual: Licorn Publishing — tarjetas fotográficas que se apilan
 * progresivamente mientras el usuario hace scroll.
 *
 * Arquitectura:
 *   · Sección contenedora: height = 100vh × (N + 1) = 500vh
 *   · Stage sticky: position sticky, top 0, height 100vh, overflow hidden
 *   · N tarjetas: position absolute, inset 0, animadas por JS scroll-driver
 *
 * Animación (rAF a 60fps — mismo patrón que Hero.astro):
 *   · Cada tarjeta "entra" desde abajo con smoothstep easing
 *   · La tarjeta anterior se "aleja" sutilmente (scale 0.96, opacity 0.75)
 *   · Sin JS: las tarjetas siguen visibles en orden correcto (fallback CSS)
 *
 * Reglas anti-slop:
 *   PROHIBIDO box-shadow    — ✓
 *   PROHIBIDO gradientes    — overlay rgba() sobre foto real ✓
 *   border-radius ≤ 4px     — ✓
 *   object-fit: cover       — ✓ en todas las imágenes
 *   Tipografía: weight 200  — ✓ en h3
 *
 * IMÁGENES (reales, Fase 6.1):
 *   YV1923_1.jpg · Helicoptero%20en%20pantano.jpg · Avion%20y%20Ambulancia%201.jpg · Helicoptero%20Eslinga%201.jpg
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

/* ── Datos de servicios ─────────────────────────────────────────────────── */
/*
 * Rutas de imagen con espacios en el nombre se codifican con encodeURI()
 * para garantizar URLs válidas en el build de Astro y en los navegadores.
 * Ejemplo: 'Helicoptero en pantano.jpg' → 'Helicoptero%20en%20pantano.jpg'
 */
const services = [
  {
    num:   '01',
    slug:  'ejecutiva',
    title: lang === 'es' ? 'Aviación Ejecutiva' : 'Executive Aviation',
    desc:  lang === 'es'
      ? 'Flota Metro y Merlin de ala fija para transporte corporativo de alta eficiencia. Conexión directa entre Caracas, el interior y el Caribe.'
      : 'Fixed-wing Metro and Merlin fleet for high-efficiency corporate transport. Direct connections between Caracas, the interior, and the Caribbean.',
    cta:   lang === 'es' ? 'Solicitar vuelo ejecutivo' : 'Request executive flight',
    href:  '/#contacto',
    img:   '/assets/IMG_0968.jpg',                                       /* Cabina ejecutiva — interior del avión */
    alt:   lang === 'es' ? 'Cabina ejecutiva Consorcio Helitec — asientos de cuero premium' : 'Helitec executive cabin — premium leather seating',
    accent: 'var(--c-sky)',
  },
  {
    num:   '02',
    slug:  'petroleras',
    title: lang === 'es' ? 'Operaciones Petroleras' : 'Petroleum Operations',
    desc:  lang === 'es'
      ? 'Helicópteros MD con disponibilidad 24/7 para soporte aéreo en plataformas marítimas e instalaciones en tierra del sector energético.'
      : 'MD helicopters with 24/7 availability for aerial support on offshore platforms and onshore energy sector facilities.',
    cta:   lang === 'es' ? 'Consultar operaciones' : 'Inquire about operations',
    href:  '/#contacto',
    img:   '/assets/opepetroleras.png',                                  /* Operaciones petroleras — imagen dedicada */
    alt:   lang === 'es' ? 'Helicóptero Helitec en operación petrolera' : 'Helitec helicopter on petroleum operations',
    accent: 'rgba(255,255,255,0.5)',
  },
  {
    num:   '03',
    slug:  'aeromedico',
    title: lang === 'es' ? 'Traslados Aeromédicos' : 'Aeromedical Transfers',
    desc:  lang === 'es'
      ? 'Metro III con configuración aeromédica certificada y camilla Spectrum Aeromed. Coordinación inmediata con ambulancias en tierra. Respuesta 24/7.'
      : 'Metro III with certified aeromedical configuration and Spectrum Aeromed stretcher. Immediate coordination with ground ambulances. 24/7 response.',
    cta:   lang === 'es' ? 'Activar emergencia médica' : 'Activate medical emergency',
    href:  'https://wa.me/584166235254?text=EMERGENCIA+AEROM%C3%89DICA',
    img:   encodeURI('/assets/Avion y Ambulancia1.jpg'),                 /* Metro III YV-147T junto a ambulancia en pista */
    alt:   lang === 'es' ? 'Metro III Helitec junto a ambulancia — servicio aeromédico' : 'Helitec Metro III alongside ambulance — aeromedical service',
    accent: 'var(--c-red)',
    isExternal: true,
  },
  {
    num:   '04',
    slug:  'mantenimiento',
    title: lang === 'es' ? 'Operaciones de Carga y Eslinga' : 'Cargo & Sling Operations',
    desc:  lang === 'es'
      ? 'Helicópteros MD equipados para carga externa con eslinga certificada. Transporte de equipos industriales a zonas de difícil acceso. Capacidad hasta 650 kg externos.'
      : 'MD helicopters equipped for external sling load operations. Industrial equipment transport to hard-to-reach zones. Up to 650 kg external capacity.',
    cta:   lang === 'es' ? 'Consultar operaciones de carga' : 'Inquire about cargo ops',
    href:  '/#contacto',
    img:   encodeURI('/assets/Helicoptero Eslinga 2.jpg'),               /* MD Helitec — eslinga de carga externa (toma 2) */
    alt:   lang === 'es' ? 'Helicóptero MD Helitec con eslinga de carga externa sobre vegetación' : 'Helitec MD helicopter with external sling load over vegetation',
    accent: 'rgba(255,255,255,0.5)',
  },
];

const NUM_CARDS = services.length; // 4
---

<section
  class="sstack"
  id="servicios"
  data-num-cards={NUM_CARDS}
  aria-labelledby="sstack-heading"
>

  <!-- Heading accesible oculto visualmente -->
  <h2 class="sr-only" id="sstack-heading">
    {lang === 'es' ? 'Nuestros servicios' : 'Our services'}
  </h2>

  <!-- ── Stage sticky: las tarjetas viven aquí ──────────────────────────── -->
  <div class="sstack__stage" aria-hidden="false">

    {services.map((svc, i) => (
      <article
        class="sstack__card"
        data-card-index={i}
        aria-label={svc.title}
      >

        <!-- Foto de fondo -->
        <img
          src={svc.img}
          alt={svc.alt}
          class="sstack__bg"
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
        />

        <!-- Overlay oscuro: rgba fijo sobre la foto — NO gradiente -->
        <div class="sstack__overlay" aria-hidden="true"></div>

        <!-- Número decorativo de fondo -->
        <span
          class="sstack__deco-num"
          aria-hidden="true"
          style={`color: ${svc.accent}`}
        >
          {svc.num}
        </span>

        <!-- Contenido de la tarjeta -->
        <div class="sstack__content">

          <!-- Número de servicio -->
          <span class="sstack__num">{svc.num}</span>

          <!-- Overline: categoría -->
          <p class="sstack__category">
            {lang === 'es' ? 'Servicio' : 'Service'}
          </p>

          <!-- Título principal -->
          <h3 class="sstack__title">{svc.title}</h3>

          <!-- Descripción -->
          <p class="sstack__desc">{svc.desc}</p>

          <!-- CTA -->
          <a
            href={svc.href}
            class="sstack__cta"
            {...(svc.isExternal
              ? { target: '_blank', rel: 'noopener noreferrer' }
              : {}
            )}
          >
            <span>{svc.cta}</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            </svg>
          </a>

        </div>

        <!-- Indicador de progreso (barra inferior) -->
        <div class="sstack__progress" aria-hidden="true">
          {services.map((_, j) => (
            <span
              class={`sstack__progress-dot${j === i ? ' is-active' : ''}`}
            ></span>
          ))}
        </div>

      </article>
    ))}

  </div>

  <!-- Spacer: scroll adicional para que la última tarjeta sea cómoda de leer -->
  <div class="sstack__spacer" aria-hidden="true"></div>

</section>


<style>
  /* ── Sección: altura total del recorrido de scroll ──────────────────────── */
  .sstack {
    /*
     * Fase 7.1 rev.2 — 560vh (equilibrio entre resistencia y fluidez):
     *   scrollableH = 560vh - 100vh (stage) = 460vh
     *   460vh / 4 tarjetas = 115vh por tarjeta
     *   JS: HOLD_FRAC=0.08 → ~9vh dead zone + ~106vh de transición real.
     *   Un swipe normal (40-60vh + momentum) cambia una tarjeta.
     *   Un swipe muy rápido puede saltar 1-2, pero no las 4.
     */
    height:   560vh;
    position: relative;
  }

  /* ── Stage: el viewport sticky que contiene las tarjetas ───────────────── */
  .sstack__stage {
    position: sticky;
    top:      0;
    height:   100vh;
    overflow: hidden;

    /* Contexto para absolute children */
    isolation: isolate;
  }

  /* ── Tarjeta base ─────────────────────────────────────────────────────── */
  .sstack__card {
    position: absolute;
    inset:    0;

    display:  flex;
    align-items: flex-end; /* Contenido en la parte inferior */

    /* Tarjeta 0: visible desde el inicio (sin JS) */
    /* Tarjetas 1–3: ocultas debajo hasta que JS las anime */
    transform: translateY(100%);
    opacity:   0;

    will-change: transform, opacity;
  }

  /* Primera tarjeta: visible por defecto (sin JS, fallback) */
  .sstack__card[data-card-index="0"] {
    transform: translateY(0);
    opacity:   1;
  }

  /* ── Foto de fondo ───────────────────────────────────────────────────── */
  .sstack__bg {
    position:        absolute;
    inset:           0;
    width:           100%;
    height:          100%;
    object-fit:      cover;         /* OBLIGATORIO — nunca deformar */
    object-position: center center;

    /* Fondo de color mientras la imagen carga */
    background-color: var(--c-bg);
  }

  /* ── Overlay: oscurece la foto para legibilidad del texto ────────────── */
  .sstack__overlay {
    position:         absolute;
    inset:            0;
    /* rgba PURO — PROHIBIDO linear-gradient decorativo */
    background-color: rgba(7, 8, 12, 0.58);
    pointer-events:   none;
  }

  /* ── Número decorativo de fondo ─────────────────────────────────────── */
  .sstack__deco-num {
    position: absolute;
    right:    var(--gutter);
    top:      50%;
    transform: translateY(-50%);

    font-family:    var(--font-display);
    font-size:      clamp(10rem, 20vw, 22rem);
    font-weight:    var(--fw-thin); /* 200 */
    letter-spacing: -0.04em;
    line-height:    1;

    /* Color viene del --accent del servicio via inline style */
    opacity:        0.07; /* Muy sutil — solo textura */
    user-select:    none;
    pointer-events: none;
    white-space:    nowrap;
  }

  /* ── Contenido ───────────────────────────────────────────────────────── */
  .sstack__content {
    position:      relative; /* Over overlay + deco-num */
    z-index:       1;

    padding-inline-start: calc(var(--sidebar-w) + var(--gutter));
    padding-inline-end:   var(--gutter);
    /*
     * Fase 7.1 — Aumentado para separar el CTA del grupo de FABs flotantes.
     * Los FABs viven a bottom ~25px y tienen 44px de alto → top ~69px.
     * Con 90-120px de padding-bottom el botón queda ~30-50px sobre los FABs.
     */
    padding-bottom:       clamp(90px, 14vh, 120px);

    max-width: 640px;
  }

  .sstack__num {
    display:        block;
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    color:          var(--c-text-3);
    margin-bottom:  8px;
  }

  .sstack__category {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);
    margin-bottom:  12px;
  }

  .sstack__title {
    font-family:    var(--font-display);
    font-size:      var(--text-2xl); /* clamp(2rem → 3.5rem) */
    font-weight:    var(--fw-thin);  /* 200 — OBLIGATORIO */
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    line-height:    1.05;
    color:          var(--c-text-1);

    margin-bottom: 16px;
  }

  .sstack__desc {
    font-family: var(--font-sans);
    font-size:   clamp(0.875rem, 1.5vw, 1rem);
    font-weight: var(--fw-light);
    color:       rgba(255, 255, 255, 0.72);
    line-height: 1.65;
    max-width:   48ch;

    margin-bottom: 28px;
  }

  /* ── CTA ghost button ────────────────────────────────────────────────── */
  .sstack__cta {
    display:         inline-flex;
    align-items:     center;
    gap:             10px;

    padding:      10px 20px;

    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    text-decoration: none;
    color:          var(--c-white);

    /* Ghost button — OBLIGATORIO según design system */
    background:    transparent;
    border:        1px solid rgba(255, 255, 255, 0.45);
    border-radius: var(--r-micro); /* 4px — límite absoluto */

    transition:
      border-color     var(--dur-fast) var(--ease-out),
      background-color var(--dur-fast) var(--ease-out);
  }

  .sstack__cta:hover {
    border-color:     rgba(255, 255, 255, 0.85);
    background-color: rgba(255, 255, 255, 0.08);
  }

  .sstack__cta svg {
    flex-shrink: 0;
    transition:  transform var(--dur-fast) var(--ease-out);
  }

  .sstack__cta:hover svg {
    transform: translateX(3px);
  }

  /* ── Barra de progreso (indicadores de tarjeta) ──────────────────────── */
  .sstack__progress {
    position: absolute;
    bottom:   clamp(24px, 4vh, 40px);
    right:    var(--gutter);

    display: flex;
    gap:     6px;
    align-items: center;
  }

  .sstack__progress-dot {
    display:          block;
    width:            20px;
    height:           1.5px;
    background-color: rgba(255, 255, 255, 0.25);

    transition: background-color var(--dur-mid) var(--ease-out),
                width var(--dur-mid) var(--ease-out);
  }

  .sstack__progress-dot.is-active {
    background-color: var(--c-white);
    width:            32px;
  }

  /* ── Spacer final ────────────────────────────────────────────────────── */
  .sstack__spacer {
    /* No necesita estilos extra — es simplemente un bloque vacío
       para que la sección tenga la altura correcta (500vh).
       El spacer está incluido en el height: 500vh de .sstack. */
    display: none; /* El spacer de scroll está dado por height en .sstack */
  }

  /* ── MOBILE ─────────────────────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .sstack__content {
      padding-inline-start: var(--gutter);
      max-width: none;
    }

    .sstack__deco-num {
      display: none; /* Sin número decorativo en mobile — demasiado ruido */
    }
  }

  @media (max-width: 639px) {
    .sstack__title {
      font-size: clamp(1.5rem, 7vw, 2rem);
    }

    .sstack__desc {
      display: none; /* En mobile muy pequeño: solo número + título + CTA */
    }
  }
</style>


<script>
  /**
   * ServicesSection — Scroll-driven stack animation · Fase 7.1
   *
   * Mejoras sobre la versión anterior:
   *
   *   1. ZONA DE HOLD (scroll resistance)
   *      Cada tarjeta tiene dos fases dentro de su "slot" de scroll:
   *        · HOLD  (50%): tarjeta completamente visible, nada se mueve.
   *                       El usuario puede leer sin que la UI lo presione.
   *        · ENTER (50%): siguiente tarjeta sube, actual retrocede.
   *      Resultado: pasar el dedo rápido ya no salta tarjetas.
   *      Con height: 700vh → scrollableH = 600vh → 150vh/tarjeta →
   *        75vh de lectura + 75vh de animación por tarjeta.
   *
   *   2. MODO COMPACTO (retorno limpio)
   *      Una vez vista la sección completa, al volver a scrollear HACIA ARRIBA
   *      las 4 tarjetas se colapsan en una cuadrícula 2×2 de miniaturas.
   *      No hay re-animación tediosa: el usuario pasa por encima rápido.
   *      Al volver a bajar, se restaura la animación normal.
   */
  (function () {
    var section = document.getElementById('servicios');
    if (!section) return;

    var stage = section.querySelector('.sstack__stage');
    var cards = Array.from(section.querySelectorAll('.sstack__card'));
    var dots  = Array.from(section.querySelectorAll('.sstack__progress-dot'));
    var N     = cards.length; /* 4 */

    if (!stage || !cards.length) return;

    /* ── Helpers ──────────────────────────────────────────────────────── */
    function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
    function smoothstep(t) { var p = clamp(t, 0, 1); return p * p * (3 - 2 * p); }
    function lerp(a, b, t) { return a + (b - a) * t; }

    /* ── Estado global ────────────────────────────────────────────────── */
    var ticking      = false;
    var isCompleted  = false;   /* Sección ya fue scrolleada completa */
    var inCompact    = false;   /* Modo miniatura activo */
    var prevScrollY  = window.scrollY;
    var transTimer   = null;

    /* ─────────────────────────────────────────────────────────────────────
       MODO NORMAL — animación scroll-driven con zonas de hold
    ───────────────────────────────────────────────────────────────────── */
    function updateStack() {
      /* Race condition fix: si compact mode está activo, ignorar este frame */
      if (inCompact) { ticking = false; return; }

      var rect      = section.getBoundingClientRect();
      var sectionH  = section.offsetHeight;   /* 560vh */
      var viewH     = window.innerHeight;
      var scrollableH = sectionH - viewH;     /* 460vh → ~115vh por tarjeta */

      var scrolled = clamp(-rect.top, 0, scrollableH);

      /*
       * HOLD_FRAC = 0.08 (mínimo):
       *   · Solo 9vh de "zona muerta" antes de que empiece la transición.
       *   · Suficiente para evitar micro-skips accidentales.
       *   · Un swipe normal cubre los ~9vh de hold y entra en los ~106vh de transición.
       *   · El usuario NO tiene que "darle fuerte" para cambiar de tarjeta.
       */
      var HOLD_FRAC  = 0.08;
      var ENTER_FRAC = 0.92;

      var rawPos   = (scrolled / scrollableH) * N;
      var slotIdx  = clamp(Math.floor(rawPos), 0, N - 1);
      var slotFrac = rawPos - slotIdx;

      var cardP;
      if (slotFrac < HOLD_FRAC) {
        /* Zona hold: tarjeta activa, ningún movimiento */
        cardP = 1 + slotIdx;
      } else {
        /* Zona enter: animación de entrada / salida */
        var enterP = (slotFrac - HOLD_FRAC) / ENTER_FRAC;
        cardP = 1 + slotIdx + enterP;
      }

      /* Nunca pasar de N (última tarjeta no va detrás de nada) */
      cardP = clamp(cardP, 1, N);

      /* Aplicar a cada tarjeta */
      cards.forEach(function (card, i) {
        var local   = cardP - i;
        var ty      = 0;
        var scale   = 1;
        var opacity = 1;

        if (local <= 0) {
          ty      = 100;
          opacity = 0;
        } else if (local < 1) {
          var ep = smoothstep(local);
          ty      = (1 - ep) * 100;
          opacity = clamp(ep * 1.5, 0, 1);
        } else {
          var bp = clamp(local - 1, 0, 1);
          scale   = lerp(1, 0.93, smoothstep(bp));
          opacity = lerp(1, 0.65, smoothstep(bp));
        }

        card.style.transform = ty !== 0
          ? 'translateY(' + ty.toFixed(3) + '%)'
          : 'scale(' + scale.toFixed(4) + ')';
        card.style.opacity = opacity.toFixed(3);
      });

      /* Dots de progreso */
      var activeIdx = clamp(Math.floor(cardP) - 1, 0, N - 1);
      dots.forEach(function (dot, i) {
        dot.classList.toggle('is-active', i === activeIdx);
      });

      ticking = false;
    }

    /* ─────────────────────────────────────────────────────────────────────
       MODO COMPACTO — cuadrícula 2×2 de miniaturas
    ───────────────────────────────────────────────────────────────────── */

    /*
     * Posiciones para cuadrícula 2×2.
     * translate(±25%, ±25%): desplaza el centro de cada tarjeta a su cuadrante.
     * Las tarjetas son position:absolute; inset:0 → dimensiones = viewport.
     * 25% de 100vw = 25vw; 25% de 100vh = 25vh.
     * scale(0.44) → cada tarjeta ocupa ~44vw × 44vh ≈ 23px de gap entre ellas.
     */
    var COMPACT_POSITIONS = [
      'translate(-25%, -25%)',  /* 0: superior izquierda */
      'translate( 25%, -25%)',  /* 1: superior derecha   */
      'translate(-25%,  25%)',  /* 2: inferior izquierda */
      'translate( 25%,  25%)',  /* 3: inferior derecha   */
    ];
    var COMPACT_SCALE   = 0.44;
    var COMPACT_OPACITY = '0.78';

    function showCompactGrid() {
      cards.forEach(function (card, i) {
        card.style.transform = COMPACT_POSITIONS[i] + ' scale(' + COMPACT_SCALE + ')';
        card.style.opacity   = COMPACT_OPACITY;
      });
      /* Todos los dots activos en modo compacto */
      dots.forEach(function (dot) { dot.classList.add('is-active'); });
      ticking = false;
    }

    /* ── Transición suave al cambiar de modo ───────────────────────────── */
    var TRANS_DUR = 360; /* ms */
    var TRANS_CSS = 'transform ' + TRANS_DUR + 'ms cubic-bezier(0.4, 0, 0.2, 1), ' +
                    'opacity '   + TRANS_DUR + 'ms ease';

    function setTransition(on) {
      var val = on ? TRANS_CSS : 'none';
      cards.forEach(function (c) { c.style.transition = val; });
    }

    function enterCompact() {
      if (inCompact) return;
      inCompact = true;
      clearTimeout(transTimer);
      setTransition(true);
      showCompactGrid();
      transTimer = setTimeout(function () { setTransition(false); }, TRANS_DUR + 20);
    }

    function exitCompact() {
      if (!inCompact) return;
      inCompact = false;
      clearTimeout(transTimer);
      setTransition(true);
      updateStack();
      transTimer = setTimeout(function () { setTransition(false); }, TRANS_DUR + 20);
    }

    /* ─────────────────────────────────────────────────────────────────────
       HANDLER DE SCROLL — elige modo según dirección y estado
    ───────────────────────────────────────────────────────────────────── */
    function onScroll() {
      var scrollY      = window.scrollY;
      var scrollingUp  = scrollY < prevScrollY;
      prevScrollY = scrollY;

      var rect      = section.getBoundingClientRect();
      var sectionH  = section.offsetHeight;
      var viewH     = window.innerHeight;
      var scrollableH = sectionH - viewH;

      var scrolled  = clamp(-rect.top, 0, scrollableH);

      /*
       * Marcar sección como "completada" cuando la última tarjeta
       * ha terminado de entrar.
       * Eso ocurre cuando rawPos ≥ N-1 (inicio del slot de la última tarjeta).
       * Con N=4: rawPos = 3 → scrolled = 3/4 × 600vh = 450vh.
       */
      if (scrolled >= (N - 1) / N * scrollableH) {
        isCompleted = true;
      }

      /* ¿El stage sticky está activo? (sección anclada al viewport) */
      var inSection = rect.top <= 0 && rect.bottom >= viewH;

      if (inSection && scrollingUp && isCompleted) {
        enterCompact();
      } else if (inSection && !scrollingUp) {
        exitCompact();
      } else if (!inSection && inCompact) {
        /* Salió de la sección — reset silencioso */
        inCompact = false;
        setTransition(false);
      }

      if (!inCompact && !ticking) {
        requestAnimationFrame(updateStack);
        ticking = true;
      }
    }

    /* ── Inicializar ────────────────────────────────────────────────────── */
    updateStack();

    /* ── Listeners ─────────────────────────────────────────────────────── */
    window.addEventListener('scroll', onScroll, { passive: true });

    if (typeof ResizeObserver !== 'undefined') {
      new ResizeObserver(function () {
        if (!inCompact) updateStack();
      }).observe(section);
    }

  })();
</script>
