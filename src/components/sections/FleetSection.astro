---
/**
 * FleetSection.astro — "Ingeniería del Servicio"
 * Consorcio Helitec
 *
 * Motor scroll: ventana (sectionHeight + vh) — fórmula original.
 * Mobile Tetris: translateY(-30) / translateX(±40) / translateX(20vw).
 * Legibilidad FAQ: opacidad logo 0.15 + backdrop blur en .faq-module.
 * Highlight sweeps: <span class="hl"> con delay al abrir acordeón.
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

/*
 * Respuestas con markup HTML — renderizadas con set:html en el template.
 * <span class="hl">...</span> marca frases para el efecto de resaltado.
 */
const faqItems = [
  {
    q: '¿QUÉ VENTAJAS TIENE UN VUELO CHÁRTER EJECUTIVO FRENTE A UN VUELO COMERCIAL?',
    a: '<span class="hl">Flexibilidad total</span> en rutas, privacidad y confort con cabinas VIP, y <span class="hl">eficiencia absoluta</span> evitando filas y demoras en terminales masivas.',
  },
  {
    q: '¿QUÉ CERTIFICACIONES DE SEGURIDAD POSEE CONSORCIO HELITEC C.A.?',
    a: 'SMS <span class="hl">certificado por la Autoridad Aeronáutica Venezolana (INAC)</span>, <span class="hl">Mantenimiento Predictivo</span> en tiempo real, y <span class="hl">Tripulaciones Expertas</span> con más de 10.000 horas de vuelo.',
  },
  {
    q: '¿CUÁNTO CUESTA UN VUELO CHÁRTER EJECUTIVO?',
    a: '<span class="hl">El costo de una operación privada se estructura de manera personalizada</span>: tipo de aeronave, distancia, tasas aeroportuarias y servicios como catering a la carta o traslados blindados.',
  },
  {
    q: '¿PUEDEN OPERAR VUELOS MÉDICOS DE EMERGENCIA?',
    a: 'Sí. Operamos en <span class="hl">alianza estratégica directa con Aeroambulancia Silva</span>, ofreciendo auténticas UCI móviles, repatriaciones sanitarias expeditivas y respuesta inmediata 24/7.',
  },
  {
    q: '¿CÓMO OPTIMIZAMOS LA LOGÍSTICA EN PLATAFORMAS PETROLERAS?',
    a: '<span class="hl">Operaciones en Enclaves Remotos</span>, <span class="hl">Cumplimiento riguroso de normativas</span> de SST exigidas por consorcios, y <span class="hl">Configuración de Flota Comercial Versátil</span> de alta densidad.',
  },
];
---


<section class="ops" id="flota" aria-labelledby="ops-heading" data-ops-section>

  <img
    src="/assets/recurso%20logo%20avion%20helitec%20(1).png"
    class="ops__plane-deco"
    alt=""
    aria-hidden="true"
    loading="lazy"
    decoding="async"
  />

  <div class="ops__inner">

    <!-- ══ COL IZQUIERDA — Tipografía desarmada (sticky en desktop) ════════ -->
    <div class="ops__left">
      <header class="ops__header">

        <p class="ops__overline">
          {lang === 'es' ? 'Ingeniería del Servicio' : 'Service Engineering'}
        </p>

        <h2 class="ops__title" id="ops-heading">
          <span class="ops__title-layer layer-outline" data-layer="outline">
            SOBRE NUESTRAS
          </span>
          <span class="ops__title-layer layer-solid" data-layer="solid">
            OPERACIONES,
          </span>
          <span class="ops__title-layer layer-accent" data-layer="accent">
            FLOTA
          </span>
          <span class="ops__title-layer layer-base" data-layer="base">
            Y SERVICIOS.
          </span>
        </h2>

      </header>
    </div>

    <!-- ══ COL DERECHA — FAQ Acordeón ══════════════════════════════════════ -->
    <div class="ops__right">

      <div
        class="faq-module"
        data-faq-module
        role="list"
        aria-label="Preguntas frecuentes"
      >

        {faqItems.map((item) => (
          <div class="faq-item" role="listitem" data-faq-item>

            <button
              class="faq-trigger"
              type="button"
              aria-expanded="false"
              data-faq-trigger
            >
              <span class="faq-trigger__text">{item.q}</span>
              <span class="faq-trigger__icon" aria-hidden="true">+</span>
            </button>

            <div class="faq-panel" data-faq-panel>
              <div class="faq-panel__inner">
                <!--
                  set:html renderiza el markup con <span class="hl"> para highlights.
                  Las clases .hl e .hl.is-highlighted son :global en el <style>.
                -->
                <p class="faq-panel__text" set:html={item.a}></p>
              </div>
            </div>

          </div>
        ))}

      </div>

    </div>

  </div>
</section>


<style>
  /* ════════════════════════════════════════════════════════════════════════
     SECCIÓN
  ════════════════════════════════════════════════════════════════════════ */

  .ops {
    position:         relative;
    background-color: var(--c-bg);
    border-top:       1px solid var(--c-line);
    padding-block:    clamp(72px, 11vh, 120px);
    overflow:         hidden;   /* recorta translateX durante slide-in */
  }


  /* ════════════════════════════════════════════════════════════════════════
     LOGO AVIÓN DE FONDO
     Reducido a opacity: 0.15 para mejorar legibilidad del FAQ.
  ════════════════════════════════════════════════════════════════════════ */

  .ops__plane-deco {
    position:        absolute;
    right:           0;
    top:             clamp(60px, 8vh, 100px);   /* subido: cola asoma sobre "SOBRE" */

    height:          clamp(420px, 58vw, 720px);
    width:           auto;

    object-fit:      contain;
    object-position: right top;

    opacity:         0.15;   /* era 0.18 — reducido para legibilidad FAQ */
    z-index:         0;
    pointer-events:  none;
    user-select:     none;
  }


  /* ════════════════════════════════════════════════════════════════════════
     GRID PRINCIPAL
  ════════════════════════════════════════════════════════════════════════ */

  .ops__inner {
    position:       relative;
    z-index:        1;

    max-width:      var(--content-max);
    margin-inline:  auto;
    padding-inline: calc(var(--sidebar-w) + var(--gutter));

    display:               grid;
    grid-template-columns: 5fr 7fr;
    gap:                   clamp(48px, 7vw, 96px);
    align-items:           start;
  }

  .ops__left {
    position: sticky;
    top:      calc(var(--header-h) + 32px);
  }


  /* ════════════════════════════════════════════════════════════════════════
     OVERLINE
  ════════════════════════════════════════════════════════════════════════ */

  .ops__overline {
    display:     flex;
    align-items: center;
    gap:         12px;

    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);

    margin-bottom: clamp(20px, 3vh, 32px);
  }

  .ops__overline::before {
    content:          '';
    display:          block;
    flex-shrink:      0;
    width:            32px;
    height:           1px;
    background-color: var(--c-sky);
  }


  /* ════════════════════════════════════════════════════════════════════════
     H2 — 4 CAPAS TIPOGRÁFICAS
  ════════════════════════════════════════════════════════════════════════ */

  .ops__title {
    display:        flex;
    flex-direction: column;
    gap:            0.1em;

    font-family:    var(--font-display);
    font-size:      clamp(2.25rem, 5vw, 4.25rem);
    letter-spacing: 0.02em;
    line-height:    1.0;
    text-transform: uppercase;
  }

  .ops__title-layer {
    display:    block;
    will-change: transform, opacity;
  }

  .layer-outline {
    color:       var(--c-red);
    font-weight: 700;
  }

  .layer-solid {
    color:       var(--c-text-1);
    font-weight: 700;
  }

  .layer-accent {
    color:       var(--c-sky);
    font-weight: 700;
  }

  .layer-base {
    color:       var(--c-text-1);
    font-weight: 700;
  }


  /* ════════════════════════════════════════════════════════════════════════
     FAQ MODULE
     Backdrop semitransparente para separar el texto del logo de fondo.
  ════════════════════════════════════════════════════════════════════════ */

  .faq-module {
    display:        flex;
    flex-direction: column;
    will-change:    transform, opacity;

    /* Legibilidad: fondo oscuro sutil + desenfoque del logo detrás */
    background:            rgba(0, 0, 0, 0.42);
    backdrop-filter:       blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border:                1px solid var(--c-line);
    border-radius:         4px;   /* máx anti-slop: 4px */
    padding:               var(--sp-3) var(--sp-5);
  }


  /* ════════════════════════════════════════════════════════════════════════
     FAQ ITEMS
  ════════════════════════════════════════════════════════════════════════ */

  .faq-item {
    border-bottom: 1px solid var(--c-line);
  }

  .faq-item:first-child {
    border-top: 1px solid var(--c-line);
  }


  /* ════════════════════════════════════════════════════════════════════════
     FAQ TRIGGER
  ════════════════════════════════════════════════════════════════════════ */

  .faq-trigger {
    width:           100%;
    display:         flex;
    align-items:     flex-start;
    justify-content: space-between;
    gap:             var(--sp-5);

    padding-block:   var(--sp-5);
    padding-inline:  0;

    background:  none;
    border:      none;
    cursor:      pointer;
    text-align:  left;
  }

  .faq-trigger:hover {
    background: none;
  }

  .faq-trigger:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
    border-radius:  2px;
  }

  .faq-trigger__text {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-2);
    line-height:    1.6;

    transition: color var(--dur-fast) var(--ease-out);
  }

  .faq-trigger:hover .faq-trigger__text,
  .faq-item.is-open  .faq-trigger__text {
    color: var(--c-text-1);
  }

  .faq-trigger__icon {
    flex-shrink:     0;
    width:           20px;
    height:          20px;
    margin-top:      1px;

    display:         flex;
    align-items:     center;
    justify-content: center;

    font-size:   1.1rem;
    font-weight: var(--fw-light);
    line-height: 1;
    color:       var(--c-sky);

    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-item.is-open .faq-trigger__icon {
    transform: rotate(45deg);
  }


  /* ════════════════════════════════════════════════════════════════════════
     FAQ PANEL
  ════════════════════════════════════════════════════════════════════════ */

  .faq-panel {
    max-height: 0;
    overflow:   hidden;
    transition: max-height 420ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-panel__inner {
    padding-bottom: var(--sp-5);
  }

  .faq-panel__text {
    font-family:  var(--font-sans);
    font-size:    var(--text-sm);
    font-weight:  var(--fw-light);
    line-height:  1.75;
    color:        var(--c-text-2);   /* subido de text-3 para mejor legibilidad */
  }


  /* ════════════════════════════════════════════════════════════════════════
     HIGHLIGHT SPANS — efecto resaltador Azul Helitec
     Idéntico al patrón de StatsSection (aprobado por Tech Lead).

     Mecanismo: background-size anima de 0% → 100% (sweep de izq a der).

     REGLA CRÍTICA: NO definir transition en el estado base (.hl).
     En Blink/WebKit, cuando transition cambia junto con la propiedad animada
     en la misma recalculación de estilos, el browser usa la transition del
     estado ANTERIOR (la base, 0ms), no la del destino — el sweep es invisible.
     Con transition SOLO en .hl.is-highlighted, el forward usa 650ms ✓ y el
     reset al quitar la clase usa "ninguna" (sin animación, instant) ✓.

     :global() necesario porque set:html no recibe el Astro CID.
  ════════════════════════════════════════════════════════════════════════ */

  :global(.hl) {
    background-image:    linear-gradient(
                           rgba(88, 181, 240, 0.38),
                           rgba(88, 181, 240, 0.38)
                         );
    background-repeat:   no-repeat;
    background-size:     0% 90%;
    background-position: left center;
    padding-inline:      2px;
    border-radius:       2px;

    /*
     * box-decoration-break: clone — en spans multi-línea, cada línea
     * recibe su propio background en vez de que el bg se "corte" en el wrap.
     */
    -webkit-box-decoration-break: clone;
            box-decoration-break: clone;

    /* ⚠ SIN transition aquí — ver explicación arriba */
  }

  :global(.hl.is-highlighted) {
    background-size: 100% 90%;
    transition: background-size 650ms cubic-bezier(0.16, 1, 0.3, 1);
  }


  /* ════════════════════════════════════════════════════════════════════════
     RESPONSIVE
  ════════════════════════════════════════════════════════════════════════ */

  @media (max-width: 1023px) {
    .ops__inner {
      grid-template-columns: 1fr;
      padding-inline:        var(--gutter);
      gap:                   clamp(40px, 8vw, 56px);
    }

    .ops__left {
      position: static;
    }
  }

  @media (max-width: 479px) {
    .ops__title {
      font-size: clamp(1.875rem, 10vw, 2.5rem);
    }

    .faq-trigger {
      padding-block: var(--sp-4);
    }
  }
</style>


<script>
  /**
   * ══════════════════════════════════════════════════════════════════════════
   * PARTE 1 — FAQ Acordeón
   *
   * Al abrir: expande panel con max-height real, activa .hl.is-highlighted
   * con delay de 150ms (sweep visible después de que el panel abre).
   * Al cerrar: colapsa panel, remueve highlights al instante (reset).
   * ══════════════════════════════════════════════════════════════════════════
   */
  (function () {
    var items = /** @type {NodeListOf<HTMLElement>} */ (
      document.querySelectorAll('[data-faq-item]')
    );
    if (!items.length) return;

    /** @param {HTMLElement} item */
    function closeItem(item) {
      var panel   = /** @type {HTMLElement|null} */ (item.querySelector('[data-faq-panel]'));
      var trigger = item.querySelector('[data-faq-trigger]');
      item.classList.remove('is-open');
      if (panel)   panel.style.maxHeight = '0';
      if (trigger) trigger.setAttribute('aria-expanded', 'false');

      /* Reset highlights: sin animación (transition: 0ms en CSS base) */
      item.querySelectorAll('.hl').forEach(function (el) {
        el.classList.remove('is-highlighted');
      });
    }

    /** @param {HTMLElement} item */
    function openItem(item) {
      var panel   = /** @type {HTMLElement|null} */ (item.querySelector('[data-faq-panel]'));
      var trigger = item.querySelector('[data-faq-trigger]');
      var inner   = panel && /** @type {HTMLElement|null} */ (panel.querySelector('.faq-panel__inner'));
      item.classList.add('is-open');
      if (panel && inner) panel.style.maxHeight = inner.scrollHeight + 'px';
      if (trigger) trigger.setAttribute('aria-expanded', 'true');

      /*
       * Highlights: delay de 150ms para que el panel abra parcialmente
       * antes de que el sweep arranque — efecto más dramático y visible.
       */
      setTimeout(function () {
        item.querySelectorAll('.hl').forEach(function (el, idx) {
          /*
           * void el.offsetWidth — fuerza un reflow sincrónico.
           * Sin esto, el browser puede batchar el estado background-size:0%
           * y background-size:100% en el mismo frame (sin detección del
           * valor inicial) → la transition no dispara.
           */
          void el.offsetWidth;
          setTimeout(function () {
            el.classList.add('is-highlighted');
          }, idx * 110); /* 110ms de escalonado entre cada frase */
        });
      }, 200); /* 200ms: panel abierto parcialmente antes de que sweeps arranquen */
    }

    items.forEach(function (item) {
      var trigger = item.querySelector('[data-faq-trigger]');
      if (!trigger) return;
      trigger.addEventListener('click', function () {
        var wasOpen = item.classList.contains('is-open');
        items.forEach(closeItem);
        if (!wasOpen) openItem(item);
      });
    });
  })();


  /**
   * ══════════════════════════════════════════════════════════════════════════
   * PARTE 2 — Motor de Scroll VANDSLAB
   *
   * Ventana: (sectionHeight + vh). p=0 al entrar el borde inferior;
   * p=1 al salir el borde superior. Timelines escalonados para efecto Tetris.
   * ══════════════════════════════════════════════════════════════════════════
   */
  (function () {

    /* ── Elementos ─────────────────────────────────────────────────────── */

    var section   = /** @type {HTMLElement|null} */ (document.querySelector('[data-ops-section]'));
    var faqModule = /** @type {HTMLElement|null} */ (section && section.querySelector('[data-faq-module]'));
    var lOutline  = /** @type {HTMLElement|null} */ (section && section.querySelector('[data-layer="outline"]'));
    var lSolid    = /** @type {HTMLElement|null} */ (section && section.querySelector('[data-layer="solid"]'));
    var lAccent   = /** @type {HTMLElement|null} */ (section && section.querySelector('[data-layer="accent"]'));
    var lBase     = /** @type {HTMLElement|null} */ (section && section.querySelector('[data-layer="base"]'));

    if (!section || !faqModule || !lOutline || !lSolid || !lAccent || !lBase) return;


    /* ── prefers-reduced-motion ────────────────────────────────────────── */

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      [lOutline, lSolid, lAccent, lBase, faqModule].forEach(function (el) {
        el.style.opacity   = '1';
        el.style.transform = 'none';
      });
      return;
    }


    /* ── Utilidades ────────────────────────────────────────────────────── */

    /** @param {number} v */
    function clamp01(v) { return v < 0 ? 0 : v > 1 ? 1 : v; }

    /** @param {number} v @param {number} lo @param {number} hi */
    function mapRange(v, lo, hi) { return clamp01((v - lo) / (hi - lo)); }

    /** easeOutCubic — rápido → deceleración premium @param {number} t */
    function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

    /** @param {number} a @param {number} b @param {number} t */
    function lerp(a, b, t) { return a + (b - a) * t; }


    /* ── Mobile detection ──────────────────────────────────────────────── */

    var isMobile = false;
    function detectMobile() { isMobile = window.innerWidth < 768; }
    detectMobile();
    window.addEventListener('resize', detectMobile, { passive: true });


    /* ── Estado inicial ────────────────────────────────────────────────── */

    function setInitialState() {
      lOutline.style.opacity   = '0';
      lOutline.style.transform = isMobile ? 'translateY(-30px)' : 'translateY(-60px)';

      lSolid.style.opacity     = '0';
      lSolid.style.transform   = isMobile ? 'translateX(-40px)' : 'translateX(-100px)';

      lAccent.style.opacity    = '0';
      lAccent.style.transform  = isMobile ? 'translateX(40px)' : 'translateX(60px)';

      lBase.style.opacity      = '0';
      lBase.style.transform    = 'none';

      faqModule.style.opacity   = '0';
      faqModule.style.transform = 'translateX('
        + Math.round(window.innerWidth * (isMobile ? 0.20 : 1.0))
        + 'px)';
    }

    setInitialState();


    /* ── Progreso ─────────────────────────────────────────────────────── */

    function getProgress() {
      var rect = section.getBoundingClientRect();
      var vh   = window.innerHeight;
      /*
       * Ventana = sectionHeight + vh.
       * p=0: sección entra por borde inferior del viewport.
       * p=1: sección sale completamente por borde superior.
       */
      return clamp01((vh - rect.top) / (rect.height + vh));
    }


    /* ── Escritura de animaciones ───────────────────────────────────────── */

    var lastP = -1;

    function applyFrame() {
      var p = getProgress();
      if (Math.abs(p - lastP) < 0.0005) return;
      lastP = p;

      var p0   = easeOut(mapRange(p, 0.05, 0.30));  /* layer-outline  */
      var p1   = easeOut(mapRange(p, 0.10, 0.35));  /* layer-solid    */
      var p2   = easeOut(mapRange(p, 0.15, 0.40));  /* layer-accent   */
      var p3   = easeOut(mapRange(p, 0.03, 0.25));  /* layer-base     */
      var pFaq = easeOut(mapRange(p, 0.10, 0.48));  /* faq-module     */

      if (isMobile) {
        /* Mobile Tetris — distancias cortas, overflow recortado por section */
        lOutline.style.opacity   = p0.toFixed(3);
        lOutline.style.transform = 'translateY(' + lerp(-30, 0, p0).toFixed(1) + 'px)';

        lSolid.style.opacity     = p1.toFixed(3);
        lSolid.style.transform   = 'translateX(' + lerp(-40, 0, p1).toFixed(1) + 'px)';

        lAccent.style.opacity    = p2.toFixed(3);
        lAccent.style.transform  = 'translateX(' + lerp(40, 0, p2).toFixed(1) + 'px)';

        lBase.style.opacity      = lerp(0, 1, p3).toFixed(3);

        faqModule.style.opacity   = pFaq.toFixed(3);
        /* 20vw calculado por frame — respeta cambios de orientación */
        faqModule.style.transform = 'translateX('
          + lerp(Math.round(window.innerWidth * 0.20), 0, pFaq).toFixed(1)
          + 'px)';

      } else {
        /* Desktop — efecto Tetris direccional completo */
        lOutline.style.opacity   = p0.toFixed(3);
        lOutline.style.transform = 'translateY(' + lerp(-60, 0, p0).toFixed(2) + 'px)';

        lSolid.style.opacity     = p1.toFixed(3);
        lSolid.style.transform   = 'translateX(' + lerp(-100, 0, p1).toFixed(2) + 'px)';

        lAccent.style.opacity    = p2.toFixed(3);
        lAccent.style.transform  = 'translateX(' + lerp(60, 0, p2).toFixed(2) + 'px)';

        lBase.style.opacity      = lerp(0, 1, p3).toFixed(3);

        faqModule.style.opacity   = pFaq.toFixed(3);
        faqModule.style.transform = 'translateX('
          + lerp(window.innerWidth, 0, pFaq).toFixed(1)
          + 'px)';
      }
    }


    /* ── Loop rAF — un frame por tick de scroll ─────────────────────────── */

    var scrollPending = false;

    function onScroll() {
      if (!scrollPending) {
        scrollPending = true;
        requestAnimationFrame(function () {
          applyFrame();
          scrollPending = false;
        });
      }
    }


    /* ── IntersectionObserver ───────────────────────────────────────────── */

    new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            window.addEventListener('scroll', onScroll, { passive: true });
            applyFrame();
          } else {
            window.removeEventListener('scroll', onScroll);
          }
        });
      },
      { rootMargin: '0px', threshold: 0 }
    ).observe(section);

    /* Frame inicial — por si la página carga con la sección ya visible */
    applyFrame();

  })();
</script>
