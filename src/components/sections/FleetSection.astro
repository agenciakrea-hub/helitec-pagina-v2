---
/**
 * FleetSection.astro
 * Consorcio Helitec — Sección "Nuestra Flota"
 *
 * Layout:
 *   · Header: overline + H2 (right-aligned) + logo grande, borde derecho
 *   · Deco foto 1: avion_helitec_sinfondo.png   — 2/3 ancho, borde izquierdo
 *   · Deco foto 2: tres_avion_helitec_sinfondo.png — 2/3 ancho, borde derecho
 *
 * Ambas imágenes tienen fondo negro que se funde con --c-bg (#07080C).
 * Se colocan fuera de fleet__inner → sin padding lateral, de borde a borde.
 *
 * Reglas anti-slop:
 *   PROHIBIDO box-shadow       — ✓
 *   PROHIBIDO linear-gradient  — ✓
 *   border-radius ≤ 4px        — ✓
 *   object-fit: contain (sin recorte, fondo se funde) — ✓
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
---


<section class="fleet" id="flota" aria-labelledby="fleet-heading">

  <!-- ── Encabezado de sección ───────────────────────────────────────────── -->
  <div class="fleet__inner">

    <header class="fleet__header">

      <!-- Texto alineado a la derecha -->
      <div class="fleet__header-text">

        <p class="fleet__overline">
          {lang === 'es' ? 'Nuestra Flota' : 'Our Fleet'}
        </p>

        <h2 class="fleet__title" id="fleet-heading">
          {lang === 'es'
            ? <>Aeronaves certificadas<br/>y listas</>
            : <>Certified aircraft,<br/>ready to fly</>
          }
        </h2>

      </div>

      <!-- Logo avión GRANDE — flush derecho, escala del H2 -->
      <img
        src="/assets/recurso%20logo%20avion%20helitec%20(1).png"
        class="fleet__plane-deco"
        alt=""
        aria-hidden="true"
        loading="lazy"
        decoding="async"
      />

    </header>

  </div>

  <!-- ── Fotos decorativas ─────────────────────────────────────────────────
    Colocadas fuera de .fleet__inner para no heredar su padding.
    Así pueden tocar el borde real de la sección (izquierdo y derecho).
    El fondo negro de las imágenes se funde con --c-bg del sitio.
  ──────────────────────────────────────────────────────────────────────── -->
  <div class="fleet__deco">

    <!--
      Foto 1 — avión de frente/lateral, fondo negro.
      2/3 del ancho de la sección, anclada al borde IZQUIERDO.
    -->
    <img
      src="/assets/avion_helitec_sinfondo.png"
      class="fleet__deco-img fleet__deco-img--left"
      alt="Aeronave Consorcio Helitec — vista lateral"
      loading="lazy"
      decoding="async"
    />

    <!--
      Foto 2 — tres aeronaves en línea (colas YV147T · YV185T · YV221T).
      2/3 del ancho de la sección, anclada al borde DERECHO.
    -->
    <img
      src="/assets/tres_avion_helitec_sinfondo.png"
      class="fleet__deco-img fleet__deco-img--right"
      alt="Flota Consorcio Helitec — tres aeronaves en línea"
      loading="lazy"
      decoding="async"
    />

  </div>

</section>


<style>
  /* ════════════════════════════════════════════════════════════════════════
     SECCIÓN
  ════════════════════════════════════════════════════════════════════════ */

  .fleet {
    background-color: var(--c-bg);
    border-top:       1px solid var(--c-line);
    padding-top:      clamp(56px, 9vh, 104px);
    overflow:         hidden; /* evita scroll horizontal si las fotos sobresalen */
  }

  .fleet__inner {
    max-width:      var(--content-max);
    margin-inline:  auto;
    padding-inline: calc(var(--sidebar-w) + var(--gutter));
  }

  /* ════════════════════════════════════════════════════════════════════════
     ENCABEZADO — overline + H2 (right) · logo flush derecho
  ════════════════════════════════════════════════════════════════════════ */

  .fleet__header {
    display:         flex;
    align-items:     flex-start;
    justify-content: space-between;
    gap:             clamp(32px, 6vw, 80px);
    margin-bottom:   clamp(36px, 5vh, 52px);
  }

  /* Bloque de texto — right-aligned */
  .fleet__header-text {
    flex:       1;
    min-width:  0;
    text-align: right;
  }

  .fleet__overline {
    display:         flex;
    align-items:     center;
    justify-content: flex-end; /* línea a la derecha del texto */
    gap:             12px;

    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);

    margin-bottom: 14px;
  }

  /* Línea decorativa — aparece a la derecha del texto */
  .fleet__overline::after {
    content:          '';
    display:          block;
    flex-shrink:      0;
    width:            32px;
    height:           1px;
    background-color: var(--c-sky);
  }

  .fleet__title {
    font-family:    var(--font-display);
    font-size:      var(--text-2xl);
    font-weight:    var(--fw-thin); /* 200 — OBLIGATORIO */
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    line-height:    1.1;
    color:          var(--c-text-1);
  }

  /*
   * Logo avión — flush derecho, a escala del bloque H2.
   * align-self: flex-start → ancla con el overline (top-aligned).
   */
  .fleet__plane-deco {
    height:      clamp(100px, 14vw, 160px);
    width:       auto;
    object-fit:  contain;
    opacity:     0.70;
    flex-shrink: 0;
    align-self:  flex-start;
  }

  /* ════════════════════════════════════════════════════════════════════════
     FOTOS DECORATIVAS
     Fuera de .fleet__inner → sin padding, van de borde a borde.
  ════════════════════════════════════════════════════════════════════════ */

  .fleet__deco {
    display:        flex;
    flex-direction: column;
    /*
     * Sin gap: los fondos negros de las imágenes se funden entre sí
     * y con el fondo del sitio, creando un espacio "aéreo" continuo.
     */
  }

  .fleet__deco-img {
    display:    block;
    width:      66.667%; /* 2/3 del ancho de la sección */
    height:     auto;
    object-fit: contain; /* proporciones naturales, sin recorte */
  }

  /* Foto 1 — borde izquierdo */
  .fleet__deco-img--left {
    align-self: flex-start;
  }

  /* Foto 2 — borde derecho */
  .fleet__deco-img--right {
    align-self: flex-end;
  }

  /* ════════════════════════════════════════════════════════════════════════
     RESPONSIVE
  ════════════════════════════════════════════════════════════════════════ */

  @media (max-width: 1023px) {
    .fleet__inner {
      padding-inline: var(--gutter);
    }
  }

  @media (max-width: 767px) {
    .fleet__header {
      gap: clamp(12px, 4vw, 20px);
    }

    .fleet__plane-deco {
      height: clamp(64px, 20vw, 96px);
    }

    /* Más ancho en móvil para que el avión no quede diminuto */
    .fleet__deco-img {
      width: 82%;
    }
  }

  @media (max-width: 479px) {
    .fleet__deco-img {
      width: 92%;
    }
  }
</style>
