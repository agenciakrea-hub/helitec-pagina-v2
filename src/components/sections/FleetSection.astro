---
/**
 * FleetSection.astro — "Ingeniería del Servicio"  v3 (Motor Scroll VANDSLAB)
 * Consorcio Helitec
 *
 * Layout: 2 columnas desktop / apilado mobile
 *   · Col izq (sticky): H2 de 4 capas animadas por scroll
 *   · Col der:           FAQ acordeón, entra desde el borde derecho
 *   · Fondo:             Logo avión gigante absolute right
 *
 * Motor de animación (scroll-driven, 60fps):
 *   IntersectionObserver → activa scroll listener solo cuando la sección
 *   está en el viewport (performance). requestAnimationFrame suaviza la
 *   escritura de transforms. progreso 0→1 mapeado a través de la sección.
 *
 *   Timelines (todos completos ≈ progress 0.48 = "centro del scroll"):
 *     layer-outline  0.05–0.30 → translateY(-60px → 0) + opacity
 *     layer-solid    0.10–0.35 → translateX(-100px → 0) + opacity
 *     layer-accent   0.15–0.40 → translateX(+60px → 0) + opacity
 *     layer-base     0.03–0.25 → opacity solo (ancla estática)
 *     faq-module     0.10–0.48 → translateX(100vw → 0) + opacity
 *
 *   Mobile (<768px):
 *     Sólo movimiento vertical sutil + opacity (sin horizontales)
 *     para evitar overflow lateral en pantallas estrechas.
 *
 * Anti-slop compliance:
 *   ✓ PROHIBIDO box-shadow
 *   ✓ PROHIBIDO linear-gradient decorativo
 *   ✓ border-radius ≤ 4px
 *   ✓ font-weight 700 en capas "pesadas" — decisión explícita del Tech Lead
 *     (referencia VANDSLAB); regla fw:200-300 aplica a titulares estándar
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const faqItems = [
  {
    q: '¿QUÉ VENTAJAS TIENE UN VUELO CHÁRTER EJECUTIVO FRENTE A UN VUELO COMERCIAL?',
    a: 'Flexibilidad total en rutas, privacidad y confort con cabinas VIP, y eficiencia absoluta evitando filas y demoras en terminales masivas.',
  },
  {
    q: '¿QUÉ CERTIFICACIONES DE SEGURIDAD POSEE CONSORCIO HELITEC C.A.?',
    a: 'Operamos bajo estrictos estándares: SMS certificado por el INAC, Mantenimiento predictivo en tiempo real, y tripulaciones expertas con más de 10,000 horas de vuelo.',
  },
  {
    q: '¿CUÁNTO CUESTA UN VUELO CHÁRTER EJECUTIVO?',
    a: 'El costo es personalizado según: tipo de aeronave seleccionada, distancia y tasas aeroportuarias, y servicios adicionales como catering a la carta o traslados blindados.',
  },
  {
    q: '¿PUEDEN OPERAR VUELOS MÉDICOS DE EMERGENCIA?',
    a: 'Sí. Operamos en alianza con Aeroambulancia Silva, ofreciendo auténticas UCI móviles, repatriaciones sanitarias expeditivas y respuesta inmediata 24/7.',
  },
  {
    q: '¿CÓMO OPTIMIZAMOS LA LOGÍSTICA EN PLATAFORMAS PETROLERAS?',
    a: 'A través de operaciones en enclaves remotos, estricto cumplimiento de normativas de Seguridad y Salud Laboral (SST) exigidas por consorcios, y flota comercial versátil de alta densidad.',
  },
];
---


<section class="ops" id="flota" aria-labelledby="ops-heading" data-ops-section>

  <!--
    Logo avión gigante — decorativo, fondo absoluto.
    right: 0 → toca el borde real del viewport (section = 100% ancho).
    z-index: 0 + pointer-events: none → bajo todo el contenido interactivo.
  -->
  <img
    src="/assets/recurso%20logo%20avion%20helitec%20(1).png"
    class="ops__plane-deco"
    alt=""
    aria-hidden="true"
    loading="lazy"
    decoding="async"
  />

  <div class="ops__inner">

    <!-- ══ COL IZQUIERDA — Tipografía desarmada (sticky) ═══════════════════ -->
    <div class="ops__left">
      <header class="ops__header">

        <p class="ops__overline">
          {lang === 'es' ? 'Ingeniería del Servicio' : 'Service Engineering'}
        </p>

        <!--
          H2 en 4 capas independientes. Cada span tiene:
          · data-layer="*"   → hook JS (sin acoplamiento a clases)
          · will-change en CSS → hint al compositor GPU
          JS sobreescribe transform/opacity mediante rAF en cada scroll tick.
        -->
        <h2 class="ops__title" id="ops-heading">
          <span class="ops__title-layer layer-outline" data-layer="outline">
            SOBRE NUESTRAS
          </span>
          <span class="ops__title-layer layer-solid" data-layer="solid">
            OPERACIONES,
          </span>
          <span class="ops__title-layer layer-accent" data-layer="accent">
            FLOTA
          </span>
          <span class="ops__title-layer layer-base" data-layer="base">
            Y SERVICIOS.
          </span>
        </h2>

      </header>
    </div>

    <!-- ══ COL DERECHA — FAQ Acordeón ══════════════════════════════════════ -->
    <div class="ops__right">

      <div
        class="faq-module"
        data-faq-module
        role="list"
        aria-label="Preguntas frecuentes"
      >

        {faqItems.map((item, i) => (
          <div class="faq-item" role="listitem" data-faq-item>

            <button
              class="faq-trigger"
              type="button"
              aria-expanded="false"
              data-faq-trigger
            >
              <span class="faq-trigger__text">{item.q}</span>
              <span class="faq-trigger__icon" aria-hidden="true">+</span>
            </button>

            <div class="faq-panel" data-faq-panel>
              <div class="faq-panel__inner">
                <p class="faq-panel__text">{item.a}</p>
              </div>
            </div>

          </div>
        ))}

      </div><!-- /.faq-module -->

    </div><!-- /.ops__right -->

  </div><!-- /.ops__inner -->
</section>


<style>
  /* ════════════════════════════════════════════════════════════════════════
     SECCIÓN CONTENEDOR
  ════════════════════════════════════════════════════════════════════════ */

  .ops {
    position:         relative;   /* anchor para el logo absolute */
    background-color: var(--c-bg);
    border-top:       1px solid var(--c-line);
    padding-block:    clamp(72px, 11vh, 120px);
    overflow:         hidden;     /* recorta translateX de todas las capas — mobile y desktop */
  }


  /* ════════════════════════════════════════════════════════════════════════
     LOGO AVIÓN DE FONDO
  ════════════════════════════════════════════════════════════════════════ */

  .ops__plane-deco {
    position:         absolute;
    right:            0;
    top:              clamp(180px, 26vh, 240px);

    height:           clamp(420px, 58vw, 720px);
    width:            auto;

    object-fit:       contain;
    object-position:  right top;

    opacity:          0.18;
    z-index:          0;
    pointer-events:   none;
    user-select:      none;
  }


  /* ════════════════════════════════════════════════════════════════════════
     GRID PRINCIPAL — 2 COLUMNAS (desktop) / APILADO (mobile)
  ════════════════════════════════════════════════════════════════════════ */

  .ops__inner {
    position:       relative;  /* stacking context sobre el logo (z:0) */
    z-index:        1;

    max-width:      var(--content-max);
    margin-inline:  auto;
    padding-inline: calc(var(--sidebar-w) + var(--gutter));

    display:               grid;
    grid-template-columns: 5fr 7fr;
    gap:                   clamp(48px, 7vw, 96px);
    align-items:           start;
  }

  /* Col izquierda sticky — el título permanece visible
     mientras el usuario scrollea el acordeón */
  .ops__left {
    position: sticky;
    top:      calc(var(--header-h) + 32px);  /* 68px header + margen */
  }


  /* ════════════════════════════════════════════════════════════════════════
     OVERLINE
  ════════════════════════════════════════════════════════════════════════ */

  .ops__overline {
    display:     flex;
    align-items: center;
    gap:         12px;

    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);

    margin-bottom: clamp(20px, 3vh, 32px);
  }

  .ops__overline::before {
    content:          '';
    display:          block;
    flex-shrink:      0;
    width:            32px;
    height:           1px;
    background-color: var(--c-sky);
  }


  /* ════════════════════════════════════════════════════════════════════════
     H2 DESARMADO — 4 CAPAS TIPOGRÁFICAS
  ════════════════════════════════════════════════════════════════════════ */

  .ops__title {
    display:        flex;
    flex-direction: column;
    gap:            0.1em;

    font-family:    var(--font-display);
    font-size:      clamp(2.25rem, 5vw, 4.25rem);
    letter-spacing: 0.02em;
    line-height:    1.0;
    text-transform: uppercase;
  }

  .ops__title-layer {
    display:    block;
    /*
     * GPU compositing hint: el motor JS actualiza transform/opacity en rAF.
     * will-change promueve cada capa a su propia layer del compositor,
     * garantizando actualizaciones sin reflow (60fps incluso en mobile).
     */
    will-change: transform, opacity;
  }

  /* Rojo Helitec sólido */
  .layer-outline {
    color:       var(--c-red);   /* #e53b1c */
    font-weight: 700;
  }

  /* Blanco puro, pesado */
  .layer-solid {
    color:       var(--c-text-1);
    font-weight: 700;
  }

  /* Azul Helitec */
  .layer-accent {
    color:       var(--c-sky);   /* #58b5f0 */
    font-weight: 700;
  }

  /* Blanco puro, pesado — ancla estática (solo opacity) */
  .layer-base {
    color:       var(--c-text-1);
    font-weight: 700;
  }


  /* ════════════════════════════════════════════════════════════════════════
     FAQ MODULE — hint GPU para el slide-in desde el borde derecho
  ════════════════════════════════════════════════════════════════════════ */

  .faq-module {
    display:        flex;
    flex-direction: column;
    will-change:    transform, opacity;
  }


  /* ════════════════════════════════════════════════════════════════════════
     FAQ ITEMS
  ════════════════════════════════════════════════════════════════════════ */

  .faq-item {
    border-bottom: 1px solid var(--c-line);
  }

  .faq-item:first-child {
    border-top: 1px solid var(--c-line);
  }


  /* ════════════════════════════════════════════════════════════════════════
     FAQ TRIGGER
  ════════════════════════════════════════════════════════════════════════ */

  .faq-trigger {
    width:           100%;
    display:         flex;
    align-items:     flex-start;
    justify-content: space-between;
    gap:             var(--sp-5);

    padding-block:   var(--sp-5);
    padding-inline:  0;

    background:      none;
    border:          none;
    cursor:          pointer;
    text-align:      left;
  }

  .faq-trigger:hover {
    background: none;
  }

  .faq-trigger:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
    border-radius:  2px;
  }

  .faq-trigger__text {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-2);
    line-height:    1.6;

    transition: color var(--dur-fast) var(--ease-out);
  }

  .faq-trigger:hover .faq-trigger__text,
  .faq-item.is-open  .faq-trigger__text {
    color: var(--c-text-1);
  }

  .faq-trigger__icon {
    flex-shrink:     0;
    width:           20px;
    height:          20px;
    margin-top:      1px;

    display:         flex;
    align-items:     center;
    justify-content: center;

    font-size:   1.1rem;
    font-weight: var(--fw-light);
    line-height: 1;
    color:       var(--c-sky);

    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-item.is-open .faq-trigger__icon {
    transform: rotate(45deg);
  }


  /* ════════════════════════════════════════════════════════════════════════
     FAQ PANEL
  ════════════════════════════════════════════════════════════════════════ */

  .faq-panel {
    max-height: 0;
    overflow:   hidden;
    transition: max-height 420ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-panel__inner {
    padding-bottom: var(--sp-5);
  }

  .faq-panel__text {
    font-family:  var(--font-sans);
    font-size:    var(--text-sm);
    font-weight:  var(--fw-light);
    line-height:  1.75;
    color:        var(--c-text-3);
  }


  /* ════════════════════════════════════════════════════════════════════════
     RESPONSIVE
  ════════════════════════════════════════════════════════════════════════ */

  @media (max-width: 1023px) {
    .ops__inner {
      grid-template-columns: 1fr;
      padding-inline:        var(--gutter);
      gap:                   clamp(40px, 8vw, 56px);
    }

    .ops__left {
      position: static;  /* Sin sticky en mobile */
    }
  }

  @media (max-width: 479px) {
    .ops__title {
      font-size: clamp(1.875rem, 10vw, 2.5rem);
    }

    .faq-trigger {
      padding-block: var(--sp-4);
    }
  }
</style>


<script>
  /**
   * ══════════════════════════════════════════════════════════════════════════
   * PARTE 1 — FAQ Acordeón (Vanilla JS)
   *
   * · Click → abre/cierra panel con max-height real (scrollHeight)
   * · Solo un panel abierto a la vez
   * · aria-expanded sincronizado
   * ══════════════════════════════════════════════════════════════════════════
   */
  (function () {
    var items = /** @type {NodeListOf<HTMLElement>} */ (
      document.querySelectorAll('[data-faq-item]')
    );
    if (!items.length) return;

    /** @param {HTMLElement} item */
    function closeItem(item) {
      var panel   = /** @type {HTMLElement|null} */ (item.querySelector('[data-faq-panel]'));
      var trigger = item.querySelector('[data-faq-trigger]');
      item.classList.remove('is-open');
      if (panel)   panel.style.maxHeight = '0';
      if (trigger) trigger.setAttribute('aria-expanded', 'false');
    }

    /** @param {HTMLElement} item */
    function openItem(item) {
      var panel   = /** @type {HTMLElement|null} */ (item.querySelector('[data-faq-panel]'));
      var trigger = item.querySelector('[data-faq-trigger]');
      var inner   = panel && /** @type {HTMLElement|null} */ (panel.querySelector('.faq-panel__inner'));
      item.classList.add('is-open');
      if (panel && inner) panel.style.maxHeight = inner.scrollHeight + 'px';
      if (trigger) trigger.setAttribute('aria-expanded', 'true');
    }

    items.forEach(function (item) {
      var trigger = item.querySelector('[data-faq-trigger]');
      if (!trigger) return;
      trigger.addEventListener('click', function () {
        var wasOpen = item.classList.contains('is-open');
        items.forEach(closeItem);
        if (!wasOpen) openItem(item);
      });
    });
  })();


  /**
   * ══════════════════════════════════════════════════════════════════════════
   * PARTE 2 — Motor de Scroll VANDSLAB
   *
   * Arquitectura:
   *   · IntersectionObserver observa [data-ops-section]
   *   · Al entrar en viewport → activa scroll listener
   *   · Al salir → remueve scroll listener (performance)
   *   · scroll handler → encola un requestAnimationFrame (un frame por tick)
   *   · applyFrame() calcula progress y escribe transforms/opacity
   *
   * Progress (p):
   *   p = 0  → tope de la sección toca el borde inferior del viewport
   *   p = 0.5 → centro de la sección = centro del viewport (≈ fully assembled)
   *   p = 1  → sección sale completamente por arriba del viewport
   *
   * Timelines (start, end):
   *   layer-outline  → [0.05, 0.30]  translateY(-60→0) + opacity
   *   layer-solid    → [0.10, 0.35]  translateX(-100→0) + opacity
   *   layer-accent   → [0.15, 0.40]  translateX(+60→0) + opacity
   *   layer-base     → [0.03, 0.25]  opacity solo (ancla)
   *   faq-module     → [0.10, 0.48]  translateX(vw→0) + opacity
   *
   * Mobile (<768px):
   *   Solo movimiento vertical sutil + opacity (sin horizontales).
   *   Evita overflow lateral en pantallas estrechas.
   *
   * prefers-reduced-motion:
   *   Si el usuario prefiere movimiento reducido, se muestran todos los
   *   elementos en su estado final sin animación.
   * ══════════════════════════════════════════════════════════════════════════
   */
  (function () {

    /* ── Selección de elementos ──────────────────────────────────────────── */

    var section   = /** @type {HTMLElement|null} */ (document.querySelector('[data-ops-section]'));
    var faqModule = /** @type {HTMLElement|null} */ (section && section.querySelector('[data-faq-module]'));
    var lOutline  = /** @type {HTMLElement|null} */ (section && section.querySelector('[data-layer="outline"]'));
    var lSolid    = /** @type {HTMLElement|null} */ (section && section.querySelector('[data-layer="solid"]'));
    var lAccent   = /** @type {HTMLElement|null} */ (section && section.querySelector('[data-layer="accent"]'));
    var lBase     = /** @type {HTMLElement|null} */ (section && section.querySelector('[data-layer="base"]'));

    if (!section || !faqModule || !lOutline || !lSolid || !lAccent || !lBase) return;


    /* ── Reducción de movimiento (accesibilidad) ────────────────────────── */

    var mql = window.matchMedia('(prefers-reduced-motion: reduce)');

    if (mql.matches) {
      /* Mostrar todo en estado final sin animación */
      [lOutline, lSolid, lAccent, lBase, faqModule].forEach(function (el) {
        el.style.opacity   = '1';
        el.style.transform = 'none';
      });
      return;
    }


    /* ── Utilidades matemáticas ─────────────────────────────────────────── */

    /** @param {number} v */
    function clamp01(v) { return v < 0 ? 0 : v > 1 ? 1 : v; }

    /**
     * Mapea v del rango [lo, hi] a [0, 1] con clamping.
     * @param {number} v @param {number} lo @param {number} hi
     */
    function mapRange(v, lo, hi) { return clamp01((v - lo) / (hi - lo)); }

    /**
     * easeOutCubic: rápido al inicio, deceleración premium al final.
     * @param {number} t
     */
    function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

    /**
     * Interpolación lineal.
     * @param {number} a @param {number} b @param {number} t
     */
    function lerp(a, b, t) { return a + (b - a) * t; }


    /* ── Detección de mobile ─────────────────────────────────────────────── */

    var isMobile = false;

    function detectMobile() {
      isMobile = window.innerWidth < 768;
    }
    detectMobile();
    window.addEventListener('resize', detectMobile, { passive: true });


    /* ── Estado inicial — JS escribe antes del primer paint ─────────────── */
    /*
     * Las capas empiezan ocultas/desplazadas. JS las anima al estado final.
     * Se establece ANTES del primer frame visible para evitar FOUC.
     * Si JS no carga: el CSS muestra los elementos sin opacity (legibles).
     */

    function setInitialState() {
      /*
       * Mobile y desktop comparten la misma lógica direccional (Tetris).
       * La diferencia es la DISTANCIA del desplazamiento: más corta en mobile
       * para que el recorrido sea proporcional al viewport estrecho.
       * overflow: hidden en .ops recorta cualquier overflow visual.
       */
      lOutline.style.opacity   = '0';
      lOutline.style.transform = isMobile ? 'translateY(-30px)' : 'translateY(-60px)';

      lSolid.style.opacity     = '0';
      lSolid.style.transform   = isMobile ? 'translateX(-40px)' : 'translateX(-100px)';

      lAccent.style.opacity    = '0';
      lAccent.style.transform  = isMobile ? 'translateX(40px)' : 'translateX(60px)';

      lBase.style.opacity      = '0';
      lBase.style.transform    = 'none';  /* ancla estática */

      faqModule.style.opacity   = '0';
      /* FAQ: entra desde la derecha.
         Mobile → 20vw (derrape suave proporcional al ancho de pantalla).
         Desktop → 100vw (entrada dramática desde fuera del viewport). */
      faqModule.style.transform = 'translateX(' + Math.round(window.innerWidth * (isMobile ? 0.20 : 1.0)) + 'px)';
    }

    setInitialState();


    /* ── Cálculo de progreso ────────────────────────────────────────────── */

    function getProgress() {
      var rect  = section.getBoundingClientRect();
      var vh    = window.innerHeight;
      /*
       * Fórmula: (vh - rect.top) / (sectionHeight + vh)
       * · p = 0 cuando rect.top = vh  (sección justo entrando por abajo)
       * · p = 0.5 cuando el centro de la sección = centro del viewport
       * · p = 1 cuando rect.bottom = 0 (sección completamente arriba)
       */
      return clamp01((vh - rect.top) / (rect.height + vh));
    }


    /* ── Escritura de animaciones ───────────────────────────────────────── */

    var lastP = -1;  /* evita escrituras innecesarias al DOM */

    function applyFrame() {
      var p = getProgress();

      /* Saltar si el progreso no cambió significativamente */
      if (Math.abs(p - lastP) < 0.0005) return;
      lastP = p;

      /*
       * Progresiones individuales por timeline.
       * mapRange(p, start, end) → 0→1 sólo en esa ventana de scroll.
       * easeOut() → deceleración premium (siente pesado y lujoso).
       */
      var p0   = easeOut(mapRange(p, 0.05, 0.30));  /* layer-outline  */
      var p1   = easeOut(mapRange(p, 0.10, 0.35));  /* layer-solid    */
      var p2   = easeOut(mapRange(p, 0.15, 0.40));  /* layer-accent   */
      var p3   = easeOut(mapRange(p, 0.03, 0.25));  /* layer-base     */
      var pFaq = easeOut(mapRange(p, 0.10, 0.48));  /* faq-module     */

      if (isMobile) {
        /*
         * ── Mobile Tetris — distancias cortas, efecto completo ────────
         * Misma dirección que desktop, valores escalados al viewport estrecho.
         * overflow: hidden en .ops recorta el desbordamiento visual.
         *
         * layer-outline  → baja desde arriba    translateY(-30 → 0)
         * layer-solid    → entra desde izquierda translateX(-40 → 0)
         * layer-accent   → entra desde derecha   translateX( 40 → 0)
         * layer-base     → opacity solo (ancla)
         * faq-module     → derrape desde derecha translateX(20vw → 0)
         */
        lOutline.style.opacity   = p0.toFixed(3);
        lOutline.style.transform = 'translateY(' + lerp(-30, 0, p0).toFixed(1) + 'px)';

        lSolid.style.opacity     = p1.toFixed(3);
        lSolid.style.transform   = 'translateX(' + lerp(-40, 0, p1).toFixed(1) + 'px)';

        lAccent.style.opacity    = p2.toFixed(3);
        lAccent.style.transform  = 'translateX(' + lerp(40, 0, p2).toFixed(1) + 'px)';

        lBase.style.opacity      = lerp(0, 1, p3).toFixed(3);

        faqModule.style.opacity   = pFaq.toFixed(3);
        /* 20vw calculado en cada frame respeta cambios de orientación */
        faqModule.style.transform = 'translateX(' + lerp(Math.round(window.innerWidth * 0.20), 0, pFaq).toFixed(1) + 'px)';

      } else {
        /* ── Desktop: efecto Tetris direccional completo ──────────────── */

        lOutline.style.opacity   = p0.toFixed(3);
        lOutline.style.transform = 'translateY(' + lerp(-60, 0, p0).toFixed(2) + 'px)';

        lSolid.style.opacity     = p1.toFixed(3);
        lSolid.style.transform   = 'translateX(' + lerp(-100, 0, p1).toFixed(2) + 'px)';

        lAccent.style.opacity    = p2.toFixed(3);
        lAccent.style.transform  = 'translateX(' + lerp(60, 0, p2).toFixed(2) + 'px)';

        lBase.style.opacity      = lerp(0, 1, p3).toFixed(3);

        faqModule.style.opacity   = pFaq.toFixed(3);
        /*
         * window.innerWidth: calculado en cada frame para respetar resize.
         * Funciona con Lenis smooth scroll — window.scrollY refleja posición real.
         */
        faqModule.style.transform = 'translateX(' + lerp(window.innerWidth, 0, pFaq).toFixed(1) + 'px)';
      }
    }


    /* ── Loop rAF — un único frame encolado por tick de scroll ──────────── */

    var scrollPending = false;

    function onScroll() {
      if (!scrollPending) {
        scrollPending = true;
        requestAnimationFrame(function () {
          applyFrame();
          scrollPending = false;
        });
      }
    }


    /* ── IntersectionObserver ───────────────────────────────────────────── */
    /*
     * Activa el scroll listener SOLO mientras la sección es visible.
     * Evita N listeners activos simultáneos en páginas largas.
     * threshold: 0 → activa en cuanto cualquier píxel entra en el viewport.
     */

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            window.addEventListener('scroll', onScroll, { passive: true });
            applyFrame();   /* frame inmediato al entrar */
          } else {
            window.removeEventListener('scroll', onScroll);
          }
        });
      },
      { rootMargin: '0px', threshold: 0 }
    );

    observer.observe(section);

    /* Frame inicial: si la página carga con la sección ya visible */
    applyFrame();

  })();
</script>
