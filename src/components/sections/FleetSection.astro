---
/**
 * FleetSection.astro — "Ingeniería del Servicio"
 * Consorcio Helitec
 *
 * Motor scroll: ventana (sectionHeight + vh) — fórmula original.
 * Mobile Tetris: translateY(-30) / translateX(±40) / translateX(20vw).
 * Legibilidad FAQ: opacidad logo 0.15 + backdrop blur en .faq-module.
 * Highlight sweeps: <span class="hl"> con delay al abrir acordeón.
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

/*
 * Respuestas con markup HTML — renderizadas con set:html en el template.
 * <span class="hl">...</span> marca frases para el efecto de resaltado.
 */
const faqItems = [
  {
    q: '¿QUÉ VENTAJAS TIENE UN VUELO CHÁRTER EJECUTIVO FRENTE A UN VUELO COMERCIAL?',
    a: '<span class="hl">Flexibilidad total</span> en rutas, privacidad y confort con cabinas VIP, y <span class="hl">eficiencia absoluta</span> evitando filas y demoras en terminales masivas.',
  },
  {
    q: '¿QUÉ CERTIFICACIONES DE SEGURIDAD POSEE CONSORCIO HELITEC C.A.?',
    a: 'SMS <span class="hl">certificado por la Autoridad Aeronáutica Venezolana (INAC)</span>, <span class="hl">Mantenimiento Predictivo</span> en tiempo real, y <span class="hl">Tripulaciones Expertas</span> con más de 10.000 horas de vuelo.',
  },
  {
    q: '¿CUÁNTO CUESTA UN VUELO CHÁRTER EJECUTIVO?',
    a: '<span class="hl">El costo de una operación privada se estructura de manera personalizada</span>: tipo de aeronave, distancia, tasas aeroportuarias y servicios como catering a la carta o traslados blindados.',
  },
  {
    q: '¿PUEDEN OPERAR VUELOS MÉDICOS DE EMERGENCIA?',
    a: 'Sí. Operamos en <span class="hl">alianza estratégica directa con Aeroambulancia Silva</span>, ofreciendo auténticas UCI móviles, repatriaciones sanitarias expeditivas y respuesta inmediata 24/7.',
  },
  {
    q: '¿CÓMO OPTIMIZAMOS LA LOGÍSTICA EN PLATAFORMAS PETROLERAS?',
    a: '<span class="hl">Operaciones en Enclaves Remotos</span>, <span class="hl">Cumplimiento riguroso de normativas</span> de SST exigidas por consorcios, y <span class="hl">Configuración de Flota Comercial Versátil</span> de alta densidad.',
  },
];
---


<section class="ops" id="flota" aria-labelledby="ops-heading" data-ops-section>

  <img
    src="/assets/recurso%20logo%20avion%20helitec%20(1).png"
    class="ops__plane-deco"
    alt=""
    aria-hidden="true"
    loading="lazy"
    decoding="async"
  />

  <div class="ops__inner">

    <!-- ══ COL IZQUIERDA — Tipografía desarmada (sticky en desktop) ════════ -->
    <div class="ops__left">
      <header class="ops__header">

        <p class="ops__overline">
          {lang === 'es' ? 'Ingeniería del Servicio' : 'Service Engineering'}
        </p>

        <h2 class="ops__title" id="ops-heading">
          <span class="ops__title-layer layer-outline" data-layer="outline">
            SOBRE NUESTRAS
          </span>
          <span class="ops__title-layer layer-solid" data-layer="solid">
            OPERACIONES,
          </span>
          <span class="ops__title-layer layer-accent" data-layer="accent">
            FLOTA
          </span>
          <span class="ops__title-layer layer-base" data-layer="base">
            Y SERVICIOS.
          </span>
        </h2>

      </header>
    </div>

    <!-- ══ COL DERECHA — FAQ Acordeón ══════════════════════════════════════ -->
    <div class="ops__right">

      <div
        class="faq-module"
        data-faq-module
        role="list"
        aria-label="Preguntas frecuentes"
      >

        {faqItems.map((item) => (
          <div class="faq-item" role="listitem" data-faq-item>

            <button
              class="faq-trigger"
              type="button"
              aria-expanded="false"
              data-faq-trigger
            >
              <span class="faq-trigger__text">{item.q}</span>
              <span class="faq-trigger__icon" aria-hidden="true">+</span>
            </button>

            <div class="faq-panel" data-faq-panel>
              <div class="faq-panel__inner">
                <!--
                  set:html renderiza el markup con <span class="hl"> para highlights.
                  Las clases .hl e .hl.is-highlighted son :global en el <style>.
                -->
                <p class="faq-panel__text" set:html={item.a}></p>
              </div>
            </div>

          </div>
        ))}

      </div>

    </div>

  </div>
</section>


<style>
  /* ════════════════════════════════════════════════════════════════════════
     SECCIÓN
  ════════════════════════════════════════════════════════════════════════ */

  .ops {
    position:         relative;
    background-color: var(--c-bg);
    border-top:       none; /* eliminado — sin líneas divisorias entre secciones */
    padding-block:    clamp(72px, 11vh, 120px);

    /*
     * overflow: hidden — CRÍTICO: hace DOS cosas simultáneas que son necesarias:
     *   1. Clipa visualmente el .ops__plane-deco (position:absolute, h:720px)
     *      que desborda por abajo y por la derecha del contenedor.
     *   2. Suprime el position:sticky de .ops__left (CSS spec: sticky queda
     *      desactivado por cualquier ancestro con scroll container). Esto es
     *      INTENCIONAL — el título debe scrollear con la página en el layout
     *      actual (sin sticky real activado).
     *
     * NUNCA reemplazar por overflow-x:clip aquí — hacerlo desbloquea el sticky
     * y elimina el clip vertical, creando el espacio negro gigante reportado.
     *
     * Fix para el scroll-freeze de iOS está en el JS: eliminando el translateX
     * del faqModule en mobile (ver setInitialState y applyFrame abajo).
     */
    overflow: hidden;
  }


  /* ════════════════════════════════════════════════════════════════════════
     LOGO AVIÓN DE FONDO
     Reducido a opacity: 0.15 para mejorar legibilidad del FAQ.
  ════════════════════════════════════════════════════════════════════════ */

  .ops__plane-deco {
    position:        absolute;
    right:           0;
    top:             clamp(60px, 8vh, 100px);

    height:          clamp(420px, 58vw, 720px);
    width:           auto;

    object-fit:      contain;
    object-position: right top;

    /* Estado inicial — motor V7: CSS transition, no JS */
    opacity:         0;
    transform:       translateX(60px);
    z-index:         0;
    pointer-events:  none;
    user-select:     none;
    will-change:     transform, opacity;
    transition:
      opacity   800ms var(--ease-out) 250ms,
      transform 800ms var(--ease-out) 250ms;
  }

  .ops--in-view .ops__plane-deco {
    opacity:   0.4;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .ops__plane-deco { transition: none; opacity: 0.4; transform: none; }
  }


  /* ════════════════════════════════════════════════════════════════════════
     GRID PRINCIPAL
  ════════════════════════════════════════════════════════════════════════ */

  .ops__inner {
    position:       relative;
    z-index:        1;

    max-width:      var(--content-max);
    margin-inline:  auto;
    padding-inline: calc(var(--sidebar-w) + var(--gutter));

    display:               grid;
    grid-template-columns: 5fr 7fr;
    gap:                   clamp(48px, 7vw, 96px);
    align-items:           start;
  }

  .ops__left {
    position: sticky;
    top:      calc(var(--header-h) + 32px);
  }


  /* ════════════════════════════════════════════════════════════════════════
     OVERLINE
  ════════════════════════════════════════════════════════════════════════ */

  .ops__overline {
    display:     flex;
    align-items: center;
    gap:         12px;

    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);

    margin-bottom: clamp(20px, 3vh, 32px);

    /* Entrada: fade-in rápido — aparece antes que los chars del título */
    opacity:    0;
    transition: opacity 450ms var(--ease-out);
  }

  .ops--in-view .ops__overline {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .ops__overline { transition: none; opacity: 1; }
  }

  .ops__overline::before {
    content:          '';
    display:          block;
    flex-shrink:      0;
    width:            32px;
    height:           1px;
    background-color: var(--c-sky);
  }


  /* ════════════════════════════════════════════════════════════════════════
     H2 — 4 CAPAS TIPOGRÁFICAS
  ════════════════════════════════════════════════════════════════════════ */

  .ops__title {
    display:        flex;
    flex-direction: column;
    gap:            0.1em;

    font-family:    var(--font-display);
    font-size:      clamp(2.25rem, 5vw, 4.25rem);
    letter-spacing: 0.02em;
    line-height:    1.0;
    text-transform: uppercase;
  }

  .ops__title-layer {
    display:        block;
    pointer-events: none; /* defensa táctil: los spans no interceptan toques */
    /* will-change eliminado — motor V7 anima .char, no el layer */
  }

  .layer-outline {
    color:       var(--c-red);
    font-weight: 700;
  }

  .layer-solid {
    color:       var(--c-text-1);
    font-weight: 700;
  }

  .layer-accent {
    color:       var(--c-sky);
    font-weight: 700;
  }

  .layer-base {
    color:       var(--c-text-1);
    font-weight: 700;
  }


  /* ════════════════════════════════════════════════════════════════════════
     CHARS — SplitText motor V7
     Cada letra del título queda envuelta en <span class="char"> por JS.
     --char-i: índice global continuo (acumulado entre las 4 capas) → el
     cascade fluye sin cortes entre "SOBRE NUESTRAS" → "Y SERVICIOS."
  ════════════════════════════════════════════════════════════════════════ */

  /*
   * :global(.char) — OBLIGATORIO para spans creados dinámicamente por JS.
   *
   * Astro compila el CSS con scope: `.char[data-astro-cid-xxx]`.
   * Los <span class="char"> generados en runtime por SplitText NO tienen
   * ese atributo → el CSS no los alcanza → display:inline, opacity:1 siempre.
   *
   * :global() elimina el scope → el selector aplica a cualquier .char del DOM,
   * independientemente de si fue renderizado por Astro o creado por JS.
   * Mismo patrón que :global(.hl) / :global(.hl.is-highlighted) en este componente.
   */
  :global(.char) {
    display:     inline-block;
    opacity:     0;
    will-change: transform, opacity;
    transition:
      opacity   380ms var(--ease-out),
      transform 380ms var(--ease-out);
    /*
     * 15ms por carácter → 42 chars × 15ms = 630ms de stagger total.
     * Transitión de 380ms → último char completa a ~1 010ms desde el trigger.
     * Asignado en JS: span.style.setProperty('--char-i', globalIdx).
     */
    transition-delay: calc(var(--char-i, 0) * 15ms);
  }

  /* Dirección de entrada por capa — cada grupo llega de un eje distinto */
  .layer-outline :global(.char) { transform: translateY(-20px);  } /* SOBRE NUESTRAS: cae arriba  */
  .layer-solid   :global(.char) { transform: translateX(-18px);  } /* OPERACIONES,:  desliza izq  */
  .layer-accent  :global(.char) { transform: translateX(18px);   } /* FLOTA:         desliza der  */
  .layer-base    :global(.char) { transform: translateY(16px);   } /* Y SERVICIOS.:  sube         */

  /* Estado VISIBLE — añadido por IntersectionObserver cuando la sección entra */
  .ops--in-view :global(.char) {
    opacity:   1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.char) {
      transition: none;
      opacity:    1;
      transform:  none;
    }
  }


  /* ════════════════════════════════════════════════════════════════════════
     FAQ MODULE
     Backdrop semitransparente para separar el texto del logo de fondo.
  ════════════════════════════════════════════════════════════════════════ */

  .faq-module {
    display:        flex;
    flex-direction: column;

    /*
     * will-change y backdrop-filter SOLO en desktop (≥ 768px).
     *
     * En mobile, body { overflow-x: clip } desencadena el axis-pairing del
     * CSS spec: overflow-y también se computa como `clip`, cambiando el
     * compositing root del documento. En iOS Safari / WebKit, un elemento
     * con will-change: transform/opacity + backdrop-filter dentro de un
     * contexto overflow:clip pierde su "backdrop source" → el elemento se
     * renderiza completamente transparente aunque opacity sea > 0.
     *
     * Solución: en mobile quitamos ambas propiedades. El efecto visual
     * (blur + glassmorphism) solo se aplica en desktop donde el compositing
     * es estable y la animación translateX justifica la GPU layer.
     */

    /* Mobile: fondo sólido — sin GPU layer, sin backdrop */
    background: rgba(2, 3, 10, 0.88); /* más opaco para compensar la ausencia de blur */
    border:     1px solid var(--c-line);
    border-radius: 4px;               /* máx anti-slop: 4px */
    padding:    var(--sp-3) var(--sp-5);
  }

  @media (min-width: 768px) {
    .faq-module {
      /* Desktop: GPU layer para el slide-in translateX + blur premium */
      will-change:             transform, opacity;
      background:              rgba(0, 0, 0, 0.42);
      backdrop-filter:         blur(10px);
      -webkit-backdrop-filter: blur(10px);

      /*
       * Slide-in desde la derecha — solo desktop.
       * translateX(100vw) está clipado por .ops { overflow: hidden };
       * el módulo aparece deslizándose desde el borde derecho de la sección.
       */
      opacity:   0;
      transform: translateX(100vw);
      transition:
        opacity   700ms var(--ease-out) 550ms,
        transform 700ms var(--ease-out) 550ms;
    }

    .ops--in-view .faq-module {
      opacity:   1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) and (min-width: 768px) {
    .faq-module { transition: none; opacity: 1; transform: none; }
  }


  /* ════════════════════════════════════════════════════════════════════════
     FAQ ITEMS
  ════════════════════════════════════════════════════════════════════════ */

  .faq-item {
    border-bottom: 1px solid var(--c-line);
  }

  .faq-item:first-child {
    border-top: 1px solid var(--c-line);
  }


  /* ════════════════════════════════════════════════════════════════════════
     FAQ TRIGGER
  ════════════════════════════════════════════════════════════════════════ */

  .faq-trigger {
    width:           100%;
    display:         flex;
    align-items:     flex-start;
    justify-content: space-between;
    gap:             var(--sp-5);

    padding-block:   var(--sp-5);
    padding-inline:  0;

    background:  none;
    border:      none;
    cursor:      pointer;
    text-align:  left;
  }

  .faq-trigger:hover {
    background: none;
  }

  .faq-trigger:focus-visible {
    outline:        2px solid var(--c-sky);
    outline-offset: 2px;
    border-radius:  2px;
  }

  .faq-trigger__text {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-2);
    line-height:    1.6;

    transition: color var(--dur-fast) var(--ease-out);
  }

  .faq-trigger:hover .faq-trigger__text,
  .faq-item.is-open  .faq-trigger__text {
    color: var(--c-text-1);
  }

  .faq-trigger__icon {
    flex-shrink:     0;
    width:           20px;
    height:          20px;
    margin-top:      1px;

    display:         flex;
    align-items:     center;
    justify-content: center;

    font-size:   1.1rem;
    font-weight: var(--fw-light);
    line-height: 1;
    color:       var(--c-sky);

    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-item.is-open .faq-trigger__icon {
    transform: rotate(45deg);
  }


  /* ════════════════════════════════════════════════════════════════════════
     FAQ PANEL
  ════════════════════════════════════════════════════════════════════════ */

  .faq-panel {
    max-height: 0;
    overflow:   hidden;
    transition: max-height 420ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-panel__inner {
    padding-bottom: var(--sp-5);
  }

  .faq-panel__text {
    font-family:  var(--font-sans);
    font-size:    var(--text-sm);
    font-weight:  var(--fw-light);
    line-height:  1.75;
    color:        var(--c-text-2);   /* subido de text-3 para mejor legibilidad */
  }


  /* ════════════════════════════════════════════════════════════════════════
     HIGHLIGHT SPANS — efecto resaltador Azul Helitec
     Idéntico al patrón de StatsSection (aprobado por Tech Lead).

     Mecanismo: background-size anima de 0% → 100% (sweep de izq a der).

     REGLA CRÍTICA: NO definir transition en el estado base (.hl).
     En Blink/WebKit, cuando transition cambia junto con la propiedad animada
     en la misma recalculación de estilos, el browser usa la transition del
     estado ANTERIOR (la base, 0ms), no la del destino — el sweep es invisible.
     Con transition SOLO en .hl.is-highlighted, el forward usa 650ms ✓ y el
     reset al quitar la clase usa "ninguna" (sin animación, instant) ✓.

     :global() necesario porque set:html no recibe el Astro CID.
  ════════════════════════════════════════════════════════════════════════ */

  :global(.hl) {
    background-image:    linear-gradient(
                           rgba(88, 181, 240, 0.38),
                           rgba(88, 181, 240, 0.38)
                         );
    background-repeat:   no-repeat;
    background-size:     0% 90%;
    background-position: left center;
    padding-inline:      2px;
    border-radius:       2px;

    /*
     * box-decoration-break: clone — en spans multi-línea, cada línea
     * recibe su propio background en vez de que el bg se "corte" en el wrap.
     */
    -webkit-box-decoration-break: clone;
            box-decoration-break: clone;

    /* ⚠ SIN transition aquí — ver explicación arriba */
  }

  :global(.hl.is-highlighted) {
    background-size: 100% 90%;
    transition: background-size 650ms cubic-bezier(0.16, 1, 0.3, 1);
  }


  /* ════════════════════════════════════════════════════════════════════════
     RESPONSIVE
  ════════════════════════════════════════════════════════════════════════ */

  @media (max-width: 1023px) {
    .ops__inner {
      grid-template-columns: 1fr;
      padding-inline:        var(--gutter);
      gap:                   clamp(40px, 8vw, 56px);
    }

    .ops__left {
      position: static;
    }
  }

  @media (max-width: 479px) {
    .ops__title {
      font-size: clamp(1.875rem, 10vw, 2.5rem);
    }

    .faq-trigger {
      padding-block: var(--sp-4);
    }
  }
</style>


<script>
  /**
   * ══════════════════════════════════════════════════════════════════════════
   * PARTE 1 — FAQ Acordeón
   *
   * Al abrir: expande panel con max-height real, activa .hl.is-highlighted
   * con delay de 150ms (sweep visible después de que el panel abre).
   * Al cerrar: colapsa panel, remueve highlights al instante (reset).
   * ══════════════════════════════════════════════════════════════════════════
   */
  (function () {
    var items = /** @type {NodeListOf<HTMLElement>} */ (
      document.querySelectorAll('[data-faq-item]')
    );
    if (!items.length) return;

    /** @param {HTMLElement} item */
    function closeItem(item) {
      var panel   = /** @type {HTMLElement|null} */ (item.querySelector('[data-faq-panel]'));
      var trigger = item.querySelector('[data-faq-trigger]');
      item.classList.remove('is-open');
      if (panel)   panel.style.maxHeight = '0';
      if (trigger) trigger.setAttribute('aria-expanded', 'false');

      /* Reset highlights: sin animación (transition: 0ms en CSS base) */
      item.querySelectorAll('.hl').forEach(function (el) {
        el.classList.remove('is-highlighted');
      });
    }

    /** @param {HTMLElement} item */
    function openItem(item) {
      var panel   = /** @type {HTMLElement|null} */ (item.querySelector('[data-faq-panel]'));
      var trigger = item.querySelector('[data-faq-trigger]');
      var inner   = panel && /** @type {HTMLElement|null} */ (panel.querySelector('.faq-panel__inner'));
      item.classList.add('is-open');
      if (panel && inner) panel.style.maxHeight = inner.scrollHeight + 'px';
      if (trigger) trigger.setAttribute('aria-expanded', 'true');

      /*
       * Highlights: delay de 150ms para que el panel abra parcialmente
       * antes de que el sweep arranque — efecto más dramático y visible.
       */
      setTimeout(function () {
        item.querySelectorAll('.hl').forEach(function (el, idx) {
          /*
           * void el.offsetWidth — fuerza un reflow sincrónico.
           * Sin esto, el browser puede batchar el estado background-size:0%
           * y background-size:100% en el mismo frame (sin detección del
           * valor inicial) → la transition no dispara.
           */
          void el.offsetWidth;
          setTimeout(function () {
            el.classList.add('is-highlighted');
          }, idx * 110); /* 110ms de escalonado entre cada frase */
        });
      }, 200); /* 200ms: panel abierto parcialmente antes de que sweeps arranquen */
    }

    items.forEach(function (item) {
      var trigger = item.querySelector('[data-faq-trigger]');
      if (!trigger) return;
      trigger.addEventListener('click', function () {
        var wasOpen = item.classList.contains('is-open');
        items.forEach(closeItem);
        if (!wasOpen) openItem(item);
      });
    });
  })();


  /**
   * ══════════════════════════════════════════════════════════════════════════
   * PARTE 2 — SplitText + IntersectionObserver (Motor V7)
   *
   * Reemplaza el motor RAF V6.1 (scroll math con sectionDocTop) por un
   * sistema IO+CSS más robusto:
   *
   *   • SplitText: cada carácter del título queda en <span class="char">
   *     con --char-i (índice global continuo entre las 4 capas).
   *     El CSS anima cada char con transition-delay calculado desde ese índice
   *     → cascade fluido de "S" hasta "." sin cortes entre líneas.
   *
   *   • IntersectionObserver añade .ops--in-view a la sección en el primer
   *     frame en que entra en el viewport → las CSS transitions se disparan.
   *     Se desconecta después (una sola vez — no re-anima al scrollear arriba).
   *
   * Ventaja vs motor RAF+scroll math:
   *   · Sin dependencia de sectionDocTop (causa del bug "animación muerta"):
   *     a DOMContentLoaded las imágenes de secciones anteriores aún no han
   *     cargado → su height es 0 → sectionDocTop demasiado pequeño → p=1
   *     en el primer applyFrame() → sobreescribe setInitialState() antes de
   *     que el usuario llegue a la sección → texto visible y estático.
   *   · Cero acceso al DOM en el render path.
   *   · Funciona con imágenes lazy-loaded, fuentes tardías y View Transitions.
   * ══════════════════════════════════════════════════════════════════════════
   */
  (function () {

    var section = /** @type {HTMLElement|null} */ (document.querySelector('[data-ops-section]'));
    if (!section) return;

    /* ── 1. SplitText ──────────────────────────────────────────────────── */

    var layers = section.querySelectorAll('.ops__title-layer');
    var globalCharIdx = 0; /* Índice continuo acumulado entre capas */

    layers.forEach(function (layer) {
      var text = (layer.textContent || '').trim();
      if (!text) return;

      /*
       * Accesibilidad:
       *   · role="text" → impide que lectores de pantalla desciendad a los
       *     <span class="char"> individuales y lean letra por letra.
       *   · aria-label → el layer anuncia el texto completo como una unidad.
       */
      layer.setAttribute('role', 'text');
      layer.setAttribute('aria-label', text);
      layer.textContent = '';

      text.split('').forEach(function (char) {
        var span = document.createElement('span');
        span.className = 'char';
        span.setAttribute('aria-hidden', 'true');
        /*
         * --char-i: indice global, CSS calcula el stagger individual.
         * El contador no se reinicia entre capas: cascade continuo.
         */
        span.style.setProperty('--char-i', String(globalCharIdx));
        /* Espacio: usar \u00A0 para que display:inline-block no colapse */
        span.textContent = char === ' ' ? '\u00A0' : char;
        layer.appendChild(span);
        globalCharIdx++;
      });
    });

    /* ── 2. IntersectionObserver + doble-rAF ──────────────────────────────
     *
     * El doble requestAnimationFrame garantiza que el browser haya pintado
     * al menos un frame con el estado inicial (opacity:0 + transform offset)
     * antes de añadir la clase trigger.
     *
     * Sin esto: si el IO dispara antes del primer paint (race condition al
     * cargar la página, especialmente con threshold:0), el browser nunca
     * observa el estado inicial → no hay transición visible, sección estática.
     */
    new IntersectionObserver(
      function (entries, observer) {
        if (!entries[0].isIntersecting) return;
        observer.disconnect();

        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            section.classList.add('ops--in-view');
          });
        });
      },
      { threshold: 0 }
    ).observe(section);

  })();


  /* [Motor V6.1 eliminado - migrado a Motor V7 arriba] */

</script>
