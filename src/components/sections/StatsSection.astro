  }

  .stats__cert-btn:hover svg {
    opacity: 1;
  }

  /* ════════════════════════════════════════════════════════════════════════
     LIGHTBOX AOC — <dialog> nativo con zoom & pan
  ════════════════════════════════════════════════════════════════════════ */

  .stats__aoc-dialog {
    /*
     * CENTRADO — fiable en todos los browsers con showModal().
     *
     * El <dialog> vive en el "top layer" (capas sobre z-index normal).
     * En ese contexto, position: fixed + inset: 0 + margin: auto lo
     * centra EXACTAMENTE en el viewport, horizontal y verticalmente.
     * Equivalente moderno a: top: 50%; left: 50%; transform: translate(-50%,-50%).
     */
    position:   fixed;
    inset:      0;          /* top:0 right:0 bottom:0 left:0 — ancla al viewport */
    margin:     auto;       /* centra dentro del rectángulo inset */

    padding:    0;
    border:     none;
    background: transparent;

    /*
     * Ancho proporcional a un documento tipo A4 portrait (~620px).
     * Sin height fija: el inner (flex column) determina la altura
     * según el contenido real del certificado.
     * max-height + overflow:hidden limita para pantallas pequeñas.
     */
    width:      min(92vw, 620px);
    height:     min(92dvh, 880px); /* ~A4 ratio en 620px → 877px + toolbar */
    max-width:  92vw;
    max-height: 92dvh;
    overflow:   hidden;
  }

  /* Backdrop nativo del <dialog> */
  .stats__aoc-dialog::backdrop {
    background-color:        rgba(4, 5, 8, 0.92);
    backdrop-filter:         blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* Inner: flex column — barra fija arriba, viewport ocupa el resto */
  .stats__aoc-inner {
    display:          flex;
    flex-direction:   column;
    height:           100%;
    background-color: var(--c-bg-raised);
    border:           1px solid var(--c-line-strong);
    overflow:         hidden;
  }

  /* ── Barra de controles ──────────────────────────────────────────────── */

  .stats__aoc-toolbar {
    display:         flex;
    align-items:     center;
    justify-content: space-between;
    flex-shrink:     0;

    padding:         10px 14px;
    border-bottom:   1px solid var(--c-line);
    background-color: rgba(7, 8, 12, 0.6);
  }

  .stats__aoc-zoom-label {
    font-family:    var(--font-sans);
    font-size:      0.6875rem; /* 11px */
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-2);
    min-width:      40px;
  }

  .stats__aoc-controls {
    display: flex;
    gap:     4px;
  }

  /* Botones de zoom + cerrar — mismo estilo base */
  .stats__aoc-ctrl,
  .stats__aoc-close {
    display:         flex;
    align-items:     center;
    justify-content: center;
    width:           30px;
    height:          30px;

    background:    transparent;
    border:        1px solid var(--c-line);
    border-radius: var(--r-micro);
    color:         var(--c-text-2);
    cursor:        pointer;

    transition:
      color        var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background   var(--dur-fast) var(--ease-out);
  }

  .stats__aoc-ctrl:hover {
    color:        var(--c-white);
    border-color: var(--c-line-strong);
    background:   rgba(255,255,255,0.05);
  }

  /* Botón cerrar — ligero acento diferenciador */
  .stats__aoc-close {
    margin-left: 8px;
    border-color: rgba(255,255,255,0.18);
  }
  .stats__aoc-close:hover {
    color:        var(--c-white);
    border-color: var(--c-text-2);
  }

  /* ── Viewport — área de imagen con overflow oculto ───────────────────── */

  .stats__aoc-viewport {
    flex:             1;
    position:         relative;
    overflow:         hidden;
    cursor:           default;

    /*
     * Centrar la imagen en el viewport.
     * La imagen usa position: absolute para ser transformada
     * con translate + scale desde su centro.
     */
    display:          flex;
    align-items:      center;
    justify-content:  center;

    /*
     * touch-action NO se define aquí en el estado base.
     * Se aplica SOLO cuando el dialog está abierto (ver regla abajo).
     * Sin esta restricción, el viewport secuestraba los eventos touch
     * de toda la página incluso cuando el modal estaba cerrado.
     */
  }

  /*
   * touch-action: none — bloquea scroll nativo del browser ÚNICAMENTE
   * cuando el visor está activo. Así el JS de pinch/pan recibe los eventos.
   * El dialog[open] selector garantiza que esto no afecta al scroll global.
   */
  .stats__aoc-dialog[open] .stats__aoc-viewport {
    touch-action: none;
  }

  /*
   * Modal cerrado — completamente intangible.
   * pointer-events: none: sin clics, sin toques fantasma.
   * visibility: hidden: el browser ni siquiera lo considera para hit-testing.
   * Esto previene que un <dialog> renderizado en el top layer pero oculto
   * intercepte eventos táctiles en el contenido de la página debajo.
   */
  .stats__aoc-dialog:not([open]) {
    pointer-events: none;
    visibility:     hidden;
  }

  .stats__aoc-viewport.is-draggable {
    cursor: grab;
  }
  .stats__aoc-viewport.is-dragging {
    cursor: grabbing;
  }

  /* Imagen: llena el ancho disponible — elimina espacio negro lateral y vertical */
  .stats__aoc-img {
    display:          block;
    width:            100%;    /* siempre ocupa el ancho del viewport */
    height:           auto;    /* proporcional a la imagen (A4: ~1.414 ratio) */
    max-width:        100%;
    object-fit:       contain;

    transform-origin: center center;
    transform:        translate(0, 0) scale(1);
    will-change:      transform;

    /* Evitar arrastre nativo del browser en la imagen */
    user-select:      none;
    -webkit-user-drag: none;
    pointer-events:   none; /* El viewport captura los eventos */
  }


  /* ════════════════════════════════════════════════════════════════════════
     LIGHT THEME OVERRIDES — inversión de paleta para sección blanca
     ─────────────────────────────────────────────────────────────────────
     Regla: todo texto → #1a1a1a / #444 / #555 para legibilidad sobre blanco.
     Acentos (líneas, íconos) → var(--c-brand) [navy] o var(--c-sky) / var(--c-red)
     conservados tal como indica el brief (v3).
     Las reglas de este bloque sobreescriben las del tema oscuro por cascada.
  ════════════════════════════════════════════════════════════════════════ */

  /* Overline: azul Helitec oscuro (navy) para contraste sobre fondo blanco */
  .stats__overline {
    color: var(--c-brand);
  }
  .stats__overline::before {
    background-color: var(--c-brand);
  }

  /* Títulos: negro corporativo */
  .stats__title {
    color: #1a1a1a;
  }

  /* Valores numéricos y de texto */
  .stats__value {
    color: #1a1a1a;
  }
  .stats__value--text,
  .stats__value--feature {
    color: #1a1a1a;
  }

  /* Labels: gris corporativo oscuro */
  .stats__label {
    color: #444444;
  }

  /* Efecto marcador: azul Helitec navy (--c-brand) sobre fondo blanco */
  .stats__label::before {
    background-color: var(--c-brand); /* #023a78 — azul Helitec oscuro */
  }

  /* Labels sobre el marcador navy: blanco para contraste */
  .stats__cell.is-visible .stats__label {
    color: var(--c-white);
  }

  /* Separador del cert block en contexto claro */
  .stats__cert {
    border-top-color: rgba(0, 0, 0, 0.10);
  }

  /* Cert block — textos en tema claro (fondo blanco/gradiente) */
  .stats__cert-title {
    color: var(--c-brand);
  }
  .stats__cert-body {
    color: #444444;
  }

  /* Palabras resaltadas en cert body */
  .stats__highlight {
    background-color: rgba(2, 58, 120, 0.08);
    color:            var(--c-brand);
    padding:          1px 5px;
    border-radius:    2px;
  }

  /* Botón "Ver certificado" — tema claro */
  .stats__cert-btn {
    color:        #1a1a1a;
    border-color: rgba(2, 58, 120, 0.28);
  }
  .stats__cert-btn svg {
    color:   var(--c-brand);
    opacity: 0.80;
  }
  .stats__cert-btn:hover {
    border-color:     rgba(2, 58, 120, 0.55);
    background-color: rgba(2, 58, 120, 0.05);
    color:            #000000;
  }
  .stats__cert-btn:hover svg {
    opacity: 1;
  }
</style>


<script>
  /**
   * StatsSection v2 — Motor de animaciones
   *
   * A. IntersectionObserver:
   *    Observa [data-stats-grid]. Cuando el 20% del grid entra en el
   *    viewport, añade .is-visible a todos los [data-stat-cell].
   *    El CSS se encarga del fade-up escalonado via --i + transition-delay.
   *
   * B. Number Counter:
   *    Para cada [data-counter] visible, lanza animateCounter().
   *    La función usa requestAnimationFrame + easeOutCubic para una
   *    deceleración natural. El número se formatea con "." como separador
   *    de miles (convención venezolana: 117.000, no 117,000).
   *
   * Las animaciones se ejecutan una única vez (observer.unobserve).
   */
  (function () {

    const grid = document.querySelector('[data-stats-grid]');
    if (!grid) return;

    const cells    = Array.from(grid.querySelectorAll('[data-stat-cell]'));
    const counters = Array.from(grid.querySelectorAll('[data-counter]'));

    /* ════════════════════════════════════════════════════════════════════
       UTILIDADES
    ════════════════════════════════════════════════════════════════════ */

    /**
     * Formatea un entero con punto como separador de miles.
     * Ejemplo: 117000 → "117.000"
     */
    function formatNumber(n) {
      return Math.round(n)
        .toString()
        .replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    }

    /**
     * Curva easeOutCubic: desaceleración suave al final.
     * t ∈ [0, 1] → output ∈ [0, 1]
     */
    function easeOutCubic(t) {
      return 1 - Math.pow(1 - t, 3);
    }

    /* ════════════════════════════════════════════════════════════════════
       B. ANIMACIÓN DE CONTADOR numérico
    ════════════════════════════════════════════════════════════════════ */

    /**
     * Anima el texto de `el` desde "prefix + 0" hasta "prefix + target"
     * en `duration` milisegundos usando rAF + easeOutCubic.
     *
     * @param {Element} el       - <span data-counter>
     * @param {number}  target   - Valor numérico final (ej: 117000)
     * @param {string}  prefix   - Prefijo fijo (ej: "+")
     * @param {number}  duration - Duración en ms (default: 2000)
     */
    function animateCounter(el, target, prefix, duration) {
      duration = duration || 2000;
      var startTime = null;

      function tick(now) {
        if (startTime === null) startTime = now;
        var elapsed  = now - startTime;
        var progress = Math.min(elapsed / duration, 1);
        var eased    = easeOutCubic(progress);
        var current  = Math.round(eased * target);

        el.textContent = prefix + formatNumber(current);

        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          /* Frame final exacto — compensa acumulación de error de redondeo */
          el.textContent = prefix + formatNumber(target);
        }
      }

      requestAnimationFrame(tick);
    }

    /* ════════════════════════════════════════════════════════════════════
       A. INTERSECTIONOBSERVER — REVEAL K3 + DISPATCH DE CONTADORES
    ════════════════════════════════════════════════════════════════════ */

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;

          /* 1. Reveal staggered: añadir .is-visible a todas las celdas */
          cells.forEach(function (cell) {
            cell.classList.add('is-visible');
          });

          /* 1b. Activar el subrayado animado de "Tres décadas" */
          var accent = document.querySelector('.stats__title-accent');
          if (accent) accent.classList.add('is-underlined');

          /* 2. Disparar contador en cada celda numérica */
          counters.forEach(function (counter) {
            var target = parseInt(counter.dataset.target || '0', 10);
            var prefix = counter.dataset.prefix || '';

            if (!isNaN(target) && target > 0) {
              animateCounter(counter, target, prefix, 2000);
            }
          });

          /* 3. Una sola ejecución — dejar de observar */
          observer.unobserve(entry.target);
        });
      },
      {
        /*
         * 20% del grid visible → disparar animaciones.
         * Suficiente para que el usuario vea el inicio de la entrada.
         */
        threshold: 0.20,
      }
    );

    observer.observe(grid);


    /* ════════════════════════════════════════════════════════════════════
       LIGHTBOX AOC — Zoom & Pan completo
       ─────────────────────────────────────────────────────────────────
       Estado: { scale, panX, panY }
         · scale  → 1.0 a 4.0 (1 = tamaño contenido, 4 = 400% zoom)
         · panX/Y → desplazamiento en px desde el centro del viewport
                    en el sistema de coordenadas del PADRE (sin escalar)

       Zoom pointer-centered (rueda):
         newPanX = pointerOffsetX * (1 - d) + panX * d
         donde d = newScale / oldScale

       Zoom botones: ×1.4 / ÷1.4 desde el centro
       Pan drag (mouse): cuando scale > 1
       Pan drag (touch): 1 dedo cuando scale > 1
       Pinch zoom (touch): 2 dedos — distancia entre puntos → newScale
    ════════════════════════════════════════════════════════════════════ */

    var openBtn   = document.getElementById('aoc-open-btn');
    var closeBtn  = document.getElementById('aoc-close-btn');
    var zoomInBtn = document.getElementById('aoc-zoom-in');
    var zoomOutBtn= document.getElementById('aoc-zoom-out');
    var zoomResetBtn = document.getElementById('aoc-zoom-reset');
    var zoomLabel = document.getElementById('aoc-zoom-label');
    var dialog    = /** @type {HTMLDialogElement|null} */ (document.getElementById('aoc-dialog'));
    var viewport  = document.getElementById('aoc-viewport');
    var img       = document.getElementById('aoc-img');

    if (!dialog || !viewport || !img) return;

    var MIN_SCALE = 1;
    var MAX_SCALE = 5;

    /* Estado del zoom/pan */
    var state = { scale: 1, panX: 0, panY: 0 };

    /* ── Aplicar transform al <img> y actualizar el label ─────────────── */
    function applyTransform() {
      img.style.transform =
        'translate(' + state.panX + 'px, ' + state.panY + 'px) scale(' + state.scale + ')';
      if (zoomLabel) zoomLabel.textContent = Math.round(state.scale * 100) + '%';

      /* Cambiar cursor del viewport según si se puede hacer pan */
      if (state.scale > 1) {
        viewport.classList.add('is-draggable');
      } else {
        viewport.classList.remove('is-draggable');
        viewport.classList.remove('is-dragging');
      }
    }

    /* ── Limitar el pan para que la imagen no se salga del viewport ─────── */
    function clampPan() {
      if (state.scale <= 1) {
        state.panX = 0;
        state.panY = 0;
        return;
      }
      /* Tamaño natural renderizado de la imagen (sin transform) */
      var iw = img.offsetWidth;
      var ih = img.offsetHeight;
      var vw = viewport.clientWidth;
      var vh = viewport.clientHeight;

      /*
       * El exceso: cuánto sobresale la imagen escalada respecto al viewport.
       * maxPan = (imagen_escalada - viewport) / 2
       * Si la imagen escalada cabe en el viewport, max = 0 → sin pan.
       */
      var maxX = Math.max(0, (iw * state.scale - vw) / 2);
      var maxY = Math.max(0, (ih * state.scale - vh) / 2);

      state.panX = Math.max(-maxX, Math.min(maxX, state.panX));
      state.panY = Math.max(-maxY, Math.min(maxY, state.panY));
    }

    /* ── Resetear estado de zoom/pan ──────────────────────────────────── */
    function resetZoom() {
      state.scale = 1;
      state.panX  = 0;
      state.panY  = 0;
      applyTransform();
    }

    /* ── Zoom centrado en un punto (px, py) del viewport ─────────────── */
    function zoomAtPoint(newScale, px, py) {
      newScale = Math.min(MAX_SCALE, Math.max(MIN_SCALE, newScale));
      var d = newScale / state.scale;
      state.panX  = px * (1 - d) + state.panX * d;
      state.panY  = py * (1 - d) + state.panY * d;
      state.scale = newScale;
      clampPan();
      applyTransform();
    }

    /* ── RUEDA DEL MOUSE — zoom pointer-centered ──────────────────────── */
    viewport.addEventListener('wheel', function (e) {
      /* Guardia: no procesar si el dialog está cerrado */
      if (!dialog.open) return;
      e.preventDefault();

      /* deltaY negativo = acercar (scroll up), positivo = alejar (scroll down) */
      var factor = e.deltaY < 0 ? 1.12 : 1 / 1.12;
      var newScale = state.scale * factor;

      /* Centro del viewport en coordenadas relativas al viewport */
      var rect = viewport.getBoundingClientRect();
      var px = e.clientX - rect.left - rect.width  / 2;
      var py = e.clientY - rect.top  - rect.height / 2;

      zoomAtPoint(newScale, px, py);
    }, { passive: false });


    /* ── BOTONES DE ZOOM ───────────────────────────────────────────────── */
    if (zoomInBtn) {
      zoomInBtn.addEventListener('click', function () {
        zoomAtPoint(state.scale * 1.4, 0, 0);
      });
    }
    if (zoomOutBtn) {
      zoomOutBtn.addEventListener('click', function () {
        zoomAtPoint(state.scale / 1.4, 0, 0);
      });
    }
    if (zoomResetBtn) {
      zoomResetBtn.addEventListener('click', resetZoom);
    }


    /* ── DRAG CON MOUSE — pan cuando scale > 1 ──────────────────────── */
    var isDragging = false;
    var dragOrigin = { x: 0, y: 0, panX: 0, panY: 0 };

    viewport.addEventListener('mousedown', function (e) {
      if (state.scale <= 1 || e.button !== 0) return;
      isDragging = true;
      dragOrigin = { x: e.clientX, y: e.clientY, panX: state.panX, panY: state.panY };
      viewport.classList.add('is-dragging');
      e.preventDefault();
    });

    window.addEventListener('mousemove', function (e) {
      if (!isDragging) return;
      state.panX = dragOrigin.panX + (e.clientX - dragOrigin.x);
      state.panY = dragOrigin.panY + (e.clientY - dragOrigin.y);
      clampPan();
      applyTransform();
    });

    window.addEventListener('mouseup', function () {
      if (!isDragging) return;
      isDragging = false;
      viewport.classList.remove('is-dragging');
    });


    /* ── TOUCH — pinch zoom + drag de un dedo ──────────────────────── */
    var lastPinchDist = 0;
    var lastPinchScale = 1;
    var touchDragOrigin = null;

    viewport.addEventListener('touchstart', function (e) {
      /* Guardia: no procesar si el dialog está cerrado */
      if (!dialog.open) return;
      if (e.touches.length === 2) {
        /* Iniciar pinch */
        e.preventDefault();
        lastPinchDist  = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY
        );
        lastPinchScale = state.scale;
        touchDragOrigin = null;
      } else if (e.touches.length === 1 && state.scale > 1) {
        /* Pan con un dedo (solo cuando hay zoom) */
        touchDragOrigin = {
          x: e.touches[0].clientX, y: e.touches[0].clientY,
          panX: state.panX, panY: state.panY
        };
      }
    }, { passive: false });

    viewport.addEventListener('touchmove', function (e) {
      /* Guardia: no procesar si el dialog está cerrado */
      if (!dialog.open) return;
      if (e.touches.length === 2 && lastPinchDist > 0) {
        e.preventDefault();
        var dist     = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY
        );
        var newScale = Math.min(MAX_SCALE, Math.max(MIN_SCALE, lastPinchScale * (dist / lastPinchDist)));

        /* Centro del pinch en coordenadas del viewport */
        var rect = viewport.getBoundingClientRect();
        var cx = ((e.touches[0].clientX + e.touches[1].clientX) / 2) - rect.left - rect.width  / 2;
        var cy = ((e.touches[0].clientY + e.touches[1].clientY) / 2) - rect.top  - rect.height / 2;

        var d = newScale / state.scale;
        state.panX  = cx * (1 - d) + state.panX * d;
        state.panY  = cy * (1 - d) + state.panY * d;
        state.scale = newScale;
        clampPan();
        applyTransform();

      } else if (e.touches.length === 1 && touchDragOrigin) {
        e.preventDefault();
        state.panX = touchDragOrigin.panX + (e.touches[0].clientX - touchDragOrigin.x);
        state.panY = touchDragOrigin.panY + (e.touches[0].clientY - touchDragOrigin.y);
        clampPan();
        applyTransform();
      }
    }, { passive: false });

    viewport.addEventListener('touchend', function (e) {
      if (e.touches.length < 2) lastPinchDist = 0;
      if (e.touches.length < 1) touchDragOrigin = null;
    });


    /* ── ABRIR / CERRAR el dialog ──────────────────────────────────── */
    if (openBtn) {
      openBtn.addEventListener('click', function () {
        dialog.showModal();
      });
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', function () {
        dialog.close();
      });
    }

    /* Cerrar al hacer clic en el backdrop (fuera del .stats__aoc-inner) */
    dialog.addEventListener('click', function (e) {
      var rect = dialog.getBoundingClientRect();
      if (
        e.clientX < rect.left   ||
        e.clientX > rect.right  ||
        e.clientY < rect.top    ||
        e.clientY > rect.bottom
      ) {
        dialog.close();
      }
    });

    /* Resetear zoom al cerrar */
    dialog.addEventListener('close', resetZoom);

  })();
</script>
