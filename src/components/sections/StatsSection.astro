---
/**
 * StatsSection.astro
 * Consorcio Helitec — "Por qué Helitec" (Dashboard de estadísticas operativas)
 *
 * v2 — Reingeniería K3 Studios + Contador numérico animado
 *
 * Grid 3×2 (desktop) / 2×3 (mobile) — 6 celdas compactas:
 *   1. +117.000  · HORAS DE VUELO EN HELICÓPTEROS         (contador rAF)
 *   2. +43.000   · HORAS DE VUELO EN AVIONES              (contador rAF)
 *   3. +171.500  · PASAJEROS TRANSPORTADOS                (contador rAF)
 *   4. Nacional e Internacional · COBERTURA DE OPERACIONES (texto fijo)
 *   5. +35       · AÑOS DE EXPERIENCIA                    (contador rAF)
 *   6. INAC · OACI · CERTIFICACIONES ACTIVAS              (texto fijo)
 *
 * Animaciones:
 *   A. Reveal staggered (K3): IntersectionObserver → fade-up por celda,
 *      transition-delay escalonado mediante --i CSS custom property
 *   B. Number counter: requestAnimationFrame, easeOutCubic, 2000ms,
 *      separador de miles "." (convención venezolana: 117.000)
 *
 * Reglas anti-slop:
 *   PROHIBIDO box-shadow       — ✓
 *   PROHIBIDO linear-gradient  — ✓
 *   border-radius ≤ 4px        — ✓ (var(--r-micro) en todo)
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

/* ── Definición de las 8 celdas estadísticas (grid 2 × 4) ───────────────── */

interface StatCell {
  /** Valor numérico a animar. null = texto fijo sin contador */
  value:     number | null;
  /** Texto estático si value es null */
  display?:  string;
  /** Prefijo que se mantiene durante la animación (ej: "+") */
  prefix?:   string;
  /**
   * Etiqueta descriptiva bajo el valor.
   * null → celda sin subtítulo (ej: "Certificado FA" no necesita una)
   */
  label:     string | null;
  /** true → activa el contador rAF en JS */
  animate:   boolean;
  /**
   * Tipo de celda — controla el renderizado HTML y los estilos:
   *   numeric → número grande animado con contador rAF
   *   text    → texto largo ("Nacional e Internacional")
   *   feature → capacidad operativa sin número (línea acento + texto)
   *   inac    → imagen del sello recurso amarillo / INAC
   */
  kind:      'numeric' | 'text' | 'feature' | 'inac';
}

const stats: StatCell[] = [

  /* ── Fila 1 — horas de vuelo ──────────────────────────────────────────── */
  {
    value:   117000,
    prefix:  '+',
    label:   lang === 'es' ? 'Horas de vuelo en helicópteros' : 'Helicopter flight hours',
    animate: true,
    kind:    'numeric',
  },
  {
    value:   43000,
    prefix:  '+',
    label:   lang === 'es' ? 'Horas de vuelo en aviones' : 'Fixed-wing flight hours',
    animate: true,
    kind:    'numeric',
  },

  /* ── Fila 2 — escala operativa ────────────────────────────────────────── */
  {
    value:   171500,
    prefix:  '+',
    label:   lang === 'es' ? 'Pasajeros transportados' : 'Passengers transported',
    animate: true,
    kind:    'numeric',
  },
  {
    value:   35,
    prefix:  '+',
    label:   lang === 'es' ? 'Años de experiencia' : 'Years of experience',
    animate: true,
    kind:    'numeric',
  },

  /* ── Fila 3 — certificaciones ─────────────────────────────────────────── */
  {
    value:   null,
    display: lang === 'es' ? 'Centro de instrucción' : 'Training Center',
    label:   lang === 'es' ? 'Certificado por INAC'  : 'INAC certified',
    animate: false,
    kind:    'feature',
  },

  /* ── Fila 4 — capacidades operativas ──────────────────────────────────── */
  {
    value:   null,
    display: lang === 'es' ? 'Taller propio'       : 'In-house workshop',
    label:   lang === 'es'
      ? 'Inventario y repuestos — disponibilidad operativa total'
      : 'Parts inventory — full operational availability',
    animate: false,
    kind:    'feature',
  },

  /* ── Fila 4 — cobertura geográfica + sello INAC ───────────────────────── */
  {
    value:   null,
    display: lang === 'es' ? 'Nacional e Internacional' : 'Domestic & International',
    label:   lang === 'es' ? 'Cobertura de operaciones'  : 'Operations coverage',
    animate: false,
    kind:    'text',
  },
  {
    value:   null,
    display: '',
    label:   lang === 'es' ? 'Certificaciones activas' : 'Active certifications',
    animate: false,
    kind:    'inac',
  },

];
---


<section class="stats" id="por-que-helitec" aria-labelledby="stats-heading">

  <div class="stats__inner">

    <!-- ── Encabezado de sección ──────────────────────────────────────────── -->
    <header class="stats__header">

      <p class="stats__overline">
        {lang === 'es' ? 'Por qué Helitec' : 'Why Helitec'}
      </p>

      <h2 class="stats__title" id="stats-heading"
        set:html={lang === 'es'
          ? '<span class="stats__title-accent">Tres décadas</span> de<br/>excelencia operativa'
          : '<span class="stats__title-accent">Three decades</span> of<br/>operational excellence'
        }
      />

    </header>

    <!-- ── Grid de estadísticas — 10 celdas (2 × 5) ────────────────────── -->
    <!--
      data-stats-grid → punto de observación del IntersectionObserver
      [data-stat-cell] → celdas individuales con animación K3
      style="- -i: N"  → índice para el transition-delay escalonado
      stats__cell--{kind} → clase de tipo para estilos específicos por variante
    -->
    <div
      class="stats__grid"
      data-stats-grid
      role="list"
      aria-label={lang === 'es' ? 'Estadísticas operativas de Helitec' : 'Helitec operational statistics'}
    >

      {stats.map((stat, i) => (
        <div
          class={`stats__cell stats__cell--${stat.kind}`}
          data-stat-cell
          style={`--i: ${i}`}
          role="listitem"
        >

          <div class="stats__value-wrap">
            {stat.kind === 'numeric' ? (
              /*
               * Celdas numéricas animadas (filas 1 y 2).
               * data-counter → marca el span para el script de conteo
               * data-target  → valor final como string (ej: "117000")
               * data-prefix  → prefijo fijo durante el conteo ("+")
               */
              <span
                class="stats__value"
                data-counter
                data-target={String(stat.value)}
                data-prefix={stat.prefix ?? ''}
                aria-label={`${stat.prefix ?? ''}${stat.value!.toLocaleString('de-DE')} ${stat.label}`}
              >
                {stat.prefix ?? ''}{stat.value!.toLocaleString('de-DE')}
              </span>

            ) : stat.kind === 'inac' ? (
              /*
               * Celda INAC: imagen del recurso amarillo (sello de certificación).
               * Fila 5, columna derecha.
               */
              <img
                src="/assets/recurso%20amarillo%20helitec%20(1).png"
                alt="INAC — Instituto Nacional de Aeronáutica Civil de Venezuela"
                class="stats__cert-logo"
                width="72"
                height="72"
                loading="lazy"
                decoding="async"
              />

            ) : stat.kind === 'feature' ? (
              /*
               * Celdas de capacidad operativa (filas 3 y 4).
               * Texto sin número, con acento gráfico (línea sky-blue via ::before).
               */
              <span class="stats__value stats__value--feature">
                {stat.display}
              </span>

            ) : (
              /*
               * Celda de texto genérico (fila 5, columna izquierda).
               * Ej: "Nacional e Internacional"
               */
              <span class="stats__value stats__value--text">
                {stat.display}
              </span>
            )}
          </div>

          {/* Subtítulo: solo si la celda tiene label (null → sin etiqueta) */}
          {stat.label && (
            <p class="stats__label">{stat.label}</p>
          )}

        </div>
      ))}

    </div>

    <!-- ── Bloque de certificación AOC ──────────────────────────────────── -->
    <div class="stats__cert">

      <div class="stats__cert-info">
        <p class="stats__cert-title">
          {lang === 'es' ? 'Certificado de Operador Aéreo' : 'Air Operator Certificate'}
        </p>
        <p class="stats__cert-body"
          set:html={lang === 'es'
            ? 'Consorcio Helitec opera bajo <span class="stats__highlight">Certificado AOC</span> otorgado por el <span class="stats__highlight">Instituto Nacional de Aeronáutica Civil (INAC)</span> de Venezuela, garantizando el cumplimiento de todas las normativas de seguridad operacional nacional e internacional.'
            : 'Consorcio Helitec operates under an <span class="stats__highlight">AOC Certificate</span> granted by Venezuela\'s <span class="stats__highlight">Instituto Nacional de Aeronáutica Civil (INAC)</span>, ensuring compliance with all national and international operational safety regulations.'
          }
        />

        <!-- Botón: abre el lightbox con el certificado AOC -->
        <button class="stats__cert-btn" id="aoc-open-btn" type="button" aria-haspopup="dialog">
          <!-- Ícono ojo — indica "visualizar", no descargar -->
          <svg width="16" height="11" viewBox="0 0 16 11" fill="none" aria-hidden="true">
            <path d="M1 5.5C1 5.5 3.5 1 8 1C12.5 1 15 5.5 15 5.5C15 5.5 12.5 10 8 10C3.5 10 1 5.5 1 5.5Z"
              stroke="currentColor" stroke-width="1.2" stroke-linecap="square" stroke-linejoin="miter"/>
            <circle cx="8" cy="5.5" r="2" stroke="currentColor" stroke-width="1.2"/>
          </svg>
          <span>{lang === 'es' ? 'Ver certificado' : 'View certificate'}</span>
        </button>
      </div>

    </div>

    <!-- ── Lightbox AOC — <dialog> nativo con zoom y pan ───────────── -->
    <!--
      Se abre con .showModal() → backdrop oscuro nativo del browser.
      Se cierra: botón ✕, clic en el backdrop, o tecla Escape.
      Zoom: rueda del mouse (desktop) | pinch con 2 dedos (mobile)
      Pan:  clic + arrastrar (desktop) | 1 dedo cuando scale > 1 (mobile)
    -->
    <dialog
      class="stats__aoc-dialog"
      id="aoc-dialog"
      aria-label={lang === 'es' ? 'Certificado de Operador Aéreo' : 'Air Operator Certificate'}
    >
      <div class="stats__aoc-inner">

        <!-- Barra de controles: zoom level + botones + cerrar -->
        <div class="stats__aoc-toolbar">
          <span class="stats__aoc-zoom-label" id="aoc-zoom-label" aria-live="polite">100%</span>
          <div class="stats__aoc-controls">
            <button class="stats__aoc-ctrl" id="aoc-zoom-out" type="button"
              aria-label={lang === 'es' ? 'Alejar' : 'Zoom out'}>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </button>
            <button class="stats__aoc-ctrl" id="aoc-zoom-reset" type="button"
              aria-label={lang === 'es' ? 'Tamaño original' : 'Reset zoom'}>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="10" height="10" rx="1" stroke="currentColor" stroke-width="1.3"/>
                <path d="M5 7h4M7 5v4" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
              </svg>
            </button>
            <button class="stats__aoc-ctrl" id="aoc-zoom-in" type="button"
              aria-label={lang === 'es' ? 'Acercar' : 'Zoom in'}>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </button>
            <button class="stats__aoc-close" id="aoc-close-btn" type="button"
              aria-label={lang === 'es' ? 'Cerrar' : 'Close'}>
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                <path d="M1 1l11 11M12 1L1 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Viewport: contiene la imagen y maneja el pan/zoom -->
        <div class="stats__aoc-viewport" id="aoc-viewport">
          <img
            src="/assets/AOC.png"
            alt="Certificado de Operador Aéreo — INAC Venezuela"
            class="stats__aoc-img"
            id="aoc-img"
            draggable="false"
            loading="lazy"
            decoding="async"
          />
        </div>

      </div>
    </dialog>

  </div>

</section>


<style>
  /* ════════════════════════════════════════════════════════════════════════
     SECCIÓN
  ════════════════════════════════════════════════════════════════════════ */

  .stats {
    /*
     * LIGHT THEME — override autorizado por Tech Lead.
     * El gradiente crea una transición elegante desde blanco puro (0–85%)
     * hasta el fondo oscuro del proyecto (85–100%), conectando visualmente
     * con la ServicesSection que le sigue.
     * NOTA: linear-gradient como fondo de sección — excepción aprobada (v3).
     */
    /*
     * Gradiente: blanco puro (0–82%) → negro puro (95–100%).
     * Llega a #000000 (= var(--c-bg)) ANTES del borde inferior de la sección,
     * eliminando la franja gris/blanca visible cuando SERVICIOS entra en pantalla.
     * La transición termina 5% antes del borde para garantizar costura limpia.
     */
    /*
     * Gradiente ease-in simulado con múltiples paradas:
     * blanco puro hasta el 86%, luego desaceleración suave
     * a través de grises intermedios antes de llegar al negro.
     * La curva comienza muy despacio y acelera al final
     * → imperceptible en el área del cert block.
     */
    background: linear-gradient(
      to bottom,
      #ffffff  0%,
      #ffffff 86%,
      #eeeeee 88%,
      #cccccc 90%,
      #999999 92%,
      #555555 95%,
      #1a1a1a 98%,
      #000000 100%
    );
    border-top:     none;
    padding-top:    clamp(56px, 9vh, 104px);
    padding-bottom: clamp(200px, 26vh, 260px);
  }

  .stats__inner {
    max-width:      var(--content-max);
    margin-inline:  auto;
    padding-inline: calc(var(--sidebar-w) + var(--gutter));
  }

  /* ════════════════════════════════════════════════════════════════════════
     ENCABEZADO
  ════════════════════════════════════════════════════════════════════════ */

  .stats__header {
    max-width:     520px;
    margin-bottom: clamp(36px, 5vh, 56px);
  }

  .stats__overline {
    display:     flex;
    align-items: center;
    gap:         12px;

    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);

    margin-bottom: 14px;
  }

  /* Línea decorativa horizontal antes del texto del overline */
  .stats__overline::before {
    content:          '';
    display:          block;
    flex-shrink:      0;
    width:            32px;
    height:           1px;
    background-color: var(--c-sky);
  }

  .stats__title {
    font-family:    var(--font-display);
    font-size:      var(--text-2xl); /* clamp(2rem, 1.5rem + 2.5vw, 3.5rem) */
    font-weight:    var(--fw-light); /* 300 — límite superior OBLIGATORIO H2 */
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    line-height:    1.1;
    color:          #111111; /* tema claro — fondo blanco */
  }

  /* ── "Tres décadas" / "Three decades" — subrayado bicolor animado ──────── */

  .stats__title-accent {
    position: relative;
    display:  inline;
  }

  /*
   * Línea bicolor: rojo (--c-red) → azul (--c-sky), coherente con hero.
   * Animación scaleX(0→1) con transform-origin: left → "se dibuja" de izq. a derecha.
   * La clase .is-underlined la agrega el IntersectionObserver al entrar en pantalla.
   */
  .stats__title-accent::after {
    content:          '';
    position:         absolute;
    bottom:           -4px;
    left:             0;
    right:            0;
    height:           2px;
    background: linear-gradient(
      to right,
      var(--c-red)  50%,
      var(--c-sky)  50%
    );
    transform:        scaleX(0);
    transform-origin: left center;
    transition:       transform 1.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events:   none;
  }

  .stats__title-accent.is-underlined::after {
    transform: scaleX(1);
  }


  /* ════════════════════════════════════════════════════════════════════════
     GRID — 2 columnas × 5 filas
  ════════════════════════════════════════════════════════════════════════ */

  .stats__grid {
    display:               grid;
    grid-template-columns: repeat(2, 1fr);
    gap:                   0;
  }

  /*
   * Sin separadores de borde entre filas ni columnas.
   * Los números y el espaciado (padding de celda) crean la separación visual.
   * La estructura de cuadrícula se percibe por el ritmo tipográfico, no por líneas.
   */

  /* ════════════════════════════════════════════════════════════════════════
     CELDA — estado inicial + animación K3 staggered fade-up
  ════════════════════════════════════════════════════════════════════════ */

  .stats__cell {
    background-color: transparent;

    /*
     * Padding reducido para apretar la grilla verticalmente.
     * Horizontal sin cambios — solo el vertical se comprime.
     */
    padding: clamp(10px, 1.4vw, 14px) clamp(16px, 2vw, 24px);

    display:        flex;
    flex-direction: column;
    gap:            6px;

  }

  /* ════════════════════════════════════════════════════════════════════════
     VALORES NUMÉRICOS — celdas 1, 2, 3, 5
  ════════════════════════════════════════════════════════════════════════ */

  .stats__value-wrap {
    display:     flex;
    align-items: baseline;
  }

  .stats__value {
    font-family:    var(--font-display);
    font-size:      clamp(1.9rem, 3.2vw, 2.75rem);
    font-weight:    var(--fw-regular); /* 400 — más legible sobre fondo blanco */
    letter-spacing: var(--ls-wide);
    line-height:    1;
    color:          #111111; /* tema claro — fondo blanco */

    /*
     * font-variant-numeric: tabular-nums evita que los caracteres
     * numéricos salten horizontalmente al cambiar de dígito durante
     * la animación del contador.
     */
    font-variant-numeric:  tabular-nums;
    font-feature-settings: "tnum" 1;
  }

  /* ════════════════════════════════════════════════════════════════════════
     VALORES TEXTO — celdas 4 y 6 (sin animación numérica)
  ════════════════════════════════════════════════════════════════════════ */

  /* Celda 4: "Nacional e Internacional" */
  .stats__value--text {
    font-family:    var(--font-display);
    font-size:      clamp(1rem, 1.8vw, 1.35rem);
    font-weight:    var(--fw-regular); /* 400 */
    letter-spacing: var(--ls-wider);
    line-height:    1.3;
    text-transform: uppercase; /* NACIONAL E INTERNACIONAL */
    color:          #111111; /* tema claro — fondo blanco */
  }

  /* ── Celdas feature (filas 3 y 4) — capacidades sin número ─────────────── */

  /*
   * El value-wrap de las feature cells dispone icono/texto en columna.
   * El acento gráfico (línea sky-blue) se inyecta via ::before en el span.
   */
  .stats__cell--feature .stats__value-wrap {
    flex-direction: column;
    align-items:    flex-start;
    gap:            0;
  }

  .stats__value--feature {
    font-family:    var(--font-display);
    font-size:      clamp(1.0rem, 1.8vw, 1.40rem);
    font-weight:    var(--fw-regular); /* 400 */
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    line-height:    1.3;
    color:          #111111; /* tema claro — fondo blanco */
  }

  /*
   * Acento gráfico: línea sky-blue de 18px que actúa como "eyebrow marker"
   * antes del texto de cada celda feature. Aparece naturalmente antes del texto.
   */
  .stats__value--feature::before {
    content:          '';
    display:          block;
    width:            18px;
    height:           1.5px;
    background-color: var(--c-sky);
    margin-bottom:    10px;
  }

  /* Imagen del sello INAC en la celda — sin borde, sin contorno */
  .stats__cert-logo {
    width:       clamp(80px, 9vw, 108px); /* Aumentado: era clamp(48px, 5vw, 68px) */
    height:      auto;
    object-fit:  contain;
    flex-shrink: 0;
  }

  /* Celda INAC — contenido centrado horizontal y verticalmente */
  .stats__cell--inac {
    align-items:     center;
    justify-content: center;
  }

  .stats__cell--inac .stats__value-wrap {
    justify-content: center;
  }


  /* ════════════════════════════════════════════════════════════════════════
     ETIQUETA — con efecto resaltador (marcador) Azul Helitec
  ════════════════════════════════════════════════════════════════════════ */

  .stats__label {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium); /* 500 — más legible */
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color:          #444444; /* tema claro — ligeramente más oscuro para legibilidad */
    line-height:    1.4;

    /*
     * EFECTO RESALTADOR (marcador de texto):
     * Un pseudo-elemento ::before con background-color sólido (Azul Helitec)
     * que "barre" de izquierda a derecha con transform: scaleX(0 → 1).
     *
     * Técnica: sin linear-gradient. Solo background-color + transform.
     * isolation: isolate → contexto de apilado propio, z-index: -1 funciona
     * dentro del <p> sin afectar a otros elementos del DOM.
     */
    position:  relative;
    isolation: isolate; /* contexto de apilado aislado para z-index del ::before */
  }

  /*
   * El "marcador" — fondo azul Helitec (#023a78) que yace detrás del texto.
   * Estado inicial: invisible (scaleX 0, origen izquierda).
   * La transición se define solo en .is-visible para evitar animación inversa al salir.
   */
  .stats__label::before {
    content:          '';
    position:         absolute;
    top:              -2px;
    bottom:           -2px;
    left:             -4px;
    right:            0;
    background-color: var(--c-brand); /* #023a78 — Azul Helitec marca */

    z-index:          -1; /* debajo del texto, dentro del contexto aislado */

    transform:        scaleX(0);
    transform-origin: left center;
    transition:       transform 0s; /* sin transición por defecto */
  }

  /*
   * Activar el barrido cuando el IntersectionObserver agrega .is-visible
   * a la celda padre (.stats__cell).
   *
   * Timing:
   *   · 2.4s con spring (0.16, 1, 0.3, 1) → muy lento y suave
   *   · Delay: stagger propio de la celda (var(--i) × 90ms)
   *            + 700ms para que el número termine de contar antes del barrido
   */
  .stats__cell.is-visible .stats__label::before {
    transform:        scaleX(1);
    transition:       transform 2.4s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--i, 0) * 90ms + 700ms);
  }

  /* ════════════════════════════════════════════════════════════════════════
     RESPONSIVE
  ════════════════════════════════════════════════════════════════════════ */

  /* Tablet/Desktop menor: quitar offset del sidebar */
  @media (max-width: 1023px) {
    .stats__inner {
      padding-inline: var(--gutter);
    }
  }

  /* Mobile (< 640px): ajustes de escala — grid ya es 2 columnas globalmente */
  @media (max-width: 639px) {
    .stats__cell {
      padding: 10px 14px;
    }

    /* Números principales: reducir escala en pantallas muy estrechas */
    .stats__value {
      font-size: clamp(1.6rem, 7vw, 2.2rem);
    }

    /* Texto "Nacional e Internacional" más compacto */
    .stats__value--text {
      font-size: clamp(0.85rem, 4vw, 1rem);
    }

    /* Feature cells: texto más pequeño en mobile */
    .stats__value--feature {
      font-size: clamp(0.85rem, 3.5vw, 1.05rem);
    }

    .stats__value--feature::before {
      width:         14px;
      margin-bottom: 7px;
    }
  }

  /* ════════════════════════════════════════════════════════════════════════
     BLOQUE DE CERTIFICACIÓN AOC (debajo del grid)
  ════════════════════════════════════════════════════════════════════════ */

  .stats__cert {
    margin-top:       clamp(28px, 4vh, 48px);

    padding:          clamp(20px, 3vw, 32px) 0;
    border-top:       1px solid var(--c-line); /* separador sutil — mismo tono que el fondo */
    background-color: transparent;
  }

  .stats__cert-info {
    display:        flex;
    flex-direction: column;
    gap:            8px;
  }

  .stats__cert-title {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);
  }

  .stats__cert-body {
    font-family: var(--font-sans);
    font-size:   clamp(0.78rem, 1.3vw, 0.875rem);
    font-weight: var(--fw-light);
    color:       var(--c-text-2);
    line-height: 1.65;
    max-width:   72ch;
  }

  /* Palabras resaltadas estilo Licorn — fondo azul Helitec sutil */
  .stats__highlight {
    background-color: rgba(88, 181, 240, 0.10);
    color:            var(--c-sky);
    padding:          1px 5px;
    border-radius:    2px; /* ≤ 4px — ANTI-SLOP */
  }

  /* Botón "Ver documento AOC" — ghost sky blue + flecha animada */
  .stats__cert-btn {
    display:     inline-flex;
    align-items: center;
    gap:         8px;
    margin-top:  var(--sp-3);

    padding: 8px 14px;

    font-family:    var(--font-sans);
    font-size:      0.6875rem; /* 11px */
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-1);

    background:    transparent;
    border:        1px solid rgba(88, 181, 240, 0.35);
    border-radius: var(--r-micro);
    cursor:        pointer;

    transition:
      border-color     var(--dur-fast) var(--ease-out),
