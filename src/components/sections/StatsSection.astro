---
/**
 * StatsSection.astro
 * Consorcio Helitec — Sección "Por qué Helitec" (Estadísticas + Certificación INAC)
 *
 * Estructura:
 *   · Encabezado: overline + título fino + párrafo contexto
 *   · Grid de estadísticas: 4 celdas con número ultra-fino + etiqueta
 *   · Badge INAC: imagen AOC.png con marco formal
 *
 * Tipografía: font-weight 200 (--fw-thin) en números,
 *             letter-spacing amplio en etiquetas.
 *
 * NOTA PARA EL CLIENTE: Los valores marcados con [DATO] son placeholders.
 *   Confirmar con operaciones: años de fundación, horas totales de vuelo.
 *   El número "8" de aeronaves se toma directamente de flota.json.
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

/* ── Datos de estadísticas ── */
/* NOTA: Reemplazar valores con datos confirmados por el cliente */
const stats = [
  {
    value: '+25',
    unit:  'años',
    label: lang === 'es' ? 'De operaciones ininterrumpidas' : 'Years of continuous operations',
  },
  {
    value: '8',
    unit:  '',
    label: lang === 'es' ? 'Aeronaves en flota activa' : 'Active fleet aircraft',
  },
  {
    value: '+30K',
    unit:  'hrs',
    label: lang === 'es' ? 'Horas de vuelo acumuladas' : 'Accumulated flight hours',
  },
  {
    value: 'INAC',
    unit:  '',
    label: lang === 'es' ? 'Certificación Aeronáutica Oficial' : 'Official Aeronautical Certification',
  },
];
---

<section class="stats" id="por-que-helitec" aria-labelledby="stats-heading">

  <div class="stats__inner">

    <!-- ── Encabezado ─────────────────────────────────────────────────────── -->
    <header class="stats__header">

      <p class="stats__overline">
        {lang === 'es' ? 'Por qué Helitec' : 'Why Helitec'}
      </p>

      <h2 class="stats__title" id="stats-heading">
        {lang === 'es'
          ? <>Tres décadas de<br/>excelencia operativa</>
          : <>Three decades of<br/>operational excellence</>
        }
      </h2>

      <p class="stats__desc">
        {lang === 'es'
          ? 'Operamos bajo los estándares más exigentes de la aviación civil venezolana. Cada vuelo refleja nuestro compromiso con la seguridad, la precisión y la confiabilidad que la industria demanda.'
          : 'We operate under the most demanding standards of Venezuelan civil aviation. Every flight reflects our commitment to the safety, precision and reliability that the industry demands.'
        }
      </p>

    </header>

    <!-- ── Grid de estadísticas ─────────────────────────────────────────── -->
    <div class="stats__grid" role="list">

      {stats.map((stat, i) => (
        <div class="stats__cell" role="listitem">
          <div class="stats__number-wrap">
            <span class="stats__value">{stat.value}</span>
            {stat.unit && (
              <span class="stats__unit">{stat.unit}</span>
            )}
          </div>
          <p class="stats__label">{stat.label}</p>
        </div>
      ))}

    </div>

    <!-- ── Badge INAC / Certificación AOC ──────────────────────────────── -->
    <div class="stats__cert">

      <div class="stats__cert-badge">
        <img
          src="/assets/AOC.png"
          alt="Certificado de Operador Aéreo — INAC Venezuela"
          class="stats__cert-img"
          width="120"
          height="120"
          loading="lazy"
        />
      </div>

      <div class="stats__cert-info">
        <p class="stats__cert-label">
          {lang === 'es' ? 'Certificado de Operador Aéreo' : 'Air Operator Certificate'}
        </p>
        <p class="stats__cert-body">
          {lang === 'es'
            ? 'Consorcio Helitec opera bajo Certificado AOC otorgado por el Instituto Nacional de Aeronáutica Civil (INAC) de Venezuela, garantizando el cumplimiento de todas las normativas de seguridad operacional.'
            : 'Consorcio Helitec operates under an AOC Certificate granted by the Instituto Nacional de Aeronáutica Civil (INAC) of Venezuela, ensuring compliance with all operational safety regulations.'
          }
        </p>
      </div>

    </div>

  </div>

</section>


<style>
  /* ── Sección ─────────────────────────────────────────────────────────────── */
  .stats {
    background-color: var(--c-bg-raised);
    border-top:       1px solid var(--c-line);
    padding-block:    clamp(64px, 10vh, 120px);
  }

  .stats__inner {
    max-width:    var(--content-max);
    margin-inline: auto;
    padding-inline: calc(var(--sidebar-w) + var(--gutter));
  }

  /* ── Encabezado ─────────────────────────────────────────────────────────── */
  .stats__header {
    max-width: 640px;
    margin-bottom: clamp(48px, 7vh, 80px);
  }

  .stats__overline {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);

    margin-bottom: 16px;

    /* Línea decorativa antes del texto */
    display:     flex;
    align-items: center;
    gap:         12px;
  }

  .stats__overline::before {
    content:          '';
    display:          block;
    width:            32px;
    height:           1px;
    background-color: var(--c-sky);
    flex-shrink:      0;
  }

  .stats__title {
    font-family:    var(--font-display);
    font-size:      var(--text-2xl); /* clamp(2rem, 1.5rem + 2.5vw, 3.5rem) */
    font-weight:    var(--fw-thin);  /* 200 — OBLIGATORIO */
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    line-height:    1.1;
    color:          var(--c-text-1);

    margin-bottom: 24px;
  }

  .stats__desc {
    font-family: var(--font-sans);
    font-size:   clamp(0.875rem, 1.5vw, 1rem);
    font-weight: var(--fw-light);
    color:       var(--c-text-2);
    line-height: 1.7;
  }

  /* ── Grid estadísticas ──────────────────────────────────────────────────── */
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);

    /* Líneas divisoras con el truco gap + background */
    gap:              1px;
    background-color: var(--c-line);
    border:           1px solid var(--c-line);

    margin-bottom: clamp(48px, 7vh, 72px);
  }

  .stats__cell {
    background-color: var(--c-bg-raised);
    padding:          clamp(24px, 4vw, 40px) clamp(20px, 3vw, 32px);

    display:        flex;
    flex-direction: column;
    gap:            8px;
  }

  /* Número + unidad en línea */
  .stats__number-wrap {
    display:     flex;
    align-items: baseline;
    gap:         4px;
  }

  .stats__value {
    font-family:    var(--font-display);
    font-size:      clamp(2.5rem, 4vw, 4rem);
    font-weight:    var(--fw-thin); /* 200 — OBLIGATORIO */
    letter-spacing: var(--ls-wide);
    color:          var(--c-text-1);
    line-height:    1;
  }

  .stats__unit {
    font-family:    var(--font-sans);
    font-size:      clamp(0.75rem, 1.2vw, 0.875rem);
    font-weight:    var(--fw-light);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-3);
    padding-bottom: 0.25em; /* Alinea con la baseline del número */
  }

  .stats__label {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-regular);
    letter-spacing: var(--ls-wide);
    color:          var(--c-text-2);
    line-height:    1.4;
  }

  /* ── Badge de certificación ─────────────────────────────────────────────── */
  .stats__cert {
    display:     flex;
    align-items: flex-start;
    gap:         clamp(24px, 4vw, 40px);

    padding:          clamp(24px, 4vw, 40px);
    border:           1px solid var(--c-line);
    background-color: var(--c-bg);
  }

  .stats__cert-badge {
    flex-shrink: 0;

    width:  100px;
    height: 100px;

    display:         flex;
    align-items:     center;
    justify-content: center;

    border:        1px solid var(--c-line-strong);
    border-radius: var(--r-micro); /* 4px */
    overflow:      hidden;

    background-color: rgba(255,255,255,0.03);
  }

  .stats__cert-img {
    width:      100%;
    height:     100%;
    object-fit: contain; /* Logo con transparencia — contain, no cover */
    padding:    8px;
  }

  .stats__cert-info {
    flex: 1;
    min-width: 0;
  }

  .stats__cert-label {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);
    margin-bottom:  10px;
  }

  .stats__cert-body {
    font-family: var(--font-sans);
    font-size:   clamp(0.8rem, 1.5vw, 0.9rem);
    font-weight: var(--fw-light);
    color:       var(--c-text-2);
    line-height: 1.65;
  }

  /* ── Responsive ─────────────────────────────────────────────────────────── */

  /* Tablet (768–1023px): 2 columnas */
  @media (max-width: 1023px) {
    .stats__inner {
      padding-inline: var(--gutter);
    }

    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Mobile (< 640px): 1 columna, cert stack */
  @media (max-width: 639px) {
    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .stats__cert {
      flex-direction: column;
      align-items:    flex-start;
    }

    .stats__cert-badge {
      width:  72px;
      height: 72px;
    }
  }

  /* Mobile muy pequeño: 1 col */
  @media (max-width: 374px) {
    .stats__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
