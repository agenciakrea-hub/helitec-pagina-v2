---
/**
 * StatsSection.astro
 * Consorcio Helitec — "Por qué Helitec" (Dashboard de estadísticas operativas)
 *
 * v2 — Reingeniería K3 Studios + Contador numérico animado
 *
 * Grid 3×2 (desktop) / 2×3 (mobile) — 6 celdas compactas:
 *   1. +117.000  · HORAS DE VUELO EN HELICÓPTEROS         (contador rAF)
 *   2. +43.000   · HORAS DE VUELO EN AVIONES              (contador rAF)
 *   3. +171.500  · PASAJEROS TRANSPORTADOS                (contador rAF)
 *   4. Nacional e Internacional · COBERTURA DE OPERACIONES (texto fijo)
 *   5. +35       · AÑOS DE EXPERIENCIA                    (contador rAF)
 *   6. INAC · OACI · CERTIFICACIONES ACTIVAS              (texto fijo)
 *
 * Animaciones:
 *   A. Reveal staggered (K3): IntersectionObserver → fade-up por celda,
 *      transition-delay escalonado mediante --i CSS custom property
 *   B. Number counter: requestAnimationFrame, easeOutCubic, 2000ms,
 *      separador de miles "." (convención venezolana: 117.000)
 *
 * Reglas anti-slop:
 *   PROHIBIDO box-shadow       — ✓
 *   PROHIBIDO linear-gradient  — ✓
 *   border-radius ≤ 4px        — ✓ (var(--r-micro) en todo)
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

/* ── Definición de las 6 celdas estadísticas ─────────────────────────────── */

interface StatCell {
  /** Valor numérico a animar. null = texto fijo sin contador */
  value:     number | null;
  /** Texto estático si value es null */
  display?:  string;
  /** Prefijo que se mantiene durante la animación (ej: "+") */
  prefix?:   string;
  /** Etiqueta descriptiva bajo el valor */
  label:     string;
  /** true → activa el contador rAF en JS */
  animate:   boolean;
}

const stats: StatCell[] = [
  {
    value:   117000,
    prefix:  '+',
    label:   lang === 'es' ? 'Horas de vuelo en helicópteros' : 'Helicopter flight hours',
    animate: true,
  },
  {
    value:   43000,
    prefix:  '+',
    label:   lang === 'es' ? 'Horas de vuelo en aviones' : 'Fixed-wing flight hours',
    animate: true,
  },
  {
    value:   171500,
    prefix:  '+',
    label:   lang === 'es' ? 'Pasajeros transportados' : 'Passengers transported',
    animate: true,
  },
  {
    value:   null,
    display: lang === 'es' ? 'Nacional e Internacional' : 'Domestic & International',
    label:   lang === 'es' ? 'Cobertura de operaciones' : 'Operations coverage',
    animate: false,
  },
  {
    value:   35,
    prefix:  '+',
    label:   lang === 'es' ? 'Años de experiencia' : 'Years of experience',
    animate: true,
  },
  {
    value:   null,
    display: 'INAC · OACI',
    label:   lang === 'es' ? 'Certificaciones activas' : 'Active certifications',
    animate: false,
  },
];
---


<section class="stats" id="por-que-helitec" aria-labelledby="stats-heading">

  <div class="stats__inner">

    <!-- ── Encabezado de sección ──────────────────────────────────────────── -->
    <header class="stats__header">

      <p class="stats__overline">
        {lang === 'es' ? 'Por qué Helitec' : 'Why Helitec'}
      </p>

      <h2 class="stats__title" id="stats-heading"
        set:html={lang === 'es'
          ? '<span class="stats__title-accent">Tres décadas</span> de<br/>excelencia operativa'
          : '<span class="stats__title-accent">Three decades</span> of<br/>operational excellence'
        }
      />

    </header>

    <!-- ── Grid de estadísticas — 6 celdas ──────────────────────────────── -->
    <!--
      data-stats-grid → punto de observación del IntersectionObserver
      [data-stat-cell] → celdas individuales con animación K3
      style="- -i: N"  → índice para el transition-delay escalonado
    -->
    <div
      class="stats__grid"
      data-stats-grid
      role="list"
      aria-label={lang === 'es' ? 'Estadísticas operativas de Helitec' : 'Helitec operational statistics'}
    >

      {stats.map((stat, i) => (
        <div
          class="stats__cell"
          data-stat-cell
          style={`--i: ${i}`}
          role="listitem"
        >

          <div class="stats__value-wrap">
            {stat.animate && stat.value !== null ? (
              /*
               * Celdas numéricas animadas.
               * data-counter  → marca el span para el script de conteo
               * data-target   → valor final como string (ej: "117000")
               * data-prefix   → prefijo a conservar durante el conteo ("+")
               * El contenido inicial es el valor ya formateado para SSR/noscript.
               */
              <span
                class="stats__value"
                data-counter
                data-target={String(stat.value)}
                data-prefix={stat.prefix ?? ''}
                aria-label={`${stat.prefix ?? ''}${stat.value.toLocaleString('de-DE')} ${stat.label}`}
              >
                {stat.prefix ?? ''}{stat.value.toLocaleString('de-DE')}
              </span>
            ) : stat.display === 'INAC · OACI' ? (
              /*
               * Celda INAC: imagen del sello oficial, sin borde ni contorno.
               * Archivo esperado: /public/assets/INAC-badge.png
               */
              <img
                src="/assets/recurso%20amarillo%20helitec.png"
                alt="INAC — Instituto Nacional de Aeronáutica Civil de Venezuela"
                class="stats__cert-logo"
                width="72"
                height="72"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <span class="stats__value stats__value--text">
                {stat.display}
              </span>
            )}
          </div>

          <p class="stats__label">{stat.label}</p>

        </div>
      ))}

    </div>

    <!-- ── Bloque de certificación AOC ──────────────────────────────────── -->
    <div class="stats__cert">

      <div class="stats__cert-info">
        <p class="stats__cert-title">
          {lang === 'es' ? 'Certificado de Operador Aéreo' : 'Air Operator Certificate'}
        </p>
        <p class="stats__cert-body"
          set:html={lang === 'es'
            ? 'Consorcio Helitec opera bajo <span class="stats__highlight">Certificado AOC</span> otorgado por el <span class="stats__highlight">Instituto Nacional de Aeronáutica Civil (INAC)</span> de Venezuela, garantizando el cumplimiento de todas las normativas de seguridad operacional nacional e internacional.'
            : 'Consorcio Helitec operates under an <span class="stats__highlight">AOC Certificate</span> granted by Venezuela\'s <span class="stats__highlight">Instituto Nacional de Aeronáutica Civil (INAC)</span>, ensuring compliance with all national and international operational safety regulations.'
          }
        />

        <!-- Botón: abre el mini popup con la imagen del documento AOC -->
        <button class="stats__cert-btn" id="aoc-open-btn" type="button" aria-haspopup="dialog">
          <span>{lang === 'es' ? 'Ver documento AOC' : 'View AOC Document'}</span>
          <svg width="12" height="10" viewBox="0 0 12 10" fill="none" aria-hidden="true">
            <path d="M1 5h10M7 1l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/>
          </svg>
        </button>
      </div>

    </div>

    <!-- ── Lightbox AOC — <dialog> nativo con zoom y pan ───────────── -->
    <!--
      Se abre con .showModal() → backdrop oscuro nativo del browser.
      Se cierra: botón ✕, clic en el backdrop, o tecla Escape.
      Zoom: rueda del mouse (desktop) | pinch con 2 dedos (mobile)
      Pan:  clic + arrastrar (desktop) | 1 dedo cuando scale > 1 (mobile)
    -->
    <dialog
      class="stats__aoc-dialog"
      id="aoc-dialog"
      aria-label={lang === 'es' ? 'Certificado de Operador Aéreo' : 'Air Operator Certificate'}
    >
      <div class="stats__aoc-inner">

        <!-- Barra de controles: zoom level + botones + cerrar -->
        <div class="stats__aoc-toolbar">
          <span class="stats__aoc-zoom-label" id="aoc-zoom-label" aria-live="polite">100%</span>
          <div class="stats__aoc-controls">
            <button class="stats__aoc-ctrl" id="aoc-zoom-out" type="button"
              aria-label={lang === 'es' ? 'Alejar' : 'Zoom out'}>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </button>
            <button class="stats__aoc-ctrl" id="aoc-zoom-reset" type="button"
              aria-label={lang === 'es' ? 'Tamaño original' : 'Reset zoom'}>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="10" height="10" rx="1" stroke="currentColor" stroke-width="1.3"/>
                <path d="M5 7h4M7 5v4" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
              </svg>
            </button>
            <button class="stats__aoc-ctrl" id="aoc-zoom-in" type="button"
              aria-label={lang === 'es' ? 'Acercar' : 'Zoom in'}>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </button>
            <button class="stats__aoc-close" id="aoc-close-btn" type="button"
              aria-label={lang === 'es' ? 'Cerrar' : 'Close'}>
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                <path d="M1 1l11 11M12 1L1 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Viewport: contiene la imagen y maneja el pan/zoom -->
        <div class="stats__aoc-viewport" id="aoc-viewport">
          <img
            src="/assets/AOC.png"
            alt="Certificado de Operador Aéreo — INAC Venezuela"
            class="stats__aoc-img"
            id="aoc-img"
            draggable="false"
            loading="lazy"
            decoding="async"
          />
        </div>

      </div>
    </dialog>

  </div>

</section>


<style>
  /* ════════════════════════════════════════════════════════════════════════
     SECCIÓN
  ════════════════════════════════════════════════════════════════════════ */

  .stats {
    background-color: var(--c-bg-raised);
    border-top:       1px solid var(--c-line);
    padding-block:    clamp(56px, 9vh, 104px);
  }

  .stats__inner {
    max-width:      var(--content-max);
    margin-inline:  auto;
    padding-inline: calc(var(--sidebar-w) + var(--gutter));
  }

  /* ════════════════════════════════════════════════════════════════════════
     ENCABEZADO
  ════════════════════════════════════════════════════════════════════════ */

  .stats__header {
    max-width:     520px;
    margin-bottom: clamp(36px, 5vh, 56px);
  }

  .stats__overline {
    display:     flex;
    align-items: center;
    gap:         12px;

    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-medium);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);

    margin-bottom: 14px;
  }

  /* Línea decorativa horizontal antes del texto del overline */
  .stats__overline::before {
    content:          '';
    display:          block;
    flex-shrink:      0;
    width:            32px;
    height:           1px;
    background-color: var(--c-sky);
  }

  .stats__title {
    font-family:    var(--font-display);
    font-size:      var(--text-2xl); /* clamp(2rem, 1.5rem + 2.5vw, 3.5rem) */
    font-weight:    var(--fw-thin);  /* 200 — OBLIGATORIO */
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    line-height:    1.1;
    color:          var(--c-text-1);
  }

  /* ── "Tres décadas" / "Three decades" — subrayado bicolor animado ──────── */

  .stats__title-accent {
    position: relative;
    display:  inline;
  }

  /*
   * Línea bicolor: rojo (--c-red) → azul (--c-sky), coherente con hero.
   * Animación scaleX(0→1) con transform-origin: left → "se dibuja" de izq. a derecha.
   * La clase .is-underlined la agrega el IntersectionObserver al entrar en pantalla.
   */
  .stats__title-accent::after {
    content:          '';
    position:         absolute;
    bottom:           -4px;
    left:             0;
    right:            0;
    height:           2px;
    background: linear-gradient(
      to right,
      var(--c-red)  50%,
      var(--c-sky)  50%
    );
    transform:        scaleX(0);
    transform-origin: left center;
    transition:       transform 1.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events:   none;
  }

  .stats__title-accent.is-underlined::after {
    transform: scaleX(1);
  }


  /* ════════════════════════════════════════════════════════════════════════
     GRID — truco gap + background-color para divisores sin border
  ════════════════════════════════════════════════════════════════════════ */

  .stats__grid {
    display:               grid;
    grid-template-columns: repeat(3, 1fr);
    gap:                   0;
    /*
     * Sin separadores visuales — los números flotan sobre el fondo negro.
     * El espaciado del padding de cada celda crea la separación visual.
     */
  }

  /* ════════════════════════════════════════════════════════════════════════
     CELDA — estado inicial + animación K3 staggered fade-up
  ════════════════════════════════════════════════════════════════════════ */

  .stats__cell {
    background-color: transparent;

    /*
     * Padding compacto para el look "dashboard".
     * Valores menores que la v1 para que las 6 celdas quepan
     * en el viewport sin scroll excesivo.
     */
    padding: clamp(20px, 2.5vw, 28px) clamp(16px, 2vw, 24px);

    display:        flex;
    flex-direction: column;
    gap:            8px;

    /*
     * ESTADO INICIAL (antes de animación K3):
     * Las celdas comienzan invisibles y desplazadas 24px hacia abajo.
     * El JS añade .is-visible cuando el observer dispara → CSS anima.
     */
    opacity:     0;
    transform:   translateY(24px);
    will-change: opacity, transform;

    transition:
      opacity   0.55s var(--ease-out),
      transform 0.55s var(--ease-out);

    /*
     * Delay escalonado K3: cada celda espera 90ms más que la anterior.
     * --i se inyecta inline desde Astro: style="- -i: 0", "- -i: 1", …
     * Celda 0 → 0ms, celda 1 → 90ms, celda 2 → 180ms, …, celda 5 → 450ms
     */
    transition-delay: calc(var(--i, 0) * 90ms);
  }

  /* Estado visible — activado por JS tras IntersectionObserver */
  .stats__cell.is-visible {
    opacity:   1;
    transform: translateY(0);
  }

  /* ════════════════════════════════════════════════════════════════════════
     VALORES NUMÉRICOS — celdas 1, 2, 3, 5
  ════════════════════════════════════════════════════════════════════════ */

  .stats__value-wrap {
    display:     flex;
    align-items: baseline;
  }

  .stats__value {
    font-family:    var(--font-display);
    font-size:      clamp(1.9rem, 3.2vw, 2.75rem);
    font-weight:    var(--fw-thin); /* 200 — OBLIGATORIO */
    letter-spacing: var(--ls-wide);
    line-height:    1;
    color:          var(--c-text-1);

    /*
     * font-variant-numeric: tabular-nums evita que los caracteres
     * numéricos salten horizontalmente al cambiar de dígito durante
     * la animación del contador.
     */
    font-variant-numeric:  tabular-nums;
    font-feature-settings: "tnum" 1;
  }

  /* ════════════════════════════════════════════════════════════════════════
     VALORES TEXTO — celdas 4 y 6 (sin animación numérica)
  ════════════════════════════════════════════════════════════════════════ */

  /* Celda 4: "Nacional e Internacional" */
  .stats__value--text {
    font-family:    var(--font-display);
    font-size:      clamp(1rem, 1.8vw, 1.35rem);
    font-weight:    var(--fw-light); /* 300 */
    letter-spacing: var(--ls-wider);
    line-height:    1.3;
    color:          var(--c-text-1);
  }

  /* Celda 6: "INAC · OACI" — mayúsculas, azul certificación */
  .stats__value--cert {
    font-size:      clamp(1.1rem, 2vw, 1.5rem);
    font-weight:    var(--fw-light); /* 300 */
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);
  }

  /* Imagen del sello INAC en la celda — sin borde, sin contorno */
  .stats__cert-logo {
    width:       clamp(48px, 5vw, 68px);
    height:      auto;
    object-fit:  contain;
    flex-shrink: 0;
  }


  /* ════════════════════════════════════════════════════════════════════════
     ETIQUETA
  ════════════════════════════════════════════════════════════════════════ */

  .stats__label {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-regular);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color:          var(--c-text-2);
    line-height:    1.4;
  }

  /* ════════════════════════════════════════════════════════════════════════
     RESPONSIVE
  ════════════════════════════════════════════════════════════════════════ */

  /* Tablet/Desktop menor: quitar offset del sidebar */
  @media (max-width: 1023px) {
    .stats__inner {
      padding-inline: var(--gutter);
    }
  }

  /* Mobile (< 640px): 2 columnas × 3 filas — compacto en viewport */
  @media (max-width: 639px) {
    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .stats__cell {
      padding: 18px 14px;
    }

    /* Valores numéricos más pequeños en pantallas estrechas */
    .stats__value {
      font-size: clamp(1.6rem, 7vw, 2.2rem);
    }

    .stats__value--text {
      font-size: clamp(0.85rem, 4vw, 1rem);
    }

    .stats__value--cert {
      font-size: clamp(0.9rem, 4.5vw, 1.1rem);
    }
  }

  /* ════════════════════════════════════════════════════════════════════════
     BLOQUE DE CERTIFICACIÓN AOC (debajo del grid)
  ════════════════════════════════════════════════════════════════════════ */

  .stats__cert {
    margin-top:  1px; /* Une visualmente con el grid */

    padding:          clamp(20px, 3vw, 32px);
    border:           1px solid var(--c-line);
    background-color: var(--c-bg);
  }

  .stats__cert-info {
    display:        flex;
    flex-direction: column;
    gap:            8px;
  }

  .stats__cert-title {
    font-family:    var(--font-sans);
    font-size:      var(--text-xs);
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color:          var(--c-sky);
  }

  .stats__cert-body {
    font-family: var(--font-sans);
    font-size:   clamp(0.78rem, 1.3vw, 0.875rem);
    font-weight: var(--fw-light);
    color:       var(--c-text-2);
    line-height: 1.65;
    max-width:   72ch;
  }

  /* Palabras resaltadas estilo Licorn — fondo azul Helitec sutil */
  .stats__highlight {
    background-color: rgba(88, 181, 240, 0.10);
    color:            var(--c-sky);
    padding:          1px 5px;
    border-radius:    2px; /* ≤ 4px — ANTI-SLOP */
  }

  /* Botón "Ver documento AOC" — ghost sky blue + flecha animada */
  .stats__cert-btn {
    display:     inline-flex;
    align-items: center;
    gap:         8px;
    margin-top:  var(--sp-3);

    padding: 8px 14px;

    font-family:    var(--font-sans);
    font-size:      0.6875rem; /* 11px */
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-1);

    background:    transparent;
    border:        1px solid rgba(88, 181, 240, 0.35);
    border-radius: var(--r-micro);
    cursor:        pointer;

    transition:
      border-color     var(--dur-fast) var(--ease-out),
      color            var(--dur-fast) var(--ease-out),
      background-color var(--dur-fast) var(--ease-out);
  }

  .stats__cert-btn:hover {
    border-color:     rgba(88, 181, 240, 0.65);
    background-color: rgba(88, 181, 240, 0.06);
    color:            var(--c-white);
  }

  .stats__cert-btn svg {
    flex-shrink: 0;
    transition:  transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .stats__cert-btn:hover svg {
    transform: translateX(4px);
  }

  /* ════════════════════════════════════════════════════════════════════════
     LIGHTBOX AOC — <dialog> nativo con zoom & pan
  ════════════════════════════════════════════════════════════════════════ */

  .stats__aoc-dialog {
    padding:    0;
    border:     none;
    background: transparent;

    /*
     * Tamaño fijo para que el flex column interior llene el espacio.
     * En mobile (<640px) ocupa casi todo el viewport.
     */
    width:      min(94vw, 740px);
    height:     min(92dvh, 920px);
    max-width:  94vw;
    max-height: 92dvh;
    overflow:   hidden;
  }

  /* Backdrop nativo del <dialog> */
  .stats__aoc-dialog::backdrop {
    background-color:        rgba(4, 5, 8, 0.92);
    backdrop-filter:         blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* Inner: flex column — barra fija arriba, viewport ocupa el resto */
  .stats__aoc-inner {
    display:          flex;
    flex-direction:   column;
    height:           100%;
    background-color: var(--c-bg-raised);
    border:           1px solid var(--c-line-strong);
    overflow:         hidden;
  }

  /* ── Barra de controles ──────────────────────────────────────────────── */

  .stats__aoc-toolbar {
    display:         flex;
    align-items:     center;
    justify-content: space-between;
    flex-shrink:     0;

    padding:         10px 14px;
    border-bottom:   1px solid var(--c-line);
    background-color: rgba(7, 8, 12, 0.6);
  }

  .stats__aoc-zoom-label {
    font-family:    var(--font-sans);
    font-size:      0.6875rem; /* 11px */
    font-weight:    var(--fw-semibold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color:          var(--c-text-2);
    min-width:      40px;
  }

  .stats__aoc-controls {
    display: flex;
    gap:     4px;
  }

  /* Botones de zoom + cerrar — mismo estilo base */
  .stats__aoc-ctrl,
  .stats__aoc-close {
    display:         flex;
    align-items:     center;
    justify-content: center;
    width:           30px;
    height:          30px;

    background:    transparent;
    border:        1px solid var(--c-line);
    border-radius: var(--r-micro);
    color:         var(--c-text-2);
    cursor:        pointer;

    transition:
      color        var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background   var(--dur-fast) var(--ease-out);
  }

  .stats__aoc-ctrl:hover {
    color:        var(--c-white);
    border-color: var(--c-line-strong);
    background:   rgba(255,255,255,0.05);
  }

  /* Botón cerrar — ligero acento diferenciador */
  .stats__aoc-close {
    margin-left: 8px;
    border-color: rgba(255,255,255,0.18);
  }
  .stats__aoc-close:hover {
    color:        var(--c-white);
    border-color: var(--c-text-2);
  }

  /* ── Viewport — área de imagen con overflow oculto ───────────────────── */

  .stats__aoc-viewport {
    flex:             1;
    position:         relative;
    overflow:         hidden;
    cursor:           default;

    /*
     * Centrar la imagen en el viewport.
     * La imagen usa position: absolute para ser transformada
     * con translate + scale desde su centro.
     */
    display:          flex;
    align-items:      center;
    justify-content:  center;

    /*
     * touch-action: none bloquea el scroll nativo del browser para
     * que los eventos touch pasen al JS de pinch/pan.
     * El JS maneja pan con 1 dedo cuando scale > 1.
     */
    touch-action:     none;
  }

  .stats__aoc-viewport.is-draggable {
    cursor: grab;
  }
  .stats__aoc-viewport.is-dragging {
    cursor: grabbing;
  }

  /* Imagen: centrada, sin distorsión, transform gestionado por JS */
  .stats__aoc-img {
    display:          block;
    max-width:        100%;
    max-height:       100%;
    width:            auto;
    height:           auto;
    object-fit:       contain;

    transform-origin: center center;
    transform:        translate(0, 0) scale(1);
    will-change:      transform;

    /* Evitar arrastre nativo del browser en la imagen */
    user-select:      none;
    -webkit-user-drag: none;
    pointer-events:   none; /* El viewport captura los eventos */
  }
</style>


<script>
  /**
   * StatsSection v2 — Motor de animaciones
   *
   * A. IntersectionObserver:
   *    Observa [data-stats-grid]. Cuando el 20% del grid entra en el
   *    viewport, añade .is-visible a todos los [data-stat-cell].
   *    El CSS se encarga del fade-up escalonado via --i + transition-delay.
   *
   * B. Number Counter:
   *    Para cada [data-counter] visible, lanza animateCounter().
   *    La función usa requestAnimationFrame + easeOutCubic para una
   *    deceleración natural. El número se formatea con "." como separador
   *    de miles (convención venezolana: 117.000, no 117,000).
   *
   * Las animaciones se ejecutan una única vez (observer.unobserve).
   */
  (function () {

    const grid = document.querySelector('[data-stats-grid]');
    if (!grid) return;

    const cells    = Array.from(grid.querySelectorAll('[data-stat-cell]'));
    const counters = Array.from(grid.querySelectorAll('[data-counter]'));

    /* ════════════════════════════════════════════════════════════════════
       UTILIDADES
    ════════════════════════════════════════════════════════════════════ */

    /**
     * Formatea un entero con punto como separador de miles.
     * Ejemplo: 117000 → "117.000"
     */
    function formatNumber(n) {
      return Math.round(n)
        .toString()
        .replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    }

    /**
     * Curva easeOutCubic: desaceleración suave al final.
     * t ∈ [0, 1] → output ∈ [0, 1]
     */
    function easeOutCubic(t) {
      return 1 - Math.pow(1 - t, 3);
    }

    /* ════════════════════════════════════════════════════════════════════
       B. ANIMACIÓN DE CONTADOR numérico
    ════════════════════════════════════════════════════════════════════ */

    /**
     * Anima el texto de `el` desde "prefix + 0" hasta "prefix + target"
     * en `duration` milisegundos usando rAF + easeOutCubic.
     *
     * @param {Element} el       - <span data-counter>
     * @param {number}  target   - Valor numérico final (ej: 117000)
     * @param {string}  prefix   - Prefijo fijo (ej: "+")
     * @param {number}  duration - Duración en ms (default: 2000)
     */
    function animateCounter(el, target, prefix, duration) {
      duration = duration || 2000;
      var startTime = null;

      function tick(now) {
        if (startTime === null) startTime = now;
        var elapsed  = now - startTime;
        var progress = Math.min(elapsed / duration, 1);
        var eased    = easeOutCubic(progress);
        var current  = Math.round(eased * target);

        el.textContent = prefix + formatNumber(current);

        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          /* Frame final exacto — compensa acumulación de error de redondeo */
          el.textContent = prefix + formatNumber(target);
        }
      }

      requestAnimationFrame(tick);
    }

    /* ════════════════════════════════════════════════════════════════════
       A. INTERSECTIONOBSERVER — REVEAL K3 + DISPATCH DE CONTADORES
    ════════════════════════════════════════════════════════════════════ */

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;

          /* 1. Reveal staggered: añadir .is-visible a todas las celdas */
          cells.forEach(function (cell) {
            cell.classList.add('is-visible');
          });

          /* 1b. Activar el subrayado animado de "Tres décadas" */
          var accent = document.querySelector('.stats__title-accent');
          if (accent) accent.classList.add('is-underlined');

          /* 2. Disparar contador en cada celda numérica */
          counters.forEach(function (counter) {
            var target = parseInt(counter.dataset.target || '0', 10);
            var prefix = counter.dataset.prefix || '';

            if (!isNaN(target) && target > 0) {
              animateCounter(counter, target, prefix, 2000);
            }
          });

          /* 3. Una sola ejecución — dejar de observar */
          observer.unobserve(entry.target);
        });
      },
      {
        /*
         * 20% del grid visible → disparar animaciones.
         * Suficiente para que el usuario vea el inicio de la entrada.
         */
        threshold: 0.20,
      }
    );

    observer.observe(grid);


    /* ════════════════════════════════════════════════════════════════════
       LIGHTBOX AOC — Zoom & Pan completo
       ─────────────────────────────────────────────────────────────────
       Estado: { scale, panX, panY }
         · scale  → 1.0 a 4.0 (1 = tamaño contenido, 4 = 400% zoom)
         · panX/Y → desplazamiento en px desde el centro del viewport
                    en el sistema de coordenadas del PADRE (sin escalar)

       Zoom pointer-centered (rueda):
         newPanX = pointerOffsetX * (1 - d) + panX * d
         donde d = newScale / oldScale

       Zoom botones: ×1.4 / ÷1.4 desde el centro
       Pan drag (mouse): cuando scale > 1
       Pan drag (touch): 1 dedo cuando scale > 1
       Pinch zoom (touch): 2 dedos — distancia entre puntos → newScale
    ════════════════════════════════════════════════════════════════════ */

    var openBtn   = document.getElementById('aoc-open-btn');
    var closeBtn  = document.getElementById('aoc-close-btn');
    var zoomInBtn = document.getElementById('aoc-zoom-in');
    var zoomOutBtn= document.getElementById('aoc-zoom-out');
    var zoomResetBtn = document.getElementById('aoc-zoom-reset');
    var zoomLabel = document.getElementById('aoc-zoom-label');
    var dialog    = /** @type {HTMLDialogElement|null} */ (document.getElementById('aoc-dialog'));
    var viewport  = document.getElementById('aoc-viewport');
    var img       = document.getElementById('aoc-img');

    if (!dialog || !viewport || !img) return;

    var MIN_SCALE = 1;
    var MAX_SCALE = 5;

    /* Estado del zoom/pan */
    var state = { scale: 1, panX: 0, panY: 0 };

    /* ── Aplicar transform al <img> y actualizar el label ─────────────── */
    function applyTransform() {
      img.style.transform =
        'translate(' + state.panX + 'px, ' + state.panY + 'px) scale(' + state.scale + ')';
      if (zoomLabel) zoomLabel.textContent = Math.round(state.scale * 100) + '%';

      /* Cambiar cursor del viewport según si se puede hacer pan */
      if (state.scale > 1) {
        viewport.classList.add('is-draggable');
      } else {
        viewport.classList.remove('is-draggable');
        viewport.classList.remove('is-dragging');
      }
    }

    /* ── Limitar el pan para que la imagen no se salga del viewport ─────── */
    function clampPan() {
      if (state.scale <= 1) {
        state.panX = 0;
        state.panY = 0;
        return;
      }
      /* Tamaño natural renderizado de la imagen (sin transform) */
      var iw = img.offsetWidth;
      var ih = img.offsetHeight;
      var vw = viewport.clientWidth;
      var vh = viewport.clientHeight;

      /*
       * El exceso: cuánto sobresale la imagen escalada respecto al viewport.
       * maxPan = (imagen_escalada - viewport) / 2
       * Si la imagen escalada cabe en el viewport, max = 0 → sin pan.
       */
      var maxX = Math.max(0, (iw * state.scale - vw) / 2);
      var maxY = Math.max(0, (ih * state.scale - vh) / 2);

      state.panX = Math.max(-maxX, Math.min(maxX, state.panX));
      state.panY = Math.max(-maxY, Math.min(maxY, state.panY));
    }

    /* ── Resetear estado de zoom/pan ──────────────────────────────────── */
    function resetZoom() {
      state.scale = 1;
      state.panX  = 0;
      state.panY  = 0;
      applyTransform();
    }

    /* ── Zoom centrado en un punto (px, py) del viewport ─────────────── */
    function zoomAtPoint(newScale, px, py) {
      newScale = Math.min(MAX_SCALE, Math.max(MIN_SCALE, newScale));
      var d = newScale / state.scale;
      state.panX  = px * (1 - d) + state.panX * d;
      state.panY  = py * (1 - d) + state.panY * d;
      state.scale = newScale;
      clampPan();
      applyTransform();
    }

    /* ── RUEDA DEL MOUSE — zoom pointer-centered ──────────────────────── */
    viewport.addEventListener('wheel', function (e) {
      e.preventDefault();

      /* deltaY negativo = acercar (scroll up), positivo = alejar (scroll down) */
      var factor = e.deltaY < 0 ? 1.12 : 1 / 1.12;
      var newScale = state.scale * factor;

      /* Centro del viewport en coordenadas relativas al viewport */
      var rect = viewport.getBoundingClientRect();
      var px = e.clientX - rect.left - rect.width  / 2;
      var py = e.clientY - rect.top  - rect.height / 2;

      zoomAtPoint(newScale, px, py);
    }, { passive: false });


    /* ── BOTONES DE ZOOM ───────────────────────────────────────────────── */
    if (zoomInBtn) {
      zoomInBtn.addEventListener('click', function () {
        zoomAtPoint(state.scale * 1.4, 0, 0);
      });
    }
    if (zoomOutBtn) {
      zoomOutBtn.addEventListener('click', function () {
        zoomAtPoint(state.scale / 1.4, 0, 0);
      });
    }
    if (zoomResetBtn) {
      zoomResetBtn.addEventListener('click', resetZoom);
    }


    /* ── DRAG CON MOUSE — pan cuando scale > 1 ──────────────────────── */
    var isDragging = false;
    var dragOrigin = { x: 0, y: 0, panX: 0, panY: 0 };

    viewport.addEventListener('mousedown', function (e) {
      if (state.scale <= 1 || e.button !== 0) return;
      isDragging = true;
      dragOrigin = { x: e.clientX, y: e.clientY, panX: state.panX, panY: state.panY };
      viewport.classList.add('is-dragging');
      e.preventDefault();
    });

    window.addEventListener('mousemove', function (e) {
      if (!isDragging) return;
      state.panX = dragOrigin.panX + (e.clientX - dragOrigin.x);
      state.panY = dragOrigin.panY + (e.clientY - dragOrigin.y);
      clampPan();
      applyTransform();
    });

    window.addEventListener('mouseup', function () {
      if (!isDragging) return;
      isDragging = false;
      viewport.classList.remove('is-dragging');
    });


    /* ── TOUCH — pinch zoom + drag de un dedo ──────────────────────── */
    var lastPinchDist = 0;
    var lastPinchScale = 1;
    var touchDragOrigin = null;

    viewport.addEventListener('touchstart', function (e) {
      if (e.touches.length === 2) {
        /* Iniciar pinch */
        e.preventDefault();
        lastPinchDist  = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY
        );
        lastPinchScale = state.scale;
        touchDragOrigin = null;
      } else if (e.touches.length === 1 && state.scale > 1) {
        /* Pan con un dedo (solo cuando hay zoom) */
        touchDragOrigin = {
          x: e.touches[0].clientX, y: e.touches[0].clientY,
          panX: state.panX, panY: state.panY
        };
      }
    }, { passive: false });

    viewport.addEventListener('touchmove', function (e) {
      if (e.touches.length === 2 && lastPinchDist > 0) {
        e.preventDefault();
        var dist     = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY
        );
        var newScale = Math.min(MAX_SCALE, Math.max(MIN_SCALE, lastPinchScale * (dist / lastPinchDist)));

        /* Centro del pinch en coordenadas del viewport */
        var rect = viewport.getBoundingClientRect();
        var cx = ((e.touches[0].clientX + e.touches[1].clientX) / 2) - rect.left - rect.width  / 2;
        var cy = ((e.touches[0].clientY + e.touches[1].clientY) / 2) - rect.top  - rect.height / 2;

        var d = newScale / state.scale;
        state.panX  = cx * (1 - d) + state.panX * d;
        state.panY  = cy * (1 - d) + state.panY * d;
        state.scale = newScale;
        clampPan();
        applyTransform();

      } else if (e.touches.length === 1 && touchDragOrigin) {
        e.preventDefault();
        state.panX = touchDragOrigin.panX + (e.touches[0].clientX - touchDragOrigin.x);
        state.panY = touchDragOrigin.panY + (e.touches[0].clientY - touchDragOrigin.y);
        clampPan();
        applyTransform();
      }
    }, { passive: false });

    viewport.addEventListener('touchend', function (e) {
      if (e.touches.length < 2) lastPinchDist = 0;
      if (e.touches.length < 1) touchDragOrigin = null;
    });


    /* ── ABRIR / CERRAR el dialog ──────────────────────────────────── */
    if (openBtn) {
      openBtn.addEventListener('click', function () {
        dialog.showModal();
      });
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', function () {
        dialog.close();
      });
    }

    /* Cerrar al hacer clic en el backdrop (fuera del .stats__aoc-inner) */
    dialog.addEventListener('click', function (e) {
      var rect = dialog.getBoundingClientRect();
      if (
        e.clientX < rect.left   ||
        e.clientX > rect.right  ||
        e.clientY < rect.top    ||
        e.clientY > rect.bottom
      ) {
        dialog.close();
      }
    });

    /* Resetear zoom al cerrar */
    dialog.addEventListener('close', resetZoom);

  })();
</script>
