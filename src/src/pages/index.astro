<!-- ═══════════════════════════════════════════════════════
     SCRIPTS
     1. Reveal (IntersectionObserver) para .reveal/.is-visible
     2. Counter animation para .counter-value[data-target]
════════════════════════════════════════════════════════════ -->
<script>
  (() => {
    // ── 1. REVEAL ──────────────────────────────────────────
    const reveals = document.querySelectorAll('.reveal');
    if (reveals.length) {
      const io = new IntersectionObserver(
        entries => entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }),
        { threshold: 0.12 }
      );
      reveals.forEach(el => io.observe(el));
    }

    // ── 2. COUNTER ANIMATION ───────────────────────────────
    /**
     * Formatea número con punto como separador de miles.
     * Ej: 171500 → "171.500"
     */
    function fmtNum(n: number): string {
      return String(Math.round(n)).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    }

    /** Ease-out cúbico */
    function easeOut(t: number): number {
      return 1 - (1 - t) ** 3;
    }

    /** Anima textContent de `el` desde 0 a `target` en `duration` ms */
    function runCounter(el: Element, target: number, duration: number) {
      const start = performance.now();
      const tick = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        el.textContent = fmtNum(easeOut(progress) * target);
        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          el.textContent = fmtNum(target);
        }
      };
      requestAnimationFrame(tick);
    }

    const counterEls = document.querySelectorAll('.counter-value[data-target]');
    if (counterEls.length) {
      const cio = new IntersectionObserver(
        entries => entries.forEach(e => {
          if (e.isIntersecting) {
            const el = e.target as HTMLElement;
            const target = parseInt(el.dataset.target ?? '0', 10);
            runCounter(el, target, 2400);
            cio.unobserve(el);
          }
        }),
        { threshold: 0.30 }
      );
      counterEls.forEach(el => cio.observe(el));
    }
  })();
</script>
