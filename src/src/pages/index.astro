---
/**
 * HELITEC — index.astro
 * Homepage principal. Rediseño UI Pilatus / Licorn Publishing.
 *
 * Cambios v5:
 *   — Tipografía 100% sans-serif (eliminada cursiva/serif en H1/H2/H3)
 *   — Hero: font-weight 200 (thin), letter-spacing premium
 *   — Stats: grid 2 columnas en mobile (sin colapso a 1fr)
 *   — Stats: valores a fw-light (300) — "Ligero = más presencia visual"
 *   — Servicios: bloques parallax fullbleed min-height 70vh
 *   — background-attachment: fixed (fallback scroll en iOS/touch)
 *   — Botones: ghost premium en todo; rojo sólido sólo en CTAFloat
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
import CTAFloat   from '../components/CTAFloat.astro';

const lang = 'es';

const WA_NUMBER = '584166235254';
const WA_MSG    = 'Hola Helitec, me gustaría recibir asesoría corporativa sobre sus servicios de vuelos chárter.';
const waHref    = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(WA_MSG)}`;

/* ── Datos de estadísticas ─────────────────────────────────
   kind: 'num' → contador animado con IntersectionObserver
   kind: 'txt' → texto estático
────────────────────────────────────────────────────────────*/
type StatNum = { kind: 'num'; target: number; label: string };
type StatTxt = { kind: 'txt'; headline: string; sub: string };
type Stat    = StatNum | StatTxt;

const stats: Stat[] = [
  { kind: 'num', target: 117000, label: 'Horas de vuelo en helicópteros' },
  { kind: 'num', target: 43000,  label: 'Horas de vuelo en aviones'      },
  { kind: 'num', target: 171500, label: 'Pasajeros transportados'         },
  { kind: 'txt', headline: 'Nacional e Internacional', sub: 'Cobertura de operaciones'   },
  { kind: 'num', target: 35,     label: 'Años de experiencia'             },
  { kind: 'txt', headline: 'INAC · OACI',             sub: 'Certificaciones activas'     },
];

/* ── Datos de servicios con foto para parallax ─────────── */
const services = [
  {
    num:   '01',
    title: 'Ala Fija Chárter',
    desc:  'Vuelos ejecutivos y corporativos en aviones Swearingen Metro y Cessna 402. Operaciones nacionales e internacionales bajo estándares de aerolíneas comerciales.',
    href:  '/servicios/ala-fija',
    photo: '/assets/PHOTO-2024-10-30-15-40-52.JPG',
  },
  {
    num:   '02',
    title: 'Ala Rotatoria',
    desc:  'Transporte a plataformas petroleras, zonas industriales y destinos sin pista convencional. Helicópteros Bell para misiones de alta exigencia operacional.',
    href:  '/servicios/ala-rotatoria',
    photo: '/assets/Helicoptero_en%20pico.jpg',
  },
  {
    num:   '03',
    title: 'Traslados Aeromédicos',
    desc:  'Evacuaciones médicas y traslados de emergencia con tripulación especializada y equipo paramédico certificado a bordo. Disponibilidad 24/7/365.',
    href:  '/servicios/aeromedico',
    photo: '/assets/Aeromedico_1.jpg',
  },
];
---

<BaseLayout
  title="Aviación Corporativa y Chárter Ejecutivo en Venezuela"
  description="Consorcio Helitec C.A. · Operador INAC certificado. Vuelos chárter, transporte industrial, helicópteros y traslados aeromédicos. Más de 35 años de operaciones en Venezuela."
  lang={lang}
>

  <Header slot="header" lang={lang} />


  <!-- ════════════════════════════════════════════════════════
       §1 — HERO
  ════════════════════════════════════════════════════════════ -->
  <section class="hero" id="hero" aria-label="Presentación">

    <!-- Fondo fotográfico con Ken Burns (clase global) -->
    <div class="hero-bg-img" aria-hidden="true">
      <img
        src="/assets/PHOTO-2024-10-30-15-40-52.JPG"
        alt=""
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1920"
        height="1080"
      />
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>

    <div class="hero-inner container">
      <div class="hero-content">

        <p class="text-overline hero-overline reveal">
          Certificado INAC · Operaciones desde 1990
        </p>

        <!-- H1 — fw-thin (200), sin cursiva, tracking premium -->
        <h1 class="hero-heading reveal" data-delay="1">
          Aviación Corporativa
          <span class="hero-heading__sub">de Precisión</span>
        </h1>

        <p class="hero-sub reveal" data-delay="2">
          Transporte ejecutivo, industrial y aeromédico bajo los estándares
          más exigentes de la aviación comercial. Más de 35 años de
          operaciones ininterrumpidas en Venezuela y la región.
        </p>

        <!-- Ghost buttons — rojo reservado para CTAFloat flotante -->
        <div class="hero-ctas reveal" data-delay="3">
          <a
            href={waHref}
            class="btn btn--ghost-premium"
            target="_blank"
            rel="noopener noreferrer"
          >
            Solicitar Cotización
          </a>
          <a href="/flota" class="btn btn--ghost">
            Conocer la Flota
          </a>
        </div>

        <div class="hero-scroll-hint reveal" data-delay="4" aria-hidden="true">
          <span class="hero-scroll-line"></span>
          <span class="hero-scroll-text">Desplazar</span>
        </div>

      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       §2 — ESTADÍSTICAS OPERACIONALES
  ════════════════════════════════════════════════════════════ -->
  <section class="stats" id="estadisticas" aria-label="Estadísticas operacionales">
    <div class="container">

      <div class="section-header reveal">
        <p class="text-overline">Historial Operacional</p>
        <!-- H2 — sin cursiva; segunda línea más ligera -->
        <h2 class="section-title">
          Números que respaldan
          <span>la confianza</span>
        </h2>
      </div>

      <div class="stats-grid">
        {stats.map((stat, i) => (
          <div
            class={`stat-item reveal${stat.kind === 'num' ? ' stat-item--num' : ' stat-item--txt'}`}
            data-delay={String((i % 3) + 1)}
          >
            {stat.kind === 'num' ? (
              <>
                <div class="stat-val-wrap" aria-label={`Más de ${stat.target.toLocaleString('de-DE')} — ${stat.label}`}>
                  <span class="stat-prefix" aria-hidden="true">+</span>
                  <span
                    class="stat-val counter-value"
                    data-target={stat.target}
                    aria-hidden="true"
                  >0</span>
                </div>
                <p class="stat-label counter-label">{stat.label}</p>
              </>
            ) : (
              <>
                <p class="stat-txt-headline">{stat.headline}</p>
                <p class="stat-label">{stat.sub}</p>
              </>
            )}
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       §3 — FRANJA INAC (Trust Badge)
  ════════════════════════════════════════════════════════════ -->
  <section class="certif" id="certificaciones" aria-label="Certificaciones oficiales">
    <div class="container">
      <div class="certif-inner reveal">

        <div class="certif-badge">
          <img
            src="/assets/logoinac.png"
            alt="Instituto Nacional de Aeronáutica Civil — INAC Venezuela"
            class="certif-logo"
            width="180"
            height="72"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="certif-divider" aria-hidden="true"></div>

        <div class="certif-body">
          <p class="text-overline certif-caption">Certificación Vigente</p>
          <p class="certif-statement">
            Operamos como <strong>Proveedor de Servicio Público de Transporte Aéreo</strong>
            bajo supervisión del INAC y el sistema de gestión de seguridad
            SMS conforme al Anexo 19 de la OACI.
          </p>
        </div>

        <div class="certif-divider" aria-hidden="true"></div>

        <div class="certif-badge certif-badge--oaci">
          <div class="certif-oaci">
            <svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
              <circle cx="22" cy="22" r="20" stroke="rgba(88,181,240,0.35)" stroke-width="1.5"/>
              <circle cx="22" cy="22" r="13" stroke="rgba(88,181,240,0.20)" stroke-width="1"/>
              <ellipse cx="22" cy="22" rx="7" ry="20" stroke="rgba(88,181,240,0.22)" stroke-width="1" fill="none"/>
              <line x1="2" y1="22" x2="42" y2="22" stroke="rgba(88,181,240,0.20)" stroke-width="1"/>
            </svg>
            <div class="certif-oaci-text">
              <span class="certif-oaci-label">SMS OACI</span>
              <span class="certif-oaci-sub">Anexo 19</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       §4 — SERVICIOS PRINCIPALES (Parallax Licorn Publishing)
       Cada servicio = bloque fullbleed con foto de fondo y
       background-attachment: fixed para efecto parallax al scroll.
  ════════════════════════════════════════════════════════════ -->
  <section class="servicios-parallax" id="servicios" aria-label="Servicios principales">

    <div class="servicios-parallax__header container reveal">
      <p class="text-overline">Capacidades Operacionales</p>
    </div>

    {services.map((svc, i) => (
      <div
        class="svc-scene"
        style={`--svc-photo: url('${svc.photo}')`}
      >
        <!-- Overlay degradado: denso en la base, transparente arriba -->
        <div class="svc-scene__overlay" aria-hidden="true"></div>

        <div class="svc-scene__content container reveal" data-delay={String(i + 1)}>
          <span class="svc-scene__num" aria-hidden="true">{svc.num}</span>
          <h3 class="svc-scene__title">{svc.title}</h3>
          <p class="svc-scene__desc">{svc.desc}</p>
          <a
            href={svc.href}
            class="svc-scene__cta"
            aria-label={`Ver servicio: ${svc.title}`}
          >
            Ver servicio
            <svg
              width="16" height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    ))}

    <!-- CTA de sección — alineado a la derecha (Pilatus) -->
    <div class="servicios-cta container reveal">
      <a href="/servicios" class="btn btn--ghost-premium">
        Ver todos los servicios
      </a>
    </div>

  </section>


  <Footer slot="footer" lang={lang} />
  <CTAFloat slot="cta" lang={lang} />

</BaseLayout>


<!-- ═══════════════════════════════════════════════════════
     ESTILOS SCOPED
════════════════════════════════════════════════════════════ -->
<style>

/* ── Encabezado de sección ──────────────────────────────── */

.section-header {
  margin-bottom: var(--space-16);
}

/* H2 — sans-serif sin cursiva. Primera línea: fw-light 300.
   Segunda línea (<span>): fw-thin 200, color levemente muted. */
.section-title {
  font-family:    var(--font-primary);
  font-size:      clamp(1.875rem, 3.5vw, 2.75rem);
  font-weight:    var(--fw-light);    /* 300 */
  color:          #fff;
  line-height:    1.08;
  margin-top:     var(--space-3);
  letter-spacing: -0.02em;
}

.section-title span {
  display:        block;
  font-weight:    var(--fw-thin);     /* 200 */
  letter-spacing:  0.01em;
  color:           rgba(255, 255, 255, 0.70);
}


/* ════════════════════════════════════════════════════════
   §1 HERO
════════════════════════════════════════════════════════════ */

.hero {
  position:   relative;
  min-height: 100vh;
  min-height: 100svh;
  display:    flex;
  align-items:center;
  background: var(--color-bg-base);
  overflow:   hidden;
}

.hero-inner {
  padding-block: clamp(var(--space-24), 14vh, var(--space-32));
  position:      relative;
  z-index:       1;
}

.hero-content { max-width: 680px; }

.hero-overline { margin-bottom: var(--space-5); }

/* H1 — fw-thin (200). Sin familia serif, sin cursiva. */
.hero-heading {
  font-family:    var(--font-primary);
  font-size:      clamp(2.5rem, 6vw, 5rem);
  font-weight:    var(--fw-thin);     /* 200 */
  color:          #fff;
  line-height:    1.04;
  letter-spacing: -0.025em;
  margin-bottom:  var(--space-7);
}

/* Segunda línea del H1 — acento cromático, tracking ligeramente abierto */
.hero-heading__sub {
  display:        block;
  color:          var(--brand-azul-cielo);
  font-weight:    var(--fw-thin);     /* 200 — consistente con primera línea */
  letter-spacing:  0.005em;
  font-style:      normal;            /* Explícito: sin cursiva */
}

.hero-sub {
  font-size:     clamp(var(--text-base), 1.5vw, var(--text-lg));
  font-weight:   var(--fw-light);
  color:         rgba(255, 255, 255, 0.65);
  line-height:   1.7;
  max-width:     52ch;
  margin-bottom: var(--space-10);
}

.hero-ctas {
  display:     flex;
  align-items: center;
  gap:         var(--space-4);
  flex-wrap:   wrap;
}

/* Indicador de scroll */
.hero-scroll-hint {
  display:     flex;
  align-items: center;
  gap:         var(--space-4);
  margin-top:  var(--space-14);
}

.hero-scroll-line {
  display:    block;
  width:      48px;
  height:     1px;
  background: rgba(255, 255, 255, 0.25);
  position:   relative;
  overflow:   hidden;
}

.hero-scroll-line::after {
  content:    '';
  position:   absolute;
  inset:      0;
  background: var(--brand-azul-cielo);
  transform:  translateX(-100%);
  animation:  scroll-line 2s var(--ease-in-out) infinite;
}

@keyframes scroll-line {
  0%   { transform: translateX(-100%); }
  50%  { transform: translateX(0); }
  100% { transform: translateX(100%); }
}

.hero-scroll-text {
  font-size:      var(--text-xs);
  font-weight:    var(--fw-medium);
  letter-spacing: var(--tracking-widest);
  text-transform: uppercase;
  color:          rgba(255, 255, 255, 0.35);
}

@media (prefers-reduced-motion: reduce) {
  .hero-scroll-line::after { animation: none; }
}


/* ════════════════════════════════════════════════════════
   §2 ESTADÍSTICAS
════════════════════════════════════════════════════════════ */

.stats {
  background:    var(--color-bg-surface);
  padding-block: var(--space-24);
  border-top:    1px solid rgba(255, 255, 255, 0.04);
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.stats-grid {
  display:               grid;
  grid-template-columns: repeat(3, 1fr);
  gap:                   0;
}

/* Mobile: SIEMPRE 2 columnas — nunca colapsar a 1 */
@media (max-width: 768px) {
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
}

.stat-item {
  padding:      var(--space-10) var(--space-8);
  border-top:   2px solid rgba(88, 181, 240, 0);
  border-right: 1px solid rgba(255, 255, 255, 0.05);
  transition:   border-top-color var(--transition-base);
  position:     relative;
}

.stat-item:nth-child(3n) { border-right: none; }
.stat-item:nth-child(n+4) {
  border-top-color: rgba(255, 255, 255, 0.05);
  border-top-width: 1px;
}
.stat-item:hover {
  border-top-width: 2px;
  border-top-color: var(--brand-azul-cielo);
}

@media (max-width: 768px) {
  .stat-item { padding: var(--space-8) var(--space-5); }
  .stat-item:nth-child(3n)  { border-right: 1px solid rgba(255, 255, 255, 0.05); }
  .stat-item:nth-child(2n)  { border-right: none; }
  .stat-item:nth-child(n+3) {
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.05);
  }
}

/* Número — fw-light (300). Escala visual = tamaño + espaciado, no bold */
.stat-val-wrap {
  display:       flex;
  align-items:   baseline;
  line-height:   1;
  margin-bottom: var(--space-3);
}

.stat-prefix {
  font-family:  var(--font-primary);
  font-size:    clamp(1.5rem, 3vw, 2.25rem);
  font-weight:  var(--fw-light);
  color:        var(--brand-azul-cielo);
  margin-right: 2px;
}

.stat-val {
  font-family:          var(--font-primary);
  font-size:            clamp(2.25rem, 5vw, 3.5rem);
  font-weight:          var(--fw-light);     /* 300 — Pilatus style */
  color:                #fff;
  letter-spacing:       -0.03em;
  line-height:          1;
  font-variant-numeric: tabular-nums;
}

/* Texto estático — mismo tratamiento ligero */
.stat-txt-headline {
  font-family:    var(--font-primary);
  font-size:      clamp(1.25rem, 2.5vw, 1.875rem);
  font-weight:    var(--fw-light);    /* 300 — sin negrita */
  color:          #fff;
  line-height:    1.2;
  letter-spacing: -0.01em;
  margin-bottom:  var(--space-3);
}

.stat-label {
  font-size:      var(--text-sm);
  font-weight:    var(--fw-medium);
  color:          rgba(255, 255, 255, 0.45);
  text-transform: uppercase;
  letter-spacing: var(--tracking-wide);
  line-height:    1.4;
}


/* ════════════════════════════════════════════════════════
   §3 CERTIFICACIONES — sin cambios de diseño
════════════════════════════════════════════════════════════ */

.certif {
  background:    var(--color-bg-brand-deep);
  padding-block: var(--space-14);
  border-top:    1px solid rgba(88, 181, 240, 0.10);
  border-bottom: 1px solid rgba(88, 181, 240, 0.10);
}

.certif-inner {
  display:     flex;
  align-items: center;
  gap:         var(--space-12);
  flex-wrap:   wrap;
}

@media (max-width: 768px) {
  .certif-inner {
    flex-direction: column;
    gap:        var(--space-8);
    text-align: center;
  }
}

.certif-badge {
  flex-shrink:     0;
  display:         flex;
  align-items:     center;
  justify-content: center;
}

.certif-logo {
  display:    block;
  max-width:  180px;
  height:     auto;
  filter:     brightness(0) invert(1);
  opacity:    0.80;
  transition: opacity var(--transition-base);
}

.certif-logo:hover { opacity: 1; }

.certif-divider {
  width:       1px;
  height:      60px;
  background:  rgba(88, 181, 240, 0.18);
  flex-shrink: 0;
}

@media (max-width: 768px) {
  .certif-divider { width: 60px; height: 1px; }
}

.certif-body    { flex: 1 1 320px; }
.certif-caption { margin-bottom: var(--space-3); }

.certif-statement {
  font-size:   var(--text-sm);
  font-weight: var(--fw-light);
  color:       rgba(255, 255, 255, 0.60);
  line-height: 1.7;
}

.certif-statement strong {
  color:       rgba(255, 255, 255, 0.85);
  font-weight: var(--fw-medium);
}

.certif-oaci {
  display:     flex;
  align-items: center;
  gap:         var(--space-4);
}

.certif-oaci svg { flex-shrink: 0; }

.certif-oaci-text {
  display:        flex;
  flex-direction: column;
  gap:            2px;
}

.certif-oaci-label {
  font-size:      var(--text-sm);
  font-weight:    var(--fw-semibold);
  color:          rgba(88, 181, 240, 0.75);
  letter-spacing: var(--tracking-wide);
}

.certif-oaci-sub {
  font-size:      var(--text-xs);
  color:          rgba(255, 255, 255, 0.35);
  letter-spacing: var(--tracking-wide);
}


/* ════════════════════════════════════════════════════════
   §4 SERVICIOS — PARALLAX FULLBLEED (Licorn Publishing)
════════════════════════════════════════════════════════════ */

.servicios-parallax {
  background: var(--color-bg-void);
}

.servicios-parallax__header {
  padding-block: var(--space-16) var(--space-8);
}

/* ── Escena individual ──────────────────────────────────
   Cada servicio ocupa mínimo 70vh.
   La foto de fondo se asigna vía CSS custom property --svc-photo
   desde un style inline en el template.
─────────────────────────────────────────────────────────── */
.svc-scene {
  position:              relative;
  min-height:            70vh;
  display:               flex;
  align-items:           flex-end;
  background-image:      var(--svc-photo);
  background-size:       cover;
  background-position:   center 30%;
  background-attachment: fixed;           /* Parallax CSS */
  background-color:      var(--color-bg-elevated); /* Fallback */
}

/* iOS / Android: fixed attachment causa artefactos en touch devices */
@media (hover: none), (pointer: coarse) {
  .svc-scene { background-attachment: scroll; }
}

/* Degradado: denso en la base para legibilidad, sutil arriba */
.svc-scene__overlay {
  position:       absolute;
  inset:          0;
  background:     linear-gradient(
    to top,
    rgba(3, 8, 16, 0.94)  0%,
    rgba(3, 8, 16, 0.55) 45%,
    rgba(3, 8, 16, 0.15) 100%
  );
  pointer-events: none;
}

/* Contenido: posición relativa sobre el overlay, pegado a la base */
.svc-scene__content {
  position:      relative;
  z-index:       1;
  padding-block: var(--space-20);
  max-width:     720px;
}

/* Número de referencia */
.svc-scene__num {
  display:        block;
  font-size:      0.60rem;
  font-weight:    var(--fw-semibold);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color:          var(--brand-azul-cielo);
  opacity:        0.70;
  margin-bottom:  var(--space-6);
}

/* H3 — fw-thin (200). Ultra-limpio, sin serif, tracking ajustado */
.svc-scene__title {
  font-family:    var(--font-primary);
  font-size:      clamp(var(--text-2xl), 4.5vw, var(--text-4xl));
  font-weight:    var(--fw-thin);         /* 200 — Pilatus */
  color:          #fff;
  letter-spacing: -0.025em;
  line-height:    1.05;
  margin-bottom:  var(--space-6);
}

.svc-scene__desc {
  font-size:     clamp(var(--text-sm), 1.4vw, var(--text-base));
  font-weight:   var(--fw-light);
  color:         rgba(255, 255, 255, 0.62);
  line-height:   1.78;
  max-width:     54ch;
  margin-bottom: var(--space-10);
}

