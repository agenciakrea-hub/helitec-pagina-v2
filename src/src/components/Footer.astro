---
/**
 * HELITEC — Footer.astro
 * Footer corporativo minimalista. Fondo azul Helitec profundo.
 * Tres pilares: navegación, flota, contacto.
 * Barra inferior: certifications strip + copyright.
 *
 * Props:
 *   lang — 'es' | 'en'
 */

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const year = new Date().getFullYear();

const i18n = {
  es: {
    tagline:    'Vuelos Chárter Ejecutivos y Traslados Aeromédicos con los más altos estándares de excelencia operativa.',
    certBadge:  'Certificado INAC',
    smsBadge:   'SMS OACI Anexo 19',
    cols: [
      {
        heading: 'Empresa',
        links: [
          { label: 'La Empresa',          href: '/nosotros'            },
          { label: 'Seguridad & Calidad',  href: '/seguridad-y-calidad' },
          { label: 'Galería',             href: '/galeria'             },
          { label: 'Preguntas Frecuentes',href: '/preguntas-frecuentes'},
          { label: 'Legal',               href: '/legal/contrato-de-servicio' },
        ],
      },
      {
        heading: 'Aeronaves',
        links: [
          { label: 'Ala Fija — Metro Series', href: '/flota#ala-fija'         },
          { label: 'Ala Rotatoria — MD Series',href: '/flota#ala-rotatoria'   },
          { label: 'Traslados Aeromédicos',   href: '/servicios#aeromedico'   },
          { label: 'Ver Flota Completa',       href: '/flota'                  },
        ],
      },
      {
        heading: 'Contacto',
        links: [],
      },
    ],
    contact: {
      phone1:   '+58 212 959-6385',
      phone2:   '959-8753 / 959-2526',
      email:    'info@helitec.com',
      address1: 'CCCT, Chuao',
      address2: 'Caracas, Venezuela',
    },
    social: [
      { label: 'Instagram', href: '#' },
      { label: 'LinkedIn',  href: '#' },
    ],
    copyright:  `© ${year} Consorcio Helitec C.A. Todos los derechos reservados.`,
    footerNote: 'Operador de Servicio Público de Transporte Aéreo Nacional e Internacional bajo estándares de líneas aéreas comerciales.',
    cta:        'Solicitar Cotización',
    ctaHref:    '/contacto',
  },
  en: {
    tagline:    'Executive Charter Flights and Aeromedical Transfers at the highest operational excellence standards.',
    certBadge:  'INAC Certified',
    smsBadge:   'SMS ICAO Annex 19',
    cols: [
      {
        heading: 'Company',
        links: [
          { label: 'About Us',          href: '/en/about'          },
          { label: 'Safety & Quality',  href: '/en/safety-quality' },
          { label: 'Gallery',           href: '/en/gallery'        },
          { label: 'FAQ',               href: '/en/faq'            },
          { label: 'Legal',             href: '/en/legal'          },
        ],
      },
      {
        heading: 'Fleet',
        links: [
          { label: 'Fixed Wing — Metro Series',   href: '/en/fleet#fixed-wing'   },
          { label: 'Rotary Wing — MD Series',      href: '/en/fleet#rotary-wing'  },
          { label: 'Aeromedical Transfers',        href: '/en/services#aeromedical'},
          { label: 'View Full Fleet',              href: '/en/fleet'              },
        ],
      },
      {
        heading: 'Contact',
        links: [],
      },
    ],
    contact: {
      phone1:   '+58 212 959-6385',
      phone2:   '959-8753 / 959-2526',
      email:    'info@helitec.com',
      address1: 'CCCT, Chuao',
      address2: 'Caracas, Venezuela',
    },
    social: [
      { label: 'Instagram', href: '#' },
      { label: 'LinkedIn',  href: '#' },
    ],
    copyright:  `© ${year} Consorcio Helitec C.A. All rights reserved.`,
    footerNote: 'Public Air Transport Operator — National & International — under commercial airline standards.',
    cta:        'Request a Quote',
    ctaHref:    '/en/contact',
  },
}[lang];
---

<footer class="site-footer" role="contentinfo">

  <!-- ── Franja superior — CTA de cierre de página ─────────── -->
  <div class="footer-cta-strip">
    <div class="footer-cta-strip__inner">
      <p class="footer-cta-strip__text">
        {lang === 'es'
          ? 'Central de Atención Ejecutiva · Disponible 24 / 7 / 365'
          : 'Executive Operations Center · Available 24 / 7 / 365'}
      </p>
      <a href={i18n.ctaHref} class="btn btn--ghost btn--sm footer-cta-strip__btn">
        {i18n.cta}
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M1 11L11 1M11 1H4M11 1V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- ── Cuerpo principal del footer ───────────────────────── -->
  <div class="footer-body">
    <div class="footer-grid">

      <!-- Columna 1: Logo + tagline + badges de certificación -->
      <div class="footer-brand">
        <a href={lang === 'es' ? '/' : '/en/'} class="footer-logo" aria-label="Consorcio Helitec">
          <span class="footer-logo__mark">H</span>
          <span class="footer-logo__wordmark">ELITEC</span>
        </a>
        <p class="footer-tagline">{i18n.tagline}</p>
        <div class="footer-badges">
          <span class="footer-badge">
            <img src="/assets/logoinac.png" alt="" class="footer-badge__logo" aria-hidden="true" loading="lazy" />
            {i18n.certBadge}
          </span>
          <span class="footer-badge">
            <!-- OACI -->
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1"/>
              <path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1"/>
              <ellipse cx="6" cy="6" rx="2.5" ry="5" stroke="currentColor" stroke-width="1"/>
            </svg>
            {i18n.smsBadge}
          </span>
        </div>
      </div>

      <!-- Columnas 2 y 3: Empresa + Aeronaves -->
      {i18n.cols.slice(0, 2).map(col => (
        <div class="footer-col">
          <h3 class="footer-col__heading">{col.heading}</h3>
          <ul class="footer-col__list" role="list">
            {col.links.map(link => (
              <li>
                <a href={link.href} class="footer-col__link">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Columna 4: Contacto -->
      <div class="footer-col footer-col--contact">
        <h3 class="footer-col__heading">{i18n.cols[2].heading}</h3>
        <div class="footer-contact">
          <a href={`tel:${i18n.contact.phone1.replace(/\s|-/g,'')}`} class="footer-contact__item footer-contact__item--highlight">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M12.5 9.5L10 12C5.5 10 2 6.5 2 2L4.5 1.5L6 4.5L4.5 6C5.5 7.5 6.5 8.5 8 9.5L9.5 8L12.5 9.5Z" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
            </svg>
            {i18n.contact.phone1}
          </a>
          <a href={`tel:${i18n.contact.phone1.replace(/\s|-/g,'')}`} class="footer-contact__item footer-contact__item--secondary">
            {i18n.contact.phone2}
          </a>
          <a href={`mailto:${i18n.contact.email}`} class="footer-contact__item">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <rect x="1" y="3" width="12" height="8" rx="1" stroke="currentColor" stroke-width="1"/>
              <path d="M1 3.5L7 8L13 3.5" stroke="currentColor" stroke-width="1"/>
            </svg>
            {i18n.contact.email}
          </a>
          <address class="footer-contact__address">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M7 1C4.8 1 3 2.8 3 5C3 8 7 13 7 13C7 13 11 8 11 5C11 2.8 9.2 1 7 1Z" stroke="currentColor" stroke-width="1"/>
              <circle cx="7" cy="5" r="1.5" stroke="currentColor" stroke-width="1"/>
            </svg>
            <span>{i18n.contact.address1}<br />{i18n.contact.address2}</span>
          </address>
        </div>

        <!-- Redes sociales -->
        <div class="footer-social">
          {i18n.social.map(s => (
            <a href={s.href} class="footer-social__link" aria-label={s.label} target="_blank" rel="noopener noreferrer">
              {s.label === 'Instagram' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              )}
              {s.label === 'LinkedIn' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- ── Barra inferior: copyright + nota legal ────────────── -->
  <div class="footer-bottom">
    <div class="footer-bottom__inner">
      <p class="footer-bottom__copy">{i18n.copyright}</p>
      <p class="footer-bottom__note">{i18n.footerNote}</p>
    </div>
  </div>

</footer>


<style>

  /* ── BASE ───────────────────────────────────────────────── */

  .site-footer {
    background: var(--color-bg-brand-deep);
    border-top: 1px solid var(--color-border-subtle);
  }


  /* ── FRANJA CTA SUPERIOR ─────────────────────────────────── */

  .footer-cta-strip {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-cta-strip__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    max-width: var(--container-xl);
    margin-inline: auto;
    padding-inline: var(--container-px);
    padding-block: var(--space-5);
  }

  .footer-cta-strip__text {
    font-size: var(--text-xs);
    font-weight: var(--fw-medium);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-muted);
    max-width: none; /* override global p */
  }

  .footer-cta-strip__btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-5);
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .footer-cta-strip__btn:hover {
    background: rgba(255,255,255,0.06);
    border-color: var(--color-border-medium);
    color: var(--color-text-primary);
  }

  @media (max-width: 640px) {
    .footer-cta-strip__inner { flex-direction: column; align-items: flex-start; }
  }


  /* ── CUERPO ─────────────────────────────────────────────── */

  .footer-body {
    max-width: var(--container-xl);
    margin-inline: auto;
    padding-inline: var(--container-px);
    padding-block: var(--space-20) var(--space-16);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1.4fr;
    gap: var(--space-12);
    align-items: start;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
  }


  /* ── LOGO Y BRAND ─────────────────────────────────────────── */

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0;
    text-decoration: none;
  }

  .footer-logo__mark {
    font-family: var(--font-primary);
    font-size: 1.75rem;
    font-weight: var(--fw-bold);
    color: var(--brand-rojo-helitec);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .footer-logo__wordmark {
    font-family: var(--font-primary);
    font-size: 1.75rem;
    font-weight: var(--fw-bold);
    color: var(--color-text-primary);
    line-height: 1;
    letter-spacing: 0.05em;
  }

  .footer-tagline {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 32ch;
  }

  .footer-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .footer-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--brand-azul-cielo);
    background: var(--brand-sky-08);
    border: 1px solid var(--color-border-brand);
    border-radius: var(--radius-full);
    line-height: 1.6;
  }

  .footer-badge__logo {
    width: 18px;
    height: auto;
    flex-shrink: 0;
    /* Adapt logo to dark background: force white with slight transparency */
    filter: brightness(0) invert(1) opacity(0.80);
  }


  /* ── COLUMNAS NAV ─────────────────────────────────────────── */

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .footer-col__heading {
    font-family: var(--font-primary);
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin-bottom: var(--space-1);
  }

  .footer-col__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
  }

  .footer-col__link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    line-height: var(--leading-snug);
    transition: color var(--transition-fast);
  }

  .footer-col__link:hover {
    color: var(--color-text-primary);
  }


  /* ── COLUMNA CONTACTO ─────────────────────────────────────── */

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-contact__item {
    display: inline-flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    line-height: var(--leading-snug);
    transition: color var(--transition-fast);
  }

  .footer-contact__item:hover {
    color: var(--color-text-primary);
  }

  .footer-contact__item svg {
    margin-top: 2px;
    flex-shrink: 0;
    color: var(--color-text-faint);
  }

  .footer-contact__item--highlight {
    color: var(--color-text-secondary);
    font-weight: var(--fw-medium);
  }

  .footer-contact__item--secondary {
    padding-left: calc(14px + var(--space-2));
    color: var(--color-text-faint);
    font-size: var(--text-xs);
  }

  .footer-contact__address {
    display: inline-flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-faint);
    line-height: var(--leading-normal);
    font-style: normal;
  }

  .footer-contact__address svg {
    margin-top: 2px;
    flex-shrink: 0;
  }

  /* Social */
  .footer-social {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .footer-social__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .footer-social__link:hover {
    color: var(--color-text-primary);
    border-color: var(--color-border-medium);
    background: rgba(255,255,255,0.04);
  }


  /* ── BARRA INFERIOR ──────────────────────────────────────── */

  .footer-bottom {
    border-top: 1px solid var(--color-border-subtle);
    background: rgba(0, 0, 0, 0.20);
  }

  .footer-bottom__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    max-width: var(--container-xl);
    margin-inline: auto;
    padding-inline: var(--container-px);
    padding-block: var(--space-5);
    flex-wrap: wrap;
  }

  .footer-bottom__copy {
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    letter-spacing: var(--tracking-wide);
    max-width: none;
  }

  .footer-bottom__note {
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    letter-spacing: var(--tracking-normal);
    text-align: right;
    max-width: 52ch;
  }

  @media (max-width: 640px) {
    .footer-bottom__inner { flex-direction: column; align-items: flex-start; }
    .footer-bottom__note  { text-align: left; }
  }

</style>
