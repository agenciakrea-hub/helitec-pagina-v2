---
/**
 * HELITEC — SideRail.astro
 * Barra lateral fija izquierda. Referencia visual: AeruKart.
 *
 * Estructura (de arriba hacia abajo):
 *   1. Scroll progress indicator — línea vertical que crece con el scroll
 *   2. Redes sociales — texto vertical rotado + href de la red
 *   3. Indicador de sección activa — punto que salta entre secciones
 *
 * Implementación:
 *   — Ancho: 56px (--sidebar-w). El layout principal debe tener
 *     padding-left: var(--sidebar-w) cuando este componente esté activo.
 *   — Siempre visible en desktop (≥1024px). Oculto en tablet/mobile.
 *   — La lógica JS actualiza el progress bar y el índice de sección activa
 *     via IntersectionObserver.
 *
 * Props:
 *   lang           — 'es' | 'en'
 *   instagramUrl   — URL de Instagram (default: '#')
 *   linkedinUrl    — URL de LinkedIn (default: '#')
 *   sections       — Array de { id: string, label: string } para el nav vertical
 */

interface Props {
  lang?:         'es' | 'en';
  instagramUrl?: string;
  linkedinUrl?:  string;
  sections?:     Array<{ id: string; label: string }>;
}

const {
  lang         = 'es',
  instagramUrl = '#',
  linkedinUrl  = '#',
  sections     = [],
} = Astro.props;

const i18n = {
  es: { follow: 'Seguir' },
  en: { follow: 'Follow' },
}[lang];
---

<!-- ─────────────────────────────────────────────────────────────
     SIDE RAIL — Barra lateral fija izquierda
     Oculta en tablet/mobile via CSS.
     El wrapper `side-rail` es position:fixed — no ocupa espacio
     en el flujo. El padding-left del layout lo compensa.
──────────────────────────────────────────────────────────────── -->
<aside class="side-rail" aria-hidden="true">

  <!-- 1 ── SCROLL PROGRESS ──────────────────────────────────── -->
  <div class="side-rail__progress-track" aria-hidden="true">
    <div class="side-rail__progress-fill" id="side-progress"></div>
  </div>

  <!-- 2 ── SOCIAL LINKS ──────────────────────────────────────── -->
  <div class="side-rail__social">

    <a
      href={instagramUrl}
      class="side-rail__link"
      target="_blank"
      rel="noopener noreferrer"
      tabindex="-1"
    >
      <span class="side-rail__link-text">Instagram</span>
    </a>

    <span class="side-rail__dot" aria-hidden="true"></span>

    <a
      href={linkedinUrl}
      class="side-rail__link"
      target="_blank"
      rel="noopener noreferrer"
      tabindex="-1"
    >
      <span class="side-rail__link-text">LinkedIn</span>
    </a>

  </div>

  <!-- 3 ── SECTION DOTS (nav vertical) ───────────────────────
       Se renderizan solo si se pasan secciones desde la página.
       El JS marca la sección activa.
  ────────────────────────────────────────────────────────────── -->
  {sections.length > 0 && (
    <nav class="side-rail__nav" aria-label="Secciones de la página">
      <ul class="side-rail__nav-list" role="list">
        {sections.map((sec, i) => (
          <li>
            <a
              href={`#${sec.id}`}
              class="side-rail__nav-dot"
              data-section={sec.id}
              tabindex="-1"
              title={sec.label}
            >
              <span class="sr-only">{sec.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}

</aside>


<style>

  /* ── RAIL BASE ───────────────────────────────────────────── */

  .side-rail {
    position:       fixed;
    top:            0;
    left:           0;
    width:          var(--sidebar-w, 56px);
    height:         100vh;
    z-index:        var(--z-sticky);

    display:        flex;
    flex-direction: column;
    align-items:    center;
    justify-content:space-between;
    padding-block:  var(--space-8);

    /* Fondo semi-transparente — se funde con el fondo de página */
    background:     transparent;
    border-right:   1px solid rgba(255, 255, 255, 0.04);

    /* Aparece con fade cuando el JS lo activa */
    opacity:        0;
    transition:     opacity 800ms var(--ease-out);
    pointer-events: none;   /* JS lo activa con .is-visible */
  }

  .side-rail.is-visible {
    opacity:        1;
    pointer-events: auto;
  }

  /* Solo visible en desktop */
  @media (max-width: 1024px) {
    .side-rail { display: none; }
  }


  /* ── PROGRESS BAR ────────────────────────────────────────── */

  .side-rail__progress-track {
    width:         1px;
    height:        72px;
    background:    rgba(255, 255, 255, 0.06);
    position:      relative;
    overflow:      hidden;
    border-radius: var(--radius-full);
  }

  .side-rail__progress-fill {
    position:         absolute;
    top:              0;
    left:             0;
    width:            100%;
    height:           0%;            /* JS actualiza este valor */
    background:       linear-gradient(
      to bottom,
      var(--brand-azul-cielo),
      rgba(88, 181, 240, 0.40)
    );
    border-radius:    inherit;
    transition:       height 80ms linear;
    will-change:      height;
  }


  /* ── SOCIAL LINKS ──────────────────────────────────────────
     El truco: rotation de -90deg + transformOrigin center,
     luego se posiciona verticalmente con flex-column.
     El texto queda de abajo hacia arriba (lectura de pie).
  ─────────────────────────────────────────────────────────── */

  .side-rail__social {
    display:        flex;
    flex-direction: column;
    align-items:    center;
    gap:            var(--space-5);
  }

  .side-rail__link {
    display:        flex;
    align-items:    center;
    justify-content:center;

    /* Rotación del texto para lectura vertical */
    writing-mode:   vertical-rl;
    text-orientation: mixed;
    transform:      rotate(180deg);   /* bottom-to-top */

    font-family:    var(--font-primary);
    font-size:      0.57rem;
    font-weight:    var(--fw-medium);
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color:          rgba(255, 255, 255, 0.28);
    text-decoration:none;
    line-height:    1;

    transition:     color var(--transition-base);
  }

  .side-rail__link:hover {
    color: var(--brand-azul-cielo);
  }

  .side-rail__link-text {
    white-space: nowrap;
  }

  /* Punto separador entre redes */
  .side-rail__dot {
    display:       block;
    width:         3px;
    height:        3px;
    border-radius: 50%;
    background:    rgba(255, 255, 255, 0.12);
  }


  /* ── SECTION NAVIGATION DOTS ──────────────────────────────
     Cada dot corresponde a una sección de la página.
     El dot activo se ilumina con el azul cielo de marca.
  ─────────────────────────────────────────────────────────── */

  .side-rail__nav {
    display:        flex;
    flex-direction: column;
    align-items:    center;
  }

  .side-rail__nav-list {
    display:        flex;
    flex-direction: column;
    align-items:    center;
    gap:            10px;
    list-style:     none;
    padding:        0;
    margin:         0;
  }

  .side-rail__nav-dot {
    display:       block;
    width:         5px;
    height:        5px;
    border-radius: 50%;
    background:    rgba(255, 255, 255, 0.14);
    border:        1px solid rgba(255, 255, 255, 0.10);
    transition:
      background    var(--transition-base),
      transform     var(--transition-base),
      border-color  var(--transition-base);
  }

  .side-rail__nav-dot:hover,
  .side-rail__nav-dot.is-active {
    background:   var(--brand-azul-cielo);
    border-color: var(--brand-azul-cielo);
    transform:    scale(1.5);
  }

  /* Respeto por reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .side-rail,
    .side-rail__progress-fill,
    .side-rail__nav-dot {
      transition: none;
    }
  }

</style>


<script>
  (() => {
    const rail     = document.querySelector<HTMLElement>('.side-rail');
    const progress = document.getElementById('side-progress') as HTMLElement | null;

    if (!rail) return;

    /* ── 1. Aparece tras 1.2s para no competir con el hero ── */
    const showRail = () => {
      setTimeout(() => rail.classList.add('is-visible'), 1200);
    };

    if (document.readyState === 'complete') {
      showRail();
    } else {
      window.addEventListener('load', showRail, { once: true });
    }

    /* ── 2. Scroll progress ──────────────────────────────── */
    if (progress) {
      const updateProgress = () => {
        const scrollTop  = window.scrollY;
        const docHeight  = document.documentElement.scrollHeight - window.innerHeight;
        if (docHeight <= 0) return;

        const pct = Math.min(100, Math.round((scrollTop / docHeight) * 100));
        progress.style.height = `${pct}%`;
      };

      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress(); // Estado inicial
    }

    /* ── 3. Section dots — IntersectionObserver ─────────── */
    const dots = document.querySelectorAll<HTMLElement>('.side-rail__nav-dot[data-section]');

    if (dots.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const id = entry.target.id;
            dots.forEach((dot) => {
              dot.classList.toggle('is-active', dot.dataset.section === id);
            });
          }),
        },
        {
          threshold:  0.35,
          rootMargin: '-10% 0px -10% 0px',
        }
      );

      // Observar cada sección referenciada
      dots.forEach((dot) => {
        const sectionId = dot.dataset.section;
        if (!sectionId) return;
        const section = document.getElementById(sectionId);
        if (section) observer.observe(section);
      });
    }
  })();
</script>
