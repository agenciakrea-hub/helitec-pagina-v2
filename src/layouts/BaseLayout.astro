---
/* ── CSS Global (bundleados por Astro, orden crítico) ───────────────────── */
import '../styles/variables.css';
import '../styles/reset.css';

/* ── Componentes globales ──────────────────────────────────────────────── */
import Preloader from '../components/Preloader.astro';

/* ── View Transitions — navegación suave entre páginas ─────────────────── */
import { ViewTransitions } from 'astro:transitions';

/**
 * BaseLayout.astro
 * Consorcio Helitec — Layout raíz de todas las páginas
 *
 * Slots disponibles:
 *   sidebar-social  → SidebarSocial.astro (íconos fijos izquierda, desktop)
 *   header          → Header.astro (logo + hamburguesa)
 *   menu-modal      → MenuModal.astro (overlay fullscreen, Konpo-style)
 *   lang-loader     → LangLoader.astro (fade cinemático cambio de idioma)
 *   default (main)  → Contenido de cada página
 *   cta-float       → FloatingCTA.astro (botón lateral WhatsApp)
 *   bottom-sheet    → ContactSheet.astro (panel contacto mobile)
 */

interface Props {
  /** Título de la página. Aparece en <title> y og:title */
  title?: string;

  /** Meta description para SEO y og:description */
  description?: string;

  /** Imagen para Open Graph (Twitter, LinkedIn, etc.) */
  ogImage?: string;

  /** Idioma activo de la página */
  lang?: 'es' | 'en';

  /**
   * Clase adicional para el <body>.
   * Útil para estados globales: 'menu-is-open', 'lang-loading', etc.
   */
  bodyClass?: string;
}

const {
  title       = 'Consorcio Helitec — Aviación Ejecutiva y Aeromédica · Venezuela',
  description = 'Soluciones de transporte aéreo corporativo de alta precisión para la industria petrolera, energética e industrial de Venezuela. Flota ejecutiva, chárter B2B y servicio aeromédico certificado INAC.',
  ogImage     = '/assets/atardecer.jpg',
  lang        = 'es',
  bodyClass   = '',
} = Astro.props;

/**
 * URL canónica — se construye desde la URL de la request en Astro
 * Requiere que `site` esté configurado en astro.config.mjs
 */
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://helitec.com.ve');
---

<!DOCTYPE html>
<html lang={lang} dir="ltr">

<head>
  <!-- ── Charset y Viewport ──────────────────────────────────────────────── -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- ── SEO Básico ──────────────────────────────────────────────────────── -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL.href} />

  <!-- Robots: indexar todo excepto drafts/admin -->
  <meta name="robots" content="index, follow" />

  <!-- ── Open Graph (LinkedIn B2B, WhatsApp preview) ───────────────────── -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL.href} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale"      content={lang === 'es' ? 'es_VE' : 'en_US'} />
  <meta property="og:site_name"   content="Consorcio Helitec" />

  <!-- ── Twitter Card ────────────────────────────────────────────────────── -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- ── Favicon ─────────────────────────────────────────────────────────── -->
  <!--
    Nota al webmaster: generar favicon.ico, apple-touch-icon.png y
    favicon-32x32.png desde Logo-Helitec-Vert-no-bkg-1.png y colocarlos
    en public/. Mientras tanto se usa el logo vertical.
  -->
  <link rel="icon"             type="image/png" href="/assets/Logo-Helitec-Vert-no-bkg-1.png" />
  <link rel="apple-touch-icon" href="/assets/Logo-Helitec-Vert-no-bkg-1.png" />

  <!-- ── Google Fonts ─────────────────────────────────────────────────────
    Sistema tipográfico v2 — 100% sans-serif (Playfair Display eliminada):
      · Montserrat — Titulares (font-display), pesos finos 200–600
      · Inter       — Body, etiquetas, UI (font-sans), pesos 300–500
    display=swap: previene FOIT (flash invisible) durante la carga
  ─────────────────────────────────────────────────────────────────────── -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Montserrat:wght@200;300;400;500;600&display=swap"
  />

  <!-- ── Estilos Base (orden importa: reset primero, variables segundo) ─── -->
  <!--
    Importados via frontmatter de Astro para que el bundler los procese.
    Ver imports al final del frontmatter si se activa Vite/Astro bundling.
    En modo estático se pueden servir desde public/styles/.
  -->

  <!-- ── Preload del hero image por defecto ──────────────────────────────── -->
  <link
    rel="preload"
    as="image"
    href="/assets/atardecer.jpg"
    fetchpriority="high"
  />

  <!-- ── Slot para meta tags adicionales por página ───────────────────────── -->
  <slot name="head" />

  <!--
    Astro View Transitions — cross-fade suave entre páginas estáticas.
    Elimina el parpadeo blanco al navegar entre / y /flota, /en/, etc.
    Ref: https://docs.astro.build/en/guides/view-transitions/
  -->
  <ViewTransitions />
</head>

<body class={bodyClass}>

  <!-- ── PRELOADER — cortina negra de entrada (K3-style) ──────────────────── -->
  <!--
    Cubre el viewport INMEDIATAMENTE al cargar.
    Se desliza hacia arriba tras window.load + mín. 700ms.
    Oculta el parpadeo inicial del video del Hero.
    z-index: 9999 — sobre todo lo demás.
  -->
  <Preloader />

  <!-- ── SKIP LINK (Accesibilidad — usuarios de teclado/lectores) ─────────── -->
  <a href="#main-content" class="sr-only">
    {lang === 'es' ? 'Saltar al contenido principal' : 'Skip to main content'}
  </a>

  <!-- ── SIDEBAR SOCIAL (desktop · position: fixed · left) ────────────────── -->
  <!--
    Componente: SidebarSocial.astro
    Inspiración: Aerukart.com — íconos en columna izquierda fija
    Visible: solo en viewport ≥ 1024px
    z-index: var(--z-sidebar) = 100
  -->
  <slot name="sidebar-social" />

  <!-- ── HEADER ────────────────────────────────────────────────────────────── -->
  <!--
    Componente: Header.astro
    Contenido: Logo horizontal blanco + botón hamburguesa
    Logo: /assets/Logo-Helitec-horiz-no-bkg-1-blanco.png
    Filosofía Pilatus: header limpio, CERO links de navegación visibles
    z-index: var(--z-header) = 200
  -->
  <slot name="header" />

  <!-- ── MENÚ MODAL FULLSCREEN ─────────────────────────────────────────────── -->
  <!--
    Componente: MenuModal.astro
    Inspiración: Konpo.studio — overlay fullscreen, grid links + servicios
    Estado: controlado por JS (data-menu-open en <body>)
    Transición bg: var(--c-bg) → var(--c-menu-open) con var(--dur-slow)
    Idioma ES/EN: último ítem del menú (Pilatus-style, NO en el header)
    z-index: var(--z-menu) = 800
  -->
  <slot name="menu-modal" />

  <!-- ── LOADER CINEMÁTICO DE IDIOMA ──────────────────────────────────────── -->
  <!--
    Componente: LangLoader.astro
    Trigger: clic en selector ES/EN dentro del menú
    Efecto: fade negro full-screen con logo centrado → navega a nueva ruta Astro
    Referencia: k3studios.ae
    z-index: var(--z-lang-loader) = 1000
  -->
  <slot name="lang-loader" />

  <!-- ── CONTENIDO PRINCIPAL ───────────────────────────────────────────────── -->
  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <!-- ── CTA FLOTANTE (WhatsApp B2B / Cotización) ─────────────────────────── -->
  <!--
    Componente: FloatingCTA.astro
    Inspiración: falconaviation.ae — botón rectangular lateral, acabado mate
    API WhatsApp: +58 416-6235254 (var(--whatsapp-number))
    Posición: fixed · right: 0 · vertical-center
    Al interactuar: expansión sutil para preparar cotización directa
    z-index: var(--z-cta-float) = 850
    PROHIBIDO: box-shadow, brillos, border-radius > 4px
  -->
  <slot name="cta-float" />

  <!-- ── BOTTOM SHEET DE CONTACTO (mobile) ────────────────────────────────── -->
  <!--
    Componente: ContactSheet.astro
    Trigger: ícono de llamada en mobile (dentro de Header o CTA float)
    Efecto: panel modal deslizante desde abajo (Bottom Sheet)
    Contenido: tarjetas de contacto — Oficina + WhatsApp B2B
    Referencia: aventuradentalarts.com
    border-radius en esquinas superiores: var(--r-micro) = 4px (límite)
    z-index: var(--z-bottom-sheet) = 900
  -->
  <slot name="bottom-sheet" />

  <!--
    ── LENIS SMOOTH SCROLL ────────────────────────────────────────────────────
    Referencia: licornpublishing.com, konpo.studio — inercia suave en el scroll.
    · ES module — deferred por defecto, no bloquea el renderizado.
    · smoothTouch: false → móvil usa scroll nativo iOS/Android (ya tiene inercia).
    · smoothWheel: true → escritorio obtiene el deslizamiento fluido Lenis.
    · window.lenisInstance expuesto globalmente para que Header.astro
      pueda pausar/reanudar Lenis cuando el menú modal esté abierto.
  ──────────────────────────────────────────────────────────────────────────── -->
  <!--
    ── SCROLL RESTORATION ─────────────────────────────────────────────────────
    Forza scroll al tope en cada carga/recarga (F5).
    · history.scrollRestoration = "manual" → el browser NO restaura la posición
      del scroll anterior (evita el "saltón" al recargar).
    · window.scrollTo(0, 0) → garantiza posición 0 incluso en SPA/View Transitions.
    · is:inline → se ejecuta de forma síncrona antes de que cualquier otro script
      intente animar o leer window.scrollY.
  ──────────────────────────────────────────────────────────────────────────── -->
  <script is:inline>
    if ('scrollRestoration' in history) {
      history.scrollRestoration = 'manual';
    }
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
  </script>

  <script is:inline type="module">
    import Lenis from 'https://cdn.jsdelivr.net/npm/lenis@1.1.20/dist/lenis.mjs';

    const lenis = new Lenis({
      duration:        1.35,
      easing:          t => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel:     true,
      smoothTouch:     false,   /* Nativo en iOS/Android */
      touchMultiplier: 2,
      infinite:        false,
    });

    /* Exponer globalmente — Header.astro llama stop()/start() al toggle del menú */
    window.lenisInstance = lenis;

    /* RAF loop */
    function raf(time) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
  </script>

</body>
</html>

<!--
  ============================================================================
  NOTAS PARA EL SIGUIENTE COMPONENTE (para el Tech Lead)
  ============================================================================

  1. CONFIGURACIÓN ASTRO REQUERIDA (astro.config.mjs):
     - site: 'https://helitec.com.ve' (para URL canónica)
     - output: 'static' (generación estática, per proyecto)
     - i18n: { defaultLocale: 'es', locales: ['es', 'en'] } para rutas /es/ y /en/

  2. IMPORTS CSS EN ASTRO:
     Para que variables.css y reset.css se apliquen globalmente, agregar
     en el frontmatter de ESTE archivo:

       import '../styles/reset.css';
       import '../styles/variables.css';

     Descomentar cuando el proyecto Astro esté inicializado con `npm create astro`.

  3. ASSETS CONFIRMADOS EN WORKSPACE:
     ✓ /assets/Logo-Helitec-horiz-no-bkg-1-blanco.png  (header)
     ✓ /assets/Logo-Helitec-Vert-no-bkg-1-blanco.png   (favicon, loader)
     ✓ /assets/Logo-Helitec-Vert-no-bkg-1.png          (favicon color)
     ✓ /assets/atardecer.jpg                            (hero background + preload + og:image)
     ✓ /assets/AOC.png                                  (certificación INAC)

  4. MAPEO FLOTA (flota.json v1.1.0):
     8 aeronaves activas:
       Ala fija (5): metro-iii, metro-23-ejecutivo, metro-23-commuter,
                     metro-23-merlin-iiib, metro-23-merlin-300
       Ala rotatoria (3): md501, md600 (sin fotos), md902-explorer (sin fotos)

  5. PRÓXIMOS COMPONENTES (en orden de construcción):
     → Header.astro
     → SidebarSocial.astro
     → (esperar luz verde del Tech Lead en cada paso)

  ============================================================================
-->
