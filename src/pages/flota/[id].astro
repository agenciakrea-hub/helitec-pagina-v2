---
/**
 * HELITEC — flota/[id].astro
 * Página de detalle de aeronave. Ruta dinámica. Fase 6.
 *
 * getStaticPaths() genera una ruta por cada aeronave activa en flota.json.
 * Secciones:
 *   .detail-hero       — Hero con imagen de fondo, breadcrumb y CTAs
 *   #galeria           — Galería exterior + interior (lightbox nativo con <dialog>)
 *   #especificaciones  — Ficha técnica completa agrupada
 *   .detail-cta        — Franja CTA final antes del footer
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header     from '../../components/Header.astro';
import Footer     from '../../components/Footer.astro';
import CTAFloat   from '../../components/CTAFloat.astro';
import flotaData  from '../../data/flota.json';

/* ── Interfaces completas ───────────────────────────────── */
interface ConfiguracionInterior {
  capacidad: string;
  distribucion: string;
  mesa_plegable?: boolean;
  mesas_plegables?: boolean;
  bano: number | null;
  carga_trasera_kg?: number;
  carga_delantera_kg?: number;
}

interface TecnicasAny {
  motores?: string;
  motor?: string;
  potencia_hp?: number;
  potencia_hp_total?: number;
  velocidad_crucero_kts: number;
  autonomia_horas: string;
  techo_servicio_pies?: number;
  cabina_presurizada?: boolean;
  acceso_carga_vuelo?: boolean;
  peso_max_despegue_lb?: number;
  carga_externa_kg?: number;
  carga_interna_kg?: number;
  tanque_auxiliar_gal?: number;
  sistema_antitorque?: string;
  certificacion_notar?: boolean;
}

interface Aeronave {
  id: string;
  modelo: string;
  fabricante: string;
  categoria: 'ala-fija' | 'ala-rotatoria';
  tipo: string;
  configuracion: string;
  activo: boolean;
  aeromedico: boolean;
  descripcion_es: string;
  descripcion_en: string;
  capacidad_pasajeros: number;
  especificaciones: {
    configuracion_interior?: ConfiguracionInterior;
    tecnicas: TecnicasAny;
  };
  rutas_imagenes: {
    thumbnail: string;
    hero: string;
    plano_cabina?: string | null;
    exterior: string[];
    interior: string[];
    aeromedico?: string[];
  };
  rutas_pdf: string[];
  matriculas_conocidas: string[];
  servicios: string[];
}

/* ── getStaticPaths ─────────────────────────────────────── */
export function getStaticPaths() {
  return (flotaData.flota as Aeronave[])
    .filter(a => a.activo)
    .map(aeronave => ({
      params: { id: aeronave.id },
      props:  { aeronave },
    }));
}

/* ── Props ──────────────────────────────────────────────── */
interface Props { aeronave: Aeronave }
const { aeronave } = Astro.props;
const lang = 'es';

/* ── WhatsApp ───────────────────────────────────────────── */
const WA_NUMBER = '582129596385';
const waMsg     = `Hola Helitec, deseo cotizar un vuelo en el ${aeronave.modelo}.`;
const waHref    = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(waMsg)}`;

/* ── Formateador de números (punto como separador de miles)  */
function fmt(n: number): string { return n.toLocaleString('de-DE'); }

/* ── Tipo de aeronave legible ─────────────────────────────  */
const TIPOS: Record<string, string> = {
  'turbohélice-bimotor':    'Turbohélice bimotor',
  'helicóptero-monomotor':  'Helicóptero monomotor',
  'helicóptero-bimotor':    'Helicóptero bimotor',
};
const tipoLbl = TIPOS[aeronave.tipo] ?? aeronave.tipo;

/* ── Categoría etiqueta ───────────────────────────────────  */
const catLbl = aeronave.categoria === 'ala-fija' ? 'Ala Fija' : 'Ala Rotatoria';

/* ── Grupos de especificaciones técnicas ──────────────────
   Normaliza todos los campos del JSON en grupos presentables.
───────────────────────────────────────────────────────────  */
interface SpecItem  { label: string; value: string; mono?: boolean }
interface SpecGroup { id: string; title: string; items: SpecItem[] }

function buildSpecGroups(a: Aeronave): SpecGroup[] {
  const t  = a.especificaciones.tecnicas;
  const ci = a.especificaciones.configuracion_interior;
  const groups: SpecGroup[] = [];

  // ── Desempeño
  const desp: SpecItem[] = [
    { label: 'Velocidad crucero',  value: `${t.velocidad_crucero_kts} kt`, mono: true },
    { label: 'Autonomía',          value: t.autonomia_horas,               mono: true },
  ];
  if (t.techo_servicio_pies) {
    desp.push({ label: 'Techo de servicio', value: `${fmt(t.techo_servicio_pies)} pies`, mono: true });
  }
  groups.push({ id: 'desempeno', title: 'Desempeño', items: desp });

  // ── Planta Motriz
  const motorStr = t.motores ?? t.motor ?? null;
  const plantaItems: SpecItem[] = [];
  if (motorStr) plantaItems.push({ label: 'Motor / es', value: motorStr });
  if (t.potencia_hp_total) {
    plantaItems.push({ label: 'Potencia total', value: `${fmt(t.potencia_hp_total)} Hp`, mono: true });
  } else if (t.potencia_hp) {
    const pLbl = a.tipo.includes('bimotor') ? 'Potencia / motor' : 'Potencia';
    plantaItems.push({ label: pLbl, value: `${fmt(t.potencia_hp)} Hp`, mono: true });
  }
  if (plantaItems.length) groups.push({ id: 'motriz', title: 'Planta Motriz', items: plantaItems });

  // ── Cabina / Pasajeros
  const cabItems: SpecItem[] = [];
  if (ci) {
    cabItems.push({ label: 'Capacidad', value: ci.capacidad });
    cabItems.push({ label: 'Distribución', value: ci.distribucion });
    const banoVal = ci.bano === null ? 'No incluido' : (ci.bano ? 'Sí' : 'No');
    cabItems.push({ label: 'Baño a bordo', value: banoVal });
    if (ci.mesa_plegable || ci.mesas_plegables) {
      cabItems.push({ label: 'Mesas plegables', value: 'Sí' });
    }
    groups.push({ id: 'cabina', title: 'Cabina', items: cabItems });
  } else {
    groups.push({
      id: 'cabina',
      title: 'Capacidad',
      items: [{ label: 'Pasajeros', value: `${a.capacidad_pasajeros}`, mono: true }],
    });
  }

  // ── Carga
  const cargaItems: SpecItem[] = [];
  if (ci?.carga_trasera_kg)   cargaItems.push({ label: 'Bodega trasera',   value: `${ci.carga_trasera_kg} kg`,   mono: true });
  if (ci?.carga_delantera_kg) cargaItems.push({ label: 'Bodega delantera', value: `${ci.carga_delantera_kg} kg`, mono: true });
  if (t.carga_externa_kg)     cargaItems.push({ label: 'Carga externa',    value: `${t.carga_externa_kg} kg`,    mono: true });
  if (t.carga_interna_kg)     cargaItems.push({ label: 'Carga interna',    value: `${t.carga_interna_kg} kg`,    mono: true });
  if (t.tanque_auxiliar_gal)  cargaItems.push({ label: 'Tanque auxiliar',  value: `${t.tanque_auxiliar_gal} gal`, mono: true });
  if (cargaItems.length) groups.push({ id: 'carga', title: 'Carga', items: cargaItems });

  // ── Sistemas
  const sisItems: SpecItem[] = [];
  if (t.cabina_presurizada  !== undefined) sisItems.push({ label: 'Cabina presurizada',    value: t.cabina_presurizada  ? 'Sí' : 'No' });
  if (t.acceso_carga_vuelo  !== undefined) sisItems.push({ label: 'Acceso carga en vuelo', value: t.acceso_carga_vuelo  ? 'Sí' : 'No' });
  if (t.sistema_antitorque) sisItems.push({ label: 'Sistema antitorque', value: t.sistema_antitorque });
  if (t.peso_max_despegue_lb) sisItems.push({ label: 'MTOW', value: `${fmt(t.peso_max_despegue_lb)} lb`, mono: true });
  if (sisItems.length) groups.push({ id: 'sistemas', title: 'Sistemas', items: sisItems });

  return groups;
}

const specGroups = buildSpecGroups(aeronave);

/* ── Galería: agrupa imágenes por tipo ────────────────────  */
const galExteriores  = aeronave.rutas_imagenes.exterior    ?? [];
const galInterior    = aeronave.rutas_imagenes.interior    ?? [];
const galAeromedico  = aeronave.rutas_imagenes.aeromedico  ?? [];
const planoCabina    = aeronave.rutas_imagenes.plano_cabina ?? null;
const hasGallery     = galExteriores.length + galInterior.length > 0;
const isNotar       = aeronave.especificaciones.tecnicas.certificacion_notar === true;

/* ── SEO ────────────────────────────────────────────────── */
const pageTitle       = `${aeronave.modelo} — ${tipoLbl}`;
const pageDescription = aeronave.descripcion_es.slice(0, 155);
const siteUrl         = 'https://www.helitec.com';
const breadcrumbJson  = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${siteUrl}/`      },
    { '@type': 'ListItem', position: 2, name: 'Flota',  item: `${siteUrl}/flota` },
    { '@type': 'ListItem', position: 3, name: aeronave.modelo                    },
  ],
});
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={aeronave.rutas_imagenes.hero}
  lang={lang}
>

  <!-- BreadcrumbList JSON-LD en el slot <head> -->
  <script type="application/ld+json" slot="head" set:html={breadcrumbJson} />

  <Header slot="header" lang={lang} />


  <!-- ════════════════════════════════════════════════════════
       HERO — imagen de fondo + texto + CTAs
  ════════════════════════════════════════════════════════════ -->
  <section class="detail-hero" aria-label={`Detalle: ${aeronave.modelo}`}>

    <!-- Fondo: imagen placeholder + overlay oscuro -->
    <div
      class="detail-hero__bg"
      style={`background-image: url('${encodeURI(aeronave.rutas_imagenes.hero)}')`}
      aria-hidden="true"
    ></div>

    <div class="detail-hero__overlay" aria-hidden="true"></div>

    <div class="container detail-hero__inner">

      <!-- Breadcrumb -->
      <nav aria-label="Ruta de navegación">
        <ol class="breadcrumb">
          <li><a href="/">Inicio</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/flota">Flota</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page">{aeronave.modelo}</li>
        </ol>
      </nav>

      <!-- Badges -->
      <div class="detail-hero__badges">
        <span class="hero-badge hero-badge--cat">{catLbl}</span>
        {aeronave.aeromedico && (
          <span class="hero-badge hero-badge--med">Aeromédico</span>
        )}
        {isNotar && (
          <span class="hero-badge hero-badge--tech">NOTAR®</span>
        )}
      </div>

      <!-- Titular -->
      <p class="detail-hero__fab text-overline">{aeronave.fabricante}</p>
      <h1 class="detail-hero__title">{aeronave.modelo}</h1>
      <p class="detail-hero__tipo">{tipoLbl}</p>
      <p class="detail-hero__desc">{aeronave.descripcion_es}</p>

      <!-- CTAs -->
      <div class="detail-hero__ctas">
        <a
          href={waHref}
          class="btn btn--primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Cotizar este {aeronave.modelo}
        </a>
        <a href="/flota" class="btn btn--ghost">
          ← Volver a la Flota
        </a>
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       GALERÍA
  ════════════════════════════════════════════════════════════ -->
  {hasGallery && (
    <section class="gallery-section" id="galeria" aria-label="Galería de imágenes">
      <div class="container">

        <div class="gallery-section__header reveal">
          <p class="text-overline">Galería</p>
          <h2 class="gallery-section__title">
            Interior y Exterior
          </h2>
        </div>

        <!-- Exteriores -->
        {galExteriores.length > 0 && (
          <div class="gallery-block reveal" data-delay="1">
            <p class="gallery-block__label">Vistas Exteriores</p>
            <div class={`gallery-grid gallery-grid--${Math.min(galExteriores.length, 3)}`}>
              {galExteriores.map((src, j) => (
                <button
                  class="gallery-thumb"
                  data-full={src}
                  data-alt={`${aeronave.modelo} — Exterior ${j + 1}`}
                  aria-label={`Ver imagen exterior ${j + 1} en pantalla completa`}
                  type="button"
                >
                  <div class="gallery-thumb__wrap">
                    <img
                      src={src}
                      alt={`${aeronave.modelo} — Exterior ${j + 1}`}
                      class="gallery-thumb__img"
                      loading="lazy"
                      decoding="async"
                      onerror="this.style.display='none'"
                    />
                    <span class="gallery-thumb__zoom" aria-hidden="true">
                      <!-- Icono zoom -->
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                           stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                        <path d="M11 8v6M8 11h6"/>
                      </svg>
                    </span>
                  </div>
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Interior / Cabina -->
        {galInterior.length > 0 && (
          <div class="gallery-block reveal" data-delay="2">
            <p class="gallery-block__label">Cabina &amp; Interior</p>
            <div class={`gallery-grid gallery-grid--${Math.min(galInterior.length, 3)}`}>
              {galInterior.map((src, j) => (
                <button
                  class="gallery-thumb"
                  data-full={src}
                  data-alt={`${aeronave.modelo} — Interior ${j + 1}`}
                  aria-label={`Ver imagen de cabina ${j + 1} en pantalla completa`}
                  type="button"
                >
                  <div class="gallery-thumb__wrap">
                    <img
                      src={src}
                      alt={`${aeronave.modelo} — Cabina ${j + 1}`}
                      class="gallery-thumb__img"
                      loading="lazy"
                      decoding="async"
                      onerror="this.style.display='none'"
                    />
                    <span class="gallery-thumb__zoom" aria-hidden="true">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                           stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                        <path d="M11 8v6M8 11h6"/>
                      </svg>
                    </span>
                  </div>
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Aeromédico (solo si aplica) -->
        {galAeromedico.length > 0 && (
          <div class="gallery-block reveal" data-delay="3">
            <p class="gallery-block__label gallery-block__label--med">
              Configuración Aeromédica
            </p>
            <div class={`gallery-grid gallery-grid--${Math.min(galAeromedico.length, 3)}`}>
              {galAeromedico.map((src, j) => (
                <button
                  class="gallery-thumb"
                  data-full={src}
                  data-alt={`${aeronave.modelo} — Aeromédico ${j + 1}`}
                  aria-label={`Ver imagen aeromédica ${j + 1}`}
                  type="button"
                >
                  <div class="gallery-thumb__wrap">
                    <img
                      src={src}
                      alt={`${aeronave.modelo} — Aeromédico ${j + 1}`}
                      class="gallery-thumb__img"
                      loading="lazy"
                      decoding="async"
                      onerror="this.style.display='none'"
                    />
                    <span class="gallery-thumb__zoom" aria-hidden="true">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                           stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                        <path d="M11 8v6M8 11h6"/>
                      </svg>
                    </span>
                  </div>
                </button>
              ))}
            </div>
          </div>
        )}

      </div>

      {/* ── Plano de cabina (si existe) ──────────────────── */}
      {planoCabina && (
        <div class="gallery-block reveal" data-delay="4">
          <p class="gallery-block__label gallery-block__label--plan">
            Plano de Cabina
          </p>
          <div class="cabin-plan-wrap">
            <img
              src={encodeURI(planoCabina)}
              alt={`${aeronave.modelo} — Plano de cabina`}
              class="cabin-plan-img"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      )}

    </div>
    </section>
  )}


  <!-- ════════════════════════════════════════════════════════
       ESPECIFICACIONES TÉCNICAS
  ════════════════════════════════════════════════════════════ -->
  <section class="specs-section" id="especificaciones" aria-label="Especificaciones técnicas">
    <div class="container">

      <div class="specs-section__header reveal">
        <p class="text-overline">Ficha Técnica</p>
        <h2 class="specs-section__title">Especificaciones</h2>
      </div>

      <div class="specs-layout">
        {specGroups.map((group, gi) => (
          <div class={`spec-group reveal`} data-delay={String((gi % 3) + 1)}>
            <h3 class="spec-group__title">{group.title}</h3>
            <dl class="spec-group__list">
              {group.items.map(item => (
                <div class="spec-row">
                  <dt class="spec-row__label">{item.label}</dt>
                  <dd class={`spec-row__value${item.mono ? ' spec-row__value--mono' : ''}`}>
                    {item.value}
                  </dd>
                </div>
              ))}
            </dl>
          </div>
        ))}
      </div>

      <!-- PDF de ficha técnica (si existe) -->
      {aeronave.rutas_pdf.length > 0 && (
        <div class="specs-pdf reveal">
          <a
            href={aeronave.rutas_pdf[0]}
            class="btn btn--ghost-sm"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Descargar ficha técnica en PDF"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round"
                 stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="12" y1="18" x2="12" y2="12"/>
              <line x1="9" y1="15" x2="15" y2="15"/>
            </svg>
            Descargar Ficha Técnica (PDF)
          </a>
        </div>
      )}

    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       CTA FINAL
  ════════════════════════════════════════════════════════════ -->
  <section class="detail-cta" aria-label="Solicitar cotización">
    <div class="container">
      <div class="detail-cta__inner reveal">

        <div class="detail-cta__text">
          <p class="text-overline">¿Interesado?</p>
          <h2 class="detail-cta__title">Cotizar el {aeronave.modelo}</h2>
          <p class="detail-cta__sub">
            Nuestro equipo de operaciones está disponible 24/7 para
            asesorarle sobre disponibilidad, rutas y condiciones de vuelo.
          </p>
        </div>

        <div class="detail-cta__actions">
          <a
            href={waHref}
            class="btn btn--primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Solicitar Cotización vía WhatsApp
          </a>
          <a href="/flota" class="btn btn--ghost">
            Ver toda la Flota
          </a>
        </div>

      </div>
    </div>
  </section>


  <!-- LIGHTBOX nativo con <dialog> (accesible, sin dependencias) -->
  <dialog class="lightbox" id="lightbox" aria-label="Visor de imágenes">
    <button class="lightbox__close" id="lightbox-close" aria-label="Cerrar visor" type="button">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <img src="" alt="" class="lightbox__img" id="lightbox-img" />
  </dialog>


  <Footer slot="footer" lang={lang} />
  <CTAFloat slot="cta" lang={lang} />

</BaseLayout>


<!-- ═══════════════════════════════════════════════════════
     ESTILOS SCOPED
════════════════════════════════════════════════════════════ -->
<style>

/* ── Contenedor ─────────────────────────────────────────── */
.container {
  width: 100%;
  max-width: 1280px;
  margin-inline: auto;
  padding-inline: var(--space-8);
}
@media (max-width: 640px) { .container { padding-inline: var(--space-5); } }

/* ── Botones ────────────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-4) var(--space-8);
  border-radius: var(--radius-full);
  font-family: var(--font-primary);
  font-size: var(--text-sm);
  font-weight: var(--fw-semibold);
  letter-spacing: var(--tracking-wide);
  text-decoration: none;
  line-height: 1;
  white-space: nowrap;
  cursor: pointer;
  border: 2px solid transparent;
  transition: background var(--transition-fast), border-color var(--transition-fast),
              color var(--transition-fast), box-shadow var(--transition-base),
              transform var(--transition-base);
}
.btn:active { transform: scale(0.97); }
.btn--primary {
  background: var(--brand-rojo-helitec); color: #fff;
  border-color: var(--brand-rojo-helitec);
  box-shadow: 0 4px 18px rgba(229,59,28,0.30);
}
.btn--primary:hover {
  background: #c93218; border-color: #c93218; color: #fff;
  box-shadow: 0 6px 26px rgba(229,59,28,0.45); transform: translateY(-1px);
}
.btn--ghost {
  background: transparent; color: var(--brand-azul-cielo);
  border-color: rgba(88,181,240,0.40);
}
.btn--ghost:hover {
  background: rgba(88,181,240,0.08); border-color: var(--brand-azul-cielo);
  color: #fff; transform: translateY(-1px);
}
.btn--ghost-sm {
  display: inline-flex; align-items: center; gap: var(--space-2);
  padding: var(--space-3) var(--space-6);
  border-radius: var(--radius-full);
  font-family: var(--font-primary); font-size: var(--text-xs);
  font-weight: var(--fw-semibold); letter-spacing: var(--tracking-wide);
  text-decoration: none; line-height: 1; white-space: nowrap; cursor: pointer;
  background: transparent; color: var(--brand-azul-cielo);
  border: 1.5px solid rgba(88,181,240,0.35);
  transition: background var(--transition-fast), border-color var(--transition-fast),
              color var(--transition-fast), transform var(--transition-base);
}
.btn--ghost-sm:hover {
  background: rgba(88,181,240,0.10); border-color: var(--brand-azul-cielo);
  color: #fff; transform: translateY(-1px);
}


