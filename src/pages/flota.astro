<!-- ═══════════════════════════════════════════════════════
     SCRIPTS
     1. Reveal — IntersectionObserver para .reveal
     2. Sub-nav activo — scroll tracking para .fleet-subnav
════════════════════════════════════════════════════════════ -->
<script>
  (() => {
    // ── 1. REVEAL ──────────────────────────────────────────
    const reveals = document.querySelectorAll('.reveal');
    if (reveals.length) {
      const io = new IntersectionObserver(
        entries => entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }),
        { threshold: 0.10 }
      );
      reveals.forEach(el => io.observe(el));
    }

    // ── 2. SUB-NAV: ACTIVE STATE + SCROLLED SHADOW ─────────
    const subnav  = document.getElementById('fleet-subnav');
    const pills   = document.querySelectorAll('[data-section]');
    const sections = ['ala-rotatoria', 'ala-fija'];

    /**
     * Marca el pill activo según qué sección está
     * más cerca del tope del viewport (debajo del sub-nav).
     */
    function syncActivePill() {
      // Offset: altura del header (~68px) + subnav (~50px)
      const OFFSET = 130;
      let active = sections[0];

      for (const id of sections) {
        const el = document.getElementById(id);
        if (el && el.getBoundingClientRect().top <= OFFSET) {
          active = id;
        }
      }

      pills.forEach(pill => {
        const p = pill as HTMLElement;
        p.classList.toggle('is-active', p.dataset.section === active);
      });
    }

    /** Añade sombra al sub-nav cuando se ha scrolleado más allá del hero */
    function syncSubnavShadow() {
      if (!subnav) return;
      const heroEnd = document.querySelector('.fleet-hero')?.getBoundingClientRect().bottom ?? 0;
      subnav.classList.toggle('is-scrolled', heroEnd <= 68);
    }

    function onScroll() {
      syncActivePill();
      syncSubnavShadow();
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // estado inicial

    // ── 3. SMOOTH SCROLL para links de anclaje ────────────
    // (navegadores modernos ya lo soportan con CSS scroll-behavior,
    //  pero añadimos offset para compensar el sub-nav sticky)
    document.querySelectorAll('a[href^="#"]').forEach(link => {
      link.addEventListener('click', e => {
        const id  = (link.getAttribute('href') ?? '').slice(1);
        const target = document.getElementById(id);
        if (!target) return;
        e.preventDefault();
        // Offset = header + subnav (~130px)
        const y = target.getBoundingClientRect().top + window.scrollY - 130;
        window.scrollTo({ top: y, behavior: 'smooth' });
      });
    });
  })();
</script>
