---
/**
 * HELITEC — flota.astro
 * Página de catálogo de flota. Fase 5.
 *
 * Fuente de datos: src/data/flota.json
 * Secciones:
 *   .fleet-hero        — Hero interno (no fullscreen)
 *   .fleet-subnav      — Sub-menú sticky con anclas
 *   #ala-rotatoria     — Grid helicópteros (3 aeronaves)
 *   #ala-fija          — Grid aviones (5 aeronaves)
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
import CTAFloat   from '../components/CTAFloat.astro';
import flotaData  from '../data/flota.json';

const lang = 'es';

/* ── Interfaces ────────────────────────────────────────────*/
interface TecnicasHeli {
  motor?: string;
  motores?: string;
  potencia_hp?: number;
  potencia_hp_total?: number;
  velocidad_crucero_kts: number;
  autonomia_horas: string;
  certificacion_notar?: boolean;
  sistema_antitorque?: string;
}
interface TecnicasFija {
  motores: string;
  velocidad_crucero_kts: number;
  autonomia_horas: string;
}
interface Aeronave {
  id: string;
  modelo: string;
  fabricante: string;
  categoria: 'ala-fija' | 'ala-rotatoria';
  tipo: string;
  configuracion: string;
  activo: boolean;
  aeromedico: boolean;
  descripcion_es: string;
  capacidad_pasajeros: number;
  especificaciones: {
    tecnicas: TecnicasHeli & TecnicasFija;
  };
  rutas_imagenes: {
    thumbnail: string;
  };
}

/* ── Datos ─────────────────────────────────────────────────*/
const flota = (flotaData.flota as Aeronave[]).filter(a => a.activo);
const helicos = flota.filter(a => a.categoria === 'ala-rotatoria');
const aviones = flota.filter(a => a.categoria === 'ala-fija');

/* ── WhatsApp ──────────────────────────────────────────────*/
const WA_NUMBER = '584166235254';
function waLink(modelo: string): string {
  const msg = `Hola Helitec, me gustaría recibir información y cotización para el ${modelo}.`;
  return `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`;
}

/* ── Especificaciones técnicas normalizadas ────────────────
   Devuelve los 3 datos que se muestran en la ficha de tarjeta.
─────────────────────────────────────────────────────────── */
function techSpecs(a: Aeronave) {
  const t = a.especificaciones.tecnicas;
  // Autonomía: "5:00 + 1:30 reserva" → mostrar sólo "5:00 h"
  const autonomia = t.autonomia_horas.split(' + ')[0] + ' h';
  return {
    pasajeros: `${a.capacidad_pasajeros}`,
    crucero:   `${t.velocidad_crucero_kts} kt`,
    autonomia,
  };
}

/* ── Tipo de aeronave legible ──────────────────────────────*/
function tipoLabel(tipo: string): string {
  const map: Record<string, string> = {
    'turbohélice-bimotor':     'Turbohélice bimotor',
    'helicóptero-monomotor':   'Helicóptero monomotor',
    'helicóptero-bimotor':     'Helicóptero bimotor',
  };
  return map[tipo] ?? tipo;
}
---

<BaseLayout
  title="Nuestra Flota · Helicópteros y Aviones"
  description={`Flota de ${flota.length} aeronaves certificadas INAC: helicópteros MD 500, MD 600, MD 902 Explorer y aviones turbohélice Swearingen Metro y Merlin. Transporte ejecutivo, industrial y aeromédico.`}
  lang={lang}
>

  <Header slot="header" lang={lang} />


  <!-- ════════════════════════════════════════════════════════
       HERO INTERNO — corto, no fullscreen
  ════════════════════════════════════════════════════════════ -->
  <section class="fleet-hero" aria-label="Flota Helitec">
    <div class="container">
      <div class="fleet-hero__content reveal">
        <p class="text-overline">Certificado INAC · {flota.length} Aeronaves Activas</p>
        <h1 class="fleet-hero__title">Nuestra Flota</h1>
        <p class="fleet-hero__sub">
          Helicópteros y aviones turbohélice con mantenimiento bajo estándares
          de aerolíneas comerciales. Disponibles para operaciones ejecutivas,
          industriales y aeromédicas.
        </p>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       SUB-NAVEGACIÓN STICKY
  ════════════════════════════════════════════════════════════ -->
  <nav class="fleet-subnav" id="fleet-subnav" aria-label="Categorías de flota">
    <div class="container">
      <div class="fleet-subnav__inner">
        <a
          href="#ala-rotatoria"
          class="fleet-subnav__pill"
          data-section="ala-rotatoria"
          aria-label="Ir a sección Ala Rotatoria"
        >
          <!-- Icono: rotor SVG inline -->
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round"
               aria-hidden="true">
            <circle cx="12" cy="12" r="2"/>
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
          </svg>
          Ala Rotatoria
          <span class="fleet-subnav__count">{helicos.length}</span>
        </a>

        <a
          href="#ala-fija"
          class="fleet-subnav__pill"
          data-section="ala-fija"
          aria-label="Ir a sección Ala Fija"
        >
          <!-- Icono: avión SVG inline -->
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
               aria-hidden="true">
            <path d="M21 16v-2l-8-5V3.5a1.5 1.5 0 0 0-3 0V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5z"/>
          </svg>
          Ala Fija
          <span class="fleet-subnav__count">{aviones.length}</span>
        </a>
      </div>
    </div>
  </nav>


  <!-- ════════════════════════════════════════════════════════
       SECCIÓN: ALA ROTATORIA
  ════════════════════════════════════════════════════════════ -->
  <section class="fleet-section" id="ala-rotatoria" aria-labelledby="cat-rotatoria">
    <div class="container">

      <div class="category-header reveal">
        <p class="text-overline">Categoría</p>
        <h2 class="category-title" id="cat-rotatoria">Ala Rotatoria</h2>
        <p class="category-sub">
          Operaciones en plataformas petroleras, zonas industriales y destinos
          sin pista convencional. Flota MD Helicopters bajo certificación INAC.
        </p>
      </div>

      <div class="fleet-grid">
        {helicos.map((a, i) => {
          const specs = techSpecs(a);
          const isNotar = a.especificaciones.tecnicas.certificacion_notar === true;
          return (
            <article class="fleet-card reveal" data-delay={String((i % 3) + 1)}>

              <!-- Imagen 16:9 -->
              <a href={`/flota/${a.id}`} class="fleet-card__img-link" tabindex="-1" aria-hidden="true">
                <div class="fleet-card__img-wrap">
                  <img
                    src={a.rutas_imagenes.thumbnail ?? '/assets/placeholder-fleet.jpg'}
                    alt={`${a.modelo} — ${a.fabricante}`}
                    class="fleet-card__img"
                    loading="lazy"
                    decoding="async"
                    onerror="this.style.display='none'"
                  />
                  <!-- Badges sobre la imagen -->
                  <div class="fleet-card__badges">
                    {a.aeromedico && (
                      <span class="fleet-badge fleet-badge--med">Aeromédico</span>
                    )}
                    {isNotar && (
                      <span class="fleet-badge fleet-badge--tech">NOTAR®</span>
                    )}
                  </div>
                </div>
              </a>

              <!-- Cuerpo de la tarjeta -->
              <div class="fleet-card__body">
                <p class="fleet-card__type">
                  {a.fabricante} · {tipoLabel(a.tipo)}
                </p>
                <h3 class="fleet-card__title">
                  <a href={`/flota/${a.id}`} class="fleet-card__title-link">
                    {a.modelo}
                  </a>
                </h3>
                <p class="fleet-card__desc">{a.descripcion_es}</p>

                <!-- Ficha técnica -->
                <div class="fleet-card__specs" role="list" aria-label="Especificaciones técnicas">
                  <div class="spec-item" role="listitem">
                    <span class="spec-val">{specs.pasajeros}</span>
                    <span class="spec-label">Pasajeros</span>
                  </div>
                  <div class="spec-sep" aria-hidden="true"></div>
                  <div class="spec-item" role="listitem">
                    <span class="spec-val">{specs.crucero}</span>
                    <span class="spec-label">Crucero</span>
                  </div>
                  <div class="spec-sep" aria-hidden="true"></div>
                  <div class="spec-item" role="listitem">
                    <span class="spec-val">{specs.autonomia}</span>
                    <span class="spec-label">Autonomía</span>
                  </div>
                </div>

                <!-- CTA -->
                <a
                  href={waLink(a.modelo)}
                  class="fleet-card__cta btn btn--ghost"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Solicitar cotización para ${a.modelo} vía WhatsApp`}
                >
                  Solicitar Cotización
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                       stroke="currentColor" stroke-width="2" stroke-linecap="round"
                       stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>

              </div>
            </article>
          );
        })}
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       SECCIÓN: ALA FIJA
  ════════════════════════════════════════════════════════════ -->
  <section class="fleet-section fleet-section--alt" id="ala-fija" aria-labelledby="cat-fija">
    <div class="container">

      <div class="category-header reveal">
        <p class="text-overline">Categoría</p>
        <h2 class="category-title" id="cat-fija">Ala Fija</h2>
        <p class="category-sub">
          Familia Swearingen con cabinas presurizadas y acceso a carga en vuelo.
          Operaciones nacionales e internacionales bajo estándares de líneas aéreas comerciales.
        </p>
      </div>

      <div class="fleet-grid">
        {aviones.map((a, i) => {
          const specs = techSpecs(a);
          return (
            <article class="fleet-card reveal" data-delay={String((i % 3) + 1)}>

              <!-- Imagen 16:9 -->
              <a href={`/flota/${a.id}`} class="fleet-card__img-link" tabindex="-1" aria-hidden="true">
                <div class="fleet-card__img-wrap">
                  <img
                    src={a.rutas_imagenes.thumbnail ?? '/assets/placeholder-fleet.jpg'}
                    alt={`${a.modelo} — ${a.fabricante}`}
                    class="fleet-card__img"
                    loading="lazy"
                    decoding="async"
                    onerror="this.style.display='none'"
                  />
                  <div class="fleet-card__badges">
                    {a.aeromedico && (
                      <span class="fleet-badge fleet-badge--med">Aeromédico</span>
                    )}
                    {a.configuracion === 'ejecutiva-vip' && (
                      <span class="fleet-badge fleet-badge--vip">VIP</span>
                    )}
                  </div>
                </div>
              </a>

              <!-- Cuerpo de la tarjeta -->
              <div class="fleet-card__body">
                <p class="fleet-card__type">
                  {a.fabricante} · {tipoLabel(a.tipo)}
                </p>
                <h3 class="fleet-card__title">
                  <a href={`/flota/${a.id}`} class="fleet-card__title-link">
                    {a.modelo}
                  </a>
                </h3>
                <p class="fleet-card__desc">{a.descripcion_es}</p>

                <!-- Ficha técnica -->
                <div class="fleet-card__specs" role="list" aria-label="Especificaciones técnicas">
                  <div class="spec-item" role="listitem">
                    <span class="spec-val">{specs.pasajeros}</span>
                    <span class="spec-label">Pasajeros</span>
                  </div>
                  <div class="spec-sep" aria-hidden="true"></div>
                  <div class="spec-item" role="listitem">
                    <span class="spec-val">{specs.crucero}</span>
                    <span class="spec-label">Crucero</span>
                  </div>
                  <div class="spec-sep" aria-hidden="true"></div>
                  <div class="spec-item" role="listitem">
                    <span class="spec-val">{specs.autonomia}</span>
                    <span class="spec-label">Autonomía</span>
                  </div>
                </div>

                <!-- CTA -->
                <a
                  href={waLink(a.modelo)}
                  class="fleet-card__cta btn btn--ghost"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Solicitar cotización para ${a.modelo} vía WhatsApp`}
                >
                  Solicitar Cotización
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                       stroke="currentColor" stroke-width="2" stroke-linecap="round"
                       stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>

              </div>
            </article>
          );
        })}
      </div>

    </div>
  </section>


  <Footer slot="footer" lang={lang} />
  <CTAFloat slot="cta" lang={lang} />

</BaseLayout>


<!-- ═══════════════════════════════════════════════════════
     ESTILOS SCOPED
════════════════════════════════════════════════════════════ -->
<style>

/* ════════════════════════════════════════════════════════
   HERO INTERNO
════════════════════════════════════════════════════════════ */
.fleet-hero {
  background: var(--color-bg-base);
  padding-block: var(--space-24) var(--space-20);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  /* Sutil gradiente atmosférico — consistente con index */
  background-image: radial-gradient(
    ellipse 60% 100% at 80% 50%,
    rgba(2, 58, 120, 0.20) 0%,
    transparent 70%
  );
}

.fleet-hero__content {
  max-width: 680px;
}

.fleet-hero__title {
  font-family: var(--font-primary);
  font-size: clamp(2.5rem, 5.5vw, 4.5rem);
  font-weight: var(--fw-thin);
  color: #fff;
  line-height: 1.05;
  letter-spacing: -0.025em;
  margin-block: var(--space-5) var(--space-6);
}

.fleet-hero__sub {
  font-size: clamp(var(--text-base), 1.5vw, var(--text-lg));
  font-weight: var(--fw-light);
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.75;
  max-width: 56ch;
}


/* ════════════════════════════════════════════════════════
   SUB-NAVEGACIÓN STICKY
════════════════════════════════════════════════════════════ */
.fleet-subnav {
  position: sticky;
  /* 68px ≈ altura del Header. Ajustar si el Header cambia. */
  top: 68px;
  z-index: 150;
  background: rgba(6, 14, 28, 0.92);
  -webkit-backdrop-filter: blur(16px);
          backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  padding-block: var(--space-4);
  transition: box-shadow var(--transition-base);
}

/* Sombra al hacer scroll (activada por JS) */
.fleet-subnav.is-scrolled {
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.40);
}

.fleet-subnav__inner {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.fleet-subnav__pill {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-5);
  border-radius: 2px;
  font-family: var(--font-primary);
  font-size: var(--text-xs);
  font-weight: var(--fw-semibold);
  letter-spacing: var(--tracking-wide);
  text-decoration: none;
  color: rgba(255, 255, 255, 0.45);
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.08);
  transition:
    color         var(--transition-fast),
    background    var(--transition-fast),
    border-color  var(--transition-fast);
}

.fleet-subnav__pill:hover {
  color: rgba(255, 255, 255, 0.80);
  border-color: rgba(255, 255, 255, 0.18);
}

/* Estado activo (controlado por JS vía IntersectionObserver) */
.fleet-subnav__pill.is-active {
  color: var(--brand-azul-cielo);
  background: rgba(88, 181, 240, 0.10);
  border-color: rgba(88, 181, 240, 0.30);
}

.fleet-subnav__count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 18px;
  height: 18px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: var(--fw-bold);
  background: rgba(255, 255, 255, 0.08);
  color: inherit;
  padding-inline: 5px;
}
.fleet-subnav__pill.is-active .fleet-subnav__count {
  background: rgba(88, 181, 240, 0.20);
}


/* ════════════════════════════════════════════════════════
   SECCIONES DE CATEGORÍA
════════════════════════════════════════════════════════════ */
.fleet-section {
  background: var(--color-bg-base);
  padding-block: var(--space-20) var(--space-24);
}
.fleet-section--alt {
  background: var(--color-bg-surface);
  border-top: 1px solid rgba(255, 255, 255, 0.04);
}

/* Encabezado de categoría */
.category-header {
  margin-bottom: var(--space-14);
  max-width: 680px;
}
.category-title {
  font-family: var(--font-primary);
  font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  font-weight: var(--fw-light);
  color: #fff;
  line-height: 1.1;
  margin-block: var(--space-3) var(--space-5);
}
.category-sub {
  font-size: var(--text-sm);
  font-weight: var(--fw-light);
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.75;
  max-width: 60ch;
}


/* ════════════════════════════════════════════════════════
   GRID DE TARJETAS
════════════════════════════════════════════════════════════ */
.fleet-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}
@media (max-width: 1024px) {
  .fleet-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .fleet-grid { grid-template-columns: 1fr; }
}


/* ════════════════════════════════════════════════════════
   TARJETA DE AERONAVE
════════════════════════════════════════════════════════════ */
.fleet-card {
  background: var(--color-bg-elevated);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: var(--radius-base);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition:
    border-color var(--transition-base),
    box-shadow   var(--transition-base),
    transform    var(--transition-base);
}
.fleet-card::before {
  content: '';
  display: block;
  height: 2px;
  background: linear-gradient(90deg, var(--brand-azul-cielo), transparent);
  opacity: 0;
  transition: opacity var(--transition-base);
}
.fleet-card:hover {
  border-color: rgba(88, 181, 240, 0.18);
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.30);
  transform: translateY(-3px);
}
.fleet-card:hover::before {
  opacity: 1;
}

/* ── Imagen (16:9) ─────────────────────────────────────── */
.fleet-card__img-link {
  display: block;
  text-decoration: none;
}
.fleet-card__img-wrap {
  position: relative;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: linear-gradient(
    160deg,
    var(--color-bg-brand-deep) 0%,
    #081832 50%,
    var(--color-bg-brand) 100%
  );
}
/* Dot pattern decorativo (placeholder visual) */
.fleet-card__img-wrap::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(88,181,240,0.07) 1px, transparent 1px);
  background-size: 28px 28px;
  pointer-events: none;
  z-index: 0;
}

.fleet-card__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
  transition: transform 700ms var(--ease-out);
}
.fleet-card:hover .fleet-card__img {
  transform: scale(1.05);
}

/* Badges sobre la imagen */
.fleet-card__badges {
  position: absolute;
  top: var(--space-3);
  right: var(--space-3);
  display: flex;
  gap: var(--space-2);
  z-index: 2;
}
.fleet-badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 8px;
  border-radius: var(--radius-full);
  font-family: var(--font-primary);
  font-size: 10px;
  font-weight: var(--fw-semibold);
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
  -webkit-backdrop-filter: blur(8px);
          backdrop-filter: blur(8px);
}
.fleet-badge--med {
  background: rgba(229, 59, 28, 0.85);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.20);
}
.fleet-badge--tech {
  background: rgba(88, 181, 240, 0.75);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.20);
}
.fleet-badge--vip {
  background: rgba(255, 215, 0, 0.75);
  color: #000;
  border: 1px solid rgba(255, 255, 255, 0.15);
}

/* ── Cuerpo ────────────────────────────────────────────── */
.fleet-card__body {
  display: flex;
  flex-direction: column;
  flex: 1;
  padding: var(--space-7) var(--space-7) var(--space-7);
}

.fleet-card__type {
  font-size: var(--text-xs);
  font-weight: var(--fw-medium);
  color: rgba(255, 255, 255, 0.30);
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
  margin-bottom: var(--space-3);
}

.fleet-card__title {
  font-family: var(--font-primary);
  font-size: clamp(var(--text-base), 2vw, var(--text-xl));
  font-weight: var(--fw-semibold);
  line-height: 1.2;
  margin-bottom: var(--space-4);
}
.fleet-card__title-link {
  color: #fff;
  text-decoration: none;
  transition: color var(--transition-fast);
}
.fleet-card__title-link:hover {
  color: var(--brand-azul-cielo);
}

.fleet-card__desc {
  font-size: var(--text-sm);
  font-weight: var(--fw-light);
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.75;
  /* Limitar a 3 líneas */
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
