---
/**
 * index.astro
 * Consorcio Helitec — Homepage principal (ES)
 *
 * Ensamblaje de componentes Fases 2–6:
 *
 *   SLOTS EN BASELAYOUT (componentes fijos / overlay):
 *   [sidebar-social]  SidebarSocial  → columna social fija izquierda (desktop)
 *   [header]          Header         → logo + hamburguesa, scroll glass effect
 *   [menu-modal]      MenuModal      → overlay grid asimétrico Konpo-style
 *   [cta-float]       SideLeadCTA    → cotizador premium — strip derecho + panel
 *   [bottom-sheet]    ContactSheet   → bottom sheet con 3 tarjetas de contacto
 *
 *   CONTENIDO PRINCIPAL (slot default → <main> + <footer>):
 *   1. Hero            → fullscreen 100dvh, transición logo scroll (rAF 60fps)
 *   2. StatsSection    → dashboard 6 celdas K3: datos reales + contador rAF
 *   3. ServicesSection → sticky scroll stack Licorn-style — 4 servicios (500vh)
 *   4. FleetSection    → carrusel táctil flota.json — 8 aeronaves
 *   5. Footer          → grid 3 cols: logo/legal + nav + contacto B2B
 *
 * Secciones pendientes (requieren luz verde del Tech Lead):
 *   · #empresa    → About / La Empresa — historia y equipo
 *   · #seguridad  → Certificaciones detalladas + normativas INAC
 *   · #contacto   → Formulario B2B completo + mapa Caracas
 *
 * View Transitions: inyectadas desde BaseLayout via <ViewTransitions />.
 */

import BaseLayout      from '../layouts/BaseLayout.astro';
import SidebarSocial   from '../components/SidebarSocial.astro';
import Header          from '../components/Header.astro';
import MenuModal       from '../components/MenuModal.astro';
import Hero            from '../components/Hero.astro';
import SideLeadCTA     from '../components/SideLeadCTA.astro';
import ContactSheet    from '../components/ContactSheet.astro';
import StatsSection    from '../components/sections/StatsSection.astro';
import ServicesSection from '../components/sections/ServicesSection.astro';
import FleetSection    from '../components/sections/FleetSection.astro';
import Footer          from '../components/Footer.astro';
---

<BaseLayout
  title       = "Consorcio Helitec — Aviación Ejecutiva y Aeromédica · Venezuela"
  description = "Soluciones de transporte aéreo corporativo de alta precisión para la industria petrolera, energética e industrial de Venezuela. Flota ejecutiva, chárter B2B y servicio aeromédico certificado INAC."
  ogImage     = "/assets/atardecer.jpg"
  lang        = "es"
>

  <!-- ════════════════════════════════════════════════════════════════════
       SLOTS — COMPONENTES FIJOS Y OVERLAYS
  ════════════════════════════════════════════════════════════════════════ -->

  <!--
    SidebarSocial — columna fija izquierda 72px
    Solo visible en desktop (≥ 1024px).
    Se oculta cuando body.menu-is-open.
    z-index: var(--z-sidebar) = 100
  -->
  <SidebarSocial slot="sidebar-social" />

  <!--
    Header — barra fija superior 68px
    · Logo blanco: opacity:0 al inicio → se activa en scroll via Hero.astro rAF
    · Hamburger: 2 barras → ✕ al abrir menú
    · Scroll ≥ 40px: añade .is-scrolled → backdrop-filter: blur(12px)
    z-index: var(--z-header) = 200
  -->
  <Header slot="header" />

  <!--
    MenuModal — overlay fullscreen grid asimétrico Konpo-style
    · Nav card: grid-column 1 / grid-row 1 span 2
    · 4 service cards: auto-placed
    · Stagger de entrada via --i y --j CSS custom properties
    z-index: var(--z-menu) = 800
  -->
  <MenuModal slot="menu-modal" lang="es" />

  <!--
    SideLeadCTA — cotizador de vuelo privado premium
    · Strip vertical 40px en el borde derecho → panel 380px
    · Form: tabs Ida/Vuelta, origen/destino, fechas, contador pax, B2B
    · Submit → WhatsApp API con mensaje estructurado
    z-index: trigger 850 / panel 848 / backdrop 847
  -->
  <SideLeadCTA slot="cta-float" />

  <!--
    ContactSheet — bottom sheet con 3 tarjetas de contacto
    · Trigger fijo bottom-right (offset del SideLeadCTA strip)
    · Cards: Operaciones / Emergencias / Ambulancia Aérea
    · Swipe down para cerrar en mobile
    z-index: sheet 900 / backdrop 898 / trigger 895
  -->
  <ContactSheet slot="bottom-sheet" lang="es" />


  <!-- ════════════════════════════════════════════════════════════════════
       CONTENIDO PRINCIPAL (slot default → <main>)
  ════════════════════════════════════════════════════════════════════════ -->

  <!--
    ── SECCIÓN 1: HERO ────────────────────────────────────────────────────
    · Fullscreen 100dvh con foto de fondo (object-fit: cover)
    · Overlay rgba — sin linear-gradient decorativo
    · Logo grande en hero → fade-out al hacer scroll
    · Header logo (#header-logo) → fade-in simultáneo via rAF
    · H1 "AVIACIÓN CORPORATIVA DE PRECISIÓN" font-weight: 200
    · Ghost CTAs: "Solicitar Cotización" + "Conocer la Flota"
    · Scroll hint: doble chevron animado
  -->
  <Hero lang="es" />

  <!--
    ── SECCIÓN 2: POR QUÉ HELITEC ─────────────────────────────────────────
    · Dashboard compacto — grid 3×2 (desktop) / 2×3 (mobile)
    · 6 celdas con datos operativos reales del cliente:
        +117.000 horas helicópteros · +43.000 horas aviones
        +171.500 pasajeros · Nacional e Internacional
        +35 años · INAC · OACI
    · Animación A: IntersectionObserver → fade-up K3 staggered (--i * 90ms)
    · Animación B: rAF number counter easeOutCubic 2000ms
    · Separador de miles "." (convención venezolana)
    · bg: var(--c-bg-raised) — contraste con hero
  -->
  <StatsSection lang="es" />

  <!--
    ── SECCIÓN 3: SERVICIOS ───────────────────────────────────────────────
    · Sticky scroll stack Licorn-style — altura total: 500vh (4 cards + buffer)
    · Stage sticky top:0 + 4 cards position:absolute
    · Animación rAF 60fps: smoothstep + lerp para scale/opacity
    · Cards: Aviación Ejecutiva · Operaciones Petroleras ·
             Traslados Aeromédicos · Mantenimiento Certificado
    · Overlay foto: rgba(7,8,12,0.58) — sin linear-gradient
    · Progress dots: 4 ticks horizontales, activo = 32px blanco
  -->
  <ServicesSection lang="es" />

  <!--
    ── SECCIÓN 4: NUESTRA FLOTA ───────────────────────────────────────────
    · Datos desde /flota.json (raíz del proyecto) — 8 aeronaves activas
    · Mobile: carrusel horizontal nativo scroll-snap-type: x mandatory
    · Desktop: CSS grid 3 columnas
    · Tarjetas: foto aspect-ratio 4/3 (object-fit: cover) + modelo + 3 specs
    · 3 specs por aeronave: Pasajeros · Velocidad crucero kts · Autonomía h
    · Placeholder para MD 600 y MD 902 (sin fotografía en assets)
    · Badges: categoría (ala fija / rotatoria) + aeromédico donde aplica
    · bg: var(--c-bg) — el más oscuro, máximo contraste con ServicesSection
  -->
  <FleetSection lang="es" />

  <!--
    ═══════════════════════════════════════════════════════════════════════
    PRÓXIMAS SECCIONES (pendientes de luz verde del Tech Lead):
      · #empresa    → About / La Empresa — historia y equipo directivo
      · #seguridad  → Certificaciones INAC detalladas + normativas OACI
      · #contacto   → Formulario B2B completo + mapa Caracas
    ═══════════════════════════════════════════════════════════════════════
  -->

  <!--
    ── FOOTER ─────────────────────────────────────────────────────────────
    · Fondo: var(--c-bg) — ultra oscuro, continúa el tono de FleetSection
    · Grid 3 columnas: Logo/Legal · Navegación · Contacto B2B
    · Bottom bar: copyright {year} + links Privacidad / Aviso legal
    · Ghost CTA "Solicitar cotización" → WhatsApp
    · Campos [DATO: ...] requieren completar por el cliente
  -->
  <Footer lang="es" />

</BaseLayout>
