---
/**
 * HELITEC — index.astro
 * Homepage principal. Fase 4.
 *
 * Secciones:
 *   #hero           — Hero fullscreen con elemento visual de brújula/radar
 *   #estadisticas   — Grilla de 6 stats (4 contadores + 2 texto estático)
 *   #certificaciones — Franja INAC trust badge
 *   #servicios      — 3 tarjetas de servicio Konpo-style
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
import CTAFloat   from '../components/CTAFloat.astro';

const lang = 'es';

const WA_NUMBER = '582129596385';
const WA_MSG    = 'Hola Helitec, me gustaría recibir asesoría corporativa sobre sus servicios de vuelos chárter.';
const waHref    = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(WA_MSG)}`;

/* ── Datos de estadísticas ─────────────────────────────────
   kind: 'num' → contador animado con IntersectionObserver
   kind: 'txt' → texto estático, no se anima
────────────────────────────────────────────────────────────*/
type StatNum = { kind: 'num'; target: number; label: string };
type StatTxt = { kind: 'txt'; headline: string; sub: string };
type Stat    = StatNum | StatTxt;

const stats: Stat[] = [
  { kind: 'num', target: 117000, label: 'Horas de vuelo en helicópteros' },
  { kind: 'num', target: 43000,  label: 'Horas de vuelo en aviones'      },
  { kind: 'num', target: 171500, label: 'Pasajeros transportados'         },
  { kind: 'txt', headline: 'Nacional e Internacional', sub: 'Cobertura de operaciones'   },
  { kind: 'num', target: 35,     label: 'Años de experiencia'             },
  { kind: 'txt', headline: 'INAC · OACI',             sub: 'Certificaciones activas'     },
];

/* ── Datos de servicios ────────────────────────────────────*/
const services = [
  {
    num:   '01',
    title: 'Ala Fija Chárter',
    desc:  'Vuelos ejecutivos y corporativos en aviones Swearingen Metro y Cessna 402. Operaciones nacionales e internacionales bajo estándares de aerolíneas comerciales.',
    href:  '/servicios/ala-fija',
  },
  {
    num:   '02',
    title: 'Ala Rotatoria',
    desc:  'Transporte a plataformas petroleras, zonas industriales y destinos sin pista convencional. Helicópteros Bell para misiones de alta exigencia operacional.',
    href:  '/servicios/ala-rotatoria',
  },
  {
    num:   '03',
    title: 'Traslados Aeromédicos',
    desc:  'Evacuaciones médicas y traslados de emergencia con tripulación especializada y equipo paramédico certificado a bordo. Disponibilidad 24/7/365.',
    href:  '/servicios/aeromedico',
  },
] as const;
---

<BaseLayout
  title="Aviación Corporativa y Chárter Ejecutivo en Venezuela"
  description="Consorcio Helitec C.A. · Operador INAC certificado. Vuelos chárter, transporte industrial, helicópteros y traslados aeromédicos. Más de 35 años de operaciones en Venezuela."
  lang={lang}
>

  <Header slot="header" lang={lang} />


  <!-- ════════════════════════════════════════════════════════
       §1 — HERO
  ════════════════════════════════════════════════════════════ -->
  <section class="hero" id="hero" aria-label="Presentación">

    <!-- Fondo: gradiente atmosférico + grid punteado -->
    <div class="hero-atmosphere" aria-hidden="true"></div>

    <div class="hero-inner container">

      <!-- ── Contenido textual ──────────────────────────── -->
      <div class="hero-content">

        <p class="text-overline hero-overline reveal">
          Certificado INAC · Operaciones desde 1990
        </p>

        <h1 class="hero-heading reveal" data-delay="1">
          Aviación Corporativa<br />
          <em>de Precisión</em>
        </h1>

        <p class="hero-sub reveal" data-delay="2">
          Transporte ejecutivo, industrial y aeromédico bajo los estándares
          más exigentes de la aviación comercial. Más de 35 años de
          operaciones ininterrumpidas en Venezuela y la región.
        </p>

        <div class="hero-ctas reveal" data-delay="3">
          <a
            href={waHref}
            class="btn btn--primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Solicitar Cotización
          </a>
          <a href="/flota" class="btn btn--ghost">
            Conocer la Flota
          </a>
        </div>

        <!-- Indicador de scroll -->
        <div class="hero-scroll-hint reveal" data-delay="4" aria-hidden="true">
          <span class="hero-scroll-line"></span>
          <span class="hero-scroll-text">Desplazar</span>
        </div>

      </div>

      <!-- ── Elemento visual: brújula de aviación ──────── -->
      <div class="hero-visual" aria-hidden="true">
        <div class="hv-ring hv-ring--outer"></div>
        <div class="hv-ring hv-ring--mid"></div>
        <div class="hv-ring hv-ring--inner"></div>
        <div class="hv-tick hv-tick--h"></div>
        <div class="hv-tick hv-tick--v"></div>
        <!-- Graduaciones cardinales -->
        <span class="hv-cardinal hv-cardinal--n">N</span>
        <span class="hv-cardinal hv-cardinal--e">E</span>
        <span class="hv-cardinal hv-cardinal--s">S</span>
        <span class="hv-cardinal hv-cardinal--w">O</span>
        <!-- Centro -->
        <div class="hv-core"></div>
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       §2 — ESTADÍSTICAS OPERACIONALES
  ════════════════════════════════════════════════════════════ -->
  <section class="stats" id="estadisticas" aria-label="Estadísticas operacionales">
    <div class="container">

      <div class="section-header reveal">
        <p class="text-overline">Historial Operacional</p>
        <h2 class="section-title">Números que respaldan<br /><em>la confianza</em></h2>
      </div>

      <div class="stats-grid">
        {stats.map((stat, i) => (
          <div
            class={`stat-item reveal${stat.kind === 'num' ? ' stat-item--num' : ' stat-item--txt'}`}
            data-delay={String((i % 3) + 1)}
          >
            {stat.kind === 'num' ? (
              <>
                <div class="stat-val-wrap" aria-label={`Más de ${stat.target.toLocaleString('de-DE')} — ${stat.label}`}>
                  <span class="stat-prefix" aria-hidden="true">+</span>
                  <span
                    class="stat-val counter-value"
                    data-target={stat.target}
                    aria-hidden="true"
                  >0</span>
                </div>
                <p class="stat-label counter-label">{stat.label}</p>
              </>
            ) : (
              <>
                <p class="stat-txt-headline">{stat.headline}</p>
                <p class="stat-label">{stat.sub}</p>
              </>
            )}
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       §3 — FRANJA INAC (Trust Badge)
  ════════════════════════════════════════════════════════════ -->
  <section class="certif" id="certificaciones" aria-label="Certificaciones oficiales">
    <div class="container">
      <div class="certif-inner reveal">

        <!-- Logo INAC con filter CSS para modo oscuro -->
        <div class="certif-badge">
          <img
            src="/assets/logoinac.png"
            alt="Instituto Nacional de Aeronáutica Civil — INAC Venezuela"
            class="certif-logo"
            width="180"
            height="72"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="certif-divider" aria-hidden="true"></div>

        <div class="certif-body">
          <p class="text-overline certif-caption">Certificación Vigente</p>
          <p class="certif-statement">
            Operamos como <strong>Proveedor de Servicio Público de Transporte Aéreo</strong>
            bajo supervisión del INAC y el sistema de gestión de seguridad
            SMS conforme al Anexo 19 de la OACI.
          </p>
        </div>

        <div class="certif-divider" aria-hidden="true"></div>

        <!-- Badge SMS OACI — SVG inline, sin dependencia de archivo externo -->
        <div class="certif-badge certif-badge--oaci">
          <div class="certif-oaci">
            <svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
              <circle cx="22" cy="22" r="20" stroke="rgba(88,181,240,0.35)" stroke-width="1.5"/>
              <circle cx="22" cy="22" r="13" stroke="rgba(88,181,240,0.20)" stroke-width="1"/>
              <!-- Meridianos simplificados -->
              <ellipse cx="22" cy="22" rx="7" ry="20" stroke="rgba(88,181,240,0.22)" stroke-width="1" fill="none"/>
              <line x1="2" y1="22" x2="42" y2="22" stroke="rgba(88,181,240,0.20)" stroke-width="1"/>
            </svg>
            <div class="certif-oaci-text">
              <span class="certif-oaci-label">SMS OACI</span>
              <span class="certif-oaci-sub">Anexo 19</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       §4 — SERVICIOS PRINCIPALES
  ════════════════════════════════════════════════════════════ -->
  <section class="servicios" id="servicios" aria-label="Servicios principales">
    <div class="container">

      <div class="section-header reveal">
        <p class="text-overline">Capacidades Operacionales</p>
        <h2 class="section-title">Soluciones para cada<br /><em>misión</em></h2>
      </div>

      <div class="servicios-grid">
        {services.map((svc, i) => (
          <a
            href={svc.href}
            class="svc-card reveal"
            data-delay={String(i + 1)}
            aria-label={`Ver servicio: ${svc.title}`}
          >
            <span class="svc-card__num" aria-hidden="true">{svc.num}</span>
            <h3 class="svc-card__title">{svc.title}</h3>
            <p class="svc-card__desc">{svc.desc}</p>
            <span class="svc-card__arrow" aria-hidden="true">
              <!-- Flecha minimalista -->
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2"
                   stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>

      <div class="servicios-cta reveal">
        <a href="/servicios" class="btn btn--ghost">
          Ver todos los servicios
        </a>
      </div>

    </div>
  </section>


  <Footer slot="footer" lang={lang} />
  <CTAFloat slot="cta" lang={lang} />

</BaseLayout>


<!-- ═══════════════════════════════════════════════════════
     ESTILOS (scoped — sólo afectan a este componente)
════════════════════════════════════════════════════════════ -->
<style>

/* ── Contenedor global ──────────────────────────────────── */
/* TODO: mover a global.css cuando se refactorice          */
.container {
  width: 100%;
  max-width: 1280px;
  margin-inline: auto;
  padding-inline: var(--space-8);
}
@media (max-width: 640px) {
  .container { padding-inline: var(--space-5); }
}

/* ── Botones (base + variantes no definidas en global.css) */
.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-4) var(--space-8);
  border-radius: var(--radius-full);
  font-family: var(--font-primary);
  font-size: var(--text-sm);
  font-weight: var(--fw-semibold);
  letter-spacing: var(--tracking-wide);
  text-decoration: none;
  line-height: 1;
  white-space: nowrap;
  cursor: pointer;
  border: 2px solid transparent;
  transition:
    background    var(--transition-fast),
    border-color  var(--transition-fast),
    color         var(--transition-fast),
    box-shadow    var(--transition-base),
    transform     var(--transition-base);
}
.btn:active { transform: scale(0.97); }

/* Primario — rojo de marca */
.btn--primary {
  background: var(--brand-rojo-helitec);
  color: #fff;
  border-color: var(--brand-rojo-helitec);
  box-shadow: 0 4px 18px rgba(229, 59, 28, 0.30);
}
.btn--primary:hover {
  background: #c93218;
  border-color: #c93218;
  box-shadow: 0 6px 26px rgba(229, 59, 28, 0.45);
  transform: translateY(-1px);
  color: #fff;
}

/* Ghost — outline azul cielo */
.btn--ghost {
  background: transparent;
  color: var(--brand-azul-cielo);
  border-color: rgba(88, 181, 240, 0.40);
}
.btn--ghost:hover {
  background: rgba(88, 181, 240, 0.08);
  border-color: var(--brand-azul-cielo);
  color: #fff;
  transform: translateY(-1px);
}

/* ── Encabezados de sección (reutilizable) ──────────────── */
.section-header {
  margin-bottom: var(--space-16);
}
.section-title {
  font-family: var(--font-primary);
  font-size: clamp(1.875rem, 3.5vw, 2.75rem);
  font-weight: var(--fw-bold);
  color: #fff;
  line-height: 1.1;
  margin-top: var(--space-3);
}
.section-title em {
  font-family: var(--font-secondary);
  font-style: italic;
  font-weight: 400;
  color: var(--brand-azul-cielo);
  letter-spacing: 0.01em;
}


/* ════════════════════════════════════════════════════════
   §1 HERO
════════════════════════════════════════════════════════════ */
.hero {
  position: relative;
  min-height: 100vh;
  min-height: 100svh;
  display: flex;
  align-items: center;
  background: var(--color-bg-base);
  overflow: hidden;
}

/* Fondo: gradiente atmosférico + dot-grid via ::before / ::after */
.hero-atmosphere {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
/* Glow azul a la derecha */
.hero-atmosphere::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 55% 75% at 78% 50%, rgba(2, 58, 120, 0.40) 0%, transparent 70%),
    radial-gradient(ellipse 35% 55% at 78% 50%, rgba(88, 181, 240, 0.07) 0%, transparent 60%);
}
/* Dot-grid sutil sobre la zona derecha */
.hero-atmosphere::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle, rgba(88, 181, 240, 0.12) 1px, transparent 1px);
  background-size: 40px 40px;
  -webkit-mask-image: radial-gradient(ellipse 50% 80% at 78% 50%, black 0%, transparent 65%);
          mask-image: radial-gradient(ellipse 50% 80% at 78% 50%, black 0%, transparent 65%);
}

/* Layout interno: 2 columnas en desktop */
.hero-inner {
  display: grid;
  grid-template-columns: 55fr 45fr;
  gap: var(--space-16);
  align-items: center;
  padding-block: var(--space-24);
  position: relative;
  z-index: 1;
}
@media (max-width: 900px) {
  .hero-inner {
    grid-template-columns: 1fr;
    gap: var(--space-12);
    padding-block: var(--space-20) var(--space-16);
  }
}

/* Contenido textual */
.hero-overline {
  margin-bottom: var(--space-5);
}

.hero-heading {
  font-family: var(--font-primary);
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: var(--fw-bold);
  color: #fff;
  line-height: 1.04;
  letter-spacing: -0.025em;
  margin-bottom: var(--space-7);
}
.hero-heading em {
  display: block;
  font-family: var(--font-secondary);
  font-style: italic;
  font-weight: 400;
  color: var(--brand-azul-cielo);
  letter-spacing: 0.005em;
}

.hero-sub {
  font-size: clamp(var(--text-base), 1.5vw, var(--text-lg));
  font-weight: var(--fw-light);
  color: rgba(255, 255, 255, 0.65);
  line-height: 1.7;
  max-width: 52ch;
  margin-bottom: var(--space-10);
}

.hero-ctas {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  flex-wrap: wrap;
}

/* Scroll hint */
.hero-scroll-hint {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  margin-top: var(--space-14);
}
.hero-scroll-line {
  display: block;
  width: 48px;
  height: 1px;
  background: rgba(255, 255, 255, 0.25);
  position: relative;
  overflow: hidden;
}
.hero-scroll-line::after {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--brand-azul-cielo);
  transform: translateX(-100%);
  animation: scroll-line 2s var(--ease-in-out) infinite;
}
@keyframes scroll-line {
  0%   { transform: translateX(-100%); }
  50%  { transform: translateX(0); }
  100% { transform: translateX(100%); }
}
.hero-scroll-text {
  font-size: var(--text-xs);
  font-weight: var(--fw-medium);
  letter-spacing: var(--tracking-widest);
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.35);
}

/* ── Elemento visual: brújula / radar ──────────────────── */
.hero-visual {
  position: relative;
  width: 440px;
  height: 440px;
  margin-inline: auto;
  flex-shrink: 0;
}
@media (max-width: 900px) {
  .hero-visual { display: none; }
}

/* Anillos concéntricos */
.hv-ring {
  position: absolute;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}
.hv-ring--outer {
  width: 420px;
  height: 420px;
  border: 1px solid rgba(88, 181, 240, 0.08);
  animation: hv-rotate 120s linear infinite;
}
.hv-ring--mid {
  width: 290px;
  height: 290px;
  border: 1px solid rgba(88, 181, 240, 0.14);
  animation: hv-rotate 80s linear infinite reverse;
}
.hv-ring--inner {
  width: 160px;
  height: 160px;
  border: 1px solid rgba(88, 181, 240, 0.22);
  box-shadow: 0 0 24px rgba(88, 181, 240, 0.08) inset;
  animation: hv-rotate 40s linear infinite;
}
@keyframes hv-rotate {
  to { rotate: 360deg; }
}

/* Ejes (crosshair) */
.hv-tick {
  position: absolute;
  top: 50%;
  left: 50%;
  background: rgba(88, 181, 240, 0.12);
  transform-origin: center;
}
.hv-tick--h {
  width: 420px;
  height: 1px;
  transform: translate(-50%, -50%);
}
.hv-tick--v {
  width: 1px;
  height: 420px;
  transform: translate(-50%, -50%);
}

/* Cardinales */
.hv-cardinal {
  position: absolute;
  font-family: var(--font-primary);
  font-size: var(--text-xs);
  font-weight: var(--fw-semibold);
  letter-spacing: var(--tracking-widest);
  color: rgba(88, 181, 240, 0.45);
}
.hv-cardinal--n { top: 6px;      left: 50%; transform: translateX(-50%); }
.hv-cardinal--e { right: 6px;    top: 50%;  transform: translateY(-50%); }
.hv-cardinal--s { bottom: 6px;   left: 50%; transform: translateX(-50%); }
.hv-cardinal--w { left: 6px;     top: 50%;  transform: translateY(-50%); }

/* Punto central */
.hv-core {
  position: absolute;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: var(--brand-azul-cielo);
  box-shadow: 0 0 16px rgba(88, 181, 240, 0.60);
  animation: hv-pulse-core 2.5s ease-in-out infinite;
}
@keyframes hv-pulse-core {
  0%, 100% { box-shadow: 0 0 16px rgba(88, 181, 240, 0.60); }
  50%       { box-shadow: 0 0 28px rgba(88, 181, 240, 0.90), 0 0 6px rgba(88, 181, 240, 1); }
}

/* Respetar prefers-reduced-motion */
@media (prefers-reduced-motion: reduce) {
  .hv-ring--outer,
  .hv-ring--mid,
  .hv-ring--inner,
  .hv-core { animation: none; }
  .hero-scroll-line::after { animation: none; }
}


/* ════════════════════════════════════════════════════════
   §2 ESTADÍSTICAS
════════════════════════════════════════════════════════════ */
.stats {
  background: var(--color-bg-surface);
  padding-block: var(--space-24);
  border-top:    1px solid rgba(255, 255, 255, 0.04);
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
}
@media (max-width: 768px) {
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .stats-grid { grid-template-columns: 1fr; }
}

.stat-item {
  padding: var(--space-10) var(--space-8);
  border-top: 2px solid rgba(88, 181, 240, 0.0);
  border-right: 1px solid rgba(255, 255, 255, 0.05);
  transition: border-top-color var(--transition-base);
  position: relative;
}
/* Última columna sin borde derecho */
.stat-item:nth-child(3n) { border-right: none; }
/* Separador horizontal entre filas */
.stat-item:nth-child(n+4) {
  border-top-color: rgba(255, 255, 255, 0.05);
  border-top-width: 1px;
}
/* Hover: acento azul cielo */
.stat-item:hover {
  border-top-width: 2px;
  border-top-color: var(--brand-azul-cielo);
}
@media (max-width: 768px) {
  .stat-item:nth-child(3n) { border-right: 1px solid rgba(255, 255, 255, 0.05); }
  .stat-item:nth-child(2n) { border-right: none; }
  .stat-item:nth-child(n+3) {
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.05);
  }
  .stat-item:nth-child(n+4) {
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.05);
  }
}

/* Valor numérico (contador) */
.stat-val-wrap {
  display: flex;
  align-items: baseline;
  gap: 0;
  line-height: 1;
  margin-bottom: var(--space-3);
}
.stat-prefix {
  font-family: var(--font-primary);
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: var(--fw-light);
  color: var(--brand-azul-cielo);
  margin-right: 2px;
}
.stat-val {
  font-family: var(--font-primary);
  font-size: clamp(2.25rem, 5vw, 3.5rem);
  font-weight: var(--fw-bold);
  color: #fff;
  letter-spacing: -0.02em;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

/* Texto estático (headline) */
.stat-txt-headline {
  font-family: var(--font-primary);
  font-size: clamp(1.25rem, 2.5vw, 1.875rem);
  font-weight: var(--fw-semibold);
  color: #fff;
  line-height: 1.2;
  margin-bottom: var(--space-3);
}

/* Etiqueta descriptiva */
.stat-label {
  font-size: var(--text-sm);
