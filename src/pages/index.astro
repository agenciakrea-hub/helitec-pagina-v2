---
/**
 * index.astro
 * Consorcio Helitec — Homepage principal (ES)
 *
 * Ensamblaje de componentes Fase 2–4:
 *   [sidebar-social] SidebarSocial  → columna social fija izquierda (desktop)
 *   [header]         Header         → logo + hamburguesa, scroll glass effect
 *   [menu-modal]     MenuModal      → overlay grid asimétrico Konpo-style
 *   [default/main]   Hero           → hero fullscreen, transición logo scroll
 *
 * View Transitions:
 *   Inyectadas desde BaseLayout via <ViewTransitions />.
 *   Permite navegación suave entre esta página y /flota sin recarga visible.
 *
 * Idioma: 'es' (ruta por defecto — /en/ se construirá en fase de i18n)
 */

import BaseLayout    from '../layouts/BaseLayout.astro';
import SidebarSocial from '../components/SidebarSocial.astro';
import Header        from '../components/Header.astro';
import MenuModal     from '../components/MenuModal.astro';
import Hero          from '../components/Hero.astro';
---

<BaseLayout
  title       = "Consorcio Helitec — Aviación Ejecutiva y Aeromédica · Venezuela"
  description = "Soluciones de transporte aéreo corporativo de alta precisión para la industria petrolera, energética e industrial de Venezuela. Flota ejecutiva, chárter B2B y servicio aeromédico certificado INAC."
  ogImage     = "/assets/PHOTO-2024-10-30-15-40-52.jpg"
  lang        = "es"
>

  <!-- Sidebar social fijo izquierda — visible solo en desktop (≥ 1024px) -->
  <SidebarSocial slot="sidebar-social" />

  <!--
    Header fijo: logo blanco + hamburguesa.
    El logo (#header-logo) inicia con opacity:0 en esta página
    → se activa con el scroll via el script de Hero.astro.
  -->
  <Header slot="header" />

  <!--
    Menú modal fullscreen — grid asimétrico Konpo-style:
    Nav card col 1 (rows 1-2) + 4 service cards auto-placed.
    Estado controlado por body.menu-is-open.
  -->
  <MenuModal slot="menu-modal" lang="es" />

  <!--
    Hero fullscreen:
    · Fondo: /assets/PHOTO-2024-10-30-15-40-52.jpg
    · Logo grande → desaparece en scroll → header logo aparece
    · H1: "AVIACIÓN CORPORATIVA DE PRECISIÓN"
    · Ghost CTAs: Solicitar Cotización + Conocer la Flota
  -->
  <Hero lang="es" />

  <!--
    ═══════════════════════════════════════════════════════════════
    PRÓXIMAS SECCIONES (pendientes de light-verde del Tech Lead):
      · #empresa    → About / La Empresa
      · #servicios  → Cards de servicios (sticky scroll Licorn-style)
      · #flota      → Fleet preview (desde flota.json)
      · #seguridad  → Certificaciones + INAC
      · #contacto   → Formulario B2B + mapa
    ═══════════════════════════════════════════════════════════════
  -->

</BaseLayout>
