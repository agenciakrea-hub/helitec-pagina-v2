}
.form-input::placeholder,
.form-textarea::placeholder {
  color: rgba(255,255,255,0.22);
}
.form-input:focus,
.form-select:focus,
.form-textarea:focus {
  border-color: rgba(88,181,240,0.45);
  box-shadow: 0 0 0 3px rgba(88,181,240,0.09);
}
.form-input.is-invalid,
.form-select.is-invalid,
.form-textarea.is-invalid {
  border-color: rgba(229,59,28,0.55);
  box-shadow: 0 0 0 3px rgba(229,59,28,0.08);
}

/* Select */
.form-select-wrap { position: relative; }
.form-select {
  cursor: pointer;
  padding-right: var(--space-10); /* espacio para la flecha */
}
.form-select option {
  background: #0f1f3a;
  color: rgba(255,255,255,0.85);
}
.select-arrow {
  position: absolute; right: var(--space-4); top: 50%;
  transform: translateY(-50%); color: rgba(255,255,255,0.30);
  pointer-events: none; flex-shrink: 0;
}

/* Textarea */
.form-textarea {
  resize: vertical; min-height: 130px;
}

/* Hint y error */
.form-hint {
  font-size: var(--text-xs); color: rgba(255,255,255,0.28);
  line-height: 1.5;
}
.form-error {
  font-size: var(--text-xs); color: #f87171;
  font-weight: var(--fw-medium);
}

/* Botón submit — full width */
.form-submit {
  width: 100%; justify-content: center;
  padding-block: var(--space-4-5, 1.125rem);
  font-size: var(--text-base);
}

/* Mensaje de éxito */
.form-success {
  display: flex; align-items: flex-start; gap: var(--space-3);
  padding: var(--space-4) var(--space-5);
  background: rgba(74,222,128,0.08);
  border: 1px solid rgba(74,222,128,0.20);
  border-radius: var(--radius-md, 8px);
  font-size: var(--text-sm); color: #86efac;
  line-height: 1.65;
}
.form-success[hidden] { display: none; }
.form-success svg { flex-shrink: 0; margin-top: 2px; }
.form-success a { color: #4ade80; text-underline-offset: 3px; }
.form-success a:hover { color: #fff; }


/* ════════════════════════════════════════════════════════
   SECCIÓN DE MAPA
════════════════════════════════════════════════════════════ */
.map-section {
