---
/**
 * HELITEC — contacto.astro
 * Página de contacto corporativo y cotizaciones. Fase 9.
 *
 * Secciones:
 *   .contact-hero    — Hero interno corto
 *   .contact-main    — 2 columnas: info institucional / formulario B2B
 *   .map-section     — Placeholder panorámico de mapa
 *
 * Estrategia de envío:
 *   El formulario no depende de ningún servidor externo.
 *   Al enviarlo, se construye un mensaje estructurado y se abre
 *   WhatsApp con los datos pre-cargados. Sin librerías de terceros.
 *
 * NOTA: Actualizar dirección, teléfonos y emails con los datos reales.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
import CTAFloat   from '../components/CTAFloat.astro';

const lang = 'es';

/* ── Información de contacto por departamento ──────────── */
interface Dept {
  id:      string;
  label:   string;
  hours:   string;
  phone?:  string;
  email?:  string;
  alert?:  boolean;   // true = resaltar como 24/7
}

const depts: Dept[] = [
  {
    id:    'ops',
    label: 'Central de Operaciones',
    hours: '24 / 7 · 365 días',
    phone: '+58 (212) 959-6385',
    alert: true,
  },
  {
    id:    'aeromedico',
    label: 'Emergencias Aeromédicas',
    hours: '24 / 7 · Despacho inmediato',
    phone: '+58 (212) 959-6385',
    alert: true,
  },
  {
    id:    'ventas',
    label: 'Ventas y Cotizaciones',
    hours: 'L – V · 8:00 AM – 6:00 PM',
    phone: '+58 (212) 959-8753',
    email: 'info@helitec.com',
  },
  {
    id:    'admin',
    label: 'Administración',
    hours: 'L – V · 8:00 AM – 5:00 PM',
    phone: '+58 (212) 959-2526',
    email: 'info@helitec.com',
  },
];

/* ── Opciones del dropdown de servicios ────────────────── */
const serviceOptions = [
  { value: '',                           label: 'Seleccione un servicio',              disabled: true },
  { value: 'Vuelo Ejecutivo',            label: 'Vuelo Ejecutivo (Ala Fija / Rotatoria)' },
  { value: 'Emergencia Aeromédica',      label: 'Emergencia Aeromédica'                  },
  { value: 'Vuelo de Carga Industrial',  label: 'Carga y Sector Industrial'              },
  { value: 'Administración de Aeronaves',label: 'Administración de Aeronaves'            },
  { value: 'Otro',                       label: 'Otro / Consulta general'                },
];
---

<BaseLayout
  title="Contacto y Cotizaciones | Consorcio Helitec"
  description="Contacte a Consorcio Helitec para cotizaciones de vuelos ejecutivos, emergencias aeromédicas, carga y administración de aeronaves. Despacho operativo 24/7/365."
  lang={lang}
>

  <Header slot="header" lang={lang} />


  <!-- ════════════════════════════════════════════════════════
       HERO INTERNO
  ════════════════════════════════════════════════════════════ -->
  <section class="contact-hero" aria-label="Contacto">
    <div class="container">
      <div class="contact-hero__content reveal">
        <p class="text-overline">Atención Ejecutiva · 24 / 7 / 365</p>
        <h1 class="contact-hero__title">
          Contacto y<br /><em>Cotizaciones</em>
        </h1>
        <p class="contact-hero__sub">
          Para solicitudes corporativas, cotizaciones formales o emergencias aeromédicas.
          El despacho operativo está disponible las 24 horas.
        </p>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       SECCIÓN PRINCIPAL — 2 columnas: Info + Formulario
  ════════════════════════════════════════════════════════════ -->
  <section class="contact-main" aria-label="Información de contacto y formulario">
    <div class="container">
      <div class="contact-grid">

        <!-- ── COLUMNA IZQUIERDA: Información institucional ── -->
        <aside class="info-col reveal" aria-label="Información de contacto">

          <!-- Dirección -->
          <div class="info-block">
            <h2 class="info-block__title">
              <svg class="info-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                   stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              Ubicación
            </h2>
            <div class="info-address">
              <p>C.C. Ciudad Tamanaco (CCCT)</p>
              <p>Chuao, Caracas</p>
              <p>Venezuela</p>
            </div>
            <p class="info-address-note">
              Líneas directas: (212) 959-8753 &nbsp;/&nbsp; (212) 959-2526
            </p>
          </div>

          <!-- Departamentos -->
          <div class="info-block">
            <h2 class="info-block__title">
              <svg class="info-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                   stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.48 2 2 0 0 1 3.6 1.28h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.28 16"/>
              </svg>
              Departamentos
            </h2>

            <ul class="dept-list">
              {depts.map(d => (
                <li class={`dept-item${d.alert ? ' dept-item--alert' : ''}`}>
                  <div class="dept-header">
                    <span class="dept-label">{d.label}</span>
                    {d.alert && (
                      <span class="dept-live" aria-label="Disponible ahora">
                        <span class="live-dot" aria-hidden="true"></span>
                        En línea
                      </span>
                    )}
                  </div>
                  <p class="dept-hours">{d.hours}</p>
                  {d.phone && (
                    <a
                      href={`tel:${d.phone.replace(/\s|\(|\)|-/g, '')}`}
                      class="dept-contact dept-contact--phone"
                      aria-label={`Llamar a ${d.label}`}
                    >
                      {d.phone}
                    </a>
                  )}
                  {d.email && (
                    <a
                      href={`mailto:${d.email}`}
                      class="dept-contact dept-contact--email"
                      aria-label={`Correo de ${d.label}`}
                    >
                      {d.email}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

          <!-- Horarios de base -->
          <div class="hours-card">
            <div class="hours-card__header">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round"
                   stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <span>Horarios de Base</span>
            </div>
            <div class="hours-rows">
              <div class="hours-row">
                <span class="hours-dept">Despacho Operaciones</span>
                <span class="hours-val hours-val--always">24 / 7 / 365</span>
              </div>
              <div class="hours-row">
                <span class="hours-dept">Despacho Aeromédico</span>
                <span class="hours-val hours-val--always">24 / 7 / 365</span>
              </div>
              <div class="hours-row">
                <span class="hours-dept">Oficinas Administrativas</span>
                <span class="hours-val">L – V · 8:00–17:00</span>
              </div>
              <div class="hours-row">
                <span class="hours-dept">Ventas y Cotizaciones</span>
                <span class="hours-val">L – V · 8:00–18:00</span>
              </div>
            </div>
          </div>

        </aside>


        <!-- ── COLUMNA DERECHA: Formulario B2B ────────────── -->
        <div class="form-col reveal" data-delay="1">
          <div class="form-card">
            <div class="form-card__header">
              <h2 class="form-card__title">Solicitud de Cotización</h2>
              <p class="form-card__sub">
                Complete el formulario. Recibirá respuesta directa de nuestro
                equipo de operaciones vía WhatsApp.
              </p>
            </div>

            <form
              id="contact-form"
              class="contact-form"
              novalidate
              aria-label="Formulario de cotización"
            >
              <!-- Nombre / Empresa -->
              <div class="form-group">
                <label for="nombre" class="form-label">
                  Nombre y Empresa <span class="form-required" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  class="form-input"
                  placeholder="Ej. Juan Pérez · Petróleos del Orinoco"
                  autocomplete="name"
                  required
                  aria-required="true"
                />
                <span class="form-error" id="error-nombre" role="alert" hidden>
                  Por favor indique su nombre y empresa.
                </span>
              </div>

              <!-- Correo + Teléfono (lado a lado en desktop) -->
              <div class="form-row-2">
                <div class="form-group">
                  <label for="correo" class="form-label">
                    Correo Electrónico <span class="form-required" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="email"
                    id="correo"
                    name="correo"
                    class="form-input"
                    placeholder="correo@empresa.com"
                    autocomplete="email"
                    required
                    aria-required="true"
                  />
                  <span class="form-error" id="error-correo" role="alert" hidden>
                    Ingrese un correo válido.
                  </span>
                </div>

                <div class="form-group">
                  <label for="telefono" class="form-label">
                    Teléfono <span class="form-required" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="tel"
                    id="telefono"
                    name="telefono"
                    class="form-input"
                    placeholder="+58 212 000-0000"
                    autocomplete="tel"
                    required
                    aria-required="true"
                  />
                  <span class="form-error" id="error-telefono" role="alert" hidden>
                    Ingrese un teléfono de contacto.
                  </span>
                </div>
              </div>

              <!-- Tipo de servicio -->
              <div class="form-group">
                <label for="servicio" class="form-label">
                  Servicio Solicitado <span class="form-required" aria-hidden="true">*</span>
                </label>
                <div class="form-select-wrap">
                  <select
                    id="servicio"
                    name="servicio"
                    class="form-select"
                    required
                    aria-required="true"
                  >
                    {serviceOptions.map(opt => (
                      <option
                        value={opt.value}
                        disabled={opt.disabled}
                        selected={opt.disabled}
                      >
                        {opt.label}
                      </option>
                    ))}
                  </select>
                  <!-- Flecha custom -->
                  <svg class="select-arrow" width="12" height="7" viewBox="0 0 12 7"
                       fill="none" aria-hidden="true">
                    <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5"
                          stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <span class="form-error" id="error-servicio" role="alert" hidden>
                  Seleccione el tipo de servicio.
                </span>
              </div>

              <!-- Detalles del vuelo -->
              <div class="form-group">
                <label for="detalles" class="form-label">
                  Detalles de la Solicitud
                </label>
                <textarea
                  id="detalles"
                  name="detalles"
                  class="form-textarea"
                  rows="5"
                  placeholder="Origen · Destino · Nº de pasajeros · Fecha estimada · Cualquier requerimiento especial"
                  aria-describedby="detalles-hint"
                ></textarea>
                <p id="detalles-hint" class="form-hint">
                  Cuanta más información aporte, más precisa será la cotización.
                </p>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                id="form-submit"
                class="form-submit btn btn--primary"
                aria-label="Enviar solicitud de cotización vía WhatsApp"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"
                     aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  <path d="M12.05 2.005C6.495 2.005 2 6.5 2 12.05c0 1.77.462 3.498 1.34 5.027L2 22l5.032-1.317A10.038 10.038 0 0012.05 22.1C17.605 22.1 22.1 17.605 22.1 12.05 22.1 6.495 17.605 2 12.05 2zm0 18.378a8.327 8.327 0 01-4.257-1.167l-.305-.182-3.165.829.844-3.085-.198-.318A8.339 8.339 0 013.717 12.05c0-4.599 3.743-8.342 8.333-8.342 4.59 0 8.334 3.743 8.334 8.342 0 4.59-3.744 8.333-8.334 8.333z"/>
                </svg>
                Enviar vía WhatsApp
              </button>

              <!-- Mensaje de éxito (oculto por defecto) -->
              <div id="form-success" class="form-success" hidden role="alert" aria-live="polite">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                     stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span>
                  Solicitud generada. Se ha abierto WhatsApp con los detalles de su
                  consulta. Si no se abrió automáticamente,
                  <a href="https://wa.me/582129596385" target="_blank" rel="noopener noreferrer">
                    haga clic aquí
                  </a>.
                </span>
              </div>

            </form>
          </div>
        </div>

      </div><!-- /contact-grid -->
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       SECCIÓN DE MAPA — Placeholder panorámico
  ════════════════════════════════════════════════════════════ -->
  <section class="map-section" aria-label="Ubicación de Consorcio Helitec">
    <div class="container">
      <div class="map-placeholder" role="img"
           aria-label="Mapa de ubicación de Consorcio Helitec en Caracas, Venezuela">
        <!-- Grid de cuadrícula — efecto de mapa oscuro -->
        <div class="map-grid" aria-hidden="true"></div>

        <!-- Marcador central -->
        <div class="map-pin-wrap" aria-hidden="true">
          <svg class="map-pin-icon" width="40" height="40" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
               stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span class="map-pin-pulse"></span>
        </div>

        <!-- Etiqueta de ubicación -->
        <div class="map-label-wrap">
          <p class="map-label-name">Consorcio Helitec C.A. · CCCT, Chuao</p>
          <p class="map-label-coords">10.4880° N, 66.8450° O · Chuao, Caracas</p>
          <!-- INTEGRAR: Reemplazar este placeholder con un iframe de Google Maps -->
          <a
            href="https://maps.google.com/?q=Centro+Comercial+Ciudad+Tamanaco,+Chuao,+Caracas,+Venezuela"
            target="_blank"
            rel="noopener noreferrer"
            class="map-open-link"
            aria-label="Abrir ubicación en Google Maps"
          >
            Abrir en Google Maps
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round"
                 stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>


  <Footer slot="footer" lang={lang} />
  <CTAFloat slot="cta" lang={lang} />

</BaseLayout>


<!-- ═══════════════════════════════════════════════════════
     ESTILOS SCOPED — Mobile-first
════════════════════════════════════════════════════════════ -->
<style>

/* ── Contenedor ─────────────────────────────────────────── */
.container {
  width: 100%; max-width: 1280px;
  margin-inline: auto; padding-inline: var(--space-5);
}
@media (min-width: 640px) { .container { padding-inline: var(--space-8); } }

/* ── Botones ────────────────────────────────────────────── */
.btn {
  display: inline-flex; align-items: center; gap: var(--space-2);
  padding: var(--space-4) var(--space-8); border-radius: var(--radius-full);
  font-family: var(--font-primary); font-size: var(--text-sm);
  font-weight: var(--fw-semibold); letter-spacing: var(--tracking-wide);
  text-decoration: none; line-height: 1; white-space: nowrap;
  cursor: pointer; border: 2px solid transparent;
  transition: background 180ms, border-color 180ms, color 180ms,
              box-shadow 300ms, transform 300ms;
}
.btn:active { transform: scale(0.97); }
.btn--primary {
  background: var(--brand-rojo-helitec); color: #fff;
  border-color: var(--brand-rojo-helitec);
  box-shadow: 0 4px 18px rgba(229,59,28,0.28);
}
.btn--primary:hover {
  background: #c93218; border-color: #c93218;
  box-shadow: 0 6px 26px rgba(229,59,28,0.42); transform: translateY(-1px);
}
.btn--primary:disabled {
  opacity: 0.60; cursor: not-allowed; transform: none;
  box-shadow: none;
}


/* ════════════════════════════════════════════════════════
   HERO INTERNO
════════════════════════════════════════════════════════════ */
.contact-hero {
  background: var(--color-bg-base);
  padding-block: var(--space-20) var(--space-16);
  border-bottom: 1px solid rgba(255,255,255,0.04);
  background-image: radial-gradient(
    ellipse 60% 80% at 75% 50%,
    rgba(2, 58, 120, 0.18) 0%, transparent 70%
  );
}
.contact-hero__content { max-width: 600px; }
.contact-hero__title {
  font-family: var(--font-primary);
  font-size: clamp(2.25rem, 5.5vw, 4.25rem);
  font-weight: var(--fw-bold);
  color: #fff;
  line-height: 1.05; letter-spacing: -0.025em;
  margin-block: var(--space-5) var(--space-6);
}
.contact-hero__title em {
  font-family: var(--font-secondary);
  font-style: italic; font-weight: 400;
  color: var(--brand-azul-cielo);
}
.contact-hero__sub {
  font-size: clamp(var(--text-base), 1.5vw, var(--text-lg));
  font-weight: var(--fw-light);
  color: rgba(255,255,255,0.52);
  line-height: 1.75; max-width: 56ch;
}


/* ════════════════════════════════════════════════════════
   SECCIÓN PRINCIPAL — 2 columnas
════════════════════════════════════════════════════════════ */
.contact-main {
  background: var(--color-bg-base);
  padding-block: var(--space-16) var(--space-20);
}

/* Grid mobile-first */
.contact-grid {
  display: flex; flex-direction: column;
  gap: var(--space-14);
}
@media (min-width: 900px) {
  .contact-grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--space-16);
    align-items: start;
  }
}


/* ── COLUMNA IZQUIERDA: Info institucional ───────────────*/
.info-block { margin-bottom: var(--space-10); }

.info-block__title {
  display: flex; align-items: center; gap: var(--space-3);
  font-family: var(--font-primary);
  font-size: var(--text-xs);
  font-weight: var(--fw-semibold);
  letter-spacing: var(--tracking-widest);
  text-transform: uppercase;
  color: var(--brand-azul-cielo);
  margin-bottom: var(--space-6);
  opacity: 0.80;
}
.info-icon { flex-shrink: 0; }

/* Dirección */
.info-address {
  margin-bottom: var(--space-3);
}
.info-address p {
  font-size: var(--text-base);
  font-weight: var(--fw-light);
  color: rgba(255,255,255,0.70);
  line-height: 1.65;
}
.info-address-note {
  font-size: var(--text-xs);
  color: rgba(255,255,255,0.35);
  line-height: 1.6;
  border-left: 2px solid rgba(88,181,240,0.25);
  padding-left: var(--space-3);
  margin-top: var(--space-3);
}

/* Lista de departamentos */
.dept-list {
  display: flex; flex-direction: column; gap: var(--space-4);
}

.dept-item {
  padding: var(--space-5);
  border-radius: var(--radius-md, 8px);
  background: var(--color-bg-surface);
  border: 1px solid rgba(255,255,255,0.05);
  transition: border-color 200ms;
}
.dept-item:hover { border-color: rgba(88,181,240,0.12); }

.dept-item--alert {
  border-color: rgba(88,181,240,0.10);
  background: rgba(2,58,120,0.18);
}
.dept-item--alert:hover { border-color: rgba(88,181,240,0.25); }

.dept-header {
  display: flex; align-items: center;
  justify-content: space-between; gap: var(--space-3);
  margin-bottom: var(--space-2);
}
.dept-label {
  font-family: var(--font-primary);
  font-size: var(--text-sm); font-weight: var(--fw-semibold);
  color: rgba(255,255,255,0.88);
}
.dept-live {
  display: inline-flex; align-items: center; gap: var(--space-1-5);
  font-size: var(--text-xs); font-weight: var(--fw-medium);
  color: #4ade80; opacity: 0.90;
  white-space: nowrap; flex-shrink: 0;
}
.live-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #4ade80;
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.35; }
}
.dept-hours {
  font-size: var(--text-xs); color: rgba(255,255,255,0.38);
  margin-bottom: var(--space-3); line-height: 1.4;
}
.dept-contact {
