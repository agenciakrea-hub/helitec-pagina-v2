</style>


<!-- ═══════════════════════════════════════════════════════
     SCRIPT — Reveal + Formulario → WhatsApp
════════════════════════════════════════════════════════════ -->
<script>
  /* ── Reveal observer ──────────────────────────────────── */
  (() => {
    const reveals = document.querySelectorAll('.reveal');
    if (!reveals.length) return;
    const io = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      }),
      { threshold: 0.10 }
    );
    reveals.forEach(el => io.observe(el));
  })();

  /* ── Formulario → WhatsApp ────────────────────────────── */
  (() => {
    const form   = document.getElementById('contact-form');
    const btn    = document.getElementById('form-submit');
    const success = document.getElementById('form-success');
    if (!form || !btn || !success) return;

    /* Validación de campo individual */
    function validateField(el) {
      const errId = `error-${el.id}`;
      const errEl = document.getElementById(errId);
      const valid = el.validity.valid;
      el.classList.toggle('is-invalid', !valid);
      if (errEl) errEl.hidden = valid;
      return valid;
    }

    /* Validar en blur para feedback inmediato */
    form.querySelectorAll('[required]').forEach(el => {
      el.addEventListener('blur', () => validateField(el), { passive: true });
    });

    form.addEventListener('submit', e => {
      e.preventDefault();

      /* Validar todos los campos requeridos */
      let ok = true;
      form.querySelectorAll('[required]').forEach(el => {
        if (!validateField(el)) ok = false;
      });
      if (!ok) return;

      /* Deshabilitar botón */
      btn.setAttribute('disabled', '');
      btn.textContent = 'Generando solicitud…';

      /* Construir mensaje estructurado para WhatsApp */
      const fd    = new FormData(form);
      const get   = key => fd.get(key)?.toString().trim() || '';

      const lines = [
        '🚁 *Solicitud de Cotización — Consorcio Helitec*',
        '',
        `*Nombre / Empresa:* ${get('nombre')}`,
        `*Correo Electrónico:* ${get('correo')}`,
        `*Teléfono:* ${get('telefono')}`,
        `*Servicio Solicitado:* ${get('servicio')}`,
      ];
      const det = get('detalles');
      if (det) { lines.push('', '*Detalles de la Solicitud:*', det); }

      const waText = encodeURIComponent(lines.join('\n'));
      window.open(`https://wa.me/582129596385?text=${waText}`, '_blank', 'noopener,noreferrer');

      /* Mostrar mensaje de éxito y resetear botón */
      setTimeout(() => {
        btn.removeAttribute('disabled');
        btn.innerHTML = `
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12.05 2.005C6.495 2.005 2 6.5 2 12.05c0 1.77.462 3.498 1.34 5.027L2 22l5.032-1.317A10.038 10.038 0 0012.05 22.1C17.605 22.1 22.1 17.605 22.1 12.05 22.1 6.495 17.605 2 12.05 2zm0 18.378a8.327 8.327 0 01-4.257-1.167l-.305-.182-3.165.829.844-3.085-.198-.318A8.339 8.339 0 013.717 12.05c0-4.599 3.743-8.342 8.333-8.342 4.59 0 8.334 3.743 8.334 8.342 0 4.59-3.744 8.333-8.334 8.333z"/>
          </svg>
          Enviar vía WhatsApp`;
        success.removeAttribute('hidden');
        success.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        setTimeout(() => success.setAttribute('hidden', ''), 8000);
      }, 800);
    });
  })();
</script>
